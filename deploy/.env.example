# .env.example — Plantry self-hosted configuration
#
# Copy this file to .env, fill in real values, then lock it down:
#   cp .env.example .env
#   chmod 600 .env       # keep secrets off of group/world read
#
# NEVER commit .env — it is in .gitignore.
# See https://github.com/gastownhall/plantry/blob/main/docs/Operations/self-hosting.md

# ── Postgres ─────────────────────────────────────────────────────────────────
# Database owner credentials.  Only the migrator connects as this role.
# POSTGRES_PASSWORD is applied by Postgres only on the FIRST volume initialisation.
# Set it once and keep it stable.  To rotate: stop postgres, remove the volume, restart.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_owner_password

# ── App user ─────────────────────────────────────────────────────────────────
# Least-privilege runtime role.  The migrator sets this password on every run;
# the web app connects with it.  Rotatable: change here, then run `docker compose up -d`.
APP_USER_PASSWORD=changeme_appuser_password

# ── Networking ───────────────────────────────────────────────────────────────
# The host port Plantry listens on.  Front this with your own reverse proxy
# (nginx, Traefik, Caddy, etc.) for TLS termination.
# If using the bundled Caddy overlay (docker-compose.caddy.yml), this port is
# not exposed to the host; comment it out or leave as-is — it is ignored.
HTTP_PORT=8080

# ── DataProtection certificate ────────────────────────────────────────────────
# Passphrase for the auto-generated self-signed PFX certificate used to encrypt
# the ASP.NET Core DataProtection key ring at rest.  The dp-cert-init one-shot
# service generates /certs/dp.pfx on first run using this password; plantry-web
# reads it on startup to decrypt the key ring.
# Choose a strong random password and keep it stable — changing it invalidates
# the key ring and logs out all users.  To rotate: stop plantry-web, remove the
# dp_certs volume, update this value, and run `docker compose up -d`.
DP_CERT_PASSWORD=changeme_cert_password

# ── Caddy overlay (optional) ──────────────────────────────────────────────────
# Required only when using docker-compose.caddy.yml for automatic TLS via
# Let's Encrypt.  Leave commented out if you are handling TLS externally.
# DNS must resolve DOMAIN to this host; ports 80 and 443 must be open.
#DOMAIN=plantry.example.com

# ── AI API key (optional) ─────────────────────────────────────────────────────
# Plantry uses an OpenAI-compatible API for receipt parsing and meal-plan
# suggestions.  Leave blank to degrade those features to a locked-feature UI;
# the rest of the app (inventory, recipes, catalog) works without it.
# Bring your own key — any provider whose API is compatible with the OpenAI
# Chat Completions format works (e.g. OpenAI, Anthropic via the compat layer,
# a local Ollama endpoint, etc.).
AI_API_KEY=

# ── Image references (optional) ───────────────────────────────────────────────
# Pin a specific version tag instead of :latest.  See release notes for the
# full list of published tags (e.g. :1, :1.4, :1.4.0).
#   Recommended: pin :1 or :1.4 to get patch releases automatically.
#   :latest tracks the most recent release and may deliver breaking changes.
#PLANTRY_WEB_IMAGE=ghcr.io/gastownhall/plantry/web:1
#MIGRATOR_IMAGE=ghcr.io/gastownhall/plantry/migrator:1
