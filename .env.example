# .env.example — required environment variables for docker-compose.prod.yml
#
# Copy this file to .env, fill in real values, then lock it down:
#   cp .env.example .env
#   chmod 600 .env       # root-owned on the production host
#
# NEVER commit .env — it is in .gitignore.
# See docs/Operations/deployment.md for the full deployment runbook.

# ── Postgres ─────────────────────────────────────────────────────────────────
# Database owner credentials. Only the migrator connects as this role.
# POSTGRES_PASSWORD is only applied by Postgres on the FIRST volume initialisation —
# pin it once and keep it stable. To rotate: stop postgres, remove the volume, restart.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_owner_password

# Slow-query logging threshold (milliseconds).  Queries that take longer than this
# value are written to the postgres container log.  Default: 1000 ms (1 second).
# Set to 0 to log every query — useful for a short investigation session, but
# high-volume on a busy instance; restore the default after your session.
# Requires no restart — takes effect on the next stack up (or postgres restart).
# See docs/Operations/query-performance.md for the full workflow.
#PGCONFIG_LOG_MIN_DURATION_STATEMENT=1000

# ── App user ─────────────────────────────────────────────────────────────────
# Least-privilege runtime role. The migrator ALTERs app_user to this password on
# every deploy; the web app connects with it. Rotatable: change here, re-run the migrator.
APP_USER_PASSWORD=changeme_appuser_password

# ── DataProtection certificate ────────────────────────────────────────────────
# Passphrase for the auto-generated self-signed PFX certificate used to encrypt
# the ASP.NET Core DataProtection key ring at rest.  The dp-cert-init one-shot
# service generates /certs/dp.pfx on first run using this password; plantry-web
# reads it on startup to decrypt the key ring.
# Choose a strong random password and keep it stable — changing it invalidates
# the key ring and logs out all users.  To rotate: stop plantry-web, remove the
# dp_certs volume, update this value, and run `docker compose up -d`.
DP_CERT_PASSWORD=changeme_cert_password

# ── Domain ───────────────────────────────────────────────────────────────────
# The public hostname Caddy will obtain a TLS certificate for.
# DNS must already point at this host before the first `docker compose up`.
DOMAIN=plantry.example.com

# ── Image references (optional) ───────────────────────────────────────────────
# Override to pin a specific SHA tag instead of :latest (per ADR-016 deploy procedure).
# The CD workflow exports PLANTRY_WEB_IMAGE before running `docker compose pull`.
# Defaults (used when unset):
#   PLANTRY_WEB_IMAGE=ghcr.io/mgasparel/plantry/web:latest
#   MIGRATOR_IMAGE=ghcr.io/mgasparel/plantry/migrator:latest
#PLANTRY_WEB_IMAGE=ghcr.io/mgasparel/plantry/web:<sha>
#MIGRATOR_IMAGE=ghcr.io/mgasparel/plantry/migrator:<sha>

# ── AI API key (optional) ─────────────────────────────────────────────────────
# Leave blank to degrade AI features to a locked-feature UI. The app still runs.
AI_API_KEY=

# ── Backups (optional) ───────────────────────────────────────────────────────
# Tunables for the `backup` sidecar (pg_dump on a schedule) and the host-side
# rclone off-host sync. All have safe defaults; see docs/Operations/deployment.md.
#   BACKUP_CRON  — pg_dump schedule, cron format (default: 0 3 * * * = 03:00 UTC daily)
#   KEEP_DAYS    — days of local dumps to retain (default: 14)
#   BACKUP_DIR   — host path for the dump bind-mount (default: ./backups)
#   RCLONE_REMOTE— rclone remote for off-host sync, consumed by deploy/backup.sh
#                  (e.g. backblaze:plantry-backups). Unset → local dumps only.
#BACKUP_CRON=0 3 * * *
#KEEP_DAYS=14
#BACKUP_DIR=./backups
#RCLONE_REMOTE=backblaze:plantry-backups

# ── Observability (always-on in prod.yml) ────────────────────────────────────
# The lgtm sidecar is always present in docker-compose.prod.yml.
# Set GF_SECURITY_ADMIN_PASSWORD to a strong password before first run.
# Grafana is bound to 127.0.0.1:3000 — access via SSH tunnel (never public port).
GF_SECURITY_ADMIN_PASSWORD=changeme_grafana_password
#GF_SECURITY_ADMIN_USER=admin

# Retention — keep disk usage finite on the shared VPS.
# Interpolated into LOKI_EXTRA_ARGS / PROMETHEUS_EXTRA_ARGS in docker-compose.prod.yml.
# Loki: Nh or Nd (e.g. 744h = ~31 days).  Prometheus: Nd or Nw (e.g. 30d, 4w).
# Tempo block-retention is not exposed as a CLI flag in grafana/otel-lgtm; the
# built-in default applies. OTEL_TEMPO_RETENTION is informational only (not consumed).
#LOKI_RETENTION_PERIOD=744h
#PROMETHEUS_RETENTION_TIME=30d
#OTEL_TEMPO_RETENTION=168h   # informational only — not consumed by lgtm today
