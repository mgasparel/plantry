# .env.example — required environment variables for docker-compose.prod.yml
#
# Copy this file to .env, fill in real values, then lock it down:
#   cp .env.example .env
#   chmod 600 .env       # root-owned on the production host
#
# NEVER commit .env — it is in .gitignore.
# See docs/Operations/deployment.md for the full deployment runbook.

# ── Postgres ─────────────────────────────────────────────────────────────────
# Database owner credentials. Only the migrator connects as this role.
# POSTGRES_PASSWORD is only applied by Postgres on the FIRST volume initialisation —
# pin it once and keep it stable. To rotate: stop postgres, remove the volume, restart.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_owner_password

# ── App user ─────────────────────────────────────────────────────────────────
# Least-privilege runtime role. The migrator ALTERs app_user to this password on
# every deploy; the web app connects with it. Rotatable: change here, re-run the migrator.
APP_USER_PASSWORD=changeme_appuser_password

# ── Domain ───────────────────────────────────────────────────────────────────
# The public hostname Caddy will obtain a TLS certificate for.
# DNS must already point at this host before the first `docker compose up`.
DOMAIN=plantry.example.com

# ── Image references (optional) ───────────────────────────────────────────────
# Override to pin a specific SHA tag instead of :latest (per ADR-016 deploy procedure).
# The CD workflow exports PLANTRY_WEB_IMAGE before running `docker compose pull`.
# Defaults (used when unset):
#   PLANTRY_WEB_IMAGE=ghcr.io/gastownhall/plantry/web:latest
#   MIGRATOR_IMAGE=ghcr.io/gastownhall/plantry/migrator:latest
#PLANTRY_WEB_IMAGE=ghcr.io/gastownhall/plantry/web:<sha>
#MIGRATOR_IMAGE=ghcr.io/gastownhall/plantry/migrator:<sha>

# ── AI API key (optional) ─────────────────────────────────────────────────────
# Leave blank to degrade AI features to a locked-feature UI. The app still runs.
AI_API_KEY=

# ── Backups (optional) ───────────────────────────────────────────────────────
# Tunables for the `backup` sidecar (pg_dump on a schedule) and the host-side
# rclone off-host sync. All have safe defaults; see docs/Operations/deployment.md.
#   BACKUP_CRON  — pg_dump schedule, cron format (default: 0 3 * * * = 03:00 UTC daily)
#   KEEP_DAYS    — days of local dumps to retain (default: 14)
#   BACKUP_DIR   — host path for the dump bind-mount (default: ./backups)
#   RCLONE_REMOTE— rclone remote for off-host sync, consumed by deploy/backup.sh
#                  (e.g. backblaze:plantry-backups). Unset → local dumps only.
#BACKUP_CRON=0 3 * * *
#KEEP_DAYS=14
#BACKUP_DIR=./backups
#RCLONE_REMOTE=backblaze:plantry-backups
