# Container image — stamped automatically by deploy.ps1, do not edit by hand
PLANTRY_WEB_IMAGE=

# ASP.NET Core HTTP port inside the container (.NET 8+ default)
PLANTRY_WEB_PORT=8080

# Host port exposed to the browser (change if 8080 is taken on your machine)
HOST_PORT=8080

# Postgres superuser password — pick something strong
POSTGRES_PASSWORD=

# app_user Postgres role password
# Fresh DB:    choose any password; deploy will create the role with it via migrations
# Existing DB: run  ALTER ROLE app_user PASSWORD '<value>';  then set this to match
DATABASE_APP_USER_PASSWORD=

# Gemini API key (receipt parsing + AI meal planner)
AI_API_KEY=
