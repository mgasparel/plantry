@using Microsoft.AspNetCore.Mvc.Rendering
@model IReadOnlyList<SelectListItem>
@*
    Renders <option>s from a dimension-grouped unit SelectListItem list (plantry-n9iw), wrapping runs
    of items sharing the same Group.Name in an <optgroup>. asp-items handles this automatically for a
    plain <select asp-items="...">, but several unit selects are hand-built inside an Alpine
    x-model-bound <select> (a @@foreach over Model.UnitOptions building raw <option> tags) and can't use
    asp-items — this partial is the one shared place those loops delegate to, instead of each
    re-implementing the group-boundary tracking. Items with no Group render outside any optgroup.

    Honors SelectListItem.Selected (plantry-pe7n) for callers that pre-select the current value
    server-side (e.g. Shopping's inline per-row qty editor, which posts a plain named <select> rather
    than binding via asp-for). Rendered via the ternary-to-string-or-null pattern used elsewhere in this
    codebase (Currency.cshtml, Import pages: selected="@@(cond ? "selected" : null)") rather than
    handing the bool straight to the attribute, which can render as the literal text selected="False".
    Existing callers that never set Selected are unaffected — it defaults to false, so the attribute is
    simply omitted.
*@
@{
    string? currentGroup = null;
}
@foreach (var u in Model)
{
    var groupName = u.Group?.Name;
    if (groupName != currentGroup)
    {
        if (currentGroup != null)
        {
            @:</optgroup>
        }
        if (groupName != null)
        {
            @:<optgroup label="@groupName">
        }
        currentGroup = groupName;
    }
    <option value="@u.Value" selected="@(u.Selected ? "selected" : null)">@u.Text</option>
}
@if (currentGroup != null)
{
    @:</optgroup>
}
