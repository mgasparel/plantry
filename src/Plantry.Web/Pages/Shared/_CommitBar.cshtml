@using System.Globalization
@model Plantry.Web.Pages.Shared.CommitBarViewModel

@*
    Sticky footer for the intake review form — proto bottom-bar layout:
    Cancel  ·  [N to resolve warning]  ·  spacer  ·  Adding M items · $value  ·  Add to pantry

    The Commit button stays disabled until every line is resolved.
    Extends CommitBarViewModel with ConfirmedValue for the "Adding · $value" summary.
    Keeps the existing htmx OOB-swap contract (id="commit-bar" on the wrapper in Review.cshtml).
*@

<div class="commit-bar">
    <button type="button" class="btn btn--ghost commit-bar__cancel"
            hx-post="@Model.DiscardUrl"
            hx-confirm="Discard this import? Nothing will be added to your pantry.">
        Cancel
    </button>
    <span class="commit-bar__spacer"></span>
    @if (Model.Remaining > 0)
    {
        <span class="commit-bar__warn">
            <svg class="icon" aria-hidden="true"><use href="#i-alert" /></svg>
            @Model.Remaining to resolve
        </span>
    }
    <div class="commit-bar__summary">
        Adding <b>@Model.Confirmed</b> items · <b class="mono">@Model.ConfirmedValue.ToString("C", CultureInfo.CurrentCulture)</b>
    </div>
    <button type="button" class="btn btn--primary"
            hx-post="@Model.CommitUrl" disabled="@(Model.CanCommit ? null : "disabled")">
        <svg class="icon" aria-hidden="true"><use href="#i-check" /></svg>
        Add to pantry
    </button>
</div>
