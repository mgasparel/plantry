@using Plantry.Web.Pages.Shared
@inject IWebHostEnvironment Env
@inject Plantry.Housekeeping.Application.ITidyUpBadgeCache TidyUpBadgeCache
@inject Plantry.SharedKernel.Tenancy.ITenantContext Tenant
@{
    var pagePath = ViewContext.RouteData.Values["page"]?.ToString() ?? "";
    var segments = pagePath.Split('/', StringSplitOptions.RemoveEmptyEntries);
    var title = ViewData["Title"]?.ToString() ?? "";
    var parents = Breadcrumbs.BuildParents(pagePath, title);
    var crumbIcon = Breadcrumbs.Icon(parents, segments);

    string NavActive(string prefix, string? except = null) =>
        NavHighlight.IsActive(ViewContext.RouteData.Values["page"]?.ToString(), prefix, except)
            ? " sidebar__link--active"
            : "";
    string BottomNavActive(string prefix) =>
        ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith(prefix) == true ? " bottom-nav__item--active" : "";

    // Tidy Up nav badge (T6): reads the cached open-finding count ONLY — never runs a detector on a
    // plain page render. A cache miss (cold start, or TTL expiry with no recent Tidy Up visit) reads
    // as 0 (no badge) until the next real Tidy Up page render repopulates it.
    var tidyUpCount = Tenant.HouseholdId is { } tidyUpHouseholdId
        ? await TidyUpBadgeCache.TryGetAsync(Plantry.SharedKernel.HouseholdId.From(tidyUpHouseholdId)) ?? 0
        : 0;
    var tidyUpSidebarBadge = new TidyUpBadgeViewModel(tidyUpCount, "sidebar-tidyup-badge", false);
}
<!DOCTYPE html>
<html lang="en" data-theme="hearth">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Plantry</title>
    <link rel="stylesheet" href="~/css/plenish.css" asp-append-version="true" />
</head>
<body class="app-body">

    @* Icon sprite — referenced via <svg class="icon"><use href="#i-NAME"/></svg> *@
    <svg style="display:none" aria-hidden="true">
        <symbol id="i-pantry" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="18" height="18" rx="2" /><path d="M3 9h18M9 9v12" />
        </symbol>
        <symbol id="i-receipt" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 3h14v18l-2.5-1.6L14 21l-2-1.6L10 21l-2.5-1.6L5 21V3Z" /><path d="M9 8h6M9 12h6" />
        </symbol>
        <symbol id="i-box" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 3 4 7v10l8 4 8-4V7l-8-4Z" /><path d="m4 7 8 4 8-4M12 11v10" />
        </symbol>
        <symbol id="i-sparkle" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 3l1.6 5.4L19 10l-5.4 1.6L12 17l-1.6-5.4L5 10l5.4-1.6L12 3Z" />
        </symbol>
        <symbol id="i-cart" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="9" cy="20" r="1.4" /><circle cx="18" cy="20" r="1.4" /><path d="M2 3h2.2l2.3 12.2a1 1 0 0 0 1 .8h9.3a1 1 0 0 0 1-.8L20 7H6" />
        </symbol>
        <symbol id="i-tag" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 12V4h8l9 9-8 8-9-9Z" /><circle cx="7.5" cy="7.5" r="1.3" />
        </symbol>
        <symbol id="i-recipe" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 3h12a1 1 0 0 1 1 1v14H7a2 2 0 0 0-2 2V3Z" /><path d="M18 18v3H7a2 2 0 0 1-2-2" /><path d="M9 7h5M9 10h5" />
        </symbol>
        <symbol id="i-settings" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="3" /><path d="M19.4 13a1.6 1.6 0 0 0 .3 1.8l.1.1a2 2 0 1 1-2.8 2.8l-.1-.1a1.6 1.6 0 0 0-2.7 1.1V19a2 2 0 1 1-4 0v-.1A1.6 1.6 0 0 0 7 17.3l-.1.1a2 2 0 1 1-2.8-2.8l.1-.1a1.6 1.6 0 0 0-1-2.7H3a2 2 0 1 1 0-4h.1A1.6 1.6 0 0 0 4.7 7l-.1-.1a2 2 0 1 1 2.8-2.8l.1.1A1.6 1.6 0 0 0 10 4.6V4a2 2 0 1 1 4 0v.1a1.6 1.6 0 0 0 2.7 1l.1-.1a2 2 0 1 1 2.8 2.8l-.1.1a1.6 1.6 0 0 0 .9 2.7H21a2 2 0 1 1 0 4h-.1a1.6 1.6 0 0 0-1.5 1Z" />
        </symbol>
        <symbol id="i-logout" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" /><path d="M16 17l5-5-5-5M21 12H9" />
        </symbol>
        <symbol id="i-components" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="7" height="7" rx="1.5" /><rect x="14" y="3" width="7" height="7" rx="1.5" />
            <rect x="3" y="14" width="7" height="7" rx="1.5" /><rect x="14" y="14" width="7" height="7" rx="1.5" />
        </symbol>
        <symbol id="i-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 6 9 17l-5-5" />
        </symbol>
        <symbol id="i-alert" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 9v4M12 17h.01M10.3 3.9 1.8 18a2 2 0 0 0 1.7 3h17a2 2 0 0 0 1.7-3L13.7 3.9a2 2 0 0 0-3.4 0Z" />
        </symbol>
        <symbol id="i-search" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="7" /><path d="m21 21-4.3-4.3" />
        </symbol>
        <symbol id="i-lock" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <rect x="4" y="11" width="16" height="9" rx="2" /><path d="M8 11V7a4 4 0 0 1 8 0v4" />
        </symbol>
        <symbol id="i-camera" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 7h4l2-2.5h6L17 7h4v13H3V7Z" /><circle cx="12" cy="13" r="3.6" />
        </symbol>
        <symbol id="i-image" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="4" width="18" height="16" rx="2" /><circle cx="8.5" cy="9.5" r="1.6" /><path d="m4 18 5-5 4 3 3-2.5 4 4" />
        </symbol>
        <symbol id="i-clock" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="8.5" /><path d="M12 7.5V12l3 2" />
        </symbol>
        <symbol id="i-minus" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <path d="M5 12h14" />
        </symbol>
        <symbol id="i-plus" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <path d="M12 5v14M5 12h14" />
        </symbol>
        <symbol id="i-edit" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 20h9" /><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5Z" />
        </symbol>
        <symbol id="i-location" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2C8.7 2 6 4.7 6 8c0 4.5 6 12 6 12s6-7.5 6-12c0-3.3-2.7-6-6-6Z" /><circle cx="12" cy="8" r="2" />
        </symbol>
        <symbol id="i-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 9l6 6 6-6" />
        </symbol>
        <symbol id="i-chevron-right" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 18l6-6-6-6" />
        </symbol>
        <symbol id="i-timer" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="13" r="8" /><path d="M12 9v4l2.5 2.5M9.5 2h5M12 2v3" />
        </symbol>
        <symbol id="i-servings" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 11h16M4 11a8 8 0 0 1 16 0M3 11h18M12 3v1.5" /><path d="M5 15h14M6 18h12" />
        </symbol>
        <symbol id="i-flame" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M8.5 14c0 4 2 6.5 5.5 6.5 3 0 5.5-2.7 5.5-6C19.5 9 16 6 14 3.5c0 3.5-2 5.5-3.5 5.5-1.5 0-2.5-1-2.5-2.5C7 8.5 5 11 5 14c0 2 .9 3.8 2.5 4.5" />
        </symbol>
        <symbol id="i-gallery" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="8" height="8" rx="1.5" /><rect x="13" y="3" width="8" height="8" rx="1.5" />
            <rect x="3" y="13" width="8" height="8" rx="1.5" /><rect x="13" y="13" width="8" height="8" rx="1.5" />
        </symbol>
        <symbol id="i-rows" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="5" width="18" height="4" rx="1" /><rect x="3" y="11" width="18" height="4" rx="1" /><rect x="3" y="17" width="18" height="4" rx="1" />
        </symbol>
        @* New icons for frequency-banded IA (plantry-8r6) *@
        <symbol id="i-calendar" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="4" width="18" height="17" rx="2" /><path d="M3 9h18M8 2v4M16 2v4" />
        </symbol>
        <symbol id="i-grid" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="7" height="7" rx="1" /><rect x="14" y="3" width="7" height="7" rx="1" />
            <rect x="3" y="14" width="7" height="7" rx="1" /><rect x="14" y="14" width="7" height="7" rx="1" />
        </symbol>
        <symbol id="i-trash" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 6h18" /><path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" /><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" /><path d="M10 11v6" /><path d="M14 11v6" />
        </symbol>
        <symbol id="i-import" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 3v12" /><path d="M7 11l5 5 5-5" /><path d="M3 19h18" />
        </symbol>
        <symbol id="i-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="4" /><path d="M12 2v2M12 20v2M2 12h2M20 12h2M5 5l1.4 1.4M17.6 17.6 19 19M19 5l-1.4 1.4M6.4 17.6 5 19" />
        </symbol>
        <symbol id="i-info" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="9" /><path d="M12 8h.01M12 12v4" />
        </symbol>
        <symbol id="i-scale" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="m16 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z" /><path d="m2 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z" /><path d="M7 21h10" /><path d="M12 3v18" /><path d="M3 7h2c2 0 5-1 7-2 2 1 5 2 7 2h2" />
        </symbol>
        @* Tidy Up (tidy-up.md T1) — revised broom from the approved prototype (.preview/data-health-page.html). *@
        <symbol id="i-broom" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 3v7" /><path d="M9.3 10h5.4a3 3 0 0 1 2.9 2.3L19 20H5l1.4-7.7A3 3 0 0 1 9.3 10Z" /><path d="M9.2 20l.5-4M14.8 20l-.5-4" />
        </symbol>
    </svg>

    @* Desktop sidebar (hidden below md breakpoint via CSS) *@
    <nav class="sidebar" aria-label="Main navigation">
        <div class="sidebar__brand">
            <a href="/Today" class="logo-wordmark">Plantry</a>
        </div>

        @* Band 1: Cook & Plan *@
        <ul class="sidebar__nav" role="list">
            <li class="sidebar__band-label">Cook &amp; Plan</li>
            <li>
                <a href="/Today" class="sidebar__link@(NavActive("/Today"))">
                    <svg class="icon" aria-hidden="true"><use href="#i-sun" /></svg> Today
                </a>
            </li>
            <li>
                <a href="/Recipes" class="sidebar__link@(NavActive("/Recipes"))">
                    <svg class="icon" aria-hidden="true"><use href="#i-recipe" /></svg> Recipes
                </a>
            </li>
            <li>
                <a href="/MealPlan" class="sidebar__link@(NavActive("/MealPlan"))">
                    <svg class="icon" aria-hidden="true"><use href="#i-calendar" /></svg> Meal Plan
                </a>
            </li>
        </ul>

        @* Band 2: Shop *@
        <ul class="sidebar__nav sidebar__nav--band" role="list">
            <li class="sidebar__band-label">Shop</li>
            <li>
                <a href="/Shopping" class="sidebar__link@(NavActive("/Shopping"))">
                    <svg class="icon" aria-hidden="true"><use href="#i-cart" /></svg> Shop
                </a>
            </li>
            <li>
                <a href="/Deals" class="sidebar__link@(NavActive("/Deals"))">
                    <svg class="icon" aria-hidden="true"><use href="#i-sparkle" /></svg> Deals
                </a>
            </li>
            <li>
                <a href="/Intake/Upload" class="sidebar__link@(NavActive("/Intake"))">
                    <svg class="icon" aria-hidden="true"><use href="#i-receipt" /></svg> Scan Receipt
                </a>
            </li>
        </ul>

        @* Band 3: Manage *@
        <ul class="sidebar__nav sidebar__nav--band" role="list">
            <li class="sidebar__band-label">Manage</li>
            <li>
                <a href="/Pantry" class="sidebar__link@(NavActive("/Pantry", except: "/Pantry/TakeStock"))">
                    <svg class="icon" aria-hidden="true"><use href="#i-pantry" /></svg> Pantry
                </a>
            </li>
            <li>
                <a href="/pantry/take-stock" class="sidebar__link@(NavActive("/Pantry/TakeStock"))">
                    <svg class="icon" aria-hidden="true"><use href="#i-check" /></svg> Take Stock
                </a>
            </li>
            <li>
                <a href="/Catalog" class="sidebar__link@(NavActive("/Catalog"))">
                    <svg class="icon" aria-hidden="true"><use href="#i-tag" /></svg> Catalog
                </a>
            </li>
            <li>
                <a href="/TidyUp" class="sidebar__link@(NavActive("/TidyUp"))">
                    <svg class="icon" aria-hidden="true"><use href="#i-broom" /></svg> Tidy Up
                    <partial name="_TidyUpBadge" model="tidyUpSidebarBadge" />
                </a>
            </li>
        </ul>

        <div class="sidebar__footer">
            @if (Env.IsDevelopment())
            {
                <a href="/Dev" class="sidebar__link@(NavActive("/Dev"))">
                    <svg class="icon" aria-hidden="true"><use href="#i-components" /></svg> Components
                </a>
                <a href="/Import" class="sidebar__link@(NavActive("/Import"))">
                    <svg class="icon" aria-hidden="true"><use href="#i-import" /></svg> Grocy Import
                </a>
            }
            <a href="/Settings" class="sidebar__link@(NavActive("/Settings"))">
                <svg class="icon" aria-hidden="true"><use href="#i-settings" /></svg> Settings
            </a>
            <form method="post" action="/Account/Logout" style="margin:0">
                @Html.AntiForgeryToken()
                <button type="submit" class="sidebar__link sidebar__link--button">
                    <svg class="icon" aria-hidden="true"><use href="#i-logout" /></svg> Sign Out
                </button>
            </form>
        </div>
    </nav>

    @* Main content column *@
    <div class="app-content">
        <header class="topbar">
            <div class="crumb">
                @if (!string.IsNullOrEmpty(crumbIcon))
                {
                    <svg class="icon" aria-hidden="true"><use href="#i-@crumbIcon" /></svg>
                }
                @foreach (var parent in parents)
                {
                    @Breadcrumbs.Label(parent) <span class="crumb-sep">/</span>
                }
                <b>@title</b>
            </div>
        </header>
        <main id="main-content" class="page-content @(ViewData["ContentClass"]?.ToString())">
            @RenderBody()
        </main>
    </div>

    @* Mobile quick-add intake sheet — Alpine-driven, always in DOM, hidden until Add tapped *@
    <div x-data="{ open: false }" id="quick-add-sheet-root">
        @* Mobile bottom nav — exactly 5 items: Today | Recipes | Add | Shop | More *@
        <nav class="bottom-nav" aria-label="Mobile navigation">
            <a href="/Today" class="bottom-nav__item@(BottomNavActive("/Today"))">
                <svg class="icon" aria-hidden="true"><use href="#i-sun" /></svg>
                <span>Today</span>
            </a>
            <a href="/Recipes" class="bottom-nav__item@(BottomNavActive("/Recipes"))">
                <svg class="icon" aria-hidden="true"><use href="#i-recipe" /></svg>
                <span>Recipes</span>
            </a>
            @* Add — opens the quick-add intake sheet; not a page navigation *@
            <button type="button" class="bottom-nav__item bottom-nav__item--add"
                    x-on:click="open = true"
                    aria-label="Add stock"
                    aria-haspopup="dialog">
                <svg class="icon" aria-hidden="true"><use href="#i-plus" /></svg>
                <span>Add</span>
            </button>
            <a href="/Shopping" class="bottom-nav__item@(BottomNavActive("/Shopping"))">
                <svg class="icon" aria-hidden="true"><use href="#i-cart" /></svg>
                <span>Shop</span>
            </a>
            <a href="/More" class="bottom-nav__item@(BottomNavActive("/More"))">
                <svg class="icon" aria-hidden="true"><use href="#i-grid" /></svg>
                <span>More</span>
            </a>
        </nav>

        @* The quick-add sheet itself *@
        <div class="sheet" role="dialog" aria-modal="true" aria-label="Add stock"
             x-show="open" x-cloak
             @@keydown.escape.window="open = false">
            <div class="sheet__overlay" x-on:click="open = false"></div>
            <div class="sheet__panel">
                <header class="sheet__header">
                    <h2 class="sheet__title">Add stock</h2>
                    <button type="button" class="sheet__close" aria-label="Close"
                            x-on:click="open = false">&times;</button>
                </header>
                <div class="quick-add-options">
                    <a href="/Pantry" class="quick-add-option" x-on:click="open = false">
                        <svg class="icon quick-add-option__icon" aria-hidden="true"><use href="#i-plus" /></svg>
                        <div class="quick-add-option__text">
                            <span class="quick-add-option__label">Add manually</span>
                            <span class="quick-add-option__sub">Log a product by name and quantity</span>
                        </div>
                    </a>
                    <a href="/Intake/Upload" class="quick-add-option" x-on:click="open = false">
                        <svg class="icon quick-add-option__icon" aria-hidden="true"><use href="#i-camera" /></svg>
                        <div class="quick-add-option__text">
                            <span class="quick-add-option__label">Scan receipt</span>
                            <span class="quick-add-option__sub">Import items from a photo or text</span>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <script src="~/js/htmx.min.js" defer></script>
    <script src="~/js/htmx-antiforgery.js" defer></script>
    @* Alpine.data registrations must load BEFORE alpine.min.js: Alpine dispatches 'alpine:init'
       and starts synchronously the moment its script runs (the DOM is already parsed by the
       time a deferred script executes), so anything registering components must already be
       listening — registering after Alpine has loaded is too late and fails silently. *@
    <script src="~/js/searchable-select.js" defer></script>
    <script src="~/js/sortable-list.js" defer></script>
    <script src="~/js/plan-tune.js" defer></script>
    <script src="~/js/alpine.min.js" defer></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
