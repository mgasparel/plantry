                    </button>
                    <div class="sl-body"><div class="sl-name">Spinach</div></div>
                    <span class="sl-qty">1 clamshell</span>
                    <div class="sl-actions"></div>
                </div>
                <div class="sl-item">
                    <button type="button" class="sl-check" aria-label="Check off Bananas">
                        <svg class="icon" aria-hidden="true"><use href="#i-check" /></svg>
                    </button>
                    <div class="sl-body">
                        <div class="sl-name">Bananas</div>
                        <div class="sl-sub">
                            <span class="sl-note">
                                <svg class="icon" aria-hidden="true"><use href="#i-edit" /></svg>
                                Slightly green please
                            </span>
                        </div>
                    </div>
                    <span class="sl-qty">1 bunch</span>
                    <div class="sl-actions"></div>
                </div>
                <div class="sl-item">
                    <button type="button" class="sl-check" aria-label="Check off Paper towels">
                        <svg class="icon" aria-hidden="true"><use href="#i-check" /></svg>
                    </button>
                    <div class="sl-body">
                        <div class="sl-name">Paper towels <span class="free-tag">custom</span></div>
                    </div>
                    <span class="sl-qty">1 pack</span>
                    <div class="sl-actions"></div>
                </div>
            </div>
        </div>
    </div>
    <pre class="code-sample"><code>@("<div class=\"sl-group\" aria-label=\"{categoryName}\">\n  <div class=\"sl-group-head\">\n    <!-- colour dot (has category): -->\n    <span class=\"cdot\" style=\"background: oklch(0.6 0.12 {hue})\" aria-hidden=\"true\"></span>\n    <!-- OR tag icon (uncategorised): -->\n    <svg class=\"icon\" style=\"color: var(--color-text-faint); width:16px; height:16px; flex:none\"><use href=\"#i-tag\"/></svg>\n    <h3>Category Name</h3>\n    <span class=\"count\">{count}</span>\n    <span class=\"spacer\"></span>\n  </div>\n  <div class=\"sl-rows\">\n    <!-- .sl-item rows -->\n  </div>\n</div>")</code></pre>
</section>

<section class="catalog-section">
    <div class="catalog-section__header">
        <h2 class="catalog-section__heading">Shopping List — item row (<code>.sl-item</code>)</h2>
    </div>
    <p>
        <code>.sl-item</code> is the row layout: <code>.sl-check</code> (square 24×24 checkbox button,
        rounded-sm, fills accent when checked via <code>.on</code>) + <code>.sl-body</code> (name + optional
        note sub-line) + <code>.sl-qty</code> pill (monospace, 999px border-radius) + <code>.sl-actions</code>
        (hover-revealed, 0→1 opacity). Free-text items show a <code>.free-tag</code> "custom" badge in the name.
        Checked items get <code>.done</code>: name struck-through with faint colour, check filled with
        <code>--color-text-faint</code>. Action buttons are shell-only in this bead; wired by sibling beads
        (plantry-853, plantry-dem).
    </p>
    <div style="max-width: 600px">
        <div class="sl-group">
            <div class="sl-rows">
                <div class="sl-item">
                    <button type="button" class="sl-check" aria-label="Check off Whole Milk">
                        <svg class="icon" aria-hidden="true"><use href="#i-check" /></svg>
                    </button>
                    <div class="sl-body"><div class="sl-name">Whole Milk</div></div>
                    <span class="sl-qty">2 L</span>
                    <div class="sl-actions">
                        <button type="button" class="sl-act" title="Add note" aria-label="Add note">
                            <svg class="icon" aria-hidden="true"><use href="#i-edit" /></svg>
                        </button>
                        <button type="button" class="sl-act danger" title="Remove" aria-label="Remove">
                            <svg class="icon" aria-hidden="true"><use href="#i-trash" /></svg>
                        </button>
                    </div>
                </div>
                <div class="sl-item">
                    <button type="button" class="sl-check" aria-label="Check off Chicken">
                        <svg class="icon" aria-hidden="true"><use href="#i-check" /></svg>
                    </button>
                    <div class="sl-body">
                        <div class="sl-name">Chicken Breast</div>
                        <div class="sl-sub">
                            <span class="sl-note">
                                <svg class="icon" aria-hidden="true"><use href="#i-edit" /></svg>
                                Portion and freeze the family pack
                            </span>
                        </div>
                    </div>
                    <span class="sl-qty">1.4 kg</span>
                    <div class="sl-actions"></div>
                </div>
                <div class="sl-item done">
                    <button type="button" class="sl-check on" aria-label="Uncheck Roma Tomatoes">
                        <svg class="icon" aria-hidden="true"><use href="#i-check" /></svg>
                    </button>
                    <div class="sl-body"><div class="sl-name">Roma Tomatoes</div></div>
                    <span class="sl-qty">6 ea</span>
                    <div class="sl-actions"></div>
                </div>
            </div>
        </div>
    </div>
    <pre class="code-sample"><code>@("<!-- Unchecked item -->\n<div class=\"sl-item\" id=\"shopping-item-{itemId}\">\n  <button type=\"button\" class=\"sl-check\"\n          hx-post=\"/Shopping?handler=CheckOff&listId={listId}&itemId={itemId}\"\n          hx-target=\"#shopping-list\" hx-swap=\"outerHTML\"\n          aria-label=\"Check off {name}\">\n    <svg class=\"icon\" aria-hidden=\"true\"><use href=\"#i-check\"/></svg>\n  </button>\n  <div class=\"sl-body\">\n    <div class=\"sl-name\">\n      {name}\n      <!-- free-text items only: -->\n      <span class=\"free-tag\">custom</span>\n    </div>\n    <!-- optional note sub-line (hidden when checked): -->\n    <div class=\"sl-sub\">\n      <span class=\"sl-note\"><svg class=\"icon\"><use href=\"#i-edit\"/></svg> {note}</span>\n    </div>\n  </div>\n  <span class=\"sl-qty\">{qty} {unit}</span>\n  <div class=\"sl-actions\" aria-label=\"Item actions\"><!-- wired by sibling beads --></div>\n</div>\n\n<!-- Checked item — add .done to .sl-item and .on to .sl-check -->\n<div class=\"sl-item done\">\n  <button type=\"button\" class=\"sl-check on\" …>…</button>\n  …\n</div>")</code></pre>
</section>

<section class="catalog-section">
    <div class="catalog-section__header">
        <h2 class="catalog-section__heading">Shopping List — inline item editors (<code>.sl-qtyedit</code>, <code>.sl-noterow</code>) (plantry-dem)</h2>
    </div>
    <p>
        Two inline editors expand in place on the item row (unchecked items only).
    </p>
    <p>
        <strong>Qty/unit editor</strong> (<code>.sl-qtyedit</code>): the <code>.sl-qty</code> pill is rendered
        as a <code>&lt;button&gt;</code> for unchecked items. Clicking it sets <code>editingQty = true</code>
        in Alpine, swapping the pill out (via <code>x-show="!editingQty"</code>) for a <code>.sl-qtyedit</code>
        form containing the <code>.sl-qty-stepper</code>, a <code>.sl-qsel</code> unit select, and a
        <code>.sl-act.save</code> button. The form posts to <code>?handler=EditQuantity</code>; on
        <code>x-on:submit</code> sets <code>editingQty = false</code>.
        Note: <code>.sl-qsel</code> currently renders only the current unit option pending plantry-259 (full unit list).
    </p>
    <p>
        <strong>Note editor</strong> (<code>.sl-noterow</code>): the pencil button in <code>.sl-actions</code>
        toggles <code>editingNote</code>. The <code>.sl-noterow</code> (inside <code>.sl-body</code>) contains
        a form with a <code>.sl-noteinput</code> text input and <code>.sl-act.save</code> button. Posts to
        <code>?handler=SetNote</code>. The active pencil button uses <code>.sl-act.active</code>.
        Escape collapses both editors via <code>x-on:keydown.escape.window</code> on the <code>.sl-item</code>.
    </p>
    <div style="max-width: 660px">
        <div class="sl-group">
            <div class="sl-rows">
                @* Qty editor open (editingQty = true) *@
                <div class="sl-item"
                     x-data="{ editingQty: true, editingNote: false, qty: '2', note: '' }"
                     x-on:keydown.escape.window="editingQty = false; editingNote = false">
                    <button type="button" class="sl-check" aria-label="Check off Whole Milk">
                        <svg class="icon" aria-hidden="true"><use href="#i-check" /></svg>
                    </button>
                    <div class="sl-body">
                        <div class="sl-name">Whole Milk</div>
                        <div class="sl-noterow" x-show="editingNote" x-cloak>
                            <form>
                                <input type="text" name="note" class="sl-noteinput" placeholder="Add a note…" maxlength="500" x-model="note" aria-label="Note for Whole Milk" />
                                <button type="submit" class="sl-act save" aria-label="Save note">
                                    <svg class="icon" aria-hidden="true"><use href="#i-check" /></svg>
                                </button>
                            </form>
                        </div>
                    </div>
                    <button type="button" class="sl-qty" x-show="!editingQty" x-on:click="editingQty = true" aria-label="Edit quantity for Whole Milk">2 L</button>
                    <form class="sl-qtyedit" x-show="editingQty" x-cloak x-on:submit="editingQty = false">
                        <div class="sl-qty-stepper">
                            <button type="button" class="sl-qbtn" aria-label="Decrease"
                                    x-on:click="qty = (+qty - 1) < 0 ? '0' : (+qty - 1).toFixed(3).replace(/\.?0+$/, '') || '0'">
                                <svg class="icon" aria-hidden="true"><use href="#i-minus" /></svg>
                            </button>
                            <input type="number" name="quantity" min="0" step="any" x-model="qty" aria-label="Quantity" />
                            <button type="button" class="sl-qbtn" aria-label="Increase"
                                    x-on:click="qty = (+qty + 1).toFixed(3).replace(/\.?0+$/, '') || '1'">
                                <svg class="icon" aria-hidden="true"><use href="#i-plus" /></svg>
                            </button>
                        </div>
                        @* .sl-qsel: full unit list supplied by plantry-259; currently only current unit shown *@
                        <select name="unitId" class="sl-qsel" aria-label="Unit">
                            <option value="">L</option>
                        </select>
                        <button type="submit" class="sl-act save" aria-label="Save quantity">
                            <svg class="icon" aria-hidden="true"><use href="#i-check" /></svg>
                        </button>
                    </form>
                    <div class="sl-actions" aria-label="Item actions">
                        <button type="button" class="sl-act"
                                x-on:click="editingNote = !editingNote"
                                x-bind:class="editingNote ? 'sl-act active' : 'sl-act'"
                                aria-label="Add note for Whole Milk">
                            <svg class="icon" aria-hidden="true"><use href="#i-edit" /></svg>
                        </button>
                        <button type="button" class="sl-act danger" aria-label="Delete Whole Milk">
                            <svg class="icon" aria-hidden="true"><use href="#i-trash" /></svg>
                        </button>
                    </div>
                </div>
                @* Note editor open (editingNote = true) *@
                <div class="sl-item"
                     x-data="{ editingQty: false, editingNote: true, qty: '1.4', note: '' }"
                     x-on:keydown.escape.window="editingQty = false; editingNote = false">
                    <button type="button" class="sl-check" aria-label="Check off Chicken Breast">
                        <svg class="icon" aria-hidden="true"><use href="#i-check" /></svg>
                    </button>
                    <div class="sl-body">
                        <div class="sl-name">Chicken Breast</div>
                        <div class="sl-noterow" x-show="editingNote" x-cloak>
                            <form x-on:submit="editingNote = false">
                                <input type="text" name="note" class="sl-noteinput" placeholder="Add a note…" maxlength="500" x-model="note" aria-label="Note for Chicken Breast" />
                                <button type="submit" class="sl-act save" aria-label="Save note">
                                    <svg class="icon" aria-hidden="true"><use href="#i-check" /></svg>
                                </button>
                            </form>
                        </div>
                    </div>
                    <button type="button" class="sl-qty" x-show="!editingQty" x-on:click="editingQty = true" aria-label="Edit quantity for Chicken Breast">1.4 kg</button>
                    <form class="sl-qtyedit" x-show="editingQty" x-cloak x-on:submit="editingQty = false">
                        <div class="sl-qty-stepper">
                            <button type="button" class="sl-qbtn" aria-label="Decrease"
                                    x-on:click="qty = (+qty - 1) < 0 ? '0' : (+qty - 1).toFixed(3).replace(/\.?0+$/, '') || '0'">
                                <svg class="icon" aria-hidden="true"><use href="#i-minus" /></svg>
                            </button>
                            <input type="number" name="quantity" min="0" step="any" x-model="qty" aria-label="Quantity" />
                            <button type="button" class="sl-qbtn" aria-label="Increase"
                                    x-on:click="qty = (+qty + 1).toFixed(3).replace(/\.?0+$/, '') || '1'">
                                <svg class="icon" aria-hidden="true"><use href="#i-plus" /></svg>
                            </button>
                        </div>
                        <select name="unitId" class="sl-qsel" aria-label="Unit">
                            <option value="">kg</option>
                        </select>
                        <button type="submit" class="sl-act save" aria-label="Save quantity">
                            <svg class="icon" aria-hidden="true"><use href="#i-check" /></svg>
                        </button>
                    </form>
                    <div class="sl-actions" aria-label="Item actions">
                        @* Active state when note editor is open *@
                        <button type="button"
                                x-on:click="editingNote = !editingNote"
                                x-bind:class="editingNote ? 'sl-act active' : 'sl-act'"
                                aria-label="Edit note for Chicken Breast">
                            <svg class="icon" aria-hidden="true"><use href="#i-edit" /></svg>
                        </button>
                        <button type="button" class="sl-act danger" aria-label="Delete Chicken Breast">
                            <svg class="icon" aria-hidden="true"><use href="#i-trash" /></svg>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="catalog-section">
    <div class="catalog-section__header">
        <h2 class="catalog-section__heading">Shopping List — checked section (<code>.sl-checked-head</code> + <code>.sl-clear</code>)</h2>
    </div>
    <p>
        <code>.sl-checked-head</code> is the divider that appears above the checked-items group.
        It contains a <code>.lbl</code> (check icon + "Checked off" text), a <code>.spacer</code>
        hairline, and a <code>.sl-clear</code> button. On hover, <code>.sl-clear</code> shifts to
        danger colours. The checked group uses a plain <code>.sl-group</code> (no group-head
        — the <code>.sl-checked-head</code> serves as the header). The <code>.sl-empty</code>
        state appears when the list has no items at all.
    </p>
    <div style="max-width: 600px">
        <div class="sl-checked-head">
            <span class="lbl">
                <svg class="icon" aria-hidden="true"><use href="#i-check" /></svg>
                Checked off
            </span>
            <span class="spacer"></span>
            <button type="button" class="sl-clear">
                <svg class="icon" aria-hidden="true"><use href="#i-trash" /></svg>
                Clear 2 checked items
            </button>
        </div>
        <div class="sl-group">
            <div class="sl-rows">
                <div class="sl-item done">
                    <button type="button" class="sl-check on" aria-label="Uncheck Eggs">
                        <svg class="icon" aria-hidden="true"><use href="#i-check" /></svg>
                    </button>
                    <div class="sl-body"><div class="sl-name">Eggs</div></div>
                    <span class="sl-qty">12 ct</span>
                    <div class="sl-actions"></div>
                </div>
            </div>
        </div>
        <div class="sl-empty" style="margin-top: 24px">
            <div class="big">Your list is empty</div>
            Add a product from the catalog or type a custom item above.
        </div>
    </div>
    <pre class="code-sample"><code>@("<!-- Checked section header -->\n<div class=\"sl-checked-head\">\n  <span class=\"lbl\">\n    <svg class=\"icon\"><use href=\"#i-check\"/></svg> Checked off\n  </span>\n  <span class=\"spacer\"></span>\n  <form method=\"post\" action=\"/Shopping?handler=ClearChecked\">\n    @AntiForgeryToken\n    <button type=\"submit\" class=\"sl-clear\">\n      <svg class=\"icon\"><use href=\"#i-trash\"/></svg>\n      Clear {count} checked {item|items}\n    </button>\n  </form>\n</div>\n\n<!-- Empty state -->\n<div class=\"sl-empty\">\n  <div class=\"big\">Your list is empty</div>\n  Add a product from the catalog or type a custom item above.\n</div>")</code></pre>
</section>

<section class="catalog-section">
    <div class="catalog-section__header">
        <h2 class="catalog-section__heading">Shopping List — "Running low in your pantry" suggestions strip (<code>.sl-suggest</code>, <code>.sl-sug</code>) (plantry-48l)</h2>
    </div>
    <p>
        <code>.sl-suggest</code> is a card rendered ABOVE the category groups when there are pantry products
        at or below par that are NOT already on the active list (capped at 5). The strip heading
        (<code>.sl-suggest-label</code>) is in warning colour. Each chip (<code>.sl-sug</code>) shows:
        the shared <code>_CatChip</code> partial (colour dot / category code), the product name (<code>.sl-sug-name</code>),
        a stock label (<code>.sl-sug-stock</code> — "N unit left" or "out"), and a round <code>.sadd</code>
        button (accent background, plus icon) that POSTs to <code>?handler=AddItem</code> with just
        <code>Input.ProductId</code> set. On POST htmx swaps <code>#shopping-list</code> with
        <code>outerHTML</code> — the strip automatically disappears for the added product in the refreshed
        fragment.
    </p>
    <div style="max-width: 700px">
        @{
            var devSugChip1 = new Plantry.Web.Pages.Shared.CatChipViewModel("Dairy", 200);
            var devSugChip2 = new Plantry.Web.Pages.Shared.CatChipViewModel("Produce", 130);
            var devSugChip3 = new Plantry.Web.Pages.Shared.CatChipViewModel(null, null);
        }
        <div class="sl-suggest" aria-label="Running low in your pantry">
            <div class="sl-suggest-label">Running low in your pantry</div>
            <div class="sl-sug-chips">
                <div class="sl-sug">
                    <partial name="Shared/_CatChip" model="devSugChip1" />
                    <span class="sl-sug-name">Whole Milk</span>
                    <span class="sl-sug-stock">0.5 L left</span>
                    <button type="button" class="sadd" aria-label="Add Whole Milk to list">
                        <svg class="icon" aria-hidden="true"><use href="#i-plus" /></svg>
                    </button>
                </div>
                <div class="sl-sug">
                    <partial name="Shared/_CatChip" model="devSugChip2" />
                    <span class="sl-sug-name">Spinach</span>
                    <span class="sl-sug-stock out">out</span>
                    <button type="button" class="sadd" aria-label="Add Spinach to list">
                        <svg class="icon" aria-hidden="true"><use href="#i-plus" /></svg>
                    </button>
                </div>
                <div class="sl-sug">
                    <partial name="Shared/_CatChip" model="devSugChip3" />
                    <span class="sl-sug-name">Flour</span>
                    <span class="sl-sug-stock out">out</span>
                    <button type="button" class="sadd" aria-label="Add Flour to list">
                        <svg class="icon" aria-hidden="true"><use href="#i-plus" /></svg>
                    </button>
                </div>
            </div>
        </div>
    </div>
    <pre class="code-sample"><code>@("<!-- Rendered above category groups in _ShoppingList.cshtml when Model.Suggestions.Count > 0 -->\n<div class=\"sl-suggest\" aria-label=\"Running low in your pantry\">\n  <div class=\"sl-suggest-label\">Running low in your pantry</div>\n  <div class=\"sl-sug-chips\">\n    @foreach (var sug in Model.Suggestions)\n    {\n      <div class=\"sl-sug\">\n        <partial name=\"Shared/_CatChip\" model=\"new CatChipViewModel(sug.CategoryName, sug.CategoryHue)\" />\n        <span class=\"sl-sug-name\">@sug.Name</span>\n        <span class=\"sl-sug-stock @(sug.OnHand <= 0 ? \\\"out\\\" : \\\"\\\")\">@sug.StockLabel</span>\n        <form method=\"post\" hx-post=\"/Shopping?handler=AddItem\"\n              hx-target=\"#shopping-list\" hx-swap=\"outerHTML\">\n          @AntiForgeryToken\n          <input type=\"hidden\" name=\"Input.ProductId\" value=\"@sug.ProductId\" />\n          <button type=\"submit\" class=\"sadd\" aria-label=\"Add @sug.Name to list\">\n            <svg class=\"icon\"><use href=\"#i-plus\"/></svg>\n          </button>\n        </form>\n      </div>\n    }\n  </div>\n</div>")</code></pre>
</section>
