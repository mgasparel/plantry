            <div><svg class="icon recipes-grid__chev" aria-hidden="true"><use href="#i-chevron-right" /></svg></div>
        </a>
        <a class="recipes-grid__row" href="#">
            <div class="recipes-grid__name-cell">
                <div class="recipes-grid__thumb-placeholder">
