@page
@using Plantry.Intake.Domain
@model Plantry.Web.Pages.Dev.IndexModel
@{
    ViewData["Title"] = "Components";
}

<section class="catalog-section">
    <h2 class="catalog-section__heading">Component gallery</h2>
    <p>
        Development-only page (hidden and 404'd outside <code>Development</code> — see
        <code>DevPagesGateMiddleware</code>) for building and browsing reusable UI primitives
        away from any real feature page. Demo data only — nothing here touches Catalog.
    </p>
</section>

<section class="catalog-section">
    <div class="catalog-section__header">
        <h2 class="catalog-section__heading">Field row</h2>
    </div>
    <p>
        <code>&lt;field&gt;</code> lays out a label and its control as one row in a fixed
        two-column grid — every row aligns, unlike <code>.field--inline</code> (a flex row where
        each label is sized to its own text). The control markup passes through untouched, so
        <code>asp-for</code>, <code>asp-items</code>, and <code>asp-validation-for</code> keep
        working exactly as they do today.
    </p>

    <form method="post" class="form-stack">
        <field asp-for="FieldRowDemo.Name">
            <input asp-for="FieldRowDemo.Name" class="field__input" placeholder="e.g. Whole milk" />
            <span asp-validation-for="FieldRowDemo.Name" class="field__error"></span>
        </field>
        <field asp-for="FieldRowDemo.Quantity">
            <input asp-for="FieldRowDemo.Quantity" class="field__input" type="number" step="any" min="0" />
            <span asp-validation-for="FieldRowDemo.Quantity" class="field__error"></span>
        </field>
        <field asp-for="FieldRowDemo.Unit">
            <select asp-for="FieldRowDemo.Unit" class="field__input" asp-items="Model.UnitOptions">
                <option value="">— Select a unit —</option>
            </select>
            <span asp-validation-for="FieldRowDemo.Unit" class="field__error"></span>
        </field>
    </form>

    <pre class="code-sample"><code>@("<field asp-for=\"Input.Name\">\n    <input asp-for=\"Input.Name\" class=\"field__input\" placeholder=\"e.g. Whole milk\" />\n    <span asp-validation-for=\"Input.Name\" class=\"field__error\"></span>\n</field>")</code></pre>
</section>

<section class="catalog-section">
    <div class="catalog-section__header">
        <h2 class="catalog-section__heading">Card</h2>
    </div>
    <p>
        <code>.card</code> groups a titled section of content into a bordered surface with
        consistent internal spacing. <code>.card__head</code> carries the title (and optional
        subtitle via <code>.card__head-sub</code>) plus any right-aligned actions in
        <code>.card__head-actions</code>. Content lives in <code>.card__body</code>. Because
        Razor partials can't slot arbitrary children, card is a pure CSS pattern — write the
        wrapper markup directly wherever a section needs it.
    </p>

    <div class="card" style="max-width: 28rem">
        <div class="card__head">
            <div>
                <h3 class="card__head-title">Section title</h3>
                <p class="card__head-sub">An optional one-line description below the title.</p>
            </div>
            <div class="card__head-actions">
                <button class="btn btn--sm btn--secondary">Action</button>
            </div>
        </div>
        <div class="card__body">
            Card body content — any child markup goes here.
        </div>
    </div>

    <pre class="code-sample"><code>@("<div class=\"card\">\n  <div class=\"card__head\">\n    <div>\n      <h3 class=\"card__head-title\">Section title</h3>\n      <p class=\"card__head-sub\">Optional subtitle</p>   <!-- omit if none -->\n    </div>\n    <div class=\"card__head-actions\">                    <!-- omit if no actions -->\n      <button class=\"btn btn--sm btn--secondary\">Action</button>\n    </div>\n  </div>\n  <div class=\"card__body\">\n    <!-- content -->\n  </div>\n</div>")</code></pre>
</section>

<section class="catalog-section">
    <div class="catalog-section__header">
        <h2 class="catalog-section__heading">Form grid field</h2>
    </div>
    <p>
        <code>&lt;field stacked&gt;</code> is an alternative layout for <code>&lt;field&gt;</code>:
        the label sits above the control (rather than left of it), making it suitable for the
        two-column <code>.form-grid</code> container used in product-editor cards. Add
        <code>full</code> to span both columns. The <code>.form-grid__unit-suffix</code> wrapper
        pins a short unit label inside the right edge of an input — useful for numeric fields
        whose unit context isn't already clear from the label.
    </p>

    <div class="card" style="max-width: 36rem">
        <div class="card__head">
            <div>
                <h3 class="card__head-title">Details</h3>
            </div>
        </div>
        <div class="card__body">
            <form method="post" class="form-grid">
                <field asp-for="FormGridDemo.Name" stacked full>
                    <input asp-for="FormGridDemo.Name" class="field__input" placeholder="e.g. Whole milk" />
                    <span asp-validation-for="FormGridDemo.Name" class="field__error"></span>
                </field>
                <field asp-for="FormGridDemo.Category" stacked>
                    <select asp-for="FormGridDemo.Category" class="field__input" asp-items="Model.UnitOptions">
                        <option value="">— Select —</option>
                    </select>
                </field>
                <field asp-for="FormGridDemo.Unit" stacked>
                    <select asp-for="FormGridDemo.Unit" class="field__input" asp-items="Model.UnitOptions">
                        <option value="">— Select —</option>
                    </select>
                </field>
                <field asp-for="FormGridDemo.Par" stacked>
                    <div class="form-grid__unit-suffix">
                        <input asp-for="FormGridDemo.Par" class="field__input" type="number" step="any" min="0" />
                        <span class="form-grid__unit-suffix__label">g</span>
                    </div>
                    <span asp-validation-for="FormGridDemo.Par" class="field__error"></span>
                </field>
            </form>
        </div>
    </div>

    <pre class="code-sample"><code>@("<div class=\"form-grid\">\n  <field asp-for=\"Input.Name\" stacked full>\n    <input asp-for=\"Input.Name\" class=\"field__input\" />\n    <span asp-validation-for=\"Input.Name\" class=\"field__error\"></span>\n  </field>\n  <field asp-for=\"Input.Par\" stacked>\n    <div class=\"form-grid__unit-suffix\">\n      <input asp-for=\"Input.Par\" class=\"field__input\" type=\"number\" />\n      <span class=\"form-grid__unit-suffix__label\">g</span>\n    </div>\n    <span asp-validation-for=\"Input.Par\" class=\"field__error\"></span>\n  </field>\n</div>")</code></pre>
</section>

<section class="catalog-section">
    <div class="catalog-section__header">
        <h2 class="catalog-section__heading">Searchable select</h2>
    </div>
    <p>
        <code>&lt;searchable-select&gt;</code> is a type-to-filter replacement for
        <code>&lt;select&gt;</code> over long option lists. A hidden input carries the value that
        actually posts (bound via <code>asp-for</code>); Alpine owns the popover/keyboard state
        and htmx swaps the option list as you type — try searching for "milk" or "pasta" below.
    </p>

    <form method="post" class="form-stack" style="max-width: 28rem">
        <field asp-for="SearchableSelectDemo.Item">
            <searchable-select asp-for="SearchableSelectDemo.Item"
                               items="Model.GroceryOptions"
                               search-url="/Dev?handler=FilterGroceries"
                               placeholder="Search groceries…" />
        </field>
    </form>

    <pre class="code-sample"><code>@("<searchable-select asp-for=\"Input.Item\"\n                   items=\"Model.GroceryOptions\"\n                   search-url=\"/Dev?handler=FilterGroceries\"\n                   placeholder=\"Search groceries…\" />")</code></pre>
</section>

<section class="catalog-section">
    <div class="catalog-section__header">
        <h2 class="catalog-section__heading">Segmented control</h2>
    </div>
    <p>
        <code>.seg-ctrl</code> is a pill-bordered group of mutually exclusive options built on
        visually-hidden radio inputs. The checked segment is filled with the accent colour; hover
        highlights unchecked options. Font size and vertical padding match <code>.field__input</code>
        so it aligns naturally in a toolbar row alongside search fields and selects. Pair with
        <code>hx-include</code> and a filter handler exactly as the Pantry toolbar does.
    </p>

    <div style="display: flex; flex-direction: column; gap: var(--space-4); max-width: 36rem">
        <div>
            <p style="font-size: var(--font-size-sm); color: var(--color-text-muted); margin: 0 0 var(--space-2)">3 options (default)</p>
            <div class="seg-ctrl" role="group" aria-label="Example filter">
                <label class="seg-ctrl__item">
                    <input type="radio" name="demo-expiry-1" value="" checked />
                    <span>All</span>
                </label>
                <label class="seg-ctrl__item">
                    <input type="radio" name="demo-expiry-1" value="soon" />
                    <span>Expiring soon</span>
                </label>
                <label class="seg-ctrl__item">
                    <input type="radio" name="demo-expiry-1" value="expired" />
                    <span>Expired</span>
                </label>
            </div>
        </div>

        <div>
            <p style="font-size: var(--font-size-sm); color: var(--color-text-muted); margin: 0 0 var(--space-2)">Alongside a <code>.field__input</code> select — heights should be flush</p>
            <div style="display: flex; align-items: center; gap: var(--space-3)">
                <div class="seg-ctrl" role="group" aria-label="Example filter 2">
                    <label class="seg-ctrl__item">
                        <input type="radio" name="demo-expiry-2" value="" checked />
                        <span>All</span>
                    </label>
                    <label class="seg-ctrl__item">
                        <input type="radio" name="demo-expiry-2" value="soon" />
                        <span>Expiring soon</span>
                    </label>
                    <label class="seg-ctrl__item">
                        <input type="radio" name="demo-expiry-2" value="expired" />
                        <span>Expired</span>
                    </label>
                </div>
                <select class="field__input" style="width: auto; min-width: 10rem">
                    <option>All categories</option>
                    <option>Dairy &amp; Eggs</option>
                    <option>Frozen</option>
                </select>
            </div>
        </div>
    </div>

    <pre class="code-sample"><code>@("<div class=\"seg-ctrl\" role=\"group\" aria-label=\"Filter by expiry\">\n  <label class=\"seg-ctrl__item\">\n    <input type=\"radio\" name=\"expiry\" value=\"\" class=\"pantry-filter\" checked\n           hx-get=\"...\" hx-trigger=\"change\" hx-target=\"#list\" hx-swap=\"outerHTML\"\n           hx-include=\".pantry-filter\" />\n    <span>All</span>\n  </label>\n  <label class=\"seg-ctrl__item\">\n    <input type=\"radio\" name=\"expiry\" value=\"soon\" class=\"pantry-filter\"\n           hx-get=\"...\" hx-trigger=\"change\" hx-target=\"#list\" hx-swap=\"outerHTML\"\n           hx-include=\".pantry-filter\" />\n    <span>Expiring soon</span>\n  </label>\n  <label class=\"seg-ctrl__item\">\n    <input type=\"radio\" name=\"expiry\" value=\"expired\" class=\"pantry-filter\"\n           hx-get=\"...\" hx-trigger=\"change\" hx-target=\"#list\" hx-swap=\"outerHTML\"\n           hx-include=\".pantry-filter\" />\n    <span>Expired</span>\n  </label>\n</div>")</code></pre>
</section>

<section class="catalog-section">
    <div class="catalog-section__header">
        <h2 class="catalog-section__heading">Match suggest ("Did you mean")</h2>
    </div>
    <p>
        <code>.match-suggest</code> is the ranked-suggestion block shown inside the review row edit drawer
        (a sibling rendered <em>before</em> the edit-grid) when the AI matched several credible product
        candidates for the same receipt line. It renders a label plus a <code>.suggest-opts</code> flex
        row of <code>.suggest-opt</code> buttons.
    </p>
    <p>
        The AI's top pick is rendered first as a pre-selected <em>best</em> chip, followed by the resolved
        alternative candidates (<c>rowModel.Alternatives</c>), each carrying its real AI confidence
        percentage in a <code>.rk</code> rank tag. The block is server-rendered and only present when there
        are two or more resolved alternatives (extras-only — excluding the primary) and the line is not yet
        confirmed or committed. The selected candidate gets the <code>.sel</code> modifier (accent border +
        background + check icon). Clicking a button pre-selects the product in the drawer's
        searchable-select — nothing commits until the user clicks <em>Confirm item</em>.
    </p>
    <div style="max-width: 36rem" x-data="{ sel: 'a' }">
        <div class="match-suggest">
            <div class="match-suggest__label">
                Did you mean — <span>several products share this name</span>
            </div>
            <div class="suggest-opts">
                <button type="button" class="suggest-opt" :class="{ 'sel': sel === 'a' }" @@click="sel = 'a'">
                    <svg class="icon" aria-hidden="true" x-show="sel === 'a'"><use href="#i-check" /></svg>
                    Cheddar, Mild <span class="rk">best</span>
                </button>
                <button type="button" class="suggest-opt" :class="{ 'sel': sel === 'b' }" @@click="sel = 'b'">
                    <svg class="icon" aria-hidden="true" x-show="sel === 'b'"><use href="#i-check" /></svg>
                    Cheddar, Sharp <span class="rk">53%</span>
                </button>
                <button type="button" class="suggest-opt" :class="{ 'sel': sel === 'c' }" @@click="sel = 'c'">
                    <svg class="icon" aria-hidden="true" x-show="sel === 'c'"><use href="#i-check" /></svg>
                    Cheddar, Marble <span class="rk">34%</span>
                </button>
            </div>
        </div>
    </div>

    <pre class="code-sample"><code>@("<div class=\"match-suggest\">\n  <div class=\"match-suggest__label\">\n    Did you mean — <span>several products share this name</span>\n  </div>\n  <div class=\"suggest-opts\">\n    <button type=\"button\" class=\"suggest-opt\" :class=\"{ 'sel': selectedProductId === '{id}' }\"\n            @click=\"selectedProductId = '{id}'; ...\">\n      <svg class=\"icon\" x-show=\"selectedProductId === '{id}'\"><use href=\"#i-check\"></use></svg>\n      Product Name <span class=\"rk\">best</span>   <!-- or: 72% -->\n    </button>\n  </div>\n</div>\n\n<!-- Only render when rowModel.Alternatives?.Count >= 2 AND line is not confirmed -->")</code></pre>
</section>

<section class="catalog-section">
    <div class="catalog-section__header">
        <h2 class="catalog-section__heading">Index list</h2>
    </div>
    <p>
        <code>_IndexList</code> extracts the primary/secondary/meta row pattern repeated across
        <code>Catalog/Index</code>, <code>Products/Index</code>, and Product Detail — including
        the empty state.
    </p>

    <h3 class="catalog-section__heading" style="font-size: var(--font-size-base)">Populated</h3>
    <partial name="Shared/_IndexList" model="Model.PopulatedList" />

    <h3 class="catalog-section__heading" style="font-size: var(--font-size-base)">Empty state</h3>
    <partial name="Shared/_IndexList" model="Model.EmptyList" />

    <pre class="code-sample"><code>@("<partial name=\"Shared/_IndexList\" model=\"Model.MyListViewModel\" />")</code></pre>
</section>

<section class="catalog-section">
    <div class="catalog-section__header">
        <h2 class="catalog-section__heading">Sortable list</h2>
    </div>
    <p>
        <code>_SortableList</code> renders a <code>.catalog-list</code> whose items can be
        dragged into a new order. Alpine (<code>wwwroot/js/sortable-list.js</code>) owns the
        drag interaction — tracking the dragged item and reordering the DOM as the pointer moves
        over siblings — and on drop, htmx posts the new order as a repeated <code>ids</code>
        field to the handler named by <code>ReorderUrl</code>, which reassigns sort orders as
        multiples of ten. This demo's handler accepts the post but doesn't persist anything, so
        reloading the page always returns to the seeded order.
    </p>

    <partial name="Shared/_SortableList" model="Model.SortableListDemo" />

    <pre class="code-sample"><code>@("<partial name=\"Shared/_SortableList\"\n         model=\"new SortableListViewModel(Model.MyItems, Url.Page(\"./Index\", \"Reorder\"), \"Nothing to reorder yet.\")\" />")</code></pre>
</section>

<section class="catalog-section">
    <div class="catalog-section__header">
        <h2 class="catalog-section__heading">Data grid</h2>
    </div>
    <p>
        <code>_DataGrid</code> renders a reusable, reflection-free table. The page maps each domain
        object to typed cells from a closed vocabulary (<code>Text</code>, <code>Muted</code>,
        <code>Link</code>, <code>Badge</code>) plus a first-class <code>Actions</code> cell — so the
        partial owns every <code>&lt;td&gt;</code> while the compiler still checks the whole
        page→grid contract. <strong>Sortable headers</strong> (Name, Category) htmx-GET a
        <code>Sort</code> handler that re-orders server-side and swaps the whole table back, marked
        up with <code>aria-sort</code>. The <strong>Edit</strong> link navigates to the real
        <code>/Catalog/Products/Edit/{id}</code> route and the product name links to
        <code>/Catalog/Products/Detail/{id}</code> — these are demo GUIDs, so following them 404s,
        but they exercise the real URL shape. <strong>Delete</strong> is an htmx POST (the app's
        first) carrying the antiforgery token via the global
        <code>htmx-antiforgery.js</code> hook; on confirm it swaps its own <code>&lt;tr&gt;</code>
        out. This demo's handlers persist nothing, so a reload restores the seeded rows.
    </p>

    <partial name="Shared/_DataGrid" model="Model.ProductGrid" />

    <pre class="code-sample"><code>@("Rows: products.Select(p => new GridRow(\n[\n    GridCell.Link(p.Name, $\"/Catalog/Products/Detail/{p.Id}\"),\n    GridCell.Text(p.Category),\n    p.IsParent ? GridCell.Badge(\"Parent\", BadgeTone.Info) : GridCell.Muted(\"—\"),\n    GridCell.Actions(\n        GridAction.Link(\"Edit\", $\"/Catalog/Products/Edit/{p.Id}\"),\n        GridAction.Post(\"Delete\", Url.Page(\"./Index\", \"Delete\", new { id = p.Id }),\n            confirm: $\"Delete {p.Name}?\", removesRow: true)),\n])).ToList()")</code></pre>
</section>

<section class="catalog-section">
    <div class="catalog-section__header">
        <h2 class="catalog-section__heading">Confidence badge</h2>
    </div>
    <p>
        <code>_ConfidenceBadge</code> renders the AI catalog-match confidence for an import line as a
        tonal badge. It takes a <code>SuggestedConfidence</code> directly and maps it to label + icon
        + tone, reusing the existing <code>.badge</code> system — <strong>High</strong> = "Matched"
        (success), <strong>Low</strong> = "Check match" (warning), <strong>None</strong> = "No match"
        (danger). No new colour tokens were introduced; the three
        <code>.badge-confidence--*</code> modifiers reuse <code>--color-*-bg</code>.
    </p>

    <div style="display: flex; gap: var(--space-3); flex-wrap: wrap; align-items: center">
        <partial name="Shared/_ConfidenceBadge" model="SuggestedConfidence.High" />
        <partial name="Shared/_ConfidenceBadge" model="SuggestedConfidence.Low" />
        <partial name="Shared/_ConfidenceBadge" model="SuggestedConfidence.None" />
    </div>

    <pre class="code-sample"><code>@("<partial name=\"Shared/_ConfidenceBadge\" model=\"line.Confidence\" />")</code></pre>
</section>

<section class="catalog-section">
    <div class="catalog-section__header">
        <h2 class="catalog-section__heading">Filter chip</h2>
    </div>
    <p>
        <code>_FilterChip</code> (partial) + <code>.filter-chip</code> (CSS) — the single reusable
        pill filter/toggle primitive. The partial renders only the inner content (leading dot or icon,
        label, optional trailing count); the caller writes the <code>&lt;button type="button"
        class="filter-chip"&gt;</code> with its own htmx / Alpine attributes. The container row is
        <code>.filter-chip-bar</code>.
    </p>
    <p>
        Active-state tones — add <code>.is-active</code> plus one tone modifier to the button:
        <code>.filter-chip--accent</code> (tag filters), <code>.filter-chip--warning</code> (use-soon
        / needs-review), <code>.filter-chip--success</code> (all / ready), <code>.filter-chip--neutral</code>.
        Alpine can drive the active state dynamically via <code>:class</code> — the base button renders
        without active classes and Alpine adds them at runtime.
    </p>

    @* ── Dot variant (intake review chips — success tone for "All" + "Ready", warning for "Needs review") *@
    <h3 class="catalog-section__heading" style="font-size: var(--font-size-base)">Dot variant — intake review (all active)</h3>
    <div class="filter-chip-bar" style="margin-bottom: var(--space-4)">
        <button type="button" class="filter-chip is-active filter-chip--success">
            <partial name="Shared/_FilterChip" model='new Plantry.Web.Pages.Shared.FilterChipViewModel("All", Count: 13)' />
        </button>
        <button type="button" class="filter-chip">
            <partial name="Shared/_FilterChip" model='new Plantry.Web.Pages.Shared.FilterChipViewModel("Needs review", DotColor: "var(--color-warning)", Count: 3)' />
        </button>
        <button type="button" class="filter-chip">
            <partial name="Shared/_FilterChip" model='new Plantry.Web.Pages.Shared.FilterChipViewModel("Ready", DotColor: "var(--color-success)", Count: 10)' />
        </button>
    </div>
    <div class="filter-chip-bar" style="margin-bottom: var(--space-4)">
        <button type="button" class="filter-chip">
            <partial name="Shared/_FilterChip" model='new Plantry.Web.Pages.Shared.FilterChipViewModel("All", Count: 13)' />
        </button>
        <button type="button" class="filter-chip is-active filter-chip--warning">
            <partial name="Shared/_FilterChip" model='new Plantry.Web.Pages.Shared.FilterChipViewModel("Needs review", DotColor: "var(--color-warning)", Count: 3)' />
        </button>
        <button type="button" class="filter-chip">
            <partial name="Shared/_FilterChip" model='new Plantry.Web.Pages.Shared.FilterChipViewModel("Ready", DotColor: "var(--color-success)", Count: 10)' />
        </button>
    </div>

    @* ── Tag filter variant (recipes browse — accent tone, dot hidden when active) *@
    <h3 class="catalog-section__heading" style="font-size: var(--font-size-base); margin-top: var(--space-5)">Dot variant — tag filters (accent tone)</h3>
    <div class="filter-chip-bar" style="margin-bottom: var(--space-4)">
        <button type="button" class="filter-chip is-active filter-chip--accent">
            <partial name="Shared/_FilterChip" model='new Plantry.Web.Pages.Shared.FilterChipViewModel("All")' />
        </button>
        <button type="button" class="filter-chip">
            <partial name="Shared/_FilterChip" model='new Plantry.Web.Pages.Shared.FilterChipViewModel("Fish", DotColor: "#4b9cd3")' />
        </button>
        <button type="button" class="filter-chip">
            <partial name="Shared/_FilterChip" model='new Plantry.Web.Pages.Shared.FilterChipViewModel("Vegetarian", DotColor: "#27ae60")' />
        </button>
        <button type="button" class="filter-chip">
            <partial name="Shared/_FilterChip" model='new Plantry.Web.Pages.Shared.FilterChipViewModel("Spicy", DotColor: "#e74c3c")' />
        </button>
    </div>

    @* ── Icon toggle variant (use-soon — warning tone) *@
    <h3 class="catalog-section__heading" style="font-size: var(--font-size-base); margin-top: var(--space-5)">Icon toggle variant — warning tone (use-soon)</h3>
    <div style="display:flex;gap:12px;align-items:center;margin-bottom: var(--space-4)">
        <button type="button" class="filter-chip">
            <partial name="Shared/_FilterChip" model='new Plantry.Web.Pages.Shared.FilterChipViewModel("Use soon", IconId: "i-timer")' />
        </button>
        <button type="button" class="filter-chip is-active filter-chip--warning">
            <partial name="Shared/_FilterChip" model='new Plantry.Web.Pages.Shared.FilterChipViewModel("Use soon", IconId: "i-timer")' />
        </button>
        <span style="font-size:var(--font-size-sm);color:var(--color-text-muted)">← off / on →</span>
    </div>

    <pre class="code-sample"><code>@("<!-- Container -->\n<div class=\"filter-chip-bar\">\n\n  <!-- Server-driven active (tag filter / use-soon) -->\n  <button type=\"button\"\n          class=\"filter-chip @(isActive ? \"is-active filter-chip--accent\" : \"\")\"\n          hx-get=\"/Recipes\" hx-target=\"#recipes-results\" hx-swap=\"innerHTML\"\n          hx-include=\"form\" hx-vals='{\"tagId\": \"@(isActive ? \"\" : tag.Id)\"}'>\n    <partial name=\"Shared/_FilterChip\"\n             model='new FilterChipViewModel(tag.Name, DotColor: isActive ? null : color)' />\n  </button>\n\n  <!-- Alpine-driven active (intake review) -->\n  <button type=\"button\"\n          class=\"filter-chip\"\n          :class=\"filter === 'all' ? 'is-active filter-chip--success' : ''\"\n          @@click=\"filter = 'all'\"\n          data-count-total=\"@total\">\n    <partial name=\"Shared/_FilterChip\"\n             model='new FilterChipViewModel(\"All\", Count: total)' />\n  </button>\n\n</div>")</code></pre>
</section>

<section class="catalog-section">
    <div class="catalog-section__header">
        <h2 class="catalog-section__heading">Category chip</h2>
    </div>
    <p>
        <code>_CatChip</code> renders a coloured category badge — a small pill showing the first
        two letters of the category name, uppercased, tinted with the category's oklch hue.
        Takes a <code>CatChipViewModel(string? Name, int? Hue)</code>. When <code>Hue</code> is
        null it renders with <code>.cat-chip--neutral</code> (no colour). The palette constants
        (<code>--cc-bg: oklch(0.92 0.045 H)</code> / <code>--cc-fg: oklch(0.42 0.105 H)</code>)
        live in the partial — edit there, not in the call sites.
    </p>

    @{
        var catChipExamples = new[]
        {
            new Plantry.Web.Pages.Shared.CatChipViewModel("Dairy & Eggs", 60),
            new Plantry.Web.Pages.Shared.CatChipViewModel("Frozen", 200),
            new Plantry.Web.Pages.Shared.CatChipViewModel("Produce", 130),
            new Plantry.Web.Pages.Shared.CatChipViewModel("Z", 320),
            new Plantry.Web.Pages.Shared.CatChipViewModel(null, null),
        };
    }
    <div style="display: flex; gap: var(--space-3); flex-wrap: wrap; align-items: center">
        @foreach (var chip in catChipExamples)
        {
            <partial name="Shared/_CatChip" model="chip" />
        }
    </div>

    <pre class="code-sample"><code>@("<partial name=\"Shared/_CatChip\" model=\"new CatChipViewModel(category.Name, category.Hue)\" />")</code></pre>
</section>

<section class="catalog-section">
    <div class="catalog-section__header">
        <h2 class="catalog-section__heading">Category dot pill</h2>
    </div>
    <p>
        <code>.sl-cat-pill</code> — a compact inline pill for roomy contexts (e.g. the recat dropdown).
        Renders a small colored dot (hue-driven via <code>--cdp-color: oklch(0.55 0.14 H)</code>) plus
        the category name. Prefer this over <code>_CatChip</code> wherever there is enough horizontal
        space for the label. In space-constrained spots (suggestion strip, etc.) keep <code>_CatChip</code>.
    </p>

    <div style="display: flex; gap: var(--space-3); flex-wrap: wrap; align-items: center; margin-bottom: var(--space-4)">
        <span class="sl-cat-pill">
            <span class="sl-cat-pill__dot" style="--cdp-color: oklch(0.55 0.14 145)" aria-hidden="true"></span>
            Produce
        </span>
        <span class="sl-cat-pill">
            <span class="sl-cat-pill__dot" style="--cdp-color: oklch(0.55 0.14 210)" aria-hidden="true"></span>
            Dairy &amp; Eggs
        </span>
        <span class="sl-cat-pill">
            <span class="sl-cat-pill__dot" style="--cdp-color: oklch(0.55 0.14 30)" aria-hidden="true"></span>
            Meat &amp; Fish
        </span>
        <span class="sl-cat-pill">
            <span class="sl-cat-pill__dot" aria-hidden="true"></span>
            Uncategorized
        </span>
    </div>

    <pre class="code-sample"><code>@("{@{\n    var dotStyle = cat.Hue.HasValue ? $\"--cdp-color: oklch(0.55 0.14 {cat.Hue})\" : null;\n}\n<span class=\"sl-cat-pill\">\n    <span class=\"sl-cat-pill__dot\" style=\"@dotStyle\" aria-hidden=\"true\"></span>\n    @cat.Name\n</span>")</code></pre>
</section>

<section class="catalog-section">
    <div class="catalog-section__header">
        <h2 class="catalog-section__heading">Meter / progress bar (<code>Shared/_Meter</code>)</h2>
    </div>
    <p>
        One reusable bar primitive — <code>Shared/_Meter</code> partial — replaces three ad-hoc
        implementations (<code>.rev-progress</code>, <code>.fulf-meter</code>, <code>.rd-fulf-bar-*</code>).
        Width is always server-set via <code>style="width:N%"</code>; no client recompute.
    </p>
    <p>
        <strong>Tones:</strong> <code>Hi</code> (green, ≥80%), <code>Mid</code> (amber, ≥50%),
        <code>Lo</code> (red, &lt;50%), <code>Accent</code> (theme accent), <code>Neutral</code>.
        <br>
        <strong>Layouts:</strong> <code>MetaLine</code> — bar + trailing inline text (intake review);
        <code>PctStack</code> — bar + right-column pct/sub (recipes grid);
        <code>BarOnly</code> — bar only, caller controls surrounding markup (recipe detail card).
    </p>

    <p><strong>MetaLine</strong> — intake review progress header (accent fill, surface card chrome):</p>
    <div style="margin-bottom: var(--space-4)">
        <div class="meter meter--meta-line meter--intake-progress">
            <div class="meter__track"><span class="meter__fill meter__fill--accent" style="width:77%"></span></div>
            <div class="meter__meta"><span><b>3</b> items need a quick look · <b>10</b> ready</span></div>
        </div>
    </div>
    <div>
        <div class="meter meter--meta-line meter--intake-progress">
            <div class="meter__track"><span class="meter__fill meter__fill--accent" style="width:100%"></span></div>
            <div class="meter__meta"><span><b>All set.</b> 13 items ready to add.</span></div>
        </div>
    </div>

    <p style="margin-top:var(--space-4)"><strong>PctStack</strong> — recipes grid fulfillment meter:</p>
    <div style="max-width:200px;display:flex;flex-direction:column;gap:18px">
        <div class="meter meter--pct-stack">
            <div class="meter__track"><span class="meter__fill fulf-hi-bg" style="width:90%"></span></div>
            <div class="meter__labels">
                <div class="meter__pct fulf-hi">90%</div>
                <div class="meter__sub">9/10 in stock</div>
            </div>
        </div>
        <div class="meter meter--pct-stack">
            <div class="meter__track"><span class="meter__fill fulf-mid-bg" style="width:60%"></span></div>
            <div class="meter__labels">
                <div class="meter__pct fulf-mid">60%</div>
                <div class="meter__sub">6/10 in stock</div>
            </div>
        </div>
        <div class="meter meter--pct-stack">
            <div class="meter__track"><span class="meter__fill fulf-lo-bg" style="width:20%"></span></div>
            <div class="meter__labels">
                <div class="meter__pct fulf-lo">20%</div>
                <div class="meter__sub">2/10 in stock</div>
            </div>
        </div>
    </div>

    <p style="margin-top:var(--space-4)"><strong>BarOnly</strong> — recipe detail card progress bar (aria progressbar):</p>
    <div style="max-width:280px">
        <div class="meter__track rd-fulf-bar" role="progressbar" aria-valuenow="50" aria-valuemin="0" aria-valuemax="100">
            <span class="meter__fill fulf-mid-bg" style="width:50%"></span>
        </div>
    </div>

    <pre class="code-sample"><code>@("<partial name=\"Shared/_Meter\" model='new MeterViewModel {\n    Percent  = pct,\n    Tone     = MeterViewModel.FulfTone(pct),\n    Layout   = MeterLayout.PctStack,\n    Label    = $\"{pct}%\",\n    SubLabel = $\"{inStock}/{total} in stock\"\n}' />")</code></pre>
</section>

<section class="catalog-section">
    <div class="catalog-section__header">
        <h2 class="catalog-section__heading">Stepper (<code>&lt;stepper&gt;</code> tag helper)</h2>
    </div>
    <p>
        The canonical −&nbsp;[value]&nbsp;+ primitive. Use the <code>&lt;stepper&gt;</code> tag helper — never
        hand-roll the markup. Four visual variants via CSS modifier; two structural modes (input vs display).
    </p>
    <p><strong>Default</strong> — 36 px icon buttons, rectangle. Intake review qty, cook page qty.</p>
    <div x-data="{ qty: 2 }" style="max-width:200px; margin-bottom: var(--space-4)">
        <stepper name="qty-demo"
                 x-model="qty"
                 decrease-click="qty = Math.max(0, qty - 1)"
                 increase-click="qty = qty + 1"
                 decrease-label="Decrease quantity"
                 increase-label="Increase quantity" />
    </div>
    <p><strong>lg</strong> — 40 px icon buttons, rounded corners. Shopping add-form + inline-edit qty.</p>
    <div x-data="{ qty: 2 }" style="max-width:200px; margin-bottom: var(--space-4)">
        <stepper variant="lg"
                 name="qty-lg-demo"
                 x-model="qty"
                 decrease-click="qty = Math.max(0, qty - 1)"
                 increase-click="qty = qty + 1"
                 decrease-label="Decrease quantity"
                 increase-label="Increase quantity" />
    </div>
    <p><strong>compact</strong> — borderless square icon buttons inside a bordered container. Recipe-detail ingredients header.</p>
    <div x-data="{ servings: 4 }" style="margin-bottom: var(--space-4)">
        <stepper variant="compact"
                 group-label="Servings"
                 x-text="servings"
                 display-fallback="4"
                 decrease-click="servings = Math.max(1, servings - 1)"
                 increase-click="servings = Math.min(24, servings + 1)"
                 decrease-disabled="servings <= 1"
                 increase-disabled="servings >= 24"
                 decrease-label="Fewer servings"
                 increase-label="More servings" />
    </div>
    <p><strong>pill</strong> — 24 px circular text-glyph (−/+) buttons, inline flow. Recipe-meta strip servings.</p>
    <div x-data="{ servings: 4 }" style="margin-bottom: var(--space-4)">
        <stepper variant="pill"
                 group-label="Servings"
                 x-text="servings + (servings === 1 ? ' serving' : ' servings')"
                 display-fallback="4 servings"
                 decrease-click="servings = Math.max(1, servings - 1)"
                 increase-click="servings = servings + 1"
                 decrease-disabled="servings <= 1"
                 decrease-label="Fewer servings"
                 increase-label="More servings" />
    </div>
    <pre class="code-sample"><code>@("// Input mode (default variant)\n<stepper name=\"Edit.Quantity\" x-model=\"v\"\n         decrease-click=\"v = Math.max(0.001, (parseFloat(v)||0) - 1)\"\n         increase-click=\"v = (parseFloat(v)||0) + 1\"\n         decrease-label=\"Decrease quantity\" increase-label=\"Increase quantity\" />\n\n// Display mode, compact (recipe detail ingredients header)\n<stepper variant=\"compact\" group-label=\"Servings\" x-text=\"servings\" display-fallback=\"4\"\n         decrease-click=\"servings = Math.max(1, servings - 1); refreshFulfilment()\"\n         increase-click=\"servings = Math.min(24, servings + 1); refreshFulfilment()\"\n         decrease-disabled=\"servings <= 1\" increase-disabled=\"servings >= 24\"\n         decrease-label=\"Fewer servings\" increase-label=\"More servings\" />")</code></pre>
</section>

@*
    ── Recipe editor components (P2-1d) ────────────────────────────────────────────────────────────
    These components are the building blocks of the recipe author/edit form (J6/J7). They are
    added to the library here first, then consumed by Pages/Recipes/Edit.cshtml.
*@

<section class="catalog-section">
    <div class="catalog-section__header">
        <h2 class="catalog-section__heading">Ingredient row editor (<code>.ingredient-row</code>)</h2>
    </div>
    <p>
        <code>.ingredient-row</code> is one editable ingredient line in the recipe editor (J6/J7).
        Each row has: a drag handle, a product search field (htmx-driven <code>searchableSelect</code>),
        a quantity + unit pair (hidden for untracked staples, C12), an optional group heading, and a delete
        button. Rows are rendered by an Alpine <code>x-for</code> template loop that keeps draft state
        per row (ADR-005). The <code>.ingredient-row--needs-conversion</code> modifier applies a warning
        left-border when a <code>NeedsConversion</code> result is returned (C10).
        An inline staple-create escape hatch (C12) replaces the product-search field with a plain text
        input when the user clicks <em>Create as staple</em>.
    </p>
    <p>
        Drag-reorder is native HTML5 drag: <code>draggable="true"</code> + Alpine event handlers
        <code>dragStart(idx)</code> / <code>dragOver(idx)</code> / <code>drop()</code> that splice
        the <code>rows[]</code> array and call <code>reassignOrdinals()</code> so hidden ordinal inputs
        stay contiguous. This mirrors the <code>_SortableList</code> pattern (htmx POST on drop) but
        is entirely Alpine-owned because the ingredient list is not persisted until submit.
    </p>
    <div class="card" style="max-width: 48rem">
        <div class="card__body" style="padding: 0" x-data="{ rows: [{ id: 1, product: 'Whole milk', qty: '2', unit: 'cup', group: '' }], dragIdx: null }">
            <div id="ingredient-rows-demo">
                <template x-for="(row, idx) in rows" :key="row.id">
                    <div class="ingredient-row" draggable="true"
                         @@dragstart.self="dragIdx = idx"
                         @@dragover.prevent="if (dragIdx !== null && dragIdx !== idx) { const m = rows.splice(dragIdx, 1)[0]; rows.splice(idx, 0, m); dragIdx = idx; }"
                         @@drop="dragIdx = null">
                        <div class="ingredient-row__body">
                            <div class="ingredient-row__drag" aria-hidden="true" style="cursor:grab;color:var(--color-text-muted);padding:var(--space-2);display:flex;align-items:center">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="8" x2="21" y2="8"/><line x1="3" y1="16" x2="21" y2="16"/></svg>
                            </div>
                            <input type="text" class="field__input" placeholder="Search products…" :value="row.product" style="flex:2;min-width:0" />
                            <input type="number" class="field__input" placeholder="Qty" :value="row.qty" style="width:5rem;text-align:center;flex-shrink:0" />
                            <select class="field__input" style="min-width:5rem;flex-shrink:0">
                                <option>cup</option><option>g</option><option>ea</option>
                            </select>
                            <input type="text" class="field__input" placeholder="Group" :value="row.group" style="flex:1;min-width:0;font-size:var(--font-size-sm)" />
                            <button type="button" class="btn btn--ghost btn--sm" @@click="rows.splice(idx, 1)" style="flex-shrink:0;color:var(--color-danger)">
                                <svg class="icon" aria-hidden="true"><use href="#i-minus" /></svg>
                            </button>
                        </div>
                    </div>
                </template>
            </div>
            <div style="padding: var(--space-4)">
                <button type="button" class="btn btn--ghost btn--sm" @@click="rows.push({ id: Date.now(), product: '', qty: '', unit: '', group: '' })">
                    <svg class="icon" aria-hidden="true"><use href="#i-plus" /></svg>
                    Add ingredient
                </button>
            </div>
        </div>
    </div>
    <pre class="code-sample"><code>@("// Alpine x-data on the outer container:\n// rows: [{ ordinal, productId, productName, qty, unitId, groupHeading, isUntracked, ... }]\n// addRow(), removeRow(idx), dragStart(idx), dragOver(idx), drop(), reassignOrdinals()\n\n// Each row:\n<div class=\"ingredient-row\" draggable=\"true\" :class=\"{'ingredient-row--needs-conversion': row.needsConversion}\"\n     @dragstart.self=\"dragStart(idx)\" @dragover.prevent=\"dragOver(idx)\" @drop=\"drop()\">\n  <div class=\"ingredient-row__body\">\n    <div class=\"ingredient-row__drag\"><!-- drag handle icon --></div>\n    <!-- product search, qty, unit, group heading, delete -->\n  </div>\n  <!-- inline conversion form shown when row.needsConversion -->\n</div>")</code></pre>
</section>

<section class="catalog-section">
    <div class="catalog-section__header">
        <h2 class="catalog-section__heading">Tag picker — type-to-filter chips (closed vocabulary)</h2>
    </div>
    <p>
        The recipe tag editor is a chip-based multi-select over a <strong>read-only, household-defined vocabulary</strong>.
        A text input filters the active defined tags into a dropdown; selecting one adds it as a chip.
        Typing a brand-new name does <em>not</em> create anything — no Enter/comma mint.
        Backspace with an empty input removes the last chip; clicking elsewhere closes the dropdown.
    </p>
    <p>
        Alpine state: <code>tags</code> is an array of <code>&#123;id, name&#125;</code> objects; <code>tagOptions</code>
        is the full active-tag list from the server (serialised once via <code>JsonSerializer.Serialize</code>
        without <code>Html.Raw</code>). Hidden inputs post <code>Input.TagIds</code> (one per chip).
        The dropdown offers only active tags not already selected — <code>filteredTagOptions()</code> excludes
        both already-selected and non-matching options. Clicking an option calls <code>addTagFromOption(opt)</code>
        via <code>@@mousedown.prevent</code> so the input blur does not fire before the click registers.
    </p>
    <p>
        <strong>Empty-household state:</strong> when <code>Model.TagOptions</code> is empty (the household
        has no active tags), the picker body shows a guidance message linking to <code>/Settings/Tags</code>
        — rendered server-side (no Alpine branch needed) because <code>TagOptions</code> is known at render time.
    </p>
    @{
        var demoTagOpts = System.Text.Json.JsonSerializer.Serialize(new[]
        {
            new { id = "aaa", name = "Breakfast" },
            new { id = "bbb", name = "Quick" },
            new { id = "ccc", name = "Vegetarian" },
            new { id = "ddd", name = "Weeknight" },
        });
    }
    <div style="max-width: 36rem"
         x-data="{
             tags: [{ id: 'bbb', name: 'Quick' }],
             tagQuery: '',
             tagDropOpen: false,
             tagOptions: @demoTagOpts,
             filteredTagOptions() {
                 const q = this.tagQuery.trim().toLowerCase();
                 return this.tagOptions.filter(o =>
                     !this.tags.some(t => t.id === o.id) &&
                     (!q || o.name.toLowerCase().includes(q)));
             },
             addTagFromOption(opt) {
                 if (!this.tags.some(t => t.id === opt.id))
                     this.tags.push({ id: opt.id, name: opt.name });
                 this.tagQuery = '';
                 this.tagDropOpen = false;
                 this.$nextTick(() => this.$refs.tagInputDemo.focus());
             },
             removeTag(i) { this.tags.splice(i, 1); },
         }">
        <template x-for="(tag, ti) in tags" :key="tag.id">
            <input type="hidden" name="Input.TagIds" :value="tag.id" />
        </template>
        <div style="position:relative">
            <div class="recipe-tag-editor"
                 style="display:flex;flex-wrap:wrap;gap:var(--space-2);align-items:center;border:1px solid var(--color-border);border-radius:var(--radius-md);padding:var(--space-2) var(--space-3);min-height:2.5rem;cursor:text"
                 @@click="$refs.tagInputDemo.focus()">
                <template x-for="(tag, ti) in tags" :key="tag.id">
                    <span class="badge badge--neutral" style="display:inline-flex;align-items:center;gap:var(--space-1)">
                        <span x-text="tag.name"></span>
                        <button type="button" class="btn btn--ghost btn--sm" style="padding:0 2px;line-height:1;font-size:inherit" aria-label="Remove tag" @@click.stop="removeTag(ti)">×</button>
                    </span>
                </template>
                <input type="text" x-ref="tagInputDemo" x-model="tagQuery"
                       placeholder="Filter tags…"
                       class="field__input"
                       style="border:none;outline:none;box-shadow:none;padding:0;min-width:8rem;flex:1"
                       @@focus="tagDropOpen = true"
                       @@input="tagDropOpen = true"
                       @@keydown.escape="tagDropOpen = false; tagQuery = ''"
                       @@keydown.backspace="if (!tagQuery && tags.length) removeTag(tags.length - 1)"
                       autocomplete="off" />
            </div>
            <div x-show="tagDropOpen && filteredTagOptions().length > 0"
                 x-cloak
                 @@click.outside="tagDropOpen = false"
                 style="position:absolute;z-index:50;left:0;right:0;margin-top:2px;background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius-md);max-height:12rem;overflow-y:auto;box-shadow:var(--shadow-md)">
                <template x-for="opt in filteredTagOptions()" :key="opt.id">
                    <button type="button"
                            class="tag-picker-option"
                            style="display:block;width:100%;text-align:left;padding:var(--space-2) var(--space-3);background:none;border:none;cursor:pointer;font:inherit;color:var(--color-text)"
                            @@mousedown.prevent="addTagFromOption(opt)"
                            x-text="opt.name"></button>
                </template>
            </div>
        </div>
        <p style="font-size:var(--font-size-sm);color:var(--color-text-muted);margin:var(--space-2) 0 0">
            Try typing to filter. Selected: <code x-text="JSON.stringify(tags)"></code>
        </p>
    </div>
    <style>
        .recipe-tag-editor:focus-within { border-color: var(--color-accent); }
        .tag-picker-option:hover { background: var(--color-surface-2) !important; }
    </style>
    <pre class="code-sample"><code>@("// Page model: TagOptions populated via tags.ListAllAsync(activeOnly: true)\n// Server-side JSON (without Html.Raw):\n// var tagsInitJson = JsonSerializer.Serialize(Input.TagIds.Zip(Input.TagNames, (id, name) => new { id, name }).ToList());\n// var tagOptionsJson = JsonSerializer.Serialize(TagOptions.Select(o => new { id = o.Value, name = o.Text }).ToList());\n\n// Alpine x-data (substitute serialised JSON for the two variables):\n// tags: <tagsInitJson>,           // [{id, name}, ...] — pre-selected chips (incl. archived)\n// tagOptions: <tagOptionsJson>,    // [{id, name}, ...] — active defined tags only\n// filteredTagOptions() — excludes already-selected and non-matching\n// addTagFromOption(opt) — pushes chip, clears query, closes dropdown\n// removeTag(i) — splices from tags[]\n\n// Hidden inputs post the TagId array (one per chip):\n<template x-for=\"(tag, ti) in tags\" :key=\"tag.id\">\n  <input type=\"hidden\" name=\"Input.TagIds\" :value=\"tag.id\" />\n</template>\n\n// Chip + filter input container:\n<div class=\"recipe-tag-editor\" @click=\"$refs.tagInput.focus()\">\n  <template x-for=\"(tag, ti) in tags\" :key=\"tag.id\">\n    <span class=\"badge badge--neutral\">\n      <span x-text=\"tag.name\"></span>\n      <button type=\"button\" @click.stop=\"removeTag(ti)\">x</button>\n    </span>\n  </template>\n  <input type=\"text\" x-ref=\"tagInput\" x-model=\"tagQuery\" placeholder=\"Filter tags…\"\n         @focus=\"tagDropOpen = true\" @input=\"tagDropOpen = true\"\n         @keydown.escape=\"tagDropOpen = false; tagQuery = ''\"\n         @keydown.backspace=\"if (!tagQuery && tags.length) removeTag(tags.length - 1)\"\n         autocomplete=\"off\" />\n</div>\n\n// Dropdown:\n<div x-show=\"tagDropOpen && filteredTagOptions().length > 0\" x-cloak @click.outside=\"tagDropOpen = false\"\n     style=\"position:absolute;...\">\n  <template x-for=\"opt in filteredTagOptions()\" :key=\"opt.id\">\n    <button type=\"button\" class=\"tag-picker-option\" @mousedown.prevent=\"addTagFromOption(opt)\" x-text=\"opt.name\"></button>\n  </template>\n</div>\n\n// Empty-household server-side guidance (when Model.TagOptions is empty):\n<p>No tags defined yet. <a href=\"/Settings/Tags\">Manage tags in Settings</a>.</p>")</code></pre>
</section>

<section class="catalog-section">
    <div class="catalog-section__header">
        <h2 class="catalog-section__heading">Servings scale offer (J7 step 3)</h2>
    </div>
    <p>
        On the recipe edit form, when the user changes the <em>Default servings</em> value on a recipe
        that already has ingredients, a <code>.seg-ctrl</code> toggle appears asking whether to
        <strong>Proportional</strong>ly scale the ingredient quantities or <strong>Keep</strong> them
        as-is. Alpine controls visibility via <code>showScaleOffer()</code> which returns true when
        <code>servings !== origServings &amp;&amp; hasIngredients</code>. The selected mode posts via a
        hidden input (<code>Input.ScaleMode</code>) which <code>AuthorRecipe</code> applies during the
        <code>Recipe.ChangeDefaultServings</code> call.
    </p>
    <div style="max-width: 36rem" x-data="{ servings: 4, origServings: 4, scaleMode: 'Keep', hasIngredients: true, showOffer() { return this.hasIngredients && this.servings !== this.origServings; } }">
        <div class="form-stack" style="gap:var(--space-3)">
            <div class="form-grid">
                <field stacked asp-for="FieldRowDemo.Quantity">
                    <input type="number" class="field__input" x-model.number="servings" min="1" step="1" />
                </field>
            </div>
            <div class="card" x-show="showOffer()" x-cloak>
                <div class="card__head">
                    <div>
                        <h3 class="card__head-title">Scale ingredients?</h3>
                        <p class="card__head-sub">You changed the default servings. How should ingredient quantities be adjusted?</p>
                    </div>
                </div>
                <div class="card__body">
                    <div class="seg-ctrl" role="group" aria-label="Scale mode">
                        <label class="seg-ctrl__item">
                            <input type="radio" name="demo-scale" value="Proportional" x-model="scaleMode" />
                            <span>Proportional — scale quantities</span>
                        </label>
                        <label class="seg-ctrl__item">
                            <input type="radio" name="demo-scale" value="Keep" x-model="scaleMode" />
                            <span>Keep — preserve quantities</span>
                        </label>
                    </div>
                </div>
            </div>
        </div>
        <p style="font-size:var(--font-size-sm);color:var(--color-text-muted);margin:var(--space-2) 0 0">
            Change the servings from 4 to something else to see the offer appear.
        </p>
    </div>
    <pre class="code-sample"><code>@("// Alpine: showScaleOffer() { return !isCreate && hasIngredients && parseInt(servings) !== origServings; }\n// Hidden input posts selected mode:\n<input type=\"hidden\" name=\"Input.ScaleMode\" :value=\"scaleMode\" />\n\n<div class=\"card\" x-show=\"showScaleOffer()\" x-cloak>\n  <div class=\"card__body\">\n    <div class=\"seg-ctrl\" role=\"group\" aria-label=\"Scale mode\">\n      <label class=\"seg-ctrl__item\">\n        <input type=\"radio\" name=\"_scaleMode\" value=\"Proportional\" x-model=\"scaleMode\" />\n        <span>Proportional — scale quantities</span>\n      </label>\n      <label class=\"seg-ctrl__item\">\n        <input type=\"radio\" name=\"_scaleMode\" value=\"Keep\" x-model=\"scaleMode\" />\n        <span>Keep — preserve quantities</span>\n      </label>\n    </div>\n  </div>\n</div>")</code></pre>
</section>

@*
    ── P4-6: Product search / create sheet ──────────────────────────────────────────────────────────
    Shared _ProductSearchCreateSheet partial — extracted from Recipes/Edit and reused by Take Stock
    inline-add (P4-7, plantry-hcj3.8). Added here first per the component-library-first convention.
*@

<section class="catalog-section">
    <div class="catalog-section__header">
        <h2 class="catalog-section__heading">Product search / create sheet (<code>Shared/_ProductSearchCreateSheet</code>)</h2>
    </div>
    <p>
        <code>Shared/_ProductSearchCreateSheet</code> is the shared bottom-drawer for picking or
        creating a catalog product. It provides two modes: a type-to-search product picker (htmx-driven
        <code>searchableSelect</code>) and an inline staple-create escape hatch (C12) that lets the user
        type a name and default unit when no match exists.
    </p>
    <p>
        <strong>Alpine contract:</strong> the host page's <code>x-data</code> must expose
        <code>sheetOpen</code>, <code>editingIdx</code> (null = adding, number = editing),
        <code>draft</code> (working copy of the row), <code>closeSheet()</code>, <code>saveSheet()</code>,
        and <code>selectProduct(row, detail)</code>.
    </p>
    <p>
        <strong>Event contract:</strong>
    </p>
    <ul style="font-size:var(--font-size-sm)">
        <li><code>sheet-product-set</code> (window) — dispatched inbound by the host when opening the sheet to
            pre-populate the search box (<code>detail: label string</code>).</li>
        <li><code>pick-product</code> — dispatched outbound from each search result <code>&lt;li&gt;</code> on click.
            <code>detail: &#123; value: ProductId, name, track: "true"|"false" &#125;</code>.
            The host catches it on the sheet element via <code>@@pick-product="selectProduct(draft, $event.detail)"</code>.</li>
    </ul>
    <p>
        <strong>Parameters (<code>ProductSearchCreateSheetViewModel</code>):</strong>
    </p>
    <ul style="font-size:var(--font-size-sm)">
        <li><code>SearchUrl</code> — htmx endpoint (<code>hx-get</code>) returning <code>&lt;li role="option"&gt;</code> markup.</li>
        <li><code>UnitOptions</code> — units for the staple-create unit select and (when <code>TrackStock</code> is true) the ingredient unit select.</li>
        <li><code>TrackStock</code> — when true (Recipes), qty + unit fields appear for tracked products.
            When false (Take Stock inline-add) those fields are hidden; count lives in the extra-fields slot.</li>
        <li><code>ExtraFieldsPartial</code> — optional partial name rendered between the product picker and action bar (e.g. Take Stock count + location fields for P4-7).</li>
    </ul>

    @*
        Live demo wrapped in a minimal Alpine host satisfying the sheet's x-data contract.
        Uses /Dev?handler=FilterGroceries (same endpoint as the searchable-select demo) so the
        picker works without a full recipe-page context.
    *@
    <div style="max-width: 36rem"
         x-data="{
             sheetOpen: false,
             editingIdx: null,
             draft: {},
             blankDraft() {
                 return { productId: '', productName: '', isUntracked: false,
                          newStapleName: null, newStapleUnit: '', qty: '', unitId: '', groupHeading: '' };
             },
             openSheet() {
                 this.editingIdx = null;
                 this.draft = this.blankDraft();
                 this.sheetOpen = true;
                 this.$nextTick(() => window.dispatchEvent(new CustomEvent('sheet-product-set', { detail: '' })));
             },
             closeSheet() { this.sheetOpen = false; },
             saveSheet() { this.sheetOpen = false; },
             selectProduct(row, detail) {
                 row.productId = detail.value;
                 row.productName = detail.name;
                 row.isUntracked = detail.track === 'false';
             },
         }">
        <button type="button" class="btn btn--secondary" @@click="openSheet()">Open sheet demo</button>
        <p x-show="!sheetOpen" style="font-size:var(--font-size-sm);color:var(--color-text-muted);margin:var(--space-2) 0 0">
            Click to open the shared sheet. Search for "milk" or "pasta".
        </p>

        <partial name="Shared/_ProductSearchCreateSheet"
                 model='new Plantry.Web.Pages.Shared.ProductSearchCreateSheetViewModel
                 {
                     SearchUrl   = "/Dev?handler=FilterGroceries",
                     UnitOptions = Model.UnitOptions,
                     TrackStock  = true,
                 }' />
    </div>

    <pre class="code-sample"><code>@(@"// View-model
new ProductSearchCreateSheetViewModel
{
    SearchUrl          = Url.Page(""./MyPage"", ""SearchProducts"")!,
    UnitOptions        = Model.UnitOptions,  // IReadOnlyList<SelectListItem>
    TrackStock         = true,               // false = hide qty/unit (Take Stock mode)
    ExtraFieldsPartial = null,               // or ""TakeStock/_CountLocationFields"" for P4-7
}

// Host x-data must expose:
//   sheetOpen, editingIdx, draft, closeSheet(), saveSheet(),
//   selectProduct(row, detail)   ← catches the pick-product event

// Usage:
<partial name=""Shared/_ProductSearchCreateSheet"" model=""Model.SheetVm"" />

// Or inline (page with Url helper):
<partial name=""Shared/_ProductSearchCreateSheet""
         model='new ProductSearchCreateSheetViewModel
         {
             SearchUrl = Url.Page(""./Edit"", ""SearchProducts"")!,
             UnitOptions = Model.UnitOptions,
             TrackStock = true,
         }' />")</code></pre>
</section>

<section class="catalog-section">
    <div class="catalog-section__header">
        <h2 class="catalog-section__heading">Recipes browse — fulfillment pill (gallery)</h2>
    </div>
    <p>
        <code>.fulf-pill</code> overlays the gallery card scrim. Translucent white background with
        blur, colored status dot (<code>.fulf-pill__dot</code>, background from <code>.fulf-hi-bg</code>
        / <code>.fulf-mid-bg</code> / <code>.fulf-lo-bg</code>) and percentage text.
    </p>
    <div style="background:#333;padding:16px;border-radius:8px;display:inline-flex;gap:12px">
        <span class="fulf-pill"><span class="fulf-pill__dot fulf-hi-bg"></span> 90%</span>
        <span class="fulf-pill"><span class="fulf-pill__dot fulf-mid-bg"></span> 60%</span>
        <span class="fulf-pill"><span class="fulf-pill__dot fulf-lo-bg"></span> 20%</span>
    </div>
