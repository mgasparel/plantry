@*
    ── P3-2 Dietary Preferences components ─────────────────────────────────────────────────────────
    These components are used by /Settings/Preferences (plantry-e78): the 5-segment StanceScale.
    Added here first per the component-library-first convention (see .claude/CLAUDE.md), then consumed
    by Settings/Preferences.cshtml.
*@

<section class="catalog-section">
    <div class="catalog-section__header">
        <h2 class="catalog-section__heading">StanceScale (<code>.stance</code>)</h2>
    </div>
    <p>
        <code>.stance</code> is the 5-segment dietary-preference control for the
        <code>/Settings/Preferences</code> page (P3-2, plantry-e78 / plantry-tvx). The container is a
        single pill shape (<code>background:surface-2; border; border-radius:999px; padding:3px</code>).
        Five mutually-exclusive stance segments are rendered as <code>role="radio"</code> buttons:
        <strong>Required</strong> (binding, good tone) &rarr; <strong>Preferred</strong> (soft, good-soft tone)
        &rarr; <strong>Neutral</strong> (default, no row stored) &rarr; <strong>Disliked</strong>
        (soft, warn tone) &rarr; <strong>Restricted</strong> (binding, bad tone).
        The selected segment carries <code>.on</code>; hard stances also carry <code>.hard</code>.
        Tone is passed via the <code>data-tone</code> attribute
        (<code>good</code>, <code>good-soft</code>, <code>neutral</code>, <code>warn</code>, <code>bad</code>).
        Selected = solid tone fill + white text; hard selected = binding ring (<code>box-shadow</code>).
        Each button fires an htmx POST to <code>/Settings/Preferences?handler=Stance</code>;
        the response swaps the enclosing <code>.tag-row</code> (<code>hx-target="#tag-row-{tagId}"</code>).
    </p>

    @{
        var demoCurrentStance = "Preferred";
    }
    <div style="display: flex; flex-direction: column; gap: var(--space-4); max-width: 560px">
        <div>
            <p style="font-size: var(--font-size-sm); color: var(--color-text-muted); margin: 0 0 var(--space-2)">Preferred selected</p>
            <div class="stance" role="radiogroup" aria-label="Demo stance">
                @foreach (var sv in new[] { ("Required","good",true), ("Preferred","good-soft",false), ("Neutral","neutral",false), ("Disliked","warn",false), ("Restricted","bad",true) })
                {
                    var isOn = sv.Item1 == demoCurrentStance;
                    <button type="button" role="radio" aria-checked="@isOn.ToString().ToLower()"
                            title="@sv.Item1" data-tone="@sv.Item2"
                            class="stance-seg @(isOn ? "on" : "") @(sv.Item3 ? "hard" : "")">
                        @sv.Item1
                    </button>
                }
            </div>
        </div>
        <div>
            <p style="font-size: var(--font-size-sm); color: var(--color-text-muted); margin: 0 0 var(--space-2)">Restricted selected (hard binding ring)</p>
            <div class="stance" role="radiogroup" aria-label="Demo stance restricted">
                @foreach (var sv in new[] { ("Required","good",true), ("Preferred","good-soft",false), ("Neutral","neutral",false), ("Disliked","warn",false), ("Restricted","bad",true) })
                {
                    var isOn = sv.Item1 == "Restricted";
                    <button type="button" role="radio" aria-checked="@isOn.ToString().ToLower()"
                            title="@sv.Item1" data-tone="@sv.Item2"
                            class="stance-seg @(isOn ? "on" : "") @(sv.Item3 ? "hard" : "")">
                        @sv.Item1
                    </button>
                }
            </div>
        </div>
    </div>

    <pre class="code-sample"><code>@("<div class=\"stance\" role=\"radiogroup\" aria-label=\"Stance for {tagName}\">\n  <!-- For each stance in (Required/good/hard, Preferred/good-soft, Neutral/neutral, Disliked/warn, Restricted/bad/hard): -->\n  <button type=\"button\" role=\"radio\"\n          aria-checked=\"{isOn}\"\n          title=\"{label}\"\n          data-tone=\"{tone}\"\n          class=\"stance-seg {isOn ? 'on' : ''} {hard ? 'hard' : ''}\"\n          hx-post=\"/Settings/Preferences?handler=Stance&tagId={tagId}&stance={value}&tagName={tagName}\"\n          hx-target=\"#tag-row-{tagId}\"\n          hx-swap=\"outerHTML\"\n          hx-include=\"[name='__RequestVerificationToken']\">\n    {label}\n  </button>\n</div>")</code></pre>
</section>

@* ── P3-1: Avatar stack (attendee display) ──────────────────────────────────── *@
<section class="catalog-section">
    <div class="catalog-section__header">
        <h2 class="catalog-section__heading">Avatar stack — <code>.pl-av</code> + <code>.att-stack</code></h2>
    </div>
    <p>
        Used in the attendee trigger button to show up to 3 member initials stacked with a −7px overlap.
        Each <code>.pl-av</code> is a <code>display:inline-grid</code> tile. Stack wraps them in <code>.att-stack</code>
        which uses negative margin to create the overlapping effect.
    </p>
    <div style="display:flex;gap:24px;align-items:center;flex-wrap:wrap;padding:16px 0">
        @* Single avatar *@
        <span class="pl-av" style="width:32px;height:32px;font-size:13px;background:var(--color-surface-2);color:var(--color-text-muted)">A</span>

        @* Stack of 3 *@
        <span class="att-stack">
            <span class="pl-av" style="width:26px;height:26px;font-size:11px;background:var(--color-surface-2);color:var(--color-text-muted)">A</span>
            <span class="pl-av" style="width:26px;height:26px;font-size:11px;background:var(--color-accent-subtle);color:var(--color-accent)">B</span>
            <span class="pl-av" style="width:26px;height:26px;font-size:11px;background:var(--color-surface-2);color:var(--color-text-muted)">C</span>
        </span>

        @* Inside att-trigger button *@
        <button type="button" class="att-trigger">
            <span class="att-stack">
                <span class="pl-av" style="width:22px;height:22px;font-size:10px;background:var(--color-surface-2);color:var(--color-text-muted)">A</span>
                <span class="pl-av" style="width:22px;height:22px;font-size:10px;background:var(--color-accent-subtle);color:var(--color-accent)">B</span>
            </span>
            <span class="att-label">Alice &amp; Bob</span>
        </button>

        @* Empty trigger *@
        <button type="button" class="att-trigger empty">
            <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            <span class="att-label">No one yet</span>
        </button>
    </div>
    <pre class="code-sample"><code>@("<!-- Single avatar -->\n<span class=\"pl-av\" style=\"width:32px;height:32px;font-size:13px;background:var(--color-surface-2);color:var(--color-text-muted)\">A</span>\n\n<!-- Stack of 3 in a trigger button -->\n<button type=\"button\" class=\"att-trigger\">\n  <span class=\"att-stack\">\n    <span class=\"pl-av\" style=\"width:22px;height:22px;font-size:10px;...\">A</span>\n    <span class=\"pl-av\" style=\"width:22px;height:22px;font-size:10px;...\">B</span>\n  </span>\n  <span class=\"att-label\">Alice &amp; Bob</span>\n</button>")</code></pre>
</section>

@* ── plantry-izgn.4: Constant-sum sliders ────────────────────────────────────── *@
<section class="catalog-section">
    <div class="catalog-section__header">
        <h2 class="catalog-section__heading">Constant-sum sliders — <code>planTune(cfg)</code></h2>
    </div>
    <p>
        <code>planTune(cfg)</code> (<code>wwwroot/js/plan-tune.js</code>) is a reusable Alpine
        component for any "allocate 100% across N buckets" need. Dragging one slider proportionally
        rescales the others so the group always sums to 100. Edge case: when all others are at 0
        the remainder splits evenly across them.
    </p>
    <p>
        Pass a <code>buckets</code> array — <code>{ key, label, color, defaultWeight }</code> — in
        the config. The <code>weights</code> map (keyed by <code>bucket.key</code>) and
        <code>rebalance(key, value)</code> are exposed on the component. The stacked fill bar below
        the sliders uses the same <code>weights</code> map. Wrap in any popover, drawer, or inline
        container — the component owns no chrome.
    </p>
    <p>
        The meal-plan auto-fill tune popover (<code>_PlanBarNav.cshtml</code>) is the canonical
        consumer: it passes waste/cost/variety as the bucket config and posts the weights as hidden
        inputs (<code>wasteWeight</code>, <code>costWeight</code>, <code>varietyWeight</code>) via
        <code>hx-include</code>.
    </p>

    @{
        // Generic 3-bucket demo — not meal-plan specific.
        var demoCfg = new
        {
            buckets = new[]
            {
                new { key = "speed",   label = "Speed",   color = "oklch(0.62 0.13 255)", defaultWeight = 50 },
                new { key = "quality", label = "Quality", color = "oklch(0.62 0.13 150)", defaultWeight = 30 },
                new { key = "cost",    label = "Cost",    color = "oklch(0.62 0.13 70)",  defaultWeight = 20 }
            }
        };
        var demoCfgJson = System.Text.Json.JsonSerializer.Serialize(demoCfg);
    }

    <div style="max-width: 340px" x-data="planTune(@Html.Raw(demoCfgJson))">

        <div class="tune-sect-label">
            Allocate 100%
            <span class="spacer"></span>
            <button type="button" class="reset" @@click="reset()">Reset</button>
        </div>

        <template x-for="m in buckets" :key="m.key">
            <div class="wt-row">
                <span class="wt-name">
                    <span class="wt-dot" :style="'background:' + m.color"></span>
                    <span x-text="m.label"></span>
                </span>
                <input type="range" min="0" max="100" :value="weights[m.key]"
                       :style="'background:linear-gradient(90deg, ' + m.color + ' ' + weights[m.key] + '%, var(--color-surface-2) ' + weights[m.key] + '%)'"
                       @@input="let v = $event.target.value; rebalance(m.key, v)" />
                <span class="wt-val" x-text="weights[m.key]"></span>
            </div>
        </template>

        <div class="wt-stack">
            <template x-for="m in buckets" :key="m.key">
                <i :style="'width:' + weights[m.key] + '%;background:' + m.color"></i>
            </template>
        </div>

        <p style="font-size: var(--font-size-sm); color: var(--color-text-muted); margin: 0">
            Sum: <span x-text="buckets.reduce((s, b) => s + weights[b.key], 0)"></span> (always 100)
        </p>
    </div>

    <pre class="code-sample"><code>@(@"// plan-tune.js — planTune(cfg) Alpine component
// cfg = { buckets: [{ key, label, color, defaultWeight }, ...] }
// Exposed: weights (map keyed by key), buckets, rebalance(key, value), reset()

<div x-data=""planTune(cfg)"">
  <template x-for=""m in buckets"" :key=""m.key"">
    <div class=""wt-row"">
      <span class=""wt-name"">
        <span class=""wt-dot"" :style=""'background:' + m.color""></span>
        <span x-text=""m.label""></span>
      </span>
      <input type=""range"" min=""0"" max=""100"" :value=""weights[m.key]""
             :style=""'background:linear-gradient(90deg, ' + m.color + ' ' + weights[m.key] + '%, var(--color-surface-2) ' + weights[m.key] + '%)'""
             @input=""let v = $event.target.value; rebalance(m.key, v)"" />
      <span class=""wt-val"" x-text=""weights[m.key]""></span>
    </div>
  </template>
  <div class=""wt-stack"">
    <template x-for=""m in buckets"" :key=""m.key"">
      <i :style=""'width:' + weights[m.key] + '%;background:' + m.color""></i>
    </template>
  </div>
  <!-- Hidden inputs for form post (name each after bucket.key + 'Weight') -->
  <template x-for=""m in buckets"" :key=""m.key"">
    <input type=""hidden"" :name=""m.key + 'Weight'"" :value=""weights[m.key]"" />
  </template>
</div>")</code></pre>
</section>
