    <pre class="code-sample"><code>@("<div class=\"fulf-meter\">\n  <div class=\"fulf-meter__bar-wrap\">\n    <span class=\"fulf-meter__bar fulf-hi-bg\" style=\"width:90%\"></span>\n  </div>\n  <div class=\"fulf-meter__labels\">\n    <div class=\"fulf-meter__pct fulf-hi\">90%</div>\n    <div class=\"fulf-meter__sub\">9/10 in stock</div>\n  </div>\n</div>")</code></pre>
</section>

<section class="catalog-section">
