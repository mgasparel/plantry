@model Plantry.Web.Pages.Intake.ReviewProjections
@*
    ADR-013 §3 OOB fragment — filter chip bar.
    Target: #rev-chips (outerHTML). Emitted as part of the _ReviewRowOobBundle on every successful
    row action so the chip counts stay in sync with the row states without a full-region repaint.

    The data-count-* attributes carry the server-authoritative counts so section headers can read
    them without DOM-counting ($root.querySelectorAll is rejected per ADR-013 amendment).
    Registered in the Dev component library (src/Plantry.Web/Pages/Dev/Index.cshtml).
*@
<div id="rev-chips" class="filter-chip-bar" hx-swap-oob="outerHTML:#rev-chips">
    <button type="button" class="filter-chip"
            :class="filter === 'all' ? 'is-active filter-chip--success' : ''"
            @@click="filter = 'all'"
            data-count-total="@Model.TotalItems">
        <partial name="Shared/_FilterChip" model='new Plantry.Web.Pages.Shared.FilterChipViewModel("All", Count: Model.TotalItems)' />
    </button>
    <button type="button" class="filter-chip"
            :class="filter === 'review' ? 'is-active filter-chip--warning' : ''"
            @@click="filter = 'review'"
            data-count-needs="@Model.NeedsCount">
        <partial name="Shared/_FilterChip" model='new Plantry.Web.Pages.Shared.FilterChipViewModel("Needs review", DotColor: "var(--color-warning)", Count: Model.NeedsCount)' />
    </button>
    <button type="button" class="filter-chip"
            :class="filter === 'ready' ? 'is-active filter-chip--success' : ''"
            @@click="filter = 'ready'"
            data-count-ready="@Model.ReadyCount">
        <partial name="Shared/_FilterChip" model='new Plantry.Web.Pages.Shared.FilterChipViewModel("Ready", DotColor: "var(--color-success)", Count: Model.ReadyCount)' />
    </button>
</div>
