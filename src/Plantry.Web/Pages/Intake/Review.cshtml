@page "{id:guid}"
@model Plantry.Web.Pages.Intake.ReviewModel
@inject Microsoft.AspNetCore.Mvc.ViewFeatures.IFileVersionProvider FileVersionProvider
@{
    ViewData["Title"] = "Review import";
    ViewData["ContentClass"] = "page-content--fluid";
    var irIslandSrc  = FileVersionProvider.AddFileVersionToPath(ViewContext.HttpContext.Request.PathBase, "/js/islands/intake-review.js");
    var irHelpersSrc = FileVersionProvider.AddFileVersionToPath(ViewContext.HttpContext.Request.PathBase, "/js/islands/helpers.js");
}

@* Island hydration payload — read by intake-review.js via readHydration('review-island-data').
   The full session state, reference data, and server-computed prefill values are embedded here
   for a zero-round-trip island mount (no flash; SSR layout is preserved by the island rendering
   the same structure). BuildHydrationJson() in Review.cshtml.cs builds this; the prefill priority
   chain (ComputePrefill) runs server-side only (ADR-020 §3 Boundary judgment call 1). *@
<script type="application/json" id="review-island-data">@Html.Raw(Model.IslandHydrationJson)</script>

@* Antiforgery token — read by the island via readAntiforgeryToken() in helpers.js *@
@Html.AntiForgeryToken()

@* Island mount point — intake-review.js renders the full review UI (receipt panel + row list + commit bar) *@
<div id="review-island-root"></div>

@section Scripts {
    <script type="module">
        const { mountIntakeReview } = await import('@Html.Raw(irIslandSrc)');
        const { readHydration }     = await import('@Html.Raw(irHelpersSrc)');

        const root = document.getElementById('review-island-root');
        const hydration = readHydration('review-island-data');

        if (root && hydration) {
            mountIntakeReview(root, hydration);
        }
    </script>
}
