@using Plantry.Intake.Domain
@model Plantry.Web.Pages.Intake.ReviewModel
@*
    ADR-013 §1 — row-action response bundle.
    Returned by RowResultAsync() on every successful row action (save/dismiss/restore).
    The response carries:
      1. The ONE changed row (primary body — swapped via HX-Retarget/HX-Reswap outerHTML on #import-line-{id})
      2. _ReviewChipsOob       → #rev-chips   (OOB outerHTML)
      3. _ReviewProgressOob    → #rev-progress (OOB outerHTML)
      4. _ReviewCommitBarOob   → #commit-bar   (OOB outerHTML)
      5. _ReviewReceiptTotalOob → #rcpt-total  (OOB outerHTML)

    htmx processes the primary body first (swapping the one row), then strips and routes each OOB
    element to its matching id. No other row is touched; open drawers and unsaved edits survive.

    All projections come from BuildProjections() (ADR-013 §2 — one computation point, cannot drift).
    Registered in the Dev component library (src/Plantry.Web/Pages/Dev/Index.cshtml).
*@
@{
    var projections = Model.BuildProjections();
    var row = (Plantry.Web.Pages.Intake.ReviewRowModel)ViewData["Row"]!;
    var rowDataStatus = row.RowViewModel.Status switch
    {
        LineStatus.Confirmed or LineStatus.Committed => "ready",
        LineStatus.Dismissed => "skipped",
        _ => "needs"
    };
    var rowXShow = rowDataStatus switch
    {
        "ready" => "filter === 'all' || filter === 'ready'",
        "skipped" => "filter === 'all'",
        _ => "filter === 'all' || filter === 'review'"
    };
    ViewData["RowDataStatus"] = rowDataStatus;
    ViewData["RowXShow"] = rowXShow;
}

@* ── Primary: the one changed row (htmx swaps this as the primary swap body) ─────────────────── *@
<partial name="_ReviewRow" model="Model" view-data="ViewData" />

@* ── OOB fragments: four aggregate projections land in their own stable id regions ─────────────── *@
<partial name="_ReviewChipsOob" model="projections" />
<partial name="_ReviewProgressOob" model="projections" />
<partial name="_ReviewCommitBarOob" model="projections" />
<partial name="_ReviewReceiptTotalOob" model="projections" />
