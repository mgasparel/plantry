@model Plantry.Web.Pages.Intake.ReviewProgress
@*
    The review header's progress bar. Rendered once inside _ReviewBody, which is itself the htmx swap
    target (#rev-body) for both the initial page load and every row action — so the counts and markup
    live in a single place and the two renders can't drift apart.
*@
<div class="rev-progress">
    <div class="rev-progress__bar">
        <div class="rev-progress__fill" style="width: @(Model.Percent)%"></div>
    </div>
    <div class="rev-progress__meta">
        @if (Model.CanCommit)
        {
            <span><b>All set.</b> @Model.Total items ready to add.</span>
        }
        else
        {
            <span><b>@Model.NeedsCount</b> @(Model.NeedsCount == 1 ? "item needs" : "items need") a quick look · <b>@Model.ReadyCount</b> ready</span>
        }
    </div>
</div>
