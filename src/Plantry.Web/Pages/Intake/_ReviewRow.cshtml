@using System.Globalization
@using Plantry.Intake.Application
@using Plantry.Intake.Domain
@using Plantry.Web.Pages.Intake
@*
    Model is the PageModel itself (not the row VM) so the model-bound <searchable-select asp-for="Edit.ProductId">
    resolves against the page's bind target; the specific row to render is passed via ViewData["Row"].

    ADR-013 §3 — data-status lives INSIDE the #import-line-{id} element so an OOB row swap carries the
    updated section membership. ViewData["RowDataStatus"] is the status string (needs/ready/skipped).
    ViewData["RowXShow"] is the Alpine x-show expression for section filtering.

    ADR-013 step 6 — qty/expiry JS-literal cleanup: v (qty) and d (expiry) are part of the row's JSON
    x-data (via JsonSerializer) instead of @qtyInitJs / @expiryInitJs interpolated literals.
    Qty still uses the .qty-stepper; expiry now uses the .expiry-field control (Date / Never).

    plantry-4ha — product-default prefill: loc (location id), unit (unit id), receiptUnitId (the
    parser-derived unit or null — "receipt unit wins"), productDefaults (productId→{unitId,locationId,dueDays})
    and locationNames (locationId→name) are all carried in x-data so Alpine can recompute live on every
    product selection (AI match, "Did you mean" chip, or dropdown). The recompute logic and the
    $watch on selectedProductId live in the reviewRow() Alpine.data component (wwwroot/js/review-row.js),
    NOT in x-init: each row is its own component instance so its helpers/state stay private. Defining
    them in x-init failed two ways — bare assignments leaked to `window` (rows clobbered one global, so
    the watch fired the wrong row's closure), and `this` inside x-init is not the component data (so
    this.productDefaults etc. were undefined when a stored helper ran later). See review-row.js.
*@
@model Plantry.Web.Pages.Intake.ReviewModel
@{
    var page = Model;
    var rowModel = (Plantry.Web.Pages.Intake.ReviewRowModel)ViewData["Row"]!;
    var row = rowModel.RowViewModel;
    var line = rowModel.Line;

    // ADR-013 §3 — data-status and x-show for section filtering (from ViewData or derived from status)
    var rowDataStatus = ViewData["RowDataStatus"] as string ?? row.Status switch
    {
        LineStatus.Confirmed or LineStatus.Committed => "ready",
        LineStatus.Dismissed => "skipped",
        _ => "needs"
    };
    var rowXShow = ViewData["RowXShow"] as string ?? rowDataStatus switch
    {
        "ready" => "filter === 'all' || filter === 'ready'",
        "skipped" => "filter === 'all'",
        _ => "filter === 'all' || filter === 'review'"
    };

    var stateClass = row.Status switch
    {
        LineStatus.Confirmed => "import-row--confirmed",
        LineStatus.Dismissed => "import-row--dismissed",
        LineStatus.Committed => "import-row--committed",
        _ => row.IsMatched ? "import-row--matched" : "import-row--unmatched",
    };

    var startOpen = row.IsUnmatched;
    var qtyValue = rowModel.PrefillQuantity?.ToString("0.###", CultureInfo.InvariantCulture) ?? "";

    // PrefillExpiry already encodes the priority chain (user-resolved > today+DefaultDueDays > null).
    var expiryValue = rowModel.PrefillExpiry?.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture) ?? "";
    var priceValue = rowModel.PrefillPrice?.ToString("0.##", CultureInfo.InvariantCulture) ?? "";
    var newNameValue = line.NewProductName ?? "";

    var initialProductIdStr = rowModel.PrefillProductId?.ToString() ?? "";
    var initialSkuIdStr = rowModel.PrefillSkuId?.ToString() ?? "";
    var initialLocationIdStr = rowModel.PrefillLocationId?.ToString() ?? "";
    var initialUnitIdStr = rowModel.PrefillUnitId?.ToString() ?? "";

    // receiptUnitIdStr: the parser-derived unit id for this line (empty when the parser detected no unit).
    // "Receipt unit wins" is resolved server-side into productDefaults below, so the drawer JS applies the
    // already-chosen unit directly — the rule lives only here (C#), never duplicated in JavaScript.
    var receiptUnitIdStr = (line.Status == LineStatus.Pending && line.SuggestedUnitLabel is not null)
        ? (rowModel.PrefillUnitId?.ToString() ?? "")   // parser had a label → treat as receipt-owned
        : "";

    // Build a productId (string) → [{id, label}] map for Alpine so it can filter
    // pack-size options dynamically when the product selection changes in the drawer.
    var skusByProductId = rowModel.SkusByProductId
        .ToDictionary(
            kvp => kvp.Key,
            kvp => kvp.Value.Select(s => new { id = s.Id.ToString(), label = s.Label }).ToList());

    // productDefaults: productId (string) → fully-resolved {unitId, locationId, expiry} for the drawer.
    // The prefill RULE (receipt-unit-wins; expiry = today + DefaultDueDays, or none) is applied here,
    // server-side, so applyProductDefaults() in review-row.js is a pure applicator — no business logic is
    // duplicated in JavaScript, so the server and the live in-drawer recompute can't drift. This encodes
    // the same rule as ComputePrefill (which seeds the initial render); both are C#, so they stay in step.
    var productDefaults = page.Session.ReferenceData.Products
        .ToDictionary(
            p => p.Id.ToString(),
            p => new
            {
                unitId = !string.IsNullOrEmpty(receiptUnitIdStr) ? receiptUnitIdStr : p.DefaultUnitId.ToString(),
                locationId = p.DefaultLocationId?.ToString() ?? "",
                expiry = p.DefaultDueDays is { } n ? page.Today.AddDays(n).ToString("yyyy-MM-dd") : ""
            });

    // locationNames: locationId (string) → display name for the reactive "Goes to" footer.
    var locationNames = page.Session.ReferenceData.Locations
        .ToDictionary(l => l.Id.ToString(), l => l.Name);

    // today as ISO string — used by the drawer's pick() to seed a fresh expiry date. Sourced from the
    // injected IClock via page.Today so the rendered value (and the resolved expiry above) is deterministic
    // under the test clock.
    var todayIso = page.Today.ToString("yyyy-MM-dd");

    var rowError = ViewData["RowError"] as string;
    var openDrawer = startOpen || !string.IsNullOrEmpty(rowError);

    // Category chip — resolve chip hue + code for this row.
    // Priority: new-product chosen category > matched/pre-fill product's category.
    var categoryById = page.Session.ReferenceData.Categories
        .ToDictionary(c => c.Id);
    var productById = page.Session.ReferenceData.Products
        .ToDictionary(p => p.Id);

    ReviewCategoryOption? chipCategory = null;
    if (line.IsNewProduct && line.NewProductCategoryId is { } newCatId && categoryById.TryGetValue(newCatId, out var newCat))
        chipCategory = newCat;
    else if (!line.IsNewProduct && rowModel.PrefillProductId is { } chipPrefillPid
             && productById.TryGetValue(chipPrefillPid, out var chipPrefillProd)
             && chipPrefillProd.CategoryId is { } prodCatId
             && categoryById.TryGetValue(prodCatId, out var prodCat))
        chipCategory = prodCat;

    var catChip = new Plantry.Web.Pages.Shared.CatChipViewModel(chipCategory?.Name, chipCategory?.Hue);

    // ADR-013 step 6 — v (qty) and d (expiry) are part of the row's JSON x-data; no interpolated JS literals.
    decimal? qtyInit = rowModel.PrefillQuantity;
    string? expiryInit = string.IsNullOrEmpty(expiryValue) ? null : expiryValue;

    // plantry-4ha — expiry mode for the .expiry-field control: "has" when there's a prefill date,
    // else "never" (a null expiry legitimately means "never expires"). The date input is disabled
    // in "never" mode so it is excluded from the POST; d is preserved so toggling back restores it.
    var expiryModeInit = expiryInit != null ? "has" : "never";

    var alpineState = System.Text.Json.JsonSerializer.Serialize(new
    {
        open = openDrawer,
        createNew = line.IsNewProduct,
        selectedProductId = initialProductIdStr,
        skuId = initialSkuIdStr,
        skus = skusByProductId,
        v = qtyInit,
        d = expiryInit,
        expiryMode = expiryModeInit,
        loc = initialLocationIdStr,
        unit = initialUnitIdStr,
        productDefaults,
        locationNames,
        today = todayIso,
    });

    // Quick-confirm: a direct POST with prefill values, shown in the collapsed row header.
    var canQuickConfirm = row.Status == LineStatus.Pending
        && !row.IsUnmatched
        && rowModel.PrefillProductId != null
        && (rowModel.PrefillQuantity ?? 0) > 0
        && rowModel.PrefillUnitId != null
        && rowModel.PrefillLocationId != null;

    var initialProduct = line.IsNewProduct ? null
        : rowModel.PrefillProductId is { } prefillPid
            ? page.ProductOptions.FirstOrDefault(o => o.Value == prefillPid.ToString())
            : null;
    // Fall back to the row's product name so the text input is never blank for identified products.
    var initialLabel = initialProduct?.Text
        ?? (rowModel.PrefillProductId != null ? row.ProductName ?? "" : "");

    // ADR-013 §3 — row forms target their own id with outerHTML. The HX-Retarget / HX-Reswap response
    // headers override the actual htmx swap; using the row's own id as the nominal hx-target is correct.
    var rowSelfTarget = $"#{row.DomId}";
}
@*
    ADR-013 §3 — x-show and data-status both live on the #import-line-{id} element itself so that
    an OOB row swap (outerHTML) carries the updated section membership and visibility in a single
    atomic replacement. No outer wrapper — the #import-line-{id} div IS the swap target's root.
    (The spike had x-show on an outer wrapper, which caused stale section visibility and DOM nesting
    after each swap; fixed per ADR-013 amendment confirmed in Opus critic pass 2.)

    plantry-4ha — the reviewRow() component (wwwroot/js/review-row.js) holds applyProductDefaults()
    (live recompute of loc/unit/d + expiryMode on every product selection — AI match, "Did you mean"
    chip, dropdown), pick() for the .expiry-field "Date" toggle, and addDays().
    x-data="reviewRow(@@alpineState)" spreads the server state onto the instance; the $watch on
    selectedProductId is wired in the component's init().
*@
<div id="@row.DomId" class="import-row @stateClass" x-data="reviewRow(@alpineState)" :class="{ 'import-row--open': open }" data-status="@rowDataStatus" x-show="@rowXShow">
@if (!string.IsNullOrEmpty(rowError))
        {
            <div class="import-row__error" role="alert">
                <svg class="icon" aria-hidden="true"><use href="#i-alert" /></svg> @rowError
            </div>
        }

        @if (row.IsDismissed)
        {
            @* Nonstock-style layout for dismissed rows *@
            <div class="import-row__nonstock-main">
                <div class="import-row__nonstock-ico">
                    <svg class="icon" aria-hidden="true"><use href="#i-tag" /></svg>
                </div>
                <div class="import-row__nonstock-name">
                    @row.RawText
                    <span class="import-row__nonstock-why">
                        @row.Price · not inventory — won't be added
                    </span>
                </div>
                <button type="button" class="btn btn--ghost btn--sm"
                        hx-post="@row.RestoreUrl" hx-target="@rowSelfTarget" hx-swap="outerHTML">
                    Add anyway
                </button>
            </div>
        }
        else
        {
            <div class="import-row__main">
                @* Category color chip — hue derived from the matched product's category (or new-product category). *@
                <partial name="Shared/_CatChip" model="catChip" />

                <div class="import-row__id">
                    <div class="import-row__name">
                        @if (row.ProductName is { } name)
                        {
                            <span class="import-row__product">@name</span>
                            @if (row.CreatedNew)
                            {
                                <span class="import-row__new">· new product</span>
                            }
                        }
                        else
                        {
                            <span class="import-row__unrecognized">Unrecognized item</span>
                        }
                    </div>
                    <div class="import-row__raw">
                        <span class="import-row__raw-tag">receipt</span>
                        <span>@row.RawText</span>
                    </div>
                </div>

                <div class="import-row__meta">
                    <div class="import-row__meta-cell">
                        <div class="import-row__meta-value">@row.Quantity<span class="import-row__meta-unit"> @row.Unit</span></div>
                        <div class="import-row__meta-label">qty</div>
                    </div>
                    <div class="import-row__meta-cell">
                        <div class="import-row__meta-value">@row.Price</div>
                        <div class="import-row__meta-label">price</div>
                    </div>
                    <div class="import-row__meta-cell">
                        <div class="import-row__meta-value">@row.Expiry</div>
                        <div class="import-row__meta-label">expires</div>
                    </div>
                    <div class="import-row__conf">
                        <partial name="Shared/_ConfidenceBadge" model="row.Confidence" />
                    </div>
                </div>

                <div class="import-row__act">
                    @if (row.IsConfirmed)
                    {
                        <span class="import-row__confirmed-flag">
                            <svg class="icon" aria-hidden="true"><use href="#i-check" /></svg> Matched
                        </span>
                    }
                    else if (row.IsCommitted)
                    {
                        <span class="import-row__locked">
                            <svg class="icon" aria-hidden="true"><use href="#i-lock" /></svg> Added
                        </span>
                    }
                    else if (canQuickConfirm)
                    {
                        <form hx-post="@row.SaveUrl" hx-target="@rowSelfTarget" hx-swap="outerHTML">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="Id" value="@(page.Id)" />
                            <input type="hidden" name="Edit.LineId" value="@line.LineId" />
                            <input type="hidden" name="Edit.CreateNew" value="false" />
                            <input type="hidden" name="Edit.ProductId" value="@rowModel.PrefillProductId" />
                            <input type="hidden" name="Edit.Quantity" value="@qtyValue" />
                            <input type="hidden" name="Edit.UnitId" value="@rowModel.PrefillUnitId" />
                            <input type="hidden" name="Edit.LocationId" value="@rowModel.PrefillLocationId" />
                            @if (!string.IsNullOrEmpty(expiryValue))
                            {
                                <input type="hidden" name="Edit.ExpiryDate" value="@expiryValue" />
                            }
                            @if (!string.IsNullOrEmpty(priceValue))
                            {
                                <input type="hidden" name="Edit.Price" value="@priceValue" />
                            }
                            <button type="submit" class="btn btn--secondary btn--sm">
                                <svg class="icon" aria-hidden="true"><use href="#i-check" /></svg> Confirm
                            </button>
                        </form>
                    }

                    @if (!row.IsCommitted)
                    {
                        <button type="button" class="import-row__toggle" @@click="open = !open" :aria-expanded="open" aria-label="Edit line">
                            <svg class="icon import-row__chev" :class="{ 'import-row__chev--open': open }" aria-hidden="true">
                                <use href="#i-chevron" />
                            </svg>
                        </button>
                    }
                </div>
            </div>

            <div class="import-row__edit review-row__edit" x-show="open" x-cloak>
                <form hx-post="@row.SaveUrl" hx-target="@rowSelfTarget" hx-swap="outerHTML">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Id" value="@(page.Id)" />
                    <input type="hidden" name="Edit.LineId" value="@line.LineId" />
                    <input type="hidden" name="Edit.CreateNew" :value="createNew" x-ref="createNew" />

                    @*
                        "Did you mean" block — sits before the edit-grid, matching the prototype layout where
                        match-suggest is a sibling of edit-grid (irow-edit > match-suggest + edit-grid + edit-foot).
                    *@
                    @if (rowModel.Alternatives is { Count: >= ImportLine.MinAlternativesForSuggestion } alts && !row.IsConfirmed && !row.IsCommitted)
                    {
                        <div class="match-suggest" x-show="!createNew">
                            <div class="match-suggest__label">
                                Did you mean — <span>several products share this name</span>
                            </div>
                            <div class="suggest-opts">
                                @* Primary suggestion is always chip 0 — pre-selected (the AI's top pick). *@
                                @if (!string.IsNullOrEmpty(initialProductIdStr))
                                {
                                    <button type="button"
                                            class="suggest-opt"
                                            data-alt-id="@initialProductIdStr"
                                            data-alt-name="@initialLabel"
                                            :class="{ 'sel': selectedProductId === '@initialProductIdStr' }"
                                            @@click="$dispatch('alt-selected', { lineId: '@line.LineId', id: $el.dataset.altId, label: $el.dataset.altName })">
                                        <svg class="icon" aria-hidden="true" x-show="selectedProductId === '@initialProductIdStr'"><use href="#i-check" /></svg>
                                        @initialLabel
                                        <span class="rk">best</span>
                                    </button>
                                }
                                @for (int i = 0; i < alts.Count; i++)
                                {
                                    var alt = alts[i];
                                    var altIdStr = alt.ProductId.ToString();
                                    var rankLabel = $"{(int)Math.Round(alt.Confidence * 100)}%";
                                    <button type="button"
                                            class="suggest-opt"
                                            data-alt-id="@altIdStr"
                                            data-alt-name="@alt.ProductName"
                                            :class="{ 'sel': selectedProductId === '@altIdStr' }"
                                            @@click="$dispatch('alt-selected', { lineId: '@line.LineId', id: $el.dataset.altId, label: $el.dataset.altName })">
                                        <svg class="icon" aria-hidden="true" x-show="selectedProductId === '@altIdStr'"><use href="#i-check" /></svg>
                                        @alt.ProductName
                                        <span class="rk">@rankLabel</span>
                                    </button>
                                }
                            </div>
                        </div>
                    }

                    @{
                        var listboxId = $"edit-product-{row.LineId}-listbox";
                        var searchUrl = Url.Page("./Review", "FilterProducts", new { Id = page.Id });
                    }
                    <div class="import-row__edit-grid">
                        @* Row 1 — Product (existing) or New name + Category (new) *@
                        <div class="form-grid__field form-grid__field--full" x-show="!createNew">
                            <label class="form-grid__field__label">Product</label>
                            <div class="form-grid__field__control">
                                @* query is seeded from data-initial-label by searchableSelect().init(); the hidden
                                   ProductId carries its value server-side (the value="" below), as in the TagHelper. *@
                                <div class="searchable-select" x-data="searchableSelect()"
                                     data-initial-label="@initialLabel"
                                     @@click.outside="open = false" @@keydown.escape="open = false"
                                     @@alt-selected.window="if($event.detail.lineId === '@line.LineId') select($event.detail.id, $event.detail.label)">
                                    <input type="hidden" name="Edit.ProductId" value="@(initialProduct?.Value ?? rowModel.PrefillProductId?.ToString() ?? "")" x-ref="hidden"
                                           @@change="selectedProductId = $event.target.value; skuId = ''" />
                                    <div class="searchable-select__control">
                                        <input type="text" class="field__input" role="combobox"
                                               aria-controls="@listboxId" aria-autocomplete="list" autocomplete="off"
                                               placeholder="Find a product…" x-model="query" :aria-expanded="open"
                                               @@focus="open = true"
                                               @@keydown.down.prevent="highlightNext()" @@keydown.up.prevent="highlightPrev()"
                                               @@keydown.enter.prevent="chooseHighlighted()"
                                               name="q" hx-get="@searchUrl" hx-trigger="keyup changed delay:250ms, focus"
                                               hx-target="#@listboxId" hx-swap="innerHTML" hx-params="q" />
                                    </div>
                                    <ul class="searchable-select__listbox" id="@listboxId" role="listbox" x-ref="listbox" x-show="open" x-cloak style="display: none">
                                        @foreach (var opt in page.ProductOptions)
                                        {
                                            <li role="option" data-value="@opt.Value" @@click="select($el.dataset.value, $el.textContent.trim())">@opt.Text</li>
                                        }
                                    </ul>
                                </div>
                            </div>
                        </div>

                        <div class="form-grid__field" style="grid-column: span 3" x-show="createNew">
                            <label class="form-grid__field__label">New product name</label>
                            <div class="form-grid__field__control">
                                <input class="field__input" name="Edit.NewProductName" value="@newNameValue"
                                       placeholder="@row.RawText" />
                            </div>
                        </div>

                        <div class="form-grid__field" x-show="createNew">
                            <label class="form-grid__field__label">Category</label>
                            <div class="form-grid__field__control">
                                <select class="field__input" name="Edit.NewProductCategoryId">
                                    <option value="">— Category —</option>
                                    @foreach (var c in page.CategoryOptions)
                                    {
                                        var sel = line.NewProductCategoryId?.ToString() == c.Value;
                                        <option value="@c.Value" selected="@sel">@c.Text</option>
                                    }
                                </select>
                            </div>
                        </div>

                        @* Pack-size (SKU) picker — only visible when the selected product has SKUs defined. *@
                        <div class="form-grid__field form-grid__field--full"
                             x-show="!createNew && (skus[selectedProductId]?.length ?? 0) > 0"
                             x-cloak>
                            <label class="form-grid__field__label">Pack size (optional)</label>
                            <div class="form-grid__field__control">
                                <select class="field__input" name="Edit.SkuId" x-model="skuId">
                                    <option value="">— Any size —</option>
                                    <template x-for="sku in (skus[selectedProductId] ?? [])" :key="sku.id">
                                        <option :value="sku.id" x-text="sku.label"></option>
                                    </template>
                                </select>
                            </div>
                        </div>

                        @* Mode toggle *@
                        <div class="review-row__mode-toggle">
                            <button type="button" class="btn btn--ghost btn--sm" x-show="!createNew"
                                    @@click="createNew = true">+ Add as new product</button>
                            <button type="button" class="btn btn--ghost btn--sm" x-show="createNew"
                                    @@click="createNew = false">← Use existing product</button>
                        </div>

                        @*
                            Row 2 — Qty stepper (span 2) · Location · Expires
                            ADR-013 step 6: qty stepper x-model="v" binds to v in the parent row x-data
                            (v is serialised as a JSON number or null; no nested x-data, no @qtyInitJs literal).

                            plantry-4ha: Location select uses x-model="loc" and name="Edit.LocationId" so it
                            posts the Alpine-managed value. Unit select similarly uses x-model="unit".
                            Both are overwritten by applyProductDefaults() on product re-selection.
                        *@
                        <div class="form-grid__field" style="grid-column: span 2">
                            <label class="form-grid__field__label">Quantity</label>
                            <div class="form-grid__field__control">
                                <div class="qty-stepper">
                                    <button type="button" class="qty-btn" @@click="v = Math.max(0.001, (parseFloat(v)||0) - 1)" aria-label="Decrease">
                                        <svg class="icon" aria-hidden="true"><use href="#i-minus" /></svg>
                                    </button>
                                    <input class="field__input" type="number" step="any" min="0" name="Edit.Quantity" x-model="v" />
                                    <button type="button" class="qty-btn" @@click="v = (parseFloat(v)||0) + 1" aria-label="Increase">
                                        <svg class="icon" aria-hidden="true"><use href="#i-plus" /></svg>
                                    </button>
                                </div>
                            </div>
                        </div>

                        <div class="form-grid__field">
                            <label class="form-grid__field__label">Location</label>
                            <div class="form-grid__field__control">
                                <select class="field__input" name="Edit.LocationId" x-model="loc">
                                    <option value="">— Location —</option>
                                    @foreach (var loc in page.LocationOptions)
                                    {
                                        <option value="@loc.Value">@loc.Text</option>
                                    }
                                </select>
                            </div>
                        </div>

                        @*
                            plantry-4ha — Expires uses the .expiry-field control (Date / Never): a .seg-ctrl toggle
                            (both options always labelled) with a native date input revealed to its LEFT, beside the
                            "Date" segment, only while "Date" is selected. expiryMode/d live in the reviewRow component;
                            selecting Date calls pick() (seeds today + opens the picker). In "never" mode the date input
                            is :disabled so it is excluded from the POST (→ null expiry = never expires), while d is
                            preserved so toggling back restores the date. The radio name is per-row so groups don't
                            collide; it is not an Edit.* field so it never binds server-side.
                        *@
                        <div class="form-grid__field">
                            <label class="form-grid__field__label">Expires</label>
                            <div class="form-grid__field__control">
                                <div class="expiry-field">
                                    <input type="date" class="field__input expiry-field__date" name="Edit.ExpiryDate" x-ref="dp"
                                           x-show="expiryMode === 'has'" x-cloak x-model="d" :disabled="expiryMode === 'never'" />
                                    <div class="seg-ctrl" role="group" aria-label="Expiry">
                                        <label class="seg-ctrl__item">
                                            <input type="radio" name="expiry-mode-@line.LineId" value="has" x-model="expiryMode" @@change="pick()" />
                                            <span>Date</span>
                                        </label>
                                        <label class="seg-ctrl__item">
                                            <input type="radio" name="expiry-mode-@line.LineId" value="never" x-model="expiryMode" />
                                            <span>Never</span>
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>

                        @* Row 3 — Unit + Price (price hidden when pre-filled from receipt) *@
                        @if (!string.IsNullOrEmpty(priceValue))
                        {
                            <input type="hidden" name="Edit.Price" value="@priceValue" />
                        }
                        @{ var unitColSpan = string.IsNullOrEmpty(priceValue) ? "span 2" : "span 4"; }
                        <div class="form-grid__field" style="grid-column: @unitColSpan">
                            <label class="form-grid__field__label">Unit</label>
                            <div class="form-grid__field__control">
                                <select class="field__input" name="Edit.UnitId" x-model="unit">
                                    <option value="">— Unit —</option>
                                    @foreach (var u in page.UnitOptions)
                                    {
                                        <option value="@u.Value">@u.Text</option>
                                    }
                                </select>
                            </div>
                        </div>

                        @if (string.IsNullOrEmpty(priceValue))
                        {
                            <div class="form-grid__field" style="grid-column: span 2">
                                <label class="form-grid__field__label">Price (optional)</label>
                                <div class="form-grid__field__control">
                                    <input class="field__input" type="number" step="any" min="0"
                                           name="Edit.Price" />
                                </div>
                            </div>
                        }
                    </div>

                    <div class="import-row__edit-foot">
                        @*
                            plantry-4ha: "Goes to" is now reactive — locationNames[loc] resolves the display
                            name from the Alpine-managed loc value, so it updates when the user switches products.
                        *@
                        <div class="import-row__edit-foot-summary">
                            <svg class="icon" aria-hidden="true"><use href="#i-location" /></svg>
                            Goes to <strong x-text="locationNames[loc] || '—'"></strong>
                            @if (line.IsNewProduct)
                            {
                                <span class="import-row__new">· new product</span>
                            }
                        </div>
                        <span class="import-row__edit-spacer"></span>
                        <button type="button" class="btn btn--ghost btn--sm import-row__edit-danger"
                                hx-post="@row.DismissUrl" hx-target="@rowSelfTarget" hx-swap="outerHTML">
                            Not pantry stock — remove
                        </button>
                        <button type="submit" class="btn btn--primary btn--sm">
                            <svg class="icon" aria-hidden="true"><use href="#i-check" /></svg> Confirm item
                        </button>
                    </div>
                </form>
            </div>
        }
    </div>
