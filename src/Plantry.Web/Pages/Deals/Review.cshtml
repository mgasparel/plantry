@page
@using Plantry.Web.Pages.Shared
@model Plantry.Web.Pages.Deals.ReviewModel
@{
    ViewData["Title"] = "Review deals";
    var correctUrl = Url.Page("./Review", "Correct")!;
}

<div class="cfg-wrap" data-screen-label="Review deals">
    <div class="cfg-head">
        <div class="eyebrow">Flyer deals</div>
        <h1>Review deals</h1>
        <p>Confirm the deals Plantry matched to your catalog, correct a wrong match by searching for the
           right product (or creating a new one), or reject a deal you don&rsquo;t want to track. Each
           choice is saved as you go.</p>
    </div>

    @* Host wrapper — owns the correction sheet state; persists across every htmx queue swap so the
       Correct affordance keeps working as the queue re-renders. See dealsReview() below. *@
    <div x-data="dealsReview('@correctUrl')" x-on:deal-correct="openCorrect($event.detail.dealId)">

        @* The review queue — re-rendered from server truth by every verb (Confirm/Correct/Reject). *@
        <div id="review-region">
            @await Html.PartialAsync("_ReviewQueue", Model)
        </div>

        @* Shared catalog search + inline-create sheet (P4-6). Composed, not rebuilt: TrackStock=false and
           no group field — a deal correction only resolves a product identity. Inline-create mints a
           catalog product (Unit from the Defaults collapsible, Category optional) which the Correct POST
           then supersedes the deal against. *@
        <partial name="Shared/_ProductSearchCreateSheet"
                 model='new ProductSearchCreateSheetViewModel
                 {
                     SearchUrl             = Model.SearchUrl,
                     UnitOptions           = Model.UnitOptions,
                     CategoryOptions       = Model.CategoryOptions,
                     TrackStock            = false,
                     Noun                  = "product",
                     ShowGroupHeading      = false,
                     CreateLabel           = "as a new product",
                     StapleNamePlaceholder = "Product name (e.g. 2% Milk)",
                     CreateViewTitle       = "New product",
                     GroupOptions          = null,
                     Title                 = "Match to a product",
                     ShowDealContext       = true,
                     RequireSelection      = true,
                 }' />
    </div>
</div>

@Html.AntiForgeryToken()

@* Alpine component for the correction sheet host. Defined in the body (NOT @@section Scripts) so it is
   parsed before the deferred alpine.min.js starts and evaluates x-data="dealsReview(...)" — the same
   ordering rule Take Stock's takeStockSheetBridge() follows. *@
<script>
function dealsReview(correctUrl) {
    return {
        // ── Shared _ProductSearchCreateSheet Alpine contract ──────────────────
        sheetOpen: false,
        sheetView: 'search',   // 'search' | 'create'
        editingIdx: null,      // part of the sheet contract (Add vs Edit title); always Add here
        draft: {},
        // ── Deals-specific ────────────────────────────────────────────────────
        activeDealId: null,
        correctUrl: correctUrl,
        // The flyer line being matched — { rawName, brand, price, store } — drives the sheet's
        // deal-context block (ShowDealContext). Null when the sheet is closed / opened without a deal.
        dealContext: null,

        // Open the correction sheet for one deal (from a card's Correct button, via the bubbling
        // deal-correct event so it survives htmx queue swaps). Reads the deal's verbatim flyer context
        // from the swapped-in queue DOM (the same DOM-truth pattern submitCorrect uses for the active
        // flyer), pre-fills the search with a cleaned query, and auto-runs the catalog search.
        openCorrect(dealId) {
            this.activeDealId = dealId;
            this.sheetView = 'search';
            this.draft = { productId: '', productName: '', newStapleName: null,
                           newStapleUnit: '', newStapleCategoryId: '' };
            this.dealContext = this.readDealContext(dealId);
            var query = this.cleanQuery(this.dealContext);
            this.sheetOpen = true;
            this.$nextTick(() => {
                // Seed the shared search box (sets the searchable-select's Alpine `query`), then focus its
                // input so htmx's `focus` trigger auto-runs the catalog search with the pre-filled query.
                window.dispatchEvent(new CustomEvent('sheet-product-set', { detail: query }));
                this.$nextTick(() => {
                    // The shared searchable-select wrapper carries no id; its input is the combobox that
                    // controls the deterministic listbox id (Id="prod-search-sheet" → -listbox).
                    var input = document.querySelector('input[aria-controls="prod-search-sheet-listbox"]');
                    if (!input) return;
                    // Write the value onto the element BEFORE focusing: htmx's `focus` trigger reads the
                    // input's current value synchronously, and Alpine's reactive x-model write of `query`
                    // may not have flushed yet — without this the first auto-search would fire with an
                    // empty q. The value equals Alpine's `query`, so the two stay in sync.
                    if (query) input.value = query;
                    input.focus();
                    input.select();
                });
            });
        },

        // Read one deal's verbatim flyer context from the rendered queue (raw name from the name cell's
        // title attribute — the untouched ACL-quarantined string; brand + price from the card; store from
        // the active flyer rail, big-chip or compact). Returns null if the card is no longer in the DOM.
        readDealContext(dealId) {
            var li = document.querySelector('#review-region [data-deal-id="' + dealId + '"]');
            if (!li) return null;
            var nameEl = li.querySelector('.deal-review-row__name');
            var brandEl = li.querySelector('.deal-review-row__brand');
            var priceEl = li.querySelector('.deal-row__amount');
            var storeEl = document.querySelector(
                '#review-region .flyer-chip.is-active .store, #review-region .active-flyer-line .store');
            return {
                rawName: nameEl ? (nameEl.getAttribute('title') || nameEl.textContent.trim()) : '',
                brand: brandEl ? brandEl.textContent.trim() : '',
                price: priceEl ? priceEl.textContent.trim() : '',
                store: storeEl ? storeEl.textContent.trim() : '',
            };
        },

        // Distil the shouting flyer line into a short catalog query (ported from the adopted focus.html
        // prototype): drop the deal's own brand tokens, size/pack measures, digits/punctuation, and common
        // filler words, then keep the first ~4 remaining words. "BREYERS CREAMERY STYLE ICE CREAM,
        // 1.41-14.11 L" (brand BREYERS) → "ice cream".
        cleanQuery(ctx) {
            if (!ctx || !ctx.rawName) return '';
            var name = ctx.rawName.toLowerCase();
            (ctx.brand || '').toLowerCase().split(/[^a-z]+/).forEach(function (w) {
                if (w.length > 2) name = name.split(w).join(' ');
            });
            return name
                .replace(/\b\d[\d.\/-]*\s*(g|kg|ml|l|ct|pk|lb|oz|pc|rolls?|boxes)\b/g, ' ')
                .replace(/[\d"']+/g, ' ')
                .replace(/[^a-z\s]/g, ' ')
                .replace(/\b(or|and|the|with|of|assorted|club|pack|frozen|fresh|variety|style|creamery|original)\b/g, ' ')
                .trim().split(/\s+/).filter(Boolean).slice(0, 4).join(' ');
        },

        closeSheet() {
            this.sheetView = 'search';
            this.sheetOpen = false;
            this.dealContext = null;
        },

        // Search-result pick — dispatched by the sheet's listbox (pick-product bubbles to the sheet).
        selectProduct(draft, detail) {
            draft.productId = detail.value;
            draft.productName = detail.name;
        },

        // Add (search view) or Create (create view) — resolve the deal's product and supersede via Correct.
        saveSheet() {
            if (this.draft.productId) {
                this.submitCorrect({ dealId: this.activeDealId, productId: this.draft.productId });
                return;
            }
            const name = (this.draft.newStapleName ?? '').trim();
            const unitId = this.draft.newStapleUnit || '';
            if (!name || !unitId) return; // stay open — a new product needs a name and a unit
            this.submitCorrect({
                dealId: this.activeDealId,
                newProductName: name,
                newProductUnitId: unitId,
                newProductCategoryId: this.draft.newStapleCategoryId || '',
            });
        },

        // One htmx POST that carries the resolved product (existing or new) and re-renders the queue from
        // server truth. The antiforgery token is attached by htmx-antiforgery.js on configRequest.
        // Threads the active flyer (read from the swapped-in region) so the re-render stays on this flyer.
        submitCorrect(values) {
            const region = document.querySelector('#review-region [data-active-flyer]');
            if (region && region.dataset.activeFlyer) values.flyer = region.dataset.activeFlyer;
            htmx.ajax('POST', this.correctUrl, { target: '#review-region', swap: 'innerHTML', values: values });
            this.closeSheet();
        },
    };
}
</script>
