@using Plantry.Deals.Domain
@using Plantry.Intake.Domain
@model Plantry.Web.Pages.Deals.ReviewModel

@*
    The review-queue region (P5-8 / DJ4). Re-rendered from server truth by every verb (Confirm/Correct/Reject),
    so the queue shrinks as it is worked and a re-drive / refresh never double-acts. When empty, the
    "all caught up" state clears the queue; the Deals-page Review entry (and, with P5-11, the Home banner)
    reflect the shrunk count on their next load.

    The queue is grouped into three confidence tiers, highest first (q9zr.2): the one-click confirms lead,
    the judgement calls follow, and the long no-match tail sits last — instead of one flat alphabetical wall.
    ReviewDeals.ListPendingAsync already sorts ValidTo → StoreName → Confidence desc → RawName, so each tier's
    rows stay in that order within its section.
*@
@if (Model.Deals.Count == 0)
{
    <div class="card">
        <div class="card__body">
            <div class="empty-state">
                <div class="empty-state__icon">
                    <svg class="icon" aria-hidden="true"><use href="#i-check" /></svg>
                </div>
                <div class="empty-state__title">All caught up</div>
                <div class="empty-state__body">
                    No deals waiting on you. New flyer deals that Plantry can&rsquo;t auto-match will show up
                    here after the next pull.
                </div>
                <a class="btn btn--secondary" href="/Deals">Back to deals</a>
            </div>
        </div>
    </div>
}
else
{
    @* Fixed tier order: High → Low → None. Each carries the shared confidence badge treatment plus a count. *@
    var tiers = new[]
    {
        (Confidence: MatchConfidence.High, Badge: SuggestedConfidence.High, Title: "Looks right"),
        (Confidence: MatchConfidence.Low, Badge: SuggestedConfidence.Low, Title: "Needs a look"),
        (Confidence: MatchConfidence.None, Badge: SuggestedConfidence.None, Title: "Not in your catalog"),
    };

    <div class="card">
        <div class="card__head">
            <h3 class="card__head-title">Deals to review</h3>
            <span class="ch-sub">&middot; @Model.Deals.Count</span>
        </div>
        <div class="card__body">
            @foreach (var tier in tiers)
            {
                var tierDeals = Model.Deals.Where(d => d.Confidence == tier.Confidence).ToList();
                if (tierDeals.Count == 0)
                {
                    continue;
                }

                <section class="deal-review-section">
                    <div class="deal-review-section__head">
                        <partial name="Shared/_ConfidenceBadge" model="tier.Badge" />
                        <span class="deal-review-section__title">@tier.Title</span>
                        <span class="ch-sub">&middot; @tierDeals.Count</span>
                    </div>
                    <ul class="catalog-list deal-review-list" role="list">
                        @foreach (var deal in tierDeals)
                        {
                            <partial name="_DealReviewCard" model="deal" />
                        }
                    </ul>
                </section>
            }
        </div>
    </div>
}
