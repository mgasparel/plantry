@model Plantry.Web.Pages.Pantry.Products.DetailModel

<div class="sheet" x-data="{ close() { document.getElementById('sheet-host').innerHTML = '' } }" role="dialog" aria-modal="true" aria-label="Set low stock threshold">
    <div class="sheet__overlay" x-on:click="close()"></div>
    <div class="sheet__panel">
        <header class="sheet__header">
            <h2 class="sheet__title">Set low stock alert</h2>
            <button type="button" class="sheet__close" aria-label="Close"
                    x-on:click="close()">&times;</button>
        </header>

        <form class="form-stack" hx-post="@Url.Page("./Detail", "SetThreshold", new { id = Model.ProductId })"
              hx-target="#sheet-host" hx-swap="innerHTML">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert--danger" role="alert"></div>

            <p class="field__hint">When total on-hand stock falls to or below this quantity, the item is marked as running low. Leave blank to disable the alert.</p>

            <div class="field field--inline">
                <label asp-for="ThresholdInput.Threshold" class="field__label">Alert when below</label>
                <input asp-for="ThresholdInput.Threshold" class="field__input" type="number" step="any" min="0" placeholder="e.g. 2" />
                <span asp-validation-for="ThresholdInput.Threshold" class="field__error"></span>
            </div>

            <div class="sheet__actions">
                <button type="submit" class="btn btn--primary">Save</button>
                <button type="button" class="btn btn--ghost"
                        x-on:click="close()">Cancel</button>
            </div>
        </form>
    </div>
</div>
