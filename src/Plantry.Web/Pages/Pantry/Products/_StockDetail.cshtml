@model Plantry.Web.Pages.Pantry.Products.StockDetailPartialModel
@using Plantry.Inventory.Application
@using Plantry.Web.Pages.Shared
@{
    var id = Model.Detail.ProductId;
    var hasStock = Model.Detail.Lots.Count > 0;
    string DeltaText(StockJournalRow r) => $"{(r.Delta > 0 ? "+" : "")}{r.Delta.ToString("0.###")} {r.UnitCode}";

    var lotsGrid = new DataGridViewModel(
        Id: "lots-grid",
        Columns:
        [
            new("Quantity"),
            new("Expiry"),
            new("Location"),
            new("Purchased"),
            new("", Align: GridAlign.End),
        ],
        Rows: [.. Model.Detail.Lots.Select(lot => new GridRow(
        [
            GridCell.Text($"{lot.Quantity.ToString("0.###")} {lot.UnitCode}"),
            lot.ExpiryDate is { } exp ? GridCell.Text(exp.ToString("d MMM yyyy")) : GridCell.Muted("—"),
            lot.LocationName is { } loc ? GridCell.Text(loc) : GridCell.Muted("—"),
            lot.PurchasedAt is { } pur ? GridCell.Text(pur.ToString("d MMM yyyy")) : GridCell.Muted("—"),
            GridCell.Actions(
                GridAction.HxGet("Use",
                    Url.Page("./Detail", "ConsumeSheet", new { id, entryId = lot.EntryId.Value })!,
                    "#sheet-host"),
                lot.IsOpen
                    // Tapping the badge un-marks the lot (plantry-1le6 UI spec §3 — corrections
                    // happen); both handlers redirect via HX-Redirect, so the target/swap here never
                    // actually gets used to swap a fragment.
                    ? GridAction.PostBadge("Open",
                        Url.Page("./Detail", "UnmarkOpen", new { id, entryId = lot.EntryId.Value })!)
                    // Rendered only while the lot is sealed (plantry-1le6 UI spec §1) — a one-tap
                    // action with no inputs, so it needs no sheet.
                    : GridAction.Post("Mark opened",
                        Url.Page("./Detail", "MarkOpen", new { id, entryId = lot.EntryId.Value })!),
                GridAction.PostTo("Discard",
                    Url.Page("./Detail", "Discard", new { id, entryId = lot.EntryId.Value })!,
                    "#stock-detail", "outerHTML")
            ),
        ]))],
        EmptyMessage: "No stock on hand.");

    var historyGrid = new DataGridViewModel(
        Id: "history-grid",
        Columns:
        [
            new("When"),
            new("Change"),
            new("Reason"),
            new("Source"),
        ],
        Rows: [.. Model.Detail.History.Select(row => new GridRow(
        [
            GridCell.Text(row.OccurredAt.ToLocalTime().ToString("d MMM yyyy HH:mm")),
            GridCell.Text(DeltaText(row)),
            GridCell.Text(row.Reason.ToString()),
            DetailModel.SourceCell(row, Model.Chips, chip => DetailModel.HrefFor(chip, Url)),
        ]))],
        EmptyMessage: "No movements recorded yet.");
}
<div id="stock-detail" class="stock-detail" @(Model.Oob ? "hx-swap-oob=true" : "")>
    @if (Model.Notice is { } notice)
    {
        <div class="alert alert--info" role="status">@notice</div>
    }

    @if (hasStock)
    {
        <section class="catalog-section">
            <h2 class="catalog-section__heading">Lots</h2>
            <partial name="Shared/_DataGrid" model="lotsGrid" />
        </section>
    }
    else
    {
        @* Zero-stock landing (plantry-sjfn): no active lots — either never stocked (the Pantry
           "Everything" scope links catalog-only products straight here) or consumed to zero.
           Add stock is the primary CTA here too, mirroring the header's toggle. *@
        <div class="card">
            <div class="empty-state">
                <p style="margin:0;">Nothing on hand — your household tracks this product but hasn't stocked it yet.</p>
                <button type="button" class="btn btn--primary"
                        hx-get="@Url.Page("./Detail", "AddStockSheet", new { id })"
                        hx-target="#sheet-host" hx-swap="innerHTML">
                    Add stock
                </button>
            </div>
        </div>
    }

    <section class="catalog-section">
        <h2 class="catalog-section__heading">History</h2>
        <partial name="Shared/_DataGrid" model="historyGrid" />
    </section>
</div>
@if (Model.Oob)
{
    <p id="product-total" class="page-header__subtitle" hx-swap-oob="true">
        @(hasStock ? $"{Model.Detail.TotalQuantity.ToString("0.###")} {Model.Detail.DisplayUnitCode} in stock" : "Not in stock")
    </p>
    <partial name="_PrimaryStockAction" model="new Plantry.Web.Pages.Pantry.Products.PrimaryStockActionPartialModel(id, hasStock, true)" />
}
