@page "{id:guid}"
@model Plantry.Web.Pages.Pantry.Products.DetailModel
@using Plantry.Web.Pages.Shared
@{
    ViewData["Title"] = Model.Detail?.Name ?? "Product";

    // Zero-stock landing (plantry-sjfn): a product with no active lots — either never stocked at all
    // (the Pantry "Everything" scope links catalog-only products straight here) or consumed down to
    // zero — gets "Not in stock" instead of a quantity, and the header's primary action swaps from
    // Consume to Add stock (_PrimaryStockAction). Keep id="product-total" so _StockDetail's OOB swap
    // of this same subtitle text stays live.
    var hasStock = Model.Detail!.Lots.Count > 0;
    var stockTotal = hasStock
        ? $"{Model.Detail.TotalQuantity.ToString("0.###")} {Model.Detail.DisplayUnitCode} in stock"
        : "Not in stock";

    // "Recipes" section (plantry-o0r8) — which household recipes directly reference this product, either
    // as a consumer ("Used in") or as the recipe's declared cook yield ("Made by"). Both roles are folded
    // into one badge cell when a recipe is somehow both (rare — same product as ingredient and yield).
    static string RoleLabel(Plantry.Recipes.Application.RecipeProductUsage u)
    {
        var roles = new List<string>();
        if (u.IsConsumer) roles.Add("Used in");
        if (u.IsProducer) roles.Add("Made by");
        return string.Join(" · ", roles);
    }
    static BadgeTone RoleTone(Plantry.Recipes.Application.RecipeProductUsage u) =>
        u.IsProducer && !u.IsConsumer ? BadgeTone.Success : BadgeTone.Info;

    var recipesGrid = new DataGridViewModel(
        Id: "product-recipes-grid",
        Columns: [new("Recipe"), new("Role")],
        Rows: [.. Model.RecipeUsages.Select(u => new GridRow(
        [
            GridCell.Link(u.Name, Url.Page("/Recipes/Details", new { id = u.RecipeId })!),
            GridCell.Badge(RoleLabel(u), RoleTone(u)),
        ]))],
        EmptyMessage: "Not used in any recipes yet.");
}

@* Shared .page-header primitive (plantry-7yf1): category -> eyebrow, name -> title,
   stock total -> subtitle (id="product-total", kept live by the OOB swap).
   Cross-link to the catalog view (plantry-kkeg): always live — a pantry product always has a
   catalog record. *@
<page-header eyebrow="@Model.Detail.CategoryName" title="@Model.Detail.Name"
             subtitle="@stockTotal" subtitle-id="product-total"
             cross-link-text="View in catalog →"
             cross-link-href="@Url.Page("/Catalog/Products/Detail", new { id = Model.ProductId })">
    <button type="button" class="btn btn--ghost"
            hx-get="@Url.Page("./Detail", "ThresholdSheet", new { id = Model.ProductId })"
            hx-target="#sheet-host" hx-swap="innerHTML">
        Set alert
    </button>
    <button type="button" class="btn btn--ghost"
            hx-get="@Url.Page("./Detail", "SetPriceSheet", new { id = Model.ProductId })"
            hx-target="#sheet-host" hx-swap="innerHTML">
        Set price
    </button>
    <partial name="_PrimaryStockAction" model="new Plantry.Web.Pages.Pantry.Products.PrimaryStockActionPartialModel(Model.ProductId, hasStock, false)" />
</page-header>

@* Current effective price (plantry-3fqm) — the same read model CostingService uses, so what's shown here
   is exactly what recipe costing will pick up. OOB-refreshed by _PriceDisplay after a "Set price" submit. *@
<partial name="_PriceDisplay" model="new Plantry.Web.Pages.Pantry.Products.PriceDisplayPartialModel(Model.PriceDisplayText, false)" />

<partial name="_StockDetail" model="new Plantry.Web.Pages.Pantry.Products.StockDetailPartialModel(Model.Detail, false, null, Model.Chips)" />

@* Product→recipes cross-context read (plantry-o0r8): every household recipe that directly references
   this product, either as an ingredient ("Used in") or as its declared cook yield ("Made by"). *@
<section class="catalog-section">
    <h2 class="catalog-section__heading">Recipes</h2>
    <partial name="Shared/_DataGrid" model="recipesGrid" />
</section>

<div id="sheet-host"></div>
