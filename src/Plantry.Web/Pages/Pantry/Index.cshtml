@page
@model Plantry.Web.Pages.Pantry.IndexModel
@{
    ViewData["Title"] = "Pantry";
}

<div class="pantry-toolbar">
    <input type="search" name="q" placeholder="Search your pantry…" class="field__input pantry-toolbar__search pantry-filter"
           hx-get="@Url.Page("./Index", "Filter")"
           hx-trigger="input changed delay:250ms, search"
           hx-target="#pantry-list" hx-swap="outerHTML"
           hx-include=".pantry-filter" />
    <button type="button" class="btn btn--primary pantry-toolbar__add"
            hx-get="@Url.Page("./Index", "AddSheet")"
            hx-target="#sheet-host" hx-swap="innerHTML">
        Add stock
    </button>

    <div class="pantry-toolbar__filters">
        <div class="seg-ctrl" role="group" aria-label="Filter by expiry">
            <label class="seg-ctrl__item">
                <input type="radio" name="expiry" value="" class="pantry-filter" checked
                       hx-get="@Url.Page("./Index", "Filter")"
                       hx-trigger="change" hx-target="#pantry-list" hx-swap="outerHTML"
                       hx-include=".pantry-filter" />
                <span>All</span>
            </label>
            <label class="seg-ctrl__item">
                <input type="radio" name="expiry" value="soon" class="pantry-filter"
                       hx-get="@Url.Page("./Index", "Filter")"
                       hx-trigger="change" hx-target="#pantry-list" hx-swap="outerHTML"
                       hx-include=".pantry-filter" />
                <span>Expiring soon</span>
            </label>
            <label class="seg-ctrl__item">
                <input type="radio" name="expiry" value="expired" class="pantry-filter"
                       hx-get="@Url.Page("./Index", "Filter")"
                       hx-trigger="change" hx-target="#pantry-list" hx-swap="outerHTML"
                       hx-include=".pantry-filter" />
                <span>Expired</span>
            </label>
        </div>

        <select name="category" class="field__input pantry-toolbar__filter-select pantry-filter"
                hx-get="@Url.Page("./Index", "Filter")"
                hx-trigger="change" hx-target="#pantry-list" hx-swap="outerHTML"
                hx-include=".pantry-filter">
            <option value="">All categories</option>
            @foreach (var opt in Model.FilterCategoryOptions)
            {
                <option value="@opt.Value">@opt.Text</option>
            }
        </select>

        <select name="location" class="field__input pantry-toolbar__filter-select pantry-filter"
                hx-get="@Url.Page("./Index", "Filter")"
                hx-trigger="change" hx-target="#pantry-list" hx-swap="outerHTML"
                hx-include=".pantry-filter">
            <option value="">All locations</option>
            @foreach (var opt in Model.FilterLocationOptions)
            {
                <option value="@opt.Value">@opt.Text</option>
            }
        </select>

        <label class="pantry-toolbar__toggle">
            <input type="checkbox" name="hideVariants" value="true" class="pantry-filter"
                   hx-get="@Url.Page("./Index", "Filter")"
                   hx-trigger="change" hx-target="#pantry-list" hx-swap="outerHTML"
                   hx-include=".pantry-filter" />
            Hide variants
        </label>
    </div>
</div>

<partial name="_PantryList" model="new Plantry.Web.Pages.Pantry.PantryListPartialModel(Model.PantryGrid, false)" />

<div id="sheet-host"></div>
