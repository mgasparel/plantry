@page "/pantry/take-stock/{locationId:guid}"
@model Plantry.Web.Pages.Pantry.TakeStock.WalkModel
@using Plantry.Web.Pages.Shared
@{
    ViewData["Title"] = Model.LocationName ?? "Take Stock";
}

@* Alpine working-set client (C7, J2/J4) + inline-add sheet state (P4-7, J5).
   rows: { [productId]: { recorded, counted, unitId, reason, dirty, failed, failMsg } }
   expandedLots: { [productId]: boolean } — tracks which rows have the lot panel open.
   sheetOpen / editingIdx / draft — shared-sheet Alpine contract (see _ProductSearchCreateSheet.cshtml).
   The beforeunload guard fires when any row is dirty — unsaved counts are discarded on navigation (C7).
   Uses x-init to wire the guard because @@beforeunload would conflict with Razor @ syntax.
   JSON data is passed via a script-block global (not inline in the double-quoted x-data attribute)
   to avoid HTML-entity escaping issues with double-quoted JSON keys (bd memory: Razor+Alpine gotcha). *@
<script>
(function () {
    'use strict';
    window['__takeStockRows_@(Model.LocationId.ToString("N"))'] = @Html.Raw(Model.AlpineRowsJson);
    window['__addItemUrl_@(Model.LocationId.ToString("N"))'] = '@Url.Page("./Walk", "AddItem", new { locationId = Model.LocationId })';
})();
</script>
<div x-data="takeStockWalk(window['__takeStockRows_@(Model.LocationId.ToString("N"))'], window['__addItemUrl_@(Model.LocationId.ToString("N"))'])"
     x-init="init()"
     x-on:collapse-lots.window="collapseLotsPanel($event.detail.productId)"
     x-on:lots-saved.window="onLotsSaved($event.detail.productId)">

    @* ── Inline-add sheet (P4-7, J5) — shared _ProductSearchCreateSheet with count+location slot *@
    @* TrackStock=false because the sheet's qty/unit fields are not shown; count lives in the slot. *@
    <partial name="Shared/_ProductSearchCreateSheet"
             model='new ProductSearchCreateSheetViewModel
             {
                 SearchUrl        = Url.Page("./Walk", "SearchProducts", new { locationId = Model.LocationId })!,
                 UnitOptions      = Model.UnitOptions,
                 TrackStock       = false,
                 ExtraFieldsPartial = "TakeStock/_CountLocationFields",
             }' />

    @Html.AntiForgeryToken()

    <div class="page-header">
        <a href="/pantry/take-stock" class="btn btn--ghost btn--sm">&larr; Locations</a>
        <h1 class="page-header__title">@(Model.LocationName ?? "Take Stock")</h1>
        @* + Add item button (P4-7, J5) — opens the inline-add sheet *@
        <button type="button" class="btn btn--secondary btn--sm take-stock-add-item"
                x-on:click="openAdd()"
                aria-label="Add a new item to this location">
            + Add item
        </button>
    </div>

    @if (Model.Rows.Count == 0)
    {
        <p class="empty-state">No items in this location.</p>
    }
    else
    {
        <ul class="take-stock-rows" role="list">
            @foreach (var row in Model.Rows)
            {
                var pid = row.ProductId.ToString();
                var recorded = row.RecordedQuantity.ToString("0.###", System.Globalization.CultureInfo.InvariantCulture);
                <li class="take-stock-row"
                    :class="{ 'take-stock-row--dirty': rows['@pid']?.dirty, 'take-stock-row--failed': rows['@pid']?.failed }">

                    <div class="take-stock-row__info">
                        <span class="take-stock-row__name">@row.ProductName</span>
                        <span class="take-stock-row__recorded">
                            @row.RecordedQuantity.ToString("0.###") @row.DisplayUnitCode recorded
                        </span>
                        <span class="take-stock-row__fail-msg"
                              x-show="rows['@pid']?.failed"
                              x-text="rows['@pid']?.failMsg ?? ''"
                              role="alert"></span>
                    </div>

                    <div class="take-stock-row__controls">
                        @* Count stepper with the canonical <stepper> tag helper *@
                        <stepper
                            name=""
                            value-bind="rows['@pid']?.counted ?? @recorded"
                            input-handler="setCount('@pid', $event.target.value)"
                            decrease-click="setCount('@pid', Math.max(0, parseFloat(rows['@pid']?.counted ?? @recorded) - 1))"
                            increase-click="setCount('@pid', parseFloat(rows['@pid']?.counted ?? @recorded) + 1)"
                            decrease-label="Decrease count for @row.ProductName"
                            increase-label="Increase count for @row.ProductName"
                            input-label="Count for @row.ProductName" />

                        <span class="take-stock-row__unit">@row.DisplayUnitCode</span>

                        @* One-tap "none left" (J2 step 4) *@
                        <button type="button"
                                class="btn btn--ghost btn--sm take-stock-row__none-left"
                                x-on:click="setNoneLeft('@pid')"
                                aria-label="None left — set @row.ProductName to zero">
                            None left
                        </button>
                    </div>

                    @* Reason selector (C9) — visible only when the row goes downward-dirty *@
                    <div class="take-stock-row__reason"
                         x-show="isDown('@pid')" x-cloak>
                        <span class="take-stock-row__reason-label">Reason:</span>
                        <div class="seg-ctrl" role="group" aria-label="Reason for @row.ProductName count change">
                            <label class="seg-ctrl__item">
                                <input type="radio" name="reason_@(pid.Replace("-",""))" value="Correction"
                                       :checked="rows['@pid']?.reason === 'Correction'"
                                       x-on:change="setReason('@pid', 'Correction')" />
                                <span>Correction</span>
                            </label>
                            <label class="seg-ctrl__item">
                                <input type="radio" name="reason_@(pid.Replace("-",""))" value="Consumed"
                                       :checked="rows['@pid']?.reason === 'Consumed'"
                                       x-on:change="setReason('@pid', 'Consumed')" />
                                <span>Used it</span>
                            </label>
                            <label class="seg-ctrl__item">
                                <input type="radio" name="reason_@(pid.Replace("-",""))" value="Discarded"
                                       :checked="rows['@pid']?.reason === 'Discarded'"
                                       x-on:change="setReason('@pid', 'Discarded')" />
                                <span>Spoiled</span>
                            </label>
                        </div>
                    </div>

                    @* Lot escape-hatch expand button (P4-5, J3) — only shown for rows with active stock *@
                    @if (row.HasActiveStock)
                    {
                        <button type="button"
                                class="btn btn--ghost btn--sm take-stock-row__lots-btn"
                                x-show="!expandedLots['@pid']"
                                x-on:click="expandLots('@pid', '@Url.Page("./Walk", "Lots", new { locationId = Model.LocationId, productId = row.ProductId })')"
                                aria-label="Expand lots for @row.ProductName"
                                aria-controls="lot-panel-@pid">
                            Adjust lots
                        </button>
                    }

                    @* Lot panel host — loaded via htmx GET /Lots on expand (P4-5, J3) *@
                    <div id="lot-panel-@pid"
                         class="take-stock-row__lot-panel"
                         data-product-id="@pid"
                         x-show="expandedLots['@pid']" x-cloak>
                    </div>
                </li>
            }
        </ul>
    }

    @* ── Dynamically-added rows (P4-7, J5) — rows inserted by the inline-add sheet
         These rows exist only in Alpine state (not in the Razor-rendered HTML).
         Rendered via x-for over the keys with isNewRow === true.
         Use a plain number input (not the <stepper> tag helper) since tag helpers cannot be
         rendered inside Alpine x-for templates at this page level. *@
    <template x-if="newRowKeys().length > 0">
        <ul class="take-stock-rows take-stock-rows--added" role="list" aria-label="Added items">
            <template x-for="pid in newRowKeys()" :key="pid">
                <li class="take-stock-row"
                    :class="{ 'take-stock-row--dirty': rows[pid]?.dirty, 'take-stock-row--failed': rows[pid]?.failed }">

                    <div class="take-stock-row__info">
                        <span class="take-stock-row__name" x-text="rows[pid]?.productName ?? '(new item)'"></span>
                        <span class="take-stock-row__recorded">
                            <span x-text="rows[pid]?.recorded ?? 0"></span>&nbsp;<span x-text="rows[pid]?.unitCode ?? ''"></span> recorded
                        </span>
                        <span class="take-stock-row__fail-msg"
                              x-show="rows[pid]?.failed"
                              x-text="rows[pid]?.failMsg ?? ''"
                              role="alert"></span>
                    </div>

                    <div class="take-stock-row__controls">
                        <input type="number" class="field__input stepper__input" step="any" min="0"
                               :value="rows[pid]?.counted ?? 0"
                               :aria-label="'Count for ' + (rows[pid]?.productName ?? 'new item')"
                               x-on:input="setCount(pid, $event.target.value)" />
                        <span class="take-stock-row__unit" x-text="rows[pid]?.unitCode ?? ''"></span>
                        <button type="button"
                                class="btn btn--ghost btn--sm take-stock-row__none-left"
                                x-on:click="setNoneLeft(pid)"
                                aria-label="None left — set to zero">
                            None left
                        </button>
                    </div>
                </li>
            </template>
        </ul>
    </template>

    @* Sticky save bar (J4) — visible when any row is dirty *@
    <div class="take-stock-savebar" x-show="isDirty()" x-cloak>
        <span class="take-stock-savebar__count"
              x-text="dirtyCount() + (dirtyCount() === 1 ? ' unsaved item' : ' unsaved items')"></span>
        <button type="button"
                class="btn btn--primary"
                :disabled="saving"
                x-text="saving ? 'Saving…' : 'Save'"
                x-on:click="save('@Url.Page("./Walk", "Save", new { locationId = Model.LocationId })')">
        </button>
    </div>

    @* Toast notification (J4 confirmation) *@
    <div class="take-stock-toast"
         role="status"
         aria-live="polite"
         x-show="toast !== null" x-cloak
         x-text="toast ?? ''"
         x-on:click="toast = null"></div>
</div>

<script>
function takeStockWalk(initialRows, addItemUrl) {
    return {
        rows: initialRows,
        _addItemUrl: addItemUrl,
        expandedLots: {},
        saving: false,
        toast: null,
        _guardHandler: null,

        // ── Inline-add sheet state (P4-7, J5) — shared sheet Alpine contract ────
        // The _ProductSearchCreateSheet partial expects these on the host x-data context.
        sheetOpen: false,
        editingIdx: null,
        draft: {},

        init() {
            // Leave-page guard (C7): fires when the user tries to navigate away with unsaved counts.
            this._guardHandler = (e) => {
                if (this.isDirty() && !this.saving) {
                    e.preventDefault();
                    e.returnValue = '';
                }
            };
            window.addEventListener('beforeunload', this._guardHandler);
        },

        destroy() {
            if (this._guardHandler) {
                window.removeEventListener('beforeunload', this._guardHandler);
            }
        },

        // ── Inline-add sheet lifecycle (P4-7, J5) ────────────────────────────────

        openAdd() {
            this.editingIdx = null;
            this.draft = { productId: '', productName: '', isUntracked: false,
                           newStapleName: null, newStapleUnit: '', groupHeading: '',
                           addCount: 1, addUnitId: '' };
            this.sheetOpen = true;
            // Push empty search so the searchable-select resets.
            this.$nextTick(() => window.dispatchEvent(new CustomEvent('sheet-product-set', { detail: '' })));
        },

        closeSheet() {
            this.sheetOpen = false;
        },

        selectProduct(row, detail) {
            row.productId = detail.value;
            row.productName = detail.name;
            row.isUntracked = false; // Take Stock always shows tracked products only.
            // Seed addUnitId from the product's default unit (Path A fix: prevents empty unitId on save).
            if (detail.defaultUnitId) {
                row.addUnitId = detail.defaultUnitId;
            }
        },

        /// <summary>
        /// saveSheet() — called by the shared sheet's Add button (P4-7, J5).
        ///
        /// Two paths:
        ///   A) Existing product picked (draft.productId set, draft.newStapleName null):
        ///      The product already exists; inject it into the working set with count = addCount (or 0).
        ///      No server round-trip needed — the product already exists in Catalog. The row is added
        ///      dirty so the user's next Save records the opening balance via RecordCountCommand.
        ///
        ///   B) New product typed (draft.newStapleName set, draft.productId empty):
        ///      POST to /AddItem to create the tracked product + opening-balance Correction.
        ///      On success, inject the returned row into the working set as already saved (not dirty).
        /// </summary>
        async saveSheet() {
            const addItemUrl = this._addItemUrl;
            // Path A: existing product selected — inject as a dirty row for the next scalar Save.
            if (this.draft.productId) {
                const pid = this.draft.productId;
                if (!this.rows[pid]) {
                    // New row: seed with 0 recorded (not in this location yet), counted = addCount.
                    const counted = parseFloat(this.draft.addCount) || 0;
                    this.rows[pid] = {
                        recorded: 0,
                        counted: counted,
                        unitCode: '',    // resolved server-side on save
                        unitId: this.draft.addUnitId || '',
                        reason: 'Correction',
                        dirty: counted !== 0,
                        failed: false,
                        failMsg: null,
                        productName: this.draft.productName,
                        isNewRow: true,  // flag so the UI renders the row name
                    };
                } else {
                    // Row already exists — just update the count.
                    const existing = this.rows[pid];
                    const newCounted = parseFloat(this.draft.addCount) || existing.counted;
                    existing.counted = newCounted;
                    existing.dirty = newCounted !== existing.recorded;
                }
                this.sheetOpen = false;
                this.toast = 'Added — tap Save to record.';
                return;
            }

            // Path B: new product name typed — create via server.
            const name = this.draft.newStapleName?.trim();
            const unitId = this.draft.addUnitId || this.draft.newStapleUnit || '';
            if (!name || !unitId) {
                // Missing required fields — stay open.
                return;
            }

            const counted = parseFloat(this.draft.addCount) || 0;
            const payload = {
                name,
                defaultUnitId: unitId,
                countedValue: counted,
                countedUnitId: unitId,
            };

            try {
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
                const resp = await fetch(addItemUrl, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token,
                        'X-Requested-With': 'XMLHttpRequest',
                    },
                    body: JSON.stringify(payload),
                });

                if (!resp.ok) {
                    this.toast = 'Add item failed (' + resp.status + ') — please try again';
                    return;
                }

                const data = await resp.json();

                if (!data.isSuccess) {
                    this.toast = data.error ?? 'Failed to create product';
                    return;
                }

                // Inject the newly created product into the working set as already-saved (not dirty).
                const pid = data.productId;
                this.rows[pid] = {
                    recorded: data.countedValue,
                    counted: data.countedValue,
                    unitCode: data.unitCode,
                    unitId: data.unitId,
                    reason: 'Correction',
                    dirty: false,
                    failed: false,
                    failMsg: null,
                    productName: data.productName,
                    isNewRow: true,
                };
                this.sheetOpen = false;
                this.toast = '✓ ' + data.productName + ' added' + (data.countedValue > 0 ? ' with ' + data.countedValue + ' ' + data.unitCode : '') + '.';
            } catch {
                this.toast = 'Network error — please try again';
            }
        },

        // ── Lot escape-hatch (P4-5, J3) ───────────────────────────────────────

        /// <summary>Expand the lot panel for a row — fetches the fragment via fetch and injects it.</summary>
        async expandLots(productId, url) {
            const host = document.getElementById('lot-panel-' + productId);
            if (!host) return;
            try {
                const resp = await fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
                if (!resp.ok) return;
                const html = await resp.text();
                host.innerHTML = html;
                // Re-init Alpine on the injected HTML so the x-data component activates.
                if (window.Alpine) window.Alpine.initTree(host);
                this.expandedLots[productId] = true;
            } catch { /* silently ignore — panel simply doesn't open */ }
        },

        collapseLotsPanel(productId) {
            const host = document.getElementById('lot-panel-' + (productId || ''));
            if (host) host.innerHTML = '';
            this.expandedLots[productId] = false;
        },

        /// <summary>
        /// Called after a successful lot-level save (lots-saved event from _LotPanel).
        /// Refreshes the lot panel so the user sees updated quantities, and clears
        /// the scalar dirty state for the product (the lots are now the truth).
        /// </summary>
        onLotsSaved(productId) {
            if (!productId) return;
            const row = this.rows[productId];
            if (row) {
                // Reset the scalar count to the recorded value so the row is no longer dirty.
                row.counted = row.recorded;
                row.dirty = false;
            }
            // Collapse and re-open the lot panel to reflect the updated quantities.
            // We cannot re-fetch without the URL — so just collapse; the user can re-expand.
            this.collapseLotsPanel(productId);
        },

        isDirty() {
            return Object.values(this.rows).some(r => r.dirty);
        },

        dirtyCount() {
            return Object.values(this.rows).filter(r => r.dirty).length;
        },

        isDown(productId) {
            const r = this.rows[productId];
            return r && r.dirty && r.counted < r.recorded;
        },

        setCount(productId, rawValue) {
            const row = this.rows[productId];
            if (!row) return;
            const parsed = parseFloat(rawValue);
            const counted = isNaN(parsed) ? row.recorded : Math.max(0, parsed);
            row.counted = counted;
            row.dirty = counted !== row.recorded;
            row.failed = false;
            row.failMsg = null;
        },

        setNoneLeft(productId) {
            this.setCount(productId, 0);
        },

        setReason(productId, reason) {
            const row = this.rows[productId];
            if (!row) return;
            row.reason = reason;
        },

        /// Returns the product id keys of rows that were added dynamically via the inline-add
        /// sheet (P4-7) and are not yet represented in the Razor-rendered HTML row list.
        newRowKeys() {
            return Object.keys(this.rows).filter(k => this.rows[k]?.isNewRow === true);
        },

        async save(url) {
            if (this.saving) return;
            this.saving = true;
            this.toast = null;

            const items = Object.entries(this.rows)
                .filter(([, r]) => r.dirty)
                .map(([productId, r]) => ({
                    productId,
                    countedValue: r.counted,
                    countedUnitId: r.unitId,
                    reason: r.reason
                }));

            try {
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
                const resp = await fetch(url, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token,
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: JSON.stringify({ items })
                });

                if (!resp.ok) {
                    this.toast = 'Save failed (' + resp.status + ') — please try again';
                    return;
                }

                const data = await resp.json();
                let saved = 0, failed = 0;

                for (const result of data.results ?? []) {
                    const row = this.rows[result.productId];
                    if (!row) continue;
                    if (result.isSuccess) {
                        row.recorded = row.counted;
                        row.dirty = false;
                        row.failed = false;
                        row.failMsg = null;
                        saved++;
                    } else {
                        row.failed = true;
                        row.failMsg = result.error ?? 'Failed to save';
                        failed++;
                    }
                }

                if (failed === 0) {
                    this.toast = saved === 1 ? '1 item updated' : saved + ' items updated';
                } else if (saved === 0) {
                    this.toast = 'Save failed — please try again';
                } else {
                    this.toast = saved + ' saved, ' + failed + ' failed — retry the highlighted rows';
                }
            } catch {
                this.toast = 'Network error — please try again';
            } finally {
                this.saving = false;
            }
        }
    };
}

// ── Lot escape-hatch Alpine component (P4-5, J3) ────────────────────────────
// Defined here (on the host page) so it is loaded before Alpine.initTree is
// called on dynamically injected _LotPanel partial markup. Scripts inside
// innerHTML fragments are never executed by the browser.
function takeStockLotPanel(data) {
    // data: { lots: { [entryId]: { unitId } }, foundUnitId }
    const initialLots = {};
    for (const eid of Object.keys(data.lots ?? {})) {
        initialLots[eid] = {
            amount: 0,
            unitId: (data.lots[eid]?.unitId ?? ''),
            spoiled: false,
            failed: false,
            failMsg: null,
        };
    }

    return {
        lots: initialLots,
        found: { amount: null, expiryDate: '', unitId: data.foundUnitId ?? '' },
        saving: false,
        status: null,

        init() {
            // nothing to wire on init — collapse handled by parent via custom event
        },

        setLotAmount(entryId, rawValue) {
            const lot = this.lots[entryId];
            if (!lot) return;
            const parsed = parseFloat(rawValue);
            lot.amount = isNaN(parsed) ? 0 : Math.max(0, parsed);
            lot.failed = false;
            lot.failMsg = null;
        },

        setSpoiled(entryId, checked) {
            const lot = this.lots[entryId];
            if (!lot) return;
            lot.spoiled = checked;
        },

        isDirty() {
            const anyLot = Object.values(this.lots).some(l => l.amount > 0);
            const foundDirty = this.found.amount != null && this.found.amount > 0;
            return anyLot || foundDirty;
        },

        async save(url) {
            if (this.saving || !this.isDirty()) return;
            this.saving = true;
            this.status = null;

            const adjustments = [];

            for (const [entryId, lot] of Object.entries(this.lots)) {
                if (lot.amount <= 0) continue;
                adjustments.push({
                    entryId,
                    amount: lot.amount,
                    unitId: lot.unitId,
                    reason: lot.spoiled ? 'Discarded' : 'Correction',
                });
            }

            if (this.found.amount != null && this.found.amount > 0) {
                adjustments.push({
                    entryId: null,
                    amount: this.found.amount,
                    unitId: this.found.unitId,
                    reason: 'Correction',
                    expiryDate: this.found.expiryDate || null,
                });
            }

            try {
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
                const resp = await fetch(url, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token,
                        'X-Requested-With': 'XMLHttpRequest',
                    },
                    body: JSON.stringify({ adjustments }),
                });

                if (!resp.ok) {
                    this.status = 'Save failed (' + resp.status + ') — please try again';
                    return;
                }

                const result = await resp.json();
                let saved = 0, failed = 0;

                for (const r of result.results ?? []) {
                    if (r.entryId) {
                        const lot = this.lots[r.entryId];
                        if (lot) {
                            lot.failed = !r.isSuccess;
                            lot.failMsg = r.isSuccess ? null : r.error ?? 'Failed';
                            if (r.isSuccess) lot.amount = 0;
                        }
                    }
                    if (r.isSuccess) saved++; else failed++;
                }

                if (failed === 0) {
                    this.status = saved === 1 ? '1 lot updated' : saved + ' lots updated';
                    this.found.amount = null;
                    this.found.expiryDate = '';
                    // Notify the parent walk component to collapse the panel.
                    this.$dispatch('lots-saved', {
                        productId: this.$el.closest('[data-product-id]')?.dataset?.productId
                    });
                } else {
                    this.status = failed + ' adjustment(s) failed — see highlighted lots';
                }
            } catch {
                this.status = 'Network error — please try again';
            } finally {
                this.saving = false;
            }
        },
    };
}
</script>
