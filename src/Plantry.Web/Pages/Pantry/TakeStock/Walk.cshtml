@page "/pantry/take-stock/{locationId:guid}"
@model Plantry.Web.Pages.Pantry.TakeStock.WalkModel
@using Plantry.Web.Pages.Shared
@inject Microsoft.AspNetCore.Mvc.ViewFeatures.IFileVersionProvider FileVersionProvider
@{
    ViewData["Title"] = Model.LocationName ?? "Take Stock";
    var tsIslandSrc  = FileVersionProvider.AddFileVersionToPath(ViewContext.HttpContext.Request.PathBase, "/js/islands/take-stock.js");
    var tsHelpersSrc = FileVersionProvider.AddFileVersionToPath(ViewContext.HttpContext.Request.PathBase, "/js/islands/helpers.js");
}

@* Island hydration payload — read by take-stock.js via readHydration('ts-walk-data'). *@
@* The island renders the whole row so the payload includes productName, recorded, unitCode, *@
@* supportedUnits, hasActiveStock, and the per-product lots URL. *@
<script type="application/json" id="ts-walk-data">@Html.Raw(Model.IslandRowsJson)</script>

@* Location name — separate hydration element so no JS string escaping in the <script> tag. *@
<script type="application/json" id="ts-walk-location">@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.LocationName ?? "Take Stock"))</script>

@* Inline-add sheet bridge (P4-7, J5) — a thin Alpine wrapper around the shared sheet only. *@
@* The shared _ProductSearchCreateSheet is Alpine-owned and cross-feature (Recipes, Shopping). *@
@* ADR-020 §2 bridge: the sheet stays Alpine; it dispatches ts-sheet-add to the island root. *@
@* See take-stock.js for the full bridge rationale. *@
<div id="ts-sheet-host"
     x-data="takeStockSheetBridge()"
     x-on:ts-open-add.window="openAdd()"
     x-on:pick-product="selectProduct(draft, $event.detail)">
    @* TrackStock=false: count lives in the island, not in the sheet's qty/unit fields.       *@
    @* Noun/ShowGroupHeading/CreateLabel/StapleNamePlaceholder: context-aware overrides so the *@
    @* sheet reads "Add item" instead of "Add ingredient", hides the Recipes-only Group field, *@
    @* and uses neutral create-product wording (the action is tracked, not staple).            *@
    @* GroupOptions: existing groups passed for the create-view Group combobox (plantry-40n6). *@
    @* CategoryOptions: active categories passed for the Defaults collapsible (plantry-y53t).  *@
    <partial name="Shared/_ProductSearchCreateSheet"
             model='new ProductSearchCreateSheetViewModel
             {
                 SearchUrl             = Url.Page("./Walk", "SearchProducts", new { locationId = Model.LocationId })!,
                 UnitOptions           = Model.UnitOptions,
                 CategoryOptions       = Model.CategoryOptions,
                 TrackStock            = false,
                 ExtraFieldsPartial    = "TakeStock/_CountLocationFields",
                 Noun                  = "item",
                 ShowGroupHeading      = false,
                 CreateLabel           = "Create new product",
                 StapleNamePlaceholder = "Product name (e.g. Salt)",
                 ShowCreateAndCount    = true,
                 GroupOptions          = Model.GroupOptions,
             }' />
</div>

@Html.AntiForgeryToken()

@* Island mount point — take-stock.js renders into this element. *@
<div id="ts-walk-root"></div>

@section Scripts {
    <script type="module">
        const { mountTakeStockWalk }             = await import('@Html.Raw(tsIslandSrc)');
        const { readHydration, readAntiforgeryToken } = await import('@Html.Raw(tsHelpersSrc)');

        const root         = document.getElementById('ts-walk-root');
        const rows         = readHydration('ts-walk-data');
        const locationName = readHydration('ts-walk-location') ?? 'Take Stock';
        const token        = readAntiforgeryToken();

        if (root && rows) {
            mountTakeStockWalk(root, {
                rows,
                saveUrl:      '@Url.Page("./Walk", "Save",    new { locationId = Model.LocationId })',
                addItemUrl:   '@Url.Page("./Walk", "AddItem", new { locationId = Model.LocationId })',
                token,
                locationName,
            });
        }
    </script>
}

@* ── Sheet bridge Alpine component ────────────────────────────────────────────────
   Owns only the sheet-open state, draft, and the two paths of saveSheet.
   On a successful add it dispatches ts-sheet-add to the island mount element so
   the Preact island updates its reactive row list.
   This is intentionally narrow — no rows map, no save logic, no dirty tracking here. *@
<script>
function takeStockSheetBridge() {
    return {
        // ── Shared sheet Alpine contract ─────────────────────────────────────
        sheetOpen: false,
        // sheetView: 'search' | 'create' — drives the two-view swap in _ProductSearchCreateSheet
        // (plantry-nb4x).  Always reset to 'search' when opening the sheet so the user lands on
        // the search view; the create affordance button navigates in-place to 'create'.
        sheetView: 'search',
        editingIdx: null,
        draft: {},

        openAdd() {
            this.editingIdx = null;
            this.sheetView = 'search';
            this.draft = { productId: '', productName: '', isUntracked: false,
                           newStapleName: null, newStapleUnit: '', newStapleCategoryId: '',
                           groupHeading: '', newGroupId: '', newGroupName: '',
                           addCount: 1, addUnitId: '' };
            this.sheetOpen = true;
            this.$nextTick(() => window.dispatchEvent(new CustomEvent('sheet-product-set', { detail: '' })));
        },

        closeSheet() {
            this.sheetView = 'search';
            this.sheetOpen = false;
        },

        selectProduct(row, detail) {
            row.productId = detail.value;
            row.productName = detail.name;
            row.isUntracked = false;
            if (detail.defaultUnitId) {
                row.addUnitId = detail.defaultUnitId;
            }
        },

        /// <summary>
        /// saveSheet() — called by the sheet's Add (search view) or Create/Create & count (create view) button.
        /// Dispatches ts-sheet-add to the island root with enough info for both paths.
        /// Path A: existing product (draft.productId set) → island injects dirty row.
        /// Path B: new product via create view (draft.newStapleName set) → island POSTs /AddItem
        ///         and injects saved row. Full create-view wiring (unit from Defaults, group) is
        ///         delivered by plantry-40n6, plantry-y53t, and plantry-l92u.
        /// </summary>
        saveSheet() {
            const islandRoot = document.getElementById('ts-walk-root');
            if (!islandRoot) return;

            // Search-view path: existing product selected — dispatch to island, no POST needed.
            if (this.draft.productId) {
                islandRoot.dispatchEvent(new CustomEvent('ts-sheet-add', {
                    bubbles: false,
                    detail: {
                        productId:   this.draft.productId,
                        productName: this.draft.productName,
                        addCount:    this.draft.addCount,
                        addUnitId:   this.draft.addUnitId,
                    }
                }));
                this.sheetView = 'search';
                this.sheetOpen = false;
                return;
            }

            // Create-view path: new product (standalone, grouped, or variant).
            // Validation: name and unit are always required.
            const name   = (this.draft.newStapleName ?? '').trim();
            const unitId = this.draft.newStapleUnit || '';
            if (!name || !unitId) return; // stay open — user must fill name and unit in create view

            // Dispatch ts-sheet-add with the full create payload (group-aware, plantry-l92u).
            // The island POSTs /AddItem and injects the saved row on success.
            islandRoot.dispatchEvent(new CustomEvent('ts-sheet-add', {
                bubbles: false,
                detail: {
                    newStapleName:       name,
                    newStapleUnit:       unitId,
                    newGroupId:          this.draft.newGroupId   || '',
                    newGroupName:        this.draft.newGroupName  || '',
                    newStapleCategoryId: this.draft.newStapleCategoryId || '',
                    addCount:            this.draft.addCount,
                    addUnitId:           this.draft.addUnitId    || unitId,
                }
            }));
            this.sheetView = 'search';
            this.sheetOpen = false;
        },
    };
}

// ── Lot escape-hatch Alpine component ────────────────────────────────────────────
// Defined here on the host page so it is available when Alpine.initTree is called on
// dynamically injected _LotPanel partial markup. Scripts inside innerHTML fragments
// are never executed by browsers (HTML spec §4.12.1 / fetch-and-run semantics).
function takeStockLotPanel(data) {
    // data: { lots: { [entryId]: { unitId } }, foundUnitId }
    const initialLots = {};
    for (const eid of Object.keys(data.lots ?? {})) {
        initialLots[eid] = {
            amount: 0,
            unitId: (data.lots[eid]?.unitId ?? ''),
            spoiled: false,
            failed: false,
            failMsg: null,
        };
    }

    return {
        lots: initialLots,
        found: { amount: null, expiryDate: '', unitId: data.foundUnitId ?? '' },
        saving: false,
        status: null,

        init() {
            // nothing to wire — collapse handled by island via window events
        },

        setLotAmount(entryId, rawValue) {
            const lot = this.lots[entryId];
            if (!lot) return;
            const parsed = parseFloat(rawValue);
            lot.amount = isNaN(parsed) ? 0 : Math.max(0, parsed);
            lot.failed = false;
            lot.failMsg = null;
        },

        setSpoiled(entryId, checked) {
            const lot = this.lots[entryId];
            if (!lot) return;
            lot.spoiled = checked;
        },

        isDirty() {
            const anyLot = Object.values(this.lots).some(l => l.amount > 0);
            const foundDirty = this.found.amount != null && this.found.amount > 0;
            return anyLot || foundDirty;
        },

        async save(url) {
            if (this.saving || !this.isDirty()) return;
            this.saving = true;
            this.status = null;

            const adjustments = [];

            for (const [entryId, lot] of Object.entries(this.lots)) {
                if (lot.amount <= 0) continue;
                adjustments.push({
                    entryId,
                    amount: lot.amount,
                    unitId: lot.unitId,
                    reason: lot.spoiled ? 'Discarded' : 'Correction',
                });
            }

            if (this.found.amount != null && this.found.amount > 0) {
                adjustments.push({
                    entryId: null,
                    amount: this.found.amount,
                    unitId: this.found.unitId,
                    reason: 'Correction',
                    expiryDate: this.found.expiryDate || null,
                });
            }

            try {
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';
                const resp = await fetch(url, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token,
                        'X-Requested-With': 'XMLHttpRequest',
                    },
                    body: JSON.stringify({ adjustments }),
                });

                if (!resp.ok) {
                    this.status = 'Save failed (' + resp.status + ') — please try again';
                    return;
                }

                const result = await resp.json();
                let saved = 0, failed = 0;

                for (const r of result.results ?? []) {
                    if (r.entryId) {
                        const lot = this.lots[r.entryId];
                        if (lot) {
                            lot.failed = !r.isSuccess;
                            lot.failMsg = r.isSuccess ? null : r.error ?? 'Failed';
                            if (r.isSuccess) lot.amount = 0;
                        }
                    }
                    if (r.isSuccess) saved++; else failed++;
                }

                if (failed === 0) {
                    this.status = saved === 1 ? '1 lot updated' : saved + ' lots updated';
                    this.found.amount = null;
                    this.found.expiryDate = '';
                    // Notify the island to collapse the lot panel and reset scalar row state.
                    this.$dispatch('lots-saved', {
                        productId: this.$el.closest('[data-product-id]')?.dataset?.productId
                    });
                } else {
                    this.status = failed + ' adjustment(s) failed — see highlighted lots';
                }
            } catch {
                this.status = 'Network error — please try again';
            } finally {
                this.saving = false;
            }
        },
    };
}
</script>
