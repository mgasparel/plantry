@model Plantry.Web.Pages.Pantry.TakeStock.LotPanelModel
@using Plantry.Inventory.Application
@*
    Lot escape-hatch panel (P4-5, J3).
    Rendered by WalkModel.OnGetLotsAsync into the lot-panel-{productId} placeholder beneath a count row.
    Alpine component: takeStockLotPanel — tracks per-lot reduce inputs, spoiled toggle, and the
    "add found stock" form; POSTs to /SaveLots on submit.
*@
<div class="ts-hatch"
     x-data='takeStockLotPanel(@Html.Raw(BuildLotJson(Model)))'
     x-init="init()">

    <div class="ts-hatch-head">
        <svg class="icon" aria-hidden="true"><use href="#i-box" /></svg>
        Individual lots — adjust each instead of one total
        <span class="spacer"></span>
        <button type="button" class="ts-retry"
                x-on:click="$dispatch('collapse-lots', { productId: '@Model.ProductId' })"
                aria-label="Collapse lot list">Collapse</button>
    </div>

    @if (Model.Lots.Count == 0)
    {
        <p class="ts-hatch-status">No active lots in this location.</p>
    }
    else
    {
        @foreach (var lot in Model.Lots)
        {
            var eid = lot.EntryId.ToString();
            <div class="ts-lot" :class="{ failed: lots['@eid']?.failed }">
                <div class="ts-lot-top">
                    <div class="ts-lot-qty">
                        <input type="number" min="0" step="any"
                               :value="lots['@eid']?.amount ?? 0"
                               x-on:input="setLotAmount('@eid', $event.target.value)"
                               aria-label="Counted quantity for this lot" />
                        <span class="lq-unit">@lot.UnitCode</span>
                    </div>
                    <div class="ts-lot-meta">
                        @if (lot.ExpiryDate is { } exp)
                        {
                            <span class="ts-lot-exp">
                                <svg class="icon" aria-hidden="true"><use href="#i-clock" /></svg>
                                @lot.Quantity.ToString("0.###") @lot.UnitCode · Expires @exp.ToString("d MMM yyyy")
                            </span>
                        }
                        else
                        {
                            <span class="ts-lot-exp none">
                                <svg class="icon" aria-hidden="true"><use href="#i-clock" /></svg>
                                @lot.Quantity.ToString("0.###") @lot.UnitCode · No expiry
                            </span>
                        }
                        <label class="ts-lot-spoiled">
                            <input type="checkbox"
                                   :checked="lots['@eid']?.spoiled ?? false"
                                   x-on:change="setSpoiled('@eid', $event.target.checked)" />
                            Spoiled (discard)
                        </label>
                    </div>
                </div>
                <span class="ts-lot-fail"
                      x-show="lots['@eid']?.failed"
                      x-text="lots['@eid']?.failMsg ?? ''"
                      role="alert"></span>
            </div>
        }
    }

    @* Add found stock — opening-balance Correction lot *@
    <div class="ts-lot found">
        <div class="ts-lot-top">
            <span class="found-tag">Found stock</span>
            <div class="ts-lot-qty">
                <input type="number" min="0" step="any"
                       x-model.number="found.amount"
                       aria-label="Quantity of found stock to add" />
                <span class="lq-unit">@(Model.Lots.FirstOrDefault()?.UnitCode ?? "")</span>
            </div>
            <input type="date" class="ts-date-input"
                   x-model="found.expiryDate"
                   aria-label="Expiry date for found stock" />
            <input type="hidden" x-bind:value="found.unitId" />
        </div>
    </div>

    @* Save / status row *@
    <div class="ts-hatch-foot">
        <button type="button"
                class="btn btn--primary btn--sm"
                :disabled="saving || !isDirty()"
                x-on:click="save('@Url.Page("./Walk", "SaveLots", new { locationId = Model.LocationId, productId = Model.ProductId })')">
            <svg class="icon" aria-hidden="true"><use href="#i-check" /></svg>
            <span x-text="saving ? 'Saving…' : 'Save lot changes'"></span>
        </button>
        <span class="ts-hatch-status" x-text="status ?? ''" role="status" aria-live="polite"></span>
    </div>
</div>

@functions {
    /// <summary>Serialises initial lot state for the Alpine data function.</summary>
    string BuildLotJson(LotPanelModel m)
    {
        // Take Stock semantics: each lot's input is the *counted* quantity, pre-filled with the
        // lot's current on-hand amount (plantry-hl6u). `original` is the recorded baseline used to
        // compute the reduction delta (original − counted) posted to SaveLots, and to decide dirty.
        var lots = m.Lots.ToDictionary(
            l => l.EntryId.ToString(),
            l => new { amount = l.Quantity, original = l.Quantity, unitId = l.UnitId.ToString(), spoiled = false, failed = false, failMsg = (string?)null });
        // found.unitId defaults to the first lot's unit Guid (the display unit for this product/location).
        var foundUnitId = m.Lots.Count > 0 ? m.Lots[0].UnitId.ToString() : "";
        var json = System.Text.Json.JsonSerializer.Serialize(new
        {
            lots,
            foundUnitId,
        });
        return json;
    }
}

@* takeStockLotPanel is defined in Walk.cshtml (the host page) — it must be
   pre-loaded at page time so it is available when Alpine.initTree re-initialises
   the injected partial markup. Scripts inside dynamically injected innerHTML do
   not execute in browsers (HTML spec §4.12.1 / fetch-and-run semantics). *@
