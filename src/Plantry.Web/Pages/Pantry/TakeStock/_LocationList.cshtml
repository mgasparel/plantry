@model Plantry.Web.Pages.Pantry.TakeStock.IndexModel

@if (Model.Locations.Count == 0)
{
    <div class="empty-state" id="take-stock-list">
        <div class="empty-state__icon"><svg class="icon" aria-hidden="true"><use href="#i-box" /></svg></div>
        <div class="empty-state__title">No storage locations yet</div>
        <div class="empty-state__body">Take Stock walks you shelf by shelf — so first, tell Plantry where things live. Add a location like Fridge or Pantry to begin.</div>
        <a class="btn btn--primary" href="/Catalog/Locations">
            <svg class="icon" aria-hidden="true"><use href="#i-plus" /></svg> Create a location
        </a>
    </div>
}
else
{
    <ul class="ts-loc-grid" role="list" id="take-stock-list">
        @foreach (var loc in Model.Locations)
        {
            <li>
                <a class="ts-loc-card" href="/pantry/take-stock/@loc.LocationId">
                    <span class="ts-loc-ico"><svg class="icon" aria-hidden="true"><use href="#i-location" /></svg></span>
                    <span class="ts-loc-main">
                        <span class="ts-loc-name">@loc.LocationName</span>
                        <span class="ts-loc-sub">Count what's on these shelves</span>
                    </span>
                    <svg class="icon ts-chev" aria-hidden="true"><use href="#i-chevron-right" /></svg>
                </a>
            </li>
        }
        @if (Model.HasNoLocationProducts)
        {
            <li>
                <a class="ts-loc-card unplaced" href="/pantry/take-stock/no-location">
                    <span class="ts-loc-ico"><svg class="icon" aria-hidden="true"><use href="#i-alert" /></svg></span>
                    <span class="ts-loc-main">
                        <span class="ts-loc-name">No location</span>
                        <span class="ts-loc-sub">Tracked products that still need filing</span>
                    </span>
                    <svg class="icon ts-chev" aria-hidden="true"><use href="#i-chevron-right" /></svg>
                </a>
            </li>
        }
    </ul>
}
