@page
@model Plantry.Web.Pages.Import.RecipesModel
@{
    ViewData["Title"] = "Recipe Staging Review — Import from Grocy";
    ViewData["ContentClass"] = "page-content--roomy";
}

@*
    Grocy import pipeline — Recipe staging review screen (plantry-zcw.6).
    Lists all 65 staged Grocy normal recipes with flag badges:
      HasFlattenedNesting, HasDroppedNotes, HasProducesProduct, CrosswalkMissing, NameCollision.
    Flagged rows are highlighted. Name collisions can be resolved inline via htmx.
*@

<div class="catalog-section">
    <h1>Step 6 — Recipe Review</h1>
    <p>
        Review staged Grocy recipes before committing them to Plantry.
        Green rows are clean; highlighted rows need attention.
        <a href="/Import">← Back to Import</a>
    </p>
</div>

@if (Model.ErrorMessage is not null)
{
    <div class="alert alert--danger" role="alert">
        <strong>Error.</strong> @Model.ErrorMessage
    </div>
}

@if (Model.CommitSuccessMessage is not null)
{
    <div class="alert alert--success" role="alert">
        <strong>Done.</strong> @Model.CommitSuccessMessage
    </div>
}

@if (Model.DeflattenSuccessMessage is not null)
{
    <div class="alert alert--success" role="alert">
        <strong>Nestings converted.</strong> @Model.DeflattenSuccessMessage
    </div>
}

@if (!Model.ManifestExists)
{
    <div class="card" style="max-width: 40rem">
        <div class="card__head">
            <div>
                <h3 class="card__head-title">No manifest found</h3>
                <p class="card__head-sub">Extract a Grocy snapshot before reviewing recipes.</p>
            </div>
        </div>
        <div class="card__body">
            <a href="/Import" class="btn btn--primary">Go to Step 1 — Extract</a>
        </div>
    </div>
    return;
}

@* Crosswalk status warnings *@
@if (!Model.ProductCrosswalkFound || !Model.UnitCrosswalkFound)
{
    <div class="alert alert--warning" role="alert">
        <strong>Crosswalks incomplete.</strong>
        Some crosswalks have not been committed yet — affected ingredients will have
        the <span class="badge badge--warning" style="font-size: 0.75rem">crosswalk?</span> flag.
        @if (!Model.ProductCrosswalkFound) { <span>Product crosswalk missing — commit products first.</span> }
        @if (!Model.UnitCrosswalkFound) { <span>Unit crosswalk missing — commit units first.</span> }
    </div>
}

<div class="card" style="margin-bottom: 1.5rem">
    <div class="card__head">
        <div>
            <h3 class="card__head-title">
                @Model.TotalRows recipes staged
                @if (Model.FlaggedCount > 0)
                {
                    <span style="margin-left: 0.75rem; font-weight: 400; font-size: 0.9rem; color: var(--color-warning-text, #92400e)">
                        · @Model.FlaggedCount flagged
                    </span>
                }
            </h3>
            <p class="card__head-sub" style="display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 0.25rem">
                @if (Model.NameCollisionCount > 0)
                {
                    <span><span class="badge badge--danger" style="font-size: 0.7rem">name collision</span> @Model.NameCollisionCount</span>
                }
                @if (Model.FlattenedNestingCount > 0)
                {
                    <span><span class="badge badge--info" style="font-size: 0.7rem">flattened</span> @Model.FlattenedNestingCount</span>
                }
                @if (Model.DroppedNotesCount > 0)
                {
                    <span><span class="badge badge--warning" style="font-size: 0.7rem">notes dropped</span> @Model.DroppedNotesCount</span>
                }
                @if (Model.ProducesProductCount > 0)
                {
                    <span><span class="badge badge--neutral" style="font-size: 0.7rem">produces</span> @Model.ProducesProductCount</span>
                }
                @if (Model.CrosswalkMissingCount > 0)
                {
                    <span><span class="badge badge--warning" style="font-size: 0.7rem">crosswalk?</span> @Model.CrosswalkMissingCount</span>
                }
            </p>
        </div>
        <div class="card__head-actions" style="display: flex; gap: 0.5rem; align-items: center">
            <a href="/Import" class="btn btn--ghost" style="font-size: 0.875rem">← Back to Import</a>
            @if (Model.ManifestExists && Model.ProductCrosswalkFound && Model.UnitCrosswalkFound)
            {
                @* Hidden inputs for cross-page drops — rows not rendered on the current page but
                   already dropped on a prior (or later) page. Current-page drops are captured by
                   the Alpine x-if hidden inputs in each _RecipeStagingRow partial. *@
                var currentPageIds = Model.PagedRows.Select(r => r.GrocyId).ToHashSet();
                @* The form id is referenced by hidden inputs in row partials (form="commit-recipes-form"). *@
                <form method="post" asp-page-handler="CommitRecipes" style="display: inline" id="commit-recipes-form">
                    @Html.AntiForgeryToken()
                    @foreach (var droppedId in Model.AllDroppedIds.Where(id => !currentPageIds.Contains(id)))
                    {
                        <input type="hidden" name="DroppedRecipeIds" value="@droppedId" />
                    }
                    <button type="submit" class="btn btn--primary" style="font-size: 0.875rem">
                        @if (Model.RecipeCrosswalkFound)
                        {
                            <span>Re-commit Recipes</span>
                        }
                        else
                        {
                            <span>Commit Recipes</span>
                        }
                    </button>
                </form>
                @* De-flatten step — available once recipes are committed. Re-imports the Grocy nesting
                   edges as native inclusion lines for untouched-since-import parents (D16). *@
                @if (Model.RecipeCrosswalkFound && Model.NestingEdgeParentCount > 0)
                {
                    <form method="post" asp-page-handler="DeflattenNestings" style="display: inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn--ghost" style="font-size: 0.875rem"
                                title="Re-import the @Model.NestingEdgeParentCount nested recipe(s) as inclusion lines">
                            Convert nestings → inclusions
                        </button>
                    </form>
                }
            }
        </div>
    </div>

    @if (Model.DeflattenSummary is { } deflatten)
    {
        <div class="card__body" style="border-top: 1px solid var(--color-border, #e5e7eb)">
            <h4 style="margin: 0 0 0.5rem">Nesting → inclusion conversion</h4>
            <p class="card__head-sub" style="display: flex; flex-wrap: wrap; gap: 0.75rem; margin: 0 0 0.75rem">
                <span><span class="badge badge--success" style="font-size: 0.7rem">converted</span> @deflatten.Converted</span>
                <span><span class="badge badge--neutral" style="font-size: 0.7rem">already converted</span> @deflatten.AlreadyConverted</span>
                <span><span class="badge badge--warning" style="font-size: 0.7rem">edited — skipped</span> @deflatten.SkippedEdited</span>
                <span><span class="badge badge--warning" style="font-size: 0.7rem">uncommitted sub — skipped</span> @deflatten.SkippedMissingSub</span>
                @if (deflatten.SkippedParentNotCommitted > 0)
                {
                    <span><span class="badge badge--warning" style="font-size: 0.7rem">parent not committed</span> @deflatten.SkippedParentNotCommitted</span>
                }
                @if (deflatten.Failed > 0)
                {
                    <span><span class="badge badge--danger" style="font-size: 0.7rem">failed</span> @deflatten.Failed</span>
                }
            </p>
            <table class="data-grid__table" style="min-width: 40rem">
                <caption class="data-grid__caption sr-only">Nesting conversion results</caption>
                <thead>
                    <tr>
                        <th scope="col" class="data-grid__header">Parent recipe</th>
                        <th scope="col" class="data-grid__header">Sub-recipe(s)</th>
                        <th scope="col" class="data-grid__header">Outcome</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in deflatten.Results)
                    {
                        <tr>
                            <td class="data-grid__cell">@r.ParentName</td>
                            <td class="data-grid__cell">@string.Join(", ", r.SubRecipeNames)</td>
                            <td class="data-grid__cell">
                                <strong>@r.Disposition</strong>
                                @if (r.Note is not null)
                                {
                                    <span style="color: var(--color-text-faint); display: block; font-size: 0.8rem">@r.Note</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <div class="card__body" style="padding: 0; overflow-x: auto">
        <table class="data-grid__table" style="min-width: 60rem" id="recipes-staging-table">
            <caption class="data-grid__caption sr-only">Grocy recipe staging review</caption>
            <thead>
                <tr>
                    <th scope="col" class="data-grid__header data-grid__cell--end" style="width: 5rem">ID</th>
                    <th scope="col" class="data-grid__header" style="width: 24rem">Recipe name</th>
                    <th scope="col" class="data-grid__header data-grid__cell--end" style="width: 6rem">Servings</th>
                    <th scope="col" class="data-grid__header data-grid__cell--end" style="width: 8rem">Ingredients</th>
                    <th scope="col" class="data-grid__header" style="width: 5rem">Photo</th>
                    <th scope="col" class="data-grid__header" style="width: 16rem">Flags</th>
                    <th scope="col" class="data-grid__header" style="width: 4.5rem; text-align: center">Drop</th>
                </tr>
            </thead>
            <tbody id="recipes-staging-body">
                @foreach (var row in Model.PagedRows)
                {
                    <partial name="_RecipeStagingRow" model="row" />
                }
            </tbody>
        </table>
    </div>
</div>

@* Pagination — drop selections are carried across pages via droppedIds query-string parameters.
   Cross-page drops (rows not rendered on this page) are baked into the link hrefs by the server.
   Current-page drops (Alpine hidden inputs) are merged in by navigateTo before navigation.
   navigateTo rebuilds droppedIds from scratch — clearing what was in the href first — so that
   un-checking a row that arrived as a carried drop is correctly un-done rather than silently
   re-applied. *@
@if (Model.TotalPages > 1)
{
    // Cross-page drops only: IDs dropped on prior pages that are not rendered on this page.
    // Current-page IDs are NOT baked in — they are supplied live by Alpine's hidden inputs.
    var paginationPageIds       = Model.PagedRows.Select(r => r.GrocyId).ToHashSet();
    var crossPageDroppedIds     = Model.AllDroppedIds.Where(id => !paginationPageIds.Contains(id));
    var crossPageDroppedQs      = string.Join("", crossPageDroppedIds.Select(id => $"&droppedIds={id}"));
    // Serialise cross-page IDs into the Alpine x-data initialiser so navigateTo can access them as this.crossPageDroppedIds.
    var crossPageIdsJson = System.Text.Json.JsonSerializer.Serialize(crossPageDroppedIds.ToArray());
    <div style="display: flex; gap: 0.5rem; align-items: center; padding: 0.5rem 0 1.5rem"
         x-data="{
             crossPageDroppedIds: @crossPageIdsJson,
             navigateTo(baseUrl) {
                 const url = new URL(baseUrl, location.origin);
                 url.searchParams.delete('droppedIds');
                 this.crossPageDroppedIds.forEach(function(id) {
                     url.searchParams.append('droppedIds', id);
                 });
                 document.querySelectorAll('input[name=DroppedRecipeIds]').forEach(function(h) {
                     url.searchParams.append('droppedIds', h.value);
                 });
                 location.href = url.toString();
             }
         }">
        @if (Model.CurrentPage > 1)
        {
            <a href="/Import/Recipes?page=@(Model.CurrentPage - 1)@crossPageDroppedQs"
               class="btn btn--ghost" style="font-size: 0.875rem"
               x-on:click.prevent="navigateTo($el.href)">← Prev</a>
        }
        <span style="font-size: 0.875rem; color: var(--color-text-faint)">
            Page @Model.CurrentPage of @Model.TotalPages (@Model.TotalRows recipes)
        </span>
        @if (Model.CurrentPage < Model.TotalPages)
        {
            <a href="/Import/Recipes?page=@(Model.CurrentPage + 1)@crossPageDroppedQs"
               class="btn btn--ghost" style="font-size: 0.875rem"
               x-on:click.prevent="navigateTo($el.href)">Next →</a>
        }
    </div>
}
