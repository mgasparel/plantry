@page
@model Plantry.Web.Pages.Import.ProductsModel
@{
    ViewData["Title"] = "Product Staging Review — Import from Grocy";
    ViewData["ContentClass"] = "page-content--roomy";
}

@*
    Grocy import pipeline — Product staging review screen (plantry-zcw.4).
    Lists all 215 staged Grocy products with flag badges (NameCollision, IsVariant,
    HasDroppedBarcode, IsMultiUnit, CrosswalkMissing). Variants are grouped under
    their parents. Flagged rows are highlighted. Name collisions can be resolved
    inline via htmx without a full page reload.
*@

<div class="catalog-section">
    <h1>Step 5 — Product Review</h1>
    <p>
        Review staged Grocy products before committing them to your Plantry catalog.
        Green rows are clean; highlighted rows need attention.
        <a href="/Import">← Back to Import</a>
    </p>
</div>

@if (Model.ErrorMessage is not null)
{
    <div class="alert alert--danger" role="alert">
        <strong>Error.</strong> @Model.ErrorMessage
    </div>
}

@if (!Model.ManifestExists)
{
    <div class="card" style="max-width: 40rem">
        <div class="card__head">
            <div>
                <h3 class="card__head-title">No manifest found</h3>
                <p class="card__head-sub">Extract a Grocy snapshot before reviewing products.</p>
            </div>
        </div>
        <div class="card__body">
            <a href="/Import" class="btn btn--primary">Go to Step 1 — Extract</a>
        </div>
    </div>
    return;
}

@* Crosswalk status warnings *@
@if (!Model.UnitCrosswalkFound || !Model.CategoryCrosswalkFound || !Model.LocationCrosswalkFound)
{
    <div class="alert alert--warning" role="alert">
        <strong>Crosswalks incomplete.</strong>
        Some crosswalks have not been committed yet — affected products will have
        the <span class="badge badge--warning" style="font-size: 0.75rem">crosswalk?</span> flag.
        @if (!Model.UnitCrosswalkFound) { <span>Unit crosswalk missing.</span> }
        @if (!Model.CategoryCrosswalkFound) { <span>Category crosswalk missing.</span> }
        @if (!Model.LocationCrosswalkFound) { <span>Location crosswalk missing.</span> }
    </div>
}

@* Commit result summary *@
@if (Model.CommitCompleted)
{
    <div class="alert @(Model.FailedCount > 0 ? "alert--warning" : "alert--success")" role="alert">
        <strong>Commit complete.</strong>
        @Model.CommittedCount committed,
        @Model.SkippedCount skipped,
        @Model.FailedCount failed.
        @if (Model.CommitCrosswalkPath is not null)
        {
            <span style="font-size: 0.8rem; color: var(--color-text-faint)"> · Crosswalk: @Model.CommitCrosswalkPath</span>
        }
    </div>
    @if (Model.FailedCount > 0)
    {
        <details style="margin-bottom: 1rem">
            <summary style="cursor: pointer; font-size: 0.875rem">Show failed products (@Model.FailedCount)</summary>
            <ul style="font-size: 0.85rem; margin-top: 0.5rem">
                @foreach (var r in Model.CommitResults.Where(r => !r.Success && !r.Skipped))
                {
                    <li><strong>@r.GrocyName</strong> (Grocy #@r.GrocyId) — @r.ErrorMessage</li>
                }
            </ul>
        </details>
    }
}

<div class="card" style="margin-bottom: 1.5rem">
    <div class="card__head">
        <div>
            <h3 class="card__head-title">
                @Model.TotalRows products staged
                @if (Model.FlaggedCount > 0)
                {
                    <span style="margin-left: 0.75rem; font-weight: 400; font-size: 0.9rem; color: var(--color-warning-text, #92400e)">
                        · @Model.FlaggedCount flagged
                    </span>
                }
            </h3>
            <p class="card__head-sub" style="display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 0.25rem">
                @if (Model.NameCollisionCount > 0)
                {
                    <span><span class="badge badge--danger" style="font-size: 0.7rem">name collision</span> @Model.NameCollisionCount</span>
                }
                @if (Model.MultiUnitCount > 0)
                {
                    <span><span class="badge badge--info" style="font-size: 0.7rem">multi-unit</span> @Model.MultiUnitCount</span>
                }
                @if (Model.VariantCount > 0)
                {
                    <span><span class="badge badge--neutral" style="font-size: 0.7rem">variant</span> @Model.VariantCount</span>
                }
                @if (Model.DroppedBarcodeCount > 0)
                {
                    <span><span class="badge badge--warning" style="font-size: 0.7rem">barcode dropped</span> @Model.DroppedBarcodeCount</span>
                }
                @if (Model.CrosswalkMissingCount > 0)
                {
                    <span><span class="badge badge--warning" style="font-size: 0.7rem">crosswalk?</span> @Model.CrosswalkMissingCount</span>
                }
            </p>
        </div>
        <div class="card__head-actions" style="display: flex; gap: 0.5rem; align-items: center">
            @{
                @* Hidden inputs for cross-page drops — rows not rendered on the current page but
                   already dropped on a prior (or later) page. Current-page drops are captured by
                   the Alpine x-if hidden inputs in each _ProductStagingRow partial. *@
                var currentPageIds = Model.PagedRows.Select(r => r.GrocyId).ToHashSet();
            }
            @* The form id is referenced by hidden inputs in row partials (form="commit-products-form"). *@
            <form method="post" asp-page-handler="CommitProducts" id="commit-products-form">
                @Html.AntiForgeryToken()
                @foreach (var droppedId in Model.AllDroppedIds.Where(id => !currentPageIds.Contains(id)))
                {
                    <input type="hidden" name="DroppedProductIds" value="@droppedId" />
                }
                <button type="submit" class="btn btn--primary" style="font-size: 0.875rem"
                        title="Commit all stageable products to the Plantry catalog">
                    Commit Products
                </button>
            </form>
            <a href="/Import" class="btn btn--ghost" style="font-size: 0.875rem">Continue to Step 6 →</a>
        </div>
    </div>

    <div class="card__body" style="padding: 0; overflow-x: auto">
        <table class="data-grid__table" style="min-width: 70rem" id="products-staging-table">
            <caption class="data-grid__caption sr-only">Grocy product staging review</caption>
            <thead>
                <tr>
                    <th scope="col" class="data-grid__header data-grid__cell--end" style="width: 5rem">ID</th>
                    <th scope="col" class="data-grid__header" style="width: 22rem">Plantry name</th>
                    <th scope="col" class="data-grid__header" style="width: 12rem">Category</th>
                    <th scope="col" class="data-grid__header" style="width: 9rem">Default unit</th>
                    <th scope="col" class="data-grid__header" style="width: 9rem">Location</th>
                    <th scope="col" class="data-grid__header" style="width: 14rem">Flags</th>
                    <th scope="col" class="data-grid__header" style="width: 4.5rem; text-align: center">Drop</th>
                </tr>
            </thead>
            <tbody id="products-staging-body">
                @foreach (var row in Model.PagedRows)
                {
                    <partial name="_ProductStagingRow" model="row" />
                }
            </tbody>
        </table>
    </div>
</div>

@* Pagination — drop selections are carried across pages via droppedIds query-string parameters.
   Cross-page drops (rows not rendered on this page) are baked into the link hrefs by the server.
   Current-page drops (Alpine hidden inputs) are merged in by navigateTo before navigation.
   navigateTo rebuilds droppedIds from scratch — clearing what was in the href first — so that
   un-checking a row that arrived as a carried drop is correctly un-done rather than silently
   re-applied. *@
@if (Model.TotalPages > 1)
{
    // Cross-page drops only: IDs dropped on prior pages that are not rendered on this page.
    // Current-page IDs are NOT baked in — they are supplied live by Alpine's hidden inputs.
    var crossPageDroppedIds = Model.AllDroppedIds.Where(id => !currentPageIds.Contains(id));
    var crossPageDroppedQs  = string.Join("", crossPageDroppedIds.Select(id => $"&droppedIds={id}"));
    // Serialise cross-page IDs into the Alpine x-data initialiser so navigateTo can access them as this.crossPageDroppedIds.
    var crossPageIdsJson = System.Text.Json.JsonSerializer.Serialize(crossPageDroppedIds.ToArray());
    <div style="display: flex; gap: 0.5rem; align-items: center; padding: 0.5rem 0 1.5rem"
         x-data="{
             crossPageDroppedIds: @crossPageIdsJson,
             navigateTo(baseUrl) {
                 const url = new URL(baseUrl, location.origin);
                 url.searchParams.delete('droppedIds');
                 this.crossPageDroppedIds.forEach(function(id) {
                     url.searchParams.append('droppedIds', id);
                 });
                 document.querySelectorAll('input[name=DroppedProductIds]').forEach(function(h) {
                     url.searchParams.append('droppedIds', h.value);
                 });
                 location.href = url.toString();
             }
         }">
        @if (Model.CurrentPage > 1)
        {
            <a href="/Import/Products?page=@(Model.CurrentPage - 1)@crossPageDroppedQs"
               class="btn btn--ghost" style="font-size: 0.875rem"
               x-on:click.prevent="navigateTo($el.href)">← Prev</a>
        }
        <span style="font-size: 0.875rem; color: var(--color-text-faint)">
            Page @Model.CurrentPage of @Model.TotalPages (@Model.TotalRows products)
        </span>
        @if (Model.CurrentPage < Model.TotalPages)
        {
            <a href="/Import/Products?page=@(Model.CurrentPage + 1)@crossPageDroppedQs"
               class="btn btn--ghost" style="font-size: 0.875rem"
               x-on:click.prevent="navigateTo($el.href)">Next →</a>
        }
    </div>
}
