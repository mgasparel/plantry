@model Plantry.Migration.Grocy.ProductStagingRow

@*
    Partial: one row in the product staging review table.
    Used both in the initial render (Products.cshtml) and as the htmx swap target
    when the user resolves a name collision via inline edit.
*@

@{
    var row = Model;
    var isVariant = row.IsVariant;
    var hasCollision = row.HasNameCollision;
    var isFlagged = row.IsFlagged;

    var rowBg = hasCollision
        ? "background: var(--color-danger-bg, #fff1f2)"
        : isFlagged
            ? "background: var(--color-warning-bg, #fffbeb)"
            : "";

    var indent = isVariant ? "padding-left: 1.5rem" : "";
}

<tr id="product-row-@row.GrocyId" style="@rowBg">
    <td class="data-grid__cell data-grid__cell--end"
        style="color: var(--color-text-faint); font-variant-numeric: tabular-nums; font-size: 0.85rem">
        @row.GrocyId
    </td>

    <td class="data-grid__cell" style="@indent">
        @if (hasCollision)
        {
            @* Inline edit form for name collision — posts via htmx, swaps this row's fragment *@
            <form hx-post="/Import/Products?handler=UpdateName"
                  hx-target="#product-row-@row.GrocyId"
                  hx-swap="outerHTML"
                  style="display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap">
                @Html.AntiForgeryToken()
                <input type="hidden" name="grocyId" value="@row.GrocyId" />
                <input type="text"
                       name="newName"
                       value="@row.PlantryName"
                       class="field__input"
                       style="font-size: 0.875rem; min-width: 14rem"
                       maxlength="200"
                       required />
                <button type="submit" class="btn btn--primary" style="font-size: 0.8rem; padding: 0.25rem 0.75rem">
                    Save
                </button>
            </form>
            <div style="font-size: 0.75rem; color: var(--color-danger-text, #991b1b); margin-top: 0.2rem">
                Grocy name: <em>@row.GrocyName</em>
            </div>
        }
        else
        {
            <span style="font-weight: 500">@row.PlantryName</span>
            @if (isVariant && row.GrocyParentProductId is { } parentId)
            {
                <br />
                <span style="font-size: 0.75rem; color: var(--color-text-faint)">
                    variant of #@parentId
                </span>
            }
        }
    </td>

    <td class="data-grid__cell" style="font-size: 0.875rem">
        @if (row.CategoryName is not null)
        {
            <span>@row.CategoryName</span>
        }
        else if (row.GrocyProductGroupId is null)
        {
            <span style="color: var(--color-text-faint)">—</span>
        }
        else
        {
            <span style="color: var(--color-warning-text, #92400e)">
                group #@row.GrocyProductGroupId
            </span>
        }
    </td>

    <td class="data-grid__cell" style="font-size: 0.875rem">
        @if (row.DefaultUnitName is not null)
        {
            <span>@row.DefaultUnitName</span>
        }
        else
        {
            <span style="color: var(--color-warning-text, #92400e)">
                unit #@row.GrocyQuIdStock
            </span>
        }
    </td>

    <td class="data-grid__cell" style="font-size: 0.875rem">
        @if (row.DefaultLocationName is not null)
        {
            <span>@row.DefaultLocationName</span>
        }
        else if (row.GrocyLocationId is null)
        {
            <span style="color: var(--color-text-faint)">—</span>
        }
        else
        {
            <span style="color: var(--color-text-faint)">loc #@row.GrocyLocationId</span>
        }
    </td>

    <td class="data-grid__cell">
        <div style="display: flex; flex-wrap: wrap; gap: 0.25rem">
            @if (hasCollision)
            {
                <span class="badge badge--danger" style="font-size: 0.7rem" title="A product with this name already exists in the catalog">name collision</span>
            }
            @if (row.IsMultiUnit && row.SynthesizedSku is { } sku)
            {
                <span class="badge badge--info"
                      style="font-size: 0.7rem"
                      title="Purchase unit '@sku.Label' differs from stock unit — SKU will be synthesized (@sku.SizeQuantity × stock unit)">
                    multi-unit
                </span>
            }
            @if (isVariant)
            {
                <span class="badge badge--neutral" style="font-size: 0.7rem" title="This product is a variant of another">variant</span>
            }
            @if (row.HasDroppedBarcode)
            {
                <span class="badge badge--warning" style="font-size: 0.7rem" title="Grocy had barcodes for this product — barcodes are not imported to Plantry">barcode</span>
            }
            @if (row.HasCrosswalkMissing)
            {
                <span class="badge badge--warning" style="font-size: 0.7rem" title="A unit, category, or location crosswalk entry is missing">crosswalk?</span>
            }
            @if (!isFlagged)
            {
                <span class="badge badge--success" style="font-size: 0.7rem">ok</span>
            }
        </div>
    </td>
</tr>
