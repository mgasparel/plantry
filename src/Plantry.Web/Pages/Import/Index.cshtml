@page
@model Plantry.Web.Pages.Import.IndexModel
@{
    ViewData["Title"] = "Import from Grocy";
}

@*
    Grocy import pipeline — Extract entry point (plantry-zcw.1).
    Shows the 'Extract from Grocy' action and collection counts from the most recent manifest.
    Subsequent pipeline stages (Stage → Reconcile → Commit) live in sibling pages.
*@

<div class="catalog-section">
    <h1>Import from Grocy</h1>
    <p>Extract a snapshot of your Grocy data — products, units, recipes, and more — then work
       through the mapping grids to reconcile them with your Plantry catalog.</p>
</div>

@if (Model.ErrorMessage is not null)
{
    <div class="alert alert--danger" role="alert">
        <strong>Extraction failed.</strong> @Model.ErrorMessage
    </div>
}

<div class="card" style="max-width: 48rem">
    <div class="card__head">
        <div>
            <h3 class="card__head-title">Step 1 — Extract</h3>
            <p class="card__head-sub">Fetch a live snapshot from Grocy and save it as a manifest file.</p>
        </div>
    </div>
    <div class="card__body">
        @if (!Model.GrocyConfigured)
        {
            <div class="empty-state">
                <svg class="empty-state__icon" aria-hidden="true"><use href="#i-lock" /></svg>
                <div class="empty-state__title">Grocy isn't configured</div>
                <p class="empty-state__body">
                    Set your Grocy URL and API key with user secrets before extracting:
                    <code>dotnet user-secrets set "Grocy:Url" "https://grocy.example.com"</code><br />
                    <code>dotnet user-secrets set "Grocy:ApiKey" "&lt;your-key&gt;"</code>
                </p>
            </div>
        }
        else
        {
            <form method="post" asp-page-handler="Extract">
                @Html.AntiForgeryToken()
                <div style="display: flex; align-items: center; gap: 1rem; flex-wrap: wrap">
                    <button type="submit" class="btn btn--primary">
                        Extract from Grocy
                    </button>
                    @if (Model.ManifestExists)
                    {
                        <span style="font-size: 13px; color: var(--color-text-faint)">
                            Last extracted: @Model.ManifestExtractedAt?.ToString("yyyy-MM-dd HH:mm") UTC
                        </span>
                    }
                </div>
            </form>
        }
    </div>
</div>

@if (Model.ManifestExists && Model.CollectionGrid is not null)
{
    <div class="card" style="max-width: 48rem; margin-top: 1.5rem">
        <div class="card__head">
            <div>
                <h3 class="card__head-title">Manifest contents</h3>
                <p class="card__head-sub">@Model.ManifestPath</p>
            </div>
        </div>
        <div class="card__body">
            <partial name="Shared/_DataGrid" model="Model.CollectionGrid" />
        </div>
    </div>

    <div class="card" style="max-width: 48rem; margin-top: 1.5rem">
        <div class="card__head">
            <div>
                <h3 class="card__head-title">Step 2 — Unit Mapping</h3>
                <p class="card__head-sub">Map Grocy units to Plantry units and commit the crosswalk.</p>
            </div>
        </div>
        <div class="card__body">
            <a href="/Import/Units" class="btn btn--primary">Open unit mapping grid →</a>
        </div>
    </div>

    <div class="card" style="max-width: 48rem; margin-top: 1.5rem">
        <div class="card__head">
            <div>
                <h3 class="card__head-title">Step 3 — Category Mapping</h3>
                <p class="card__head-sub">Map Grocy product groups to Plantry categories and commit the crosswalk.</p>
            </div>
        </div>
        <div class="card__body">
            <a href="/Import/Categories" class="btn btn--primary">Open category mapping grid →</a>
        </div>
    </div>

    <div class="card" style="max-width: 48rem; margin-top: 1.5rem">
        <div class="card__head">
            <div>
                <h3 class="card__head-title">Step 4 — Location Mapping</h3>
                <p class="card__head-sub">Map Grocy locations to Plantry locations and commit the crosswalk.</p>
            </div>
        </div>
        <div class="card__body">
            <a href="/Import/Locations" class="btn btn--primary">Open location mapping grid →</a>
        </div>
    </div>

    <div class="card" style="max-width: 48rem; margin-top: 1.5rem">
        <div class="card__head">
            <div>
                <h3 class="card__head-title">Step 5 — Product Review</h3>
                <p class="card__head-sub">Review all 215 staged products, resolve name collisions, and inspect multi-unit and variant flags before committing.</p>
            </div>
        </div>
        <div class="card__body">
            <a href="/Import/Products" class="btn btn--primary">Open product review →</a>
        </div>
    </div>

    <div class="card" style="max-width: 48rem; margin-top: 1.5rem">
        <div class="card__head">
            <div>
                <h3 class="card__head-title">Step 6 — Recipe Review</h3>
                <p class="card__head-sub">Review all 65 staged recipes: inspect flattened nestings, dropped ingredient notes, and produces-product flags before committing.</p>
            </div>
        </div>
        <div class="card__body">
            <a href="/Import/Recipes" class="btn btn--primary">Open recipe review →</a>
        </div>
    </div>
}
