@page
@model Plantry.Web.Pages.More.IndexModel
@{
    ViewData["Title"] = "More";
    var tidyUpBadge = new Plantry.Web.Pages.Shared.TidyUpBadgeViewModel(Model.TidyUpCount, "more-tidyup-badge", false);
}

<page-header title="More" subtitle="Pantry, catalog, and settings — the rest of Plantry in one place." />

<nav class="hub-list" aria-label="More options">
    <a href="/Pantry" class="hub-list__item">
        <span class="hub-list__icon"><svg class="icon" aria-hidden="true"><use href="#i-pantry" /></svg></span>
        <div class="hub-list__text">
            <span class="hub-list__label">Pantry</span>
            <span class="hub-list__sub">Your stock and inventory</span>
        </div>
        <svg class="icon hub-list__chevron" aria-hidden="true"><use href="#i-chevron-right" /></svg>
    </a>
    <a href="/Catalog" class="hub-list__item">
        <span class="hub-list__icon"><svg class="icon" aria-hidden="true"><use href="#i-tag" /></svg></span>
        <div class="hub-list__text">
            <span class="hub-list__label">Catalog</span>
            <span class="hub-list__sub">Products, categories, units &amp; locations</span>
        </div>
        <svg class="icon hub-list__chevron" aria-hidden="true"><use href="#i-chevron-right" /></svg>
    </a>
    <a href="/TidyUp" class="hub-list__item">
        <span class="hub-list__icon"><svg class="icon" aria-hidden="true"><use href="#i-broom" /></svg></span>
        <div class="hub-list__text">
            <span class="hub-list__label">Tidy Up</span>
            <span class="hub-list__sub">Small data gaps left over from quick entry</span>
        </div>
        <partial name="_TidyUpBadge" model="tidyUpBadge" />
        <svg class="icon hub-list__chevron" aria-hidden="true"><use href="#i-chevron-right" /></svg>
    </a>
    <a href="/Settings" class="hub-list__item">
        <span class="hub-list__icon"><svg class="icon" aria-hidden="true"><use href="#i-settings" /></svg></span>
        <div class="hub-list__text">
            <span class="hub-list__label">Settings</span>
            <span class="hub-list__sub">Account and household settings</span>
        </div>
        <svg class="icon hub-list__chevron" aria-hidden="true"><use href="#i-chevron-right" /></svg>
    </a>
</nav>
