@model Plantry.Web.Pages.Settings.TagStanceRowViewModel
@* Single tag row — htmx swap target for per-tag stance changes.
   The id attribute is the htmx target: hx-target="#tag-row-{TagId}".
   Alpine handles the optimistic saved-flash (auto-fades after 1400 ms).

   This is a component in the Dev library (StanceScale + tag-row patterns — see Dev/Index.cshtml).
*@
@{
    var rowId = $"tag-row-{Model.TagId}";
    // (value, label, data-tone, isHard) — ordered Required→Restricted (hard-positive→hard-negative)
    var stanceOptions = new[]
    {
        ("Required",   "Required",   "good",      true),
        ("Preferred",  "Preferred",  "good-soft", false),
        ("Neutral",    "Neutral",    "neutral",   false),
        ("Disliked",   "Disliked",   "warn",      false),
        ("Restricted", "Restricted", "bad",       true),
    };
    var touched = Model.Stance != "Neutral";
    var encodedName = Uri.EscapeDataString(Model.TagName ?? "");
}

<div class="tag-row @(touched ? "touched" : "")"
     id="@rowId"
     x-data="{ saved: @Model.Saved.ToString().ToLower() }"
     x-init="if (saved) { setTimeout(() => saved = false, 1400) }">
    <div class="tag-name">
        <span class="tdot" aria-hidden="true"></span>
        <span class="tn">@Model.TagName</span>
        <span class="tag-saved @(Model.Saved ? "show" : "")" x-bind:class="saved ? 'show' : ''" aria-live="polite">
            <svg class="icon" aria-hidden="true" style="width:13px;height:13px"><use href="#i-check" /></svg>
            Saved
        </span>
    </div>
    @* 5-segment StanceScale — canonical component (see Dev component library) *@
    <div class="stance" role="radiogroup" aria-label="Stance for @Model.TagName">
        @foreach (var (value, label, tone, isHard) in stanceOptions)
        {
            var isOn = Model.Stance == value;
            <button type="button"
                    role="radio"
                    aria-checked="@isOn.ToString().ToLower()"
                    title="@label"
                    data-tone="@tone"
                    class="stance-seg @(isOn ? "on" : "") @(isHard ? "hard" : "")"
                    hx-post="/Settings/Preferences?handler=Stance&tagId=@Model.TagId&stance=@value&tagName=@encodedName"
                    hx-target="#@rowId"
                    hx-swap="outerHTML"
                    hx-include="[name='__RequestVerificationToken']">
                @label
            </button>
        }
    </div>
</div>
