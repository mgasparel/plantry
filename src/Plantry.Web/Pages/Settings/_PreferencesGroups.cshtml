@model Plantry.MealPlanning.Application.PreferencesViewModel

<div id="prefs-groups">
    @foreach (var group in Model.Groups)
    {
        @* dot color: oklch(0.62 0.13 HUE) matches plan-data.js tagDot() *@
        var dotStyle = group.CategoryHue.HasValue
            ? $"background: oklch(0.62 0.13 {group.CategoryHue})"
            : "background: var(--color-text-faint)";
        @* stable slug id for OOB swaps — single source of truth: PreferencesModel.CategorySlug *@
        var catSlug = Plantry.Web.Pages.Settings.PreferencesModel.CategorySlug(group.Category);

        <div class="tag-cat card">
            <div class="card-head">
                <span class="cat-mark" style="@dotStyle" aria-hidden="true"></span>
                <h3>@group.Category</h3>
                <div class="spacer"></div>
                <partial name="Settings/_PrefsCatCount"
                         model="@(new Plantry.Web.Pages.Settings.PrefsCatCountViewModel(catSlug, group.SetCount))" />
            </div>
            <div class="tag-rows">
                @foreach (var tag in group.Tags)
                {
                    <partial name="Settings/_TagStanceRow"
                             model="@(new Plantry.Web.Pages.Settings.TagStanceRowViewModel(tag.TagId, tag.Name, tag.Stance, Saved: false))" />
                }
            </div>
        </div>
    }
</div>
