@page
@model Plantry.Web.Pages.Settings.PreferencesModel
@{
    ViewData["Title"] = "Dietary preferences";
}

@* ── Config page chrome (matches ClaudeDesignProto/prefs.jsx cfg-wrap + cfg-head) ─────────── *@
<div class="cfg-wrap" data-screen-label="Dietary preferences">
    <div class="cfg-head">
        <div class="eyebrow">Personal profile</div>
        <h1>Dietary preferences</h1>
        <p>
            Set your stance on each food tag. The planner reads these to keep meals within
            everyone&rsquo;s needs &mdash; allergies and hard rules are binding, soft preferences just
            nudge the suggestions.
        </p>
    </div>

    @if (Model.ViewModel is null || Model.ViewModel.Groups.Count == 0)
    {
        <div class="catalog-section">
            <p class="catalog-section__empty">No food tags are defined yet. Add tags when authoring recipes.</p>
        </div>
    }
    else
    {
        @* ── Member tab strip (visual; edits scoped to signed-in user only) ─── *@
        <div class="mem-tabs" role="tablist" aria-label="Household member">
            @foreach (var member in Model.ViewModel.Members)
            {
                var isYou = member.UserId == Model.CurrentUserId;
                <div role="tab" aria-selected="@isYou.ToString().ToLower()"
                     class="mem-tab @(isYou ? "on" : "")">
                    <span class="pl-av" aria-hidden="true"
                          style="width:26px;height:26px;font-size:11px;background:var(--color-accent-subtle);color:var(--color-accent)">@member.Initials</span>
                    <span class="mt-name">
                        @member.DisplayName
                        @if (isYou)
                        {
                            <span class="mt-you">You</span>
                        }
                    </span>
                </div>
            }
        </div>

        @* ── Scale legend (matches ClaudeDesignProto/prefs.jsx scale-legend) ─── *@
        <div class="scale-legend" aria-label="The stance scale">
            <span class="sl-title">The scale</span>
            <span class="legend-chip legend-chip--good">
                <span class="lc-dot"></span>Required
                <span class="lc-hard">· binding</span>
            </span>
            <span class="sl-arrow" aria-hidden="true"></span>
            <span class="legend-chip legend-chip--good-soft">
                <span class="lc-dot"></span>Preferred
            </span>
            <span class="sl-arrow" aria-hidden="true"></span>
            <span class="legend-chip legend-chip--neutral">
                <span class="lc-dot"></span>Neutral
            </span>
            <span class="sl-arrow" aria-hidden="true"></span>
            <span class="legend-chip legend-chip--warn">
                <span class="lc-dot"></span>Disliked
            </span>
            <span class="sl-arrow" aria-hidden="true"></span>
            <span class="legend-chip legend-chip--bad">
                <span class="lc-dot"></span>Restricted
                <span class="lc-hard">· binding</span>
            </span>
        </div>

        @* ── Progress meta line ─────────────────────────────────────────────── *@
        @Html.Partial("Settings/_PrefsMeta", new Plantry.Web.Pages.Settings.PrefsMetaViewModel(
            (Model.ViewModel!.Members.FirstOrDefault(m => m.UserId == Model.CurrentUserId)?.Initials) ?? "Y",
            (Model.ViewModel.Members.FirstOrDefault(m => m.UserId == Model.CurrentUserId)?.DisplayName) ?? "You",
            Model.ViewModel.SetCount,
            Model.ViewModel.TotalTags))

        @* ── Tag groups ────────────────────────────────────────────────────── *@
        <partial name="Settings/_PreferencesGroups" model="Model.ViewModel" />
    }
</div>
