@page
@model Plantry.Web.Pages.Settings.IndexModel
@{
    ViewData["Title"] = "Settings";
}

<page-header title="Settings" subtitle="Household and meal planning preferences." />

<section class="catalog-section">
    <h2 class="catalog-section__heading">Household</h2>
    <nav class="hub-list" aria-label="Household settings">
        <a href="/Settings/Members" class="hub-list__item">
            <span class="hub-list__icon"><svg class="icon" aria-hidden="true"><use href="#i-users" /></svg></span>
            <div class="hub-list__text">
                <span class="hub-list__label">Members</span>
                <span class="hub-list__sub">Invite people to your household and manage who has access</span>
            </div>
            <svg class="icon hub-list__chevron" aria-hidden="true"><use href="#i-chevron-right" /></svg>
        </a>
        <a href="/Settings/Currency" class="hub-list__item">
            <span class="hub-list__icon"><svg class="icon" aria-hidden="true"><use href="#i-coins" /></svg></span>
            <div class="hub-list__text">
                <span class="hub-list__label">Display currency</span>
                <span class="hub-list__sub">Choose the currency Plantry shows budgets, recipe costs, and deal prices in</span>
            </div>
            <svg class="icon hub-list__chevron" aria-hidden="true"><use href="#i-chevron-right" /></svg>
        </a>
    </nav>
</section>

<section class="catalog-section">
    <h2 class="catalog-section__heading">Recipes &amp; meal planning</h2>
    <nav class="hub-list" aria-label="Recipes and meal planning settings">
        <a href="/Settings/Tags" class="hub-list__item">
            <span class="hub-list__icon"><svg class="icon" aria-hidden="true"><use href="#i-tag" /></svg></span>
            <div class="hub-list__text">
                <span class="hub-list__label">Tags</span>
                <span class="hub-list__sub">Define and manage the tags your household uses on recipes</span>
            </div>
            <svg class="icon hub-list__chevron" aria-hidden="true"><use href="#i-chevron-right" /></svg>
        </a>
        <a href="/Settings/MealSlots" class="hub-list__item">
            <span class="hub-list__icon"><svg class="icon" aria-hidden="true"><use href="#i-clock" /></svg></span>
            <div class="hub-list__text">
                <span class="hub-list__label">Meal slots</span>
                <span class="hub-list__sub">Configure the daily meals your household plans</span>
            </div>
            <svg class="icon hub-list__chevron" aria-hidden="true"><use href="#i-chevron-right" /></svg>
        </a>
        <a href="/Settings/Preferences" class="hub-list__item">
            <span class="hub-list__icon"><svg class="icon" aria-hidden="true"><use href="#i-leaf" /></svg></span>
            <div class="hub-list__text">
                <span class="hub-list__label">Dietary preferences</span>
                <span class="hub-list__sub">Set your stance on food tags &mdash; the AI planner reads these to keep meals within everyone&rsquo;s needs</span>
            </div>
            <svg class="icon hub-list__chevron" aria-hidden="true"><use href="#i-chevron-right" /></svg>
        </a>
        <a href="/Settings/MealPlanning" class="hub-list__item">
            <span class="hub-list__icon"><svg class="icon" aria-hidden="true"><use href="#i-calendar" /></svg></span>
            <div class="hub-list__text">
                <span class="hub-list__label">Meal planning defaults</span>
                <span class="hub-list__sub">Set the household default weekly budget and AI planning priorities</span>
            </div>
            <svg class="icon hub-list__chevron" aria-hidden="true"><use href="#i-chevron-right" /></svg>
        </a>
    </nav>
</section>

<section class="catalog-section">
    <h2 class="catalog-section__heading">Pantry, AI &amp; deals</h2>
    <nav class="hub-list" aria-label="Pantry, AI, and deals settings">
        <a href="/Settings/Pantry" class="hub-list__item">
            <span class="hub-list__icon"><svg class="icon" aria-hidden="true"><use href="#i-timer" /></svg></span>
            <div class="hub-list__text">
                <span class="hub-list__label">Expiring soon</span>
                <span class="hub-list__sub">Set how many days ahead stock counts as expiring soon &mdash; drives the Today list, pantry badges, and the recipe &ldquo;use soon&rdquo; filter</span>
            </div>
            <svg class="icon hub-list__chevron" aria-hidden="true"><use href="#i-chevron-right" /></svg>
        </a>
        <a href="/Settings/Ai" class="hub-list__item">
            <span class="hub-list__icon"><svg class="icon" aria-hidden="true"><use href="#i-sparkle" /></svg></span>
            <div class="hub-list__text">
                <span class="hub-list__label">AI assistance</span>
                <span class="hub-list__sub">Turn AI-assisted suggestions and conversions on or off &mdash; receipt scanning is separate and always available</span>
            </div>
            <svg class="icon hub-list__chevron" aria-hidden="true"><use href="#i-chevron-right" /></svg>
        </a>
        <a href="/Settings/StoresAndDeals" class="hub-list__item">
            <span class="hub-list__icon"><svg class="icon" aria-hidden="true"><use href="#i-cart" /></svg></span>
            <div class="hub-list__text">
                <span class="hub-list__label">Stores &amp; Deals</span>
                <span class="hub-list__sub">Choose which stores Plantry pulls weekly flyer deals from</span>
            </div>
            <svg class="icon hub-list__chevron" aria-hidden="true"><use href="#i-chevron-right" /></svg>
        </a>
    </nav>
</section>
