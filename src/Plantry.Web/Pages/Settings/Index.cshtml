@page
@model Plantry.Web.Pages.Settings.IndexModel
@{
    ViewData["Title"] = "Settings";
}

<section class="catalog-section">
    <h2 class="catalog-section__heading">Settings</h2>
    <p>Household and meal planning preferences.</p>
</section>

<section class="catalog-section">
    <h2 class="catalog-section__heading">Household</h2>
    <ul class="catalog-list" role="list">
        <li class="catalog-list__item">
            <a class="catalog-list__primary" href="/Settings/Members">Members</a>
            <span class="catalog-list__secondary">Invite people to your household and manage who has access</span>
        </li>
    </ul>
</section>

@* Meal Planning group (catalog-list pattern — mirrors Catalog/Index.cshtml, per the IA decision). *@
<section class="catalog-section">
    <h2 class="catalog-section__heading">Recipes</h2>
    <ul class="catalog-list" role="list">
        <li class="catalog-list__item">
            <a class="catalog-list__primary" href="/Settings/Tags">Tags</a>
            <span class="catalog-list__secondary">Define and manage the tags your household uses on recipes</span>
        </li>
    </ul>
</section>

<section class="catalog-section">
    <h2 class="catalog-section__heading">Meal Planning</h2>
    <ul class="catalog-list" role="list">
        <li class="catalog-list__item">
            <a class="catalog-list__primary" href="/Settings/MealSlots">Meal slots</a>
            <span class="catalog-list__secondary">Configure the daily meals your household plans</span>
        </li>
        <li class="catalog-list__item">
            <a class="catalog-list__primary" href="/Settings/Preferences">Dietary preferences</a>
            <span class="catalog-list__secondary">Set your stance on food tags — the AI planner reads these to keep meals within everyone&rsquo;s needs</span>
        </li>
        <li class="catalog-list__item">
            <a class="catalog-list__primary" href="/Settings/MealPlanning">Meal planning defaults</a>
            <span class="catalog-list__secondary">Set the household default weekly budget and AI planning priorities</span>
        </li>
    </ul>
</section>

<section class="catalog-section">
    <h2 class="catalog-section__heading">Pantry</h2>
    <ul class="catalog-list" role="list">
        <li class="catalog-list__item">
            <a class="catalog-list__primary" href="/Settings/Pantry">Expiring soon</a>
            <span class="catalog-list__secondary">Set how many days ahead stock counts as expiring soon &mdash; drives the Today list, pantry badges, and the recipe &ldquo;use soon&rdquo; filter</span>
        </li>
    </ul>
</section>

<section class="catalog-section">
    <h2 class="catalog-section__heading">AI</h2>
    <ul class="catalog-list" role="list">
        <li class="catalog-list__item">
            <a class="catalog-list__primary" href="/Settings/Ai">AI assistance</a>
            <span class="catalog-list__secondary">Turn AI-assisted suggestions and conversions on or off &mdash; receipt scanning is separate and always available</span>
        </li>
    </ul>
</section>

<section class="catalog-section">
    <h2 class="catalog-section__heading">Deals</h2>
    <ul class="catalog-list" role="list">
        <li class="catalog-list__item">
            <a class="catalog-list__primary" href="/Settings/StoresAndDeals">Stores &amp; Deals</a>
            <span class="catalog-list__secondary">Choose which stores Plantry pulls weekly flyer deals from</span>
        </li>
    </ul>
</section>
