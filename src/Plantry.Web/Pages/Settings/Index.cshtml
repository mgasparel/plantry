@page
@model Plantry.Web.Pages.Settings.IndexModel
@{
    ViewData["Title"] = "Settings";
}

<section class="catalog-section">
    <h2 class="catalog-section__heading">Settings</h2>
    <p>Household and meal planning preferences.</p>
</section>

@* P3-2 (plantry-e78) will add the Dietary Preferences sub-page and hub link.
   Hub entries added per slice — P3-0 left this empty intentionally. *@

<section class="catalog-section">
    <h3 class="catalog-section__heading">Meal Planning</h3>
    <ul class="settings-hub-list">
        <li>
            <a href="/Settings/MealSlots" class="settings-hub-link">
                <span class="settings-hub-link__title">Meal slots</span>
                <span class="settings-hub-link__sub">Configure the daily meals your household plans</span>
                <svg class="icon settings-hub-link__arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
            </a>
        </li>
    </ul>
</section>
