@page
@model Plantry.Web.Pages.Settings.CurrencyModel
@{
    ViewData["Title"] = "Display currency";
}

<div class="cfg-wrap" data-screen-label="Display currency">
    <div class="cfg-head">
        <div class="eyebrow">Household setup</div>
        <h1>Display currency</h1>
        <p>
            The currency Plantry shows money in &mdash; your weekly budget, recipe costs, and deal
            prices. Changing it never rewrites amounts you&rsquo;ve already saved; each keeps its own
            currency until you save it again.
        </p>
    </div>

    <form method="post" class="form-stack">
        <div class="card" style="max-width: 40rem">
            <div class="card__head">
                <div>
                    <h3 class="card__head-title">Display currency</h3>
                    <p class="card__head-sub">Applies household-wide.</p>
                </div>
            </div>
            <div class="card__body">
                <div class="field">
                    <label class="field__label" for="Currency">Currency</label>
                    <select id="Currency" name="Currency" class="field__input" style="width:auto">
                        @foreach (var option in Plantry.Web.Pages.Settings.CurrencyModel.Options)
                        {
                            <option value="@option.Code" selected="@(option.Code == Model.Currency)">@option.Label</option>
                        }
                    </select>
                    <span asp-validation-for="Currency" class="field__error"></span>
                </div>
            </div>
        </div>

        @if (Model.Saved)
        {
            @await Html.PartialAsync("Settings/_SettingSaved", "Setting saved")
        }

        <button type="submit" class="btn btn--primary">Save</button>
    </form>
</div>
