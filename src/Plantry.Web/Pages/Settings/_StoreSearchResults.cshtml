@model Plantry.Web.Pages.Settings.StoresAndDealsModel

@{
    var subscribedStoreNames = Model.Subscriptions
        .Where(s => s.IsActive)
        .Select(s => s.StoreName)
        .ToHashSet(StringComparer.OrdinalIgnoreCase);
}

@if (!Model.Searched)
{
    <p class="store-search__hint">Enter a postal code and search to find stores near you.</p>
}
else if (Model.SearchResults.Count == 0)
{
    <p class="store-search__hint">No stores found for that search. Flipp couldn&rsquo;t match a merchant —
        try a different postal code or store name.</p>
}
else
{
    <ul class="catalog-list store-results" role="list">
        @foreach (var merchant in Model.SearchResults)
        {
            var alreadySubscribed = subscribedStoreNames.Contains(merchant.Name);
            <partial name="_StoreSearchResultItem"
                     model="new Plantry.Web.Pages.Settings.StoreResultItem(
                         merchant.ExternalRef, merchant.Name, Model.PostalCode, alreadySubscribed)" />
        }
    </ul>
}
