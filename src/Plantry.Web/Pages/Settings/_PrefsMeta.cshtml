@model Plantry.Web.Pages.Settings.PrefsMetaViewModel
@* Progress meta line — htmx OOB swap target (id=prefs-meta).
   Rendered inline on GET and swapped out-of-band on every stance POST.
   See OnPostStanceAsync in Preferences.cshtml.cs.
*@
<div class="prefs-meta" id="prefs-meta">
    <span class="pl-av" aria-hidden="true"
          style="width:20px;height:20px;font-size:10px;background:var(--color-accent-subtle);color:var(--color-accent)">@Model.Initials</span>
    <span><b>@Model.DisplayName</b> (You)</span>
    <span class="pm-dot" aria-hidden="true"></span>
    <span><b>@Model.SetCount</b> of @Model.TotalTags tags set &middot; @Model.NeutralCount neutral</span>
    <form method="post" asp-page-handler="Reset"
          hx-post="/Settings/Preferences?handler=Reset"
          hx-target="#prefs-groups"
          hx-swap="outerHTML">
        @Html.AntiForgeryToken()
        <button type="submit" class="reset-link"
                @(Model.SetCount == 0 ? "disabled" : "")>
            Reset to neutral
        </button>
    </form>
</div>
