@page
@model Plantry.Web.Pages.Shopping.IndexModel
@{
    ViewData["Title"] = "Shopping";
    var list = Model.ShoppingList;
    var activeCount = list is not null ? list.TotalCount - list.CheckedCount : 0;
    var checkedCount = list?.CheckedCount ?? 0;
    var totalCount = list?.TotalCount ?? 0;
}

<div class="sl-wrap">
    @* ── Header (sl-head) ──────────────────────────────────────────────── *@
    <div class="sl-head">
        <div>
            <h1>Shopping List</h1>
            <p>One shared list for your household &middot; grouped by aisle.</p>
        </div>
        <div class="spacer"></div>
        <div class="sl-summary">
            <div class="ss">
                <div class="n">@activeCount</div>
                <div class="l">to buy</div>
            </div>
            <div class="ss done">
                <div class="n">@checkedCount</div>
                <div class="l">checked</div>
            </div>
            <div class="ss">
                <div class="n">@totalCount</div>
                <div class="l">total</div>
            </div>
        </div>
    </div>

    @* ── Add item form (sl-add card, SPEC §3b) ─────────────────────────── *@
    @* Extracted to _AddForm so an AddItem POST can swap it out-of-band — clearing it on
       success or re-rendering it with validation errors on failure (plantry-3dh.1 A/B/C). *@
    <div class="sl-add">
        <partial name="_AddForm" model="Model" />
    </div>

    @* ── Shopping list fragment (groups + checked + empty) ─────────────── *@
    <partial name="_ShoppingList"
             model="new Plantry.Web.Pages.Shopping.ShoppingListPartialModel(Model.ShoppingList, Model.ProductOptions, Model.UnitOptions, Model.CategoryOptions, Model.UnitOptionsList, Model.Suggestions, false)" />
</div>
