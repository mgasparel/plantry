@page
@model Plantry.Web.Pages.Shopping.IndexModel
@{
    ViewData["Title"] = "Shopping";
}

<div class="sl-wrap">
    @* ── Header (sl-head) ──────────────────────────────────────────────── *@
    <div class="sl-head">
        <div>
            <h1>Shopping List</h1>
            <p>One shared list for your household &middot; grouped by aisle.</p>
        </div>
        <div class="spacer"></div>
        @* Summary stat box extracted to a partial so every mutation handler can OOB-swap
           #sl-summary and keep to-buy / checked / total counts live (plantry-3dh.2 A). *@
        <partial name="_ShoppingSummary"
                 model="new Plantry.Web.Pages.Shopping.ShoppingSummaryPartialModel(Model.ShoppingList, false)" />
    </div>

    @* ── Add item form (sl-add card, SPEC §3b) ─────────────────────────── *@
    @* Extracted to _AddForm so an AddItem POST can swap it out-of-band — clearing it on
       success or re-rendering it with validation errors on failure (plantry-3dh.1 A/B/C). *@
    <div class="sl-add">
        <partial name="_AddForm" model="Model" />
    </div>

    @* ── Pantry suggestions strip (plantry-48l / plantry-14q) ──────────── *@
    @* Decoupled from #shopping-list; lives in its own #pantry-suggestions container.
       Only recomputed/re-rendered by the 3 handlers that change onListProductIds
       (product-backed AddItem, DeleteItem, ClearChecked) via OOB swap. *@
    <partial name="_PantrySuggestions"
             model="new Plantry.Web.Pages.Shopping.PantrySuggestionsPartialModel(Model.Suggestions, false)" />

    @* ── Shopping list fragment (groups + checked + empty) ─────────────── *@
    <partial name="_ShoppingList"
             model="new Plantry.Web.Pages.Shopping.ShoppingListPartialModel(Model.ShoppingList, Model.ProductOptions, Model.UnitOptions, Model.CategoryOptions, Model.UnitOptionsList, false)" />
</div>
