@using Plantry.Web.Pages.Shopping
@model IndexModel
@*
    Response for an AddItem POST. Renders two top-level fragments:
      1. #shopping-list — the refreshed list, swapped into the form's hx-target (main swap).
      2. #add-item-form — the add form with hx-swap-oob, swapped in place so it resets on
         success (Input was cleared by the handler) or shows validation errors on failure.
    Together these deliver plantry-3dh.1 items A (clear on success) and C (validation feedback).
*@
<partial name="_ShoppingList"
         model="new ShoppingListPartialModel(Model.ShoppingList, Model.ProductOptions, Model.UnitOptions, Model.CategoryOptions, Model.UnitOptionsList, Model.Suggestions, false)" />
@{ ViewData["FormOob"] = true; }
<partial name="_AddForm" model="Model" />
