@using Plantry.Web.Pages.Shopping
@model IndexModel
@*
    Response for an AddItem POST. Renders three or four top-level fragments:
      1. #shopping-list    — the refreshed list, swapped into the form's hx-target (main swap).
      2. #add-item-form    — the add form with hx-swap-oob, swapped in place so it resets on
         success (Input was cleared by the handler) or shows validation errors on failure.
      3. #sl-summary       — OOB swap to keep the header stat box live (plantry-3dh.2 A).
      4. #pantry-suggestions — OOB swap, emitted only for product-backed adds (Model.SuggestionsOob).
    Together these deliver plantry-3dh.1 items A (clear on success) and C (validation feedback),
    plantry-14q (decouple suggestions strip from list swap), and plantry-3dh.2 A (live totals).
*@
<partial name="_ShoppingList"
         model="new ShoppingListPartialModel(Model.ShoppingList, Model.ProductOptions, Model.UnitOptions, Model.CategoryOptions, Model.UnitOptionsList, false)" />
@{ ViewData["FormOob"] = true; }
<partial name="_AddForm" model="Model" />
<partial name="_ShoppingSummary"
         model="new ShoppingSummaryPartialModel(Model.ShoppingList, true)" />
@if (Model.SuggestionsOob)
{
    <partial name="_PantrySuggestions"
             model="new PantrySuggestionsPartialModel(Model.Suggestions, true)" />
}
