@using Plantry.Shopping.Application
@using System.Text.Json
@model ShoppingListItemView

@{
    var doneClass = Model.IsChecked ? " done" : "";
    var checkOnClass = Model.IsChecked ? " on" : "";
    var isFreeText = Model.ProductId is null && Model.FreeText is not null;
    var checkOffUrl = Url.Page("./Index", "CheckOff", new { listId = Model.ListId, itemId = Model.ItemId });
    var uncheckUrl = Url.Page("./Index", "UncheckItem", new { listId = Model.ListId, itemId = Model.ItemId });
    var deleteUrl = Url.Page("./Index", "DeleteItem", new { listId = Model.ListId, itemId = Model.ItemId });
    var editQtyUrl = Url.Page("./Index", "EditQuantity", new { listId = Model.ListId, itemId = Model.ItemId });
    var setNoteUrl = Url.Page("./Index", "SetNote", new { listId = Model.ListId, itemId = Model.ItemId });
    var hasNote = !string.IsNullOrWhiteSpace(Model.Note);
    // The toggle posts to the uncheck handler if checked, or the check-off handler if unchecked.
    var toggleUrl = Model.IsChecked ? uncheckUrl : checkOffUrl;
    // Alpine x-data: use JsonSerializer so Razor HTML-encodes the quotes correctly.
    // Never use @Html.Raw(JsonSerializer...) inside a double-quoted x-data attribute.
    var currentQty = Model.Quantity.HasValue ? Model.Quantity.Value.ToString("0.###") : "";
    var currentNote = Model.Note ?? "";
    // Serialize booleans for Alpine — plain JS literals, no string wrapping needed.
}

<div class="sl-item@(doneClass)"
     id="shopping-item-@Model.ItemId"
     x-data="{ editingQty: false, editingNote: false, qty: @(JsonSerializer.Serialize(currentQty)), note: @(JsonSerializer.Serialize(currentNote)) }"
     x-on:keydown.escape.window="editingQty = false; editingNote = false">
    @* Square check toggle (SPEC §3c): posts check-off or uncheck depending on current state. *@
    <button type="button"
            class="sl-check@(checkOnClass)"
            hx-post="@toggleUrl"
            hx-target="#shopping-list"
            hx-swap="outerHTML"
            aria-label="@(Model.IsChecked ? "Uncheck" : "Check off") @Model.DisplayName">
        <svg class="icon" aria-hidden="true"><use href="#i-check" /></svg>
    </button>

    <div class="sl-body">
        <div class="sl-name">
            @Model.DisplayName
            @if (isFreeText)
            {
                <span class="free-tag">custom</span>
            }
        </div>
        @if (!Model.IsChecked && (hasNote || Model.HasPantryStock))
        {
            <div class="sl-sub">
                @if (Model.HasPantryStock)
                {
                    if (Model.OnHand > 0)
                    {
                        <span class="sl-instock">@(Model.OnHand!.Value.ToString("0.###")) @Model.PantryUnitCode in pantry</span>
                    }
                    else
                    {
                        <span class="sl-instock out">out</span>
                    }
                    @if (Model.IsLow == true)
                    {
                        <span class="dot" aria-hidden="true"></span>
                        <span class="sl-low">low</span>
                    }
                }
                @if (hasNote && Model.HasPantryStock)
                {
                    <span class="dot" aria-hidden="true"></span>
                }
                @if (hasNote)
                {
                    <span class="sl-note">
                        <svg class="icon" aria-hidden="true"><use href="#i-edit" /></svg>
                        @Model.Note
                    </span>
                }
            </div>
        }

        @* Inline note editor: .sl-noterow expands below the name row when editingNote is true *@
        @if (!Model.IsChecked)
        {
            <div class="sl-noterow" x-show="editingNote" x-cloak>
                <form hx-post="@setNoteUrl"
                      hx-target="#shopping-list"
                      hx-swap="outerHTML"
                      x-on:submit="editingNote = false">
                    @Html.AntiForgeryToken()
                    <input type="text"
                           name="note"
                           class="sl-noteinput"
                           placeholder="Add a note…"
                           maxlength="500"
                           x-model="note"
                           aria-label="Note for @Model.DisplayName" />
                    <button type="submit" class="sl-act save" aria-label="Save note">
                        <svg class="icon" aria-hidden="true"><use href="#i-check" /></svg>
                    </button>
                </form>
            </div>
        }
    </div>

    @* Quantity pill: clicking swaps to the inline stepper when not checked. *@
    @if (!Model.IsChecked)
    {
        @* Read-only pill — shown when not editing *@
        <button type="button"
                class="sl-qty"
                x-show="!editingQty"
                x-on:click="editingQty = true"
                aria-label="Edit quantity for @Model.DisplayName">
            @if (Model.Quantity.HasValue)
            {
                @(Model.Quantity.Value.ToString("0.###"))@(Model.UnitCode is not null ? " " + Model.UnitCode : "")
            }
            else
            {
                <svg class="icon" aria-hidden="true"><use href="#i-edit" /></svg>
                <span>qty</span>
            }
        </button>

        @* Inline quantity editor — shown when editingQty is true *@
        <form class="sl-qtyedit"
              x-show="editingQty"
              x-cloak
              hx-post="@editQtyUrl"
              hx-target="#shopping-list"
              hx-swap="outerHTML"
              x-on:submit="editingQty = false">
            @Html.AntiForgeryToken()
            <div class="sl-qty-stepper">
                <button type="button" class="sl-qbtn" aria-label="Decrease"
                        x-on:click="qty = (+qty - 1) < 0 ? '0' : (+qty - 1).toFixed(3).replace(/\.?0+$/, '') || '0'">
                    <svg class="icon" aria-hidden="true"><use href="#i-minus" /></svg>
                </button>
                <input type="number"
                       name="quantity"
                       min="0"
                       step="any"
                       x-model="qty"
                       aria-label="Quantity" />
                <button type="button" class="sl-qbtn" aria-label="Increase"
                        x-on:click="qty = (+qty + 1).toFixed(3).replace(/\.?0+$/, '') || '1'">
                    <svg class="icon" aria-hidden="true"><use href="#i-plus" /></svg>
                </button>
            </div>
            @* Unit select — plantry-259 will supply the full unit options list.
               For now, render with the current unit as the only option (or no-unit if none set).
               The current unitId is posted back so save is a no-op for the unit. *@
            <select name="unitId" class="sl-qsel" aria-label="Unit">
                @if (Model.UnitId.HasValue)
                {
                    <option value="@Model.UnitId.Value">@(Model.UnitCode ?? Model.UnitId.Value.ToString())</option>
                }
                else
                {
                    <option value="">no unit</option>
                }
            </select>
            <button type="submit" class="sl-act save" aria-label="Save quantity">
                <svg class="icon" aria-hidden="true"><use href="#i-check" /></svg>
            </button>
        </form>
    }
    else
    {
        @* Checked items: read-only qty pill, no editor *@
        @if (Model.Quantity.HasValue)
        {
            <span class="sl-qty">
                @(Model.Quantity.Value.ToString("0.###"))@(Model.UnitCode is not null ? " " + Model.UnitCode : "")
            </span>
        }
    }

    @* Action buttons (hover-revealed). Same .sl-actions group as plantry-853; editor buttons added here (plantry-dem). *@
    <div class="sl-actions" aria-label="Item actions">
        @if (!Model.IsChecked)
        {
            @* Pencil: toggle the note editor inline below the row *@
            <button type="button"
                    class="sl-act"
                    x-on:click="editingNote = !editingNote; if (editingNote) $nextTick(() => $el.closest('.sl-item').querySelector('.sl-noteinput')?.focus())"
                    x-bind:class="editingNote ? 'sl-act active' : 'sl-act'"
                    aria-label="@(hasNote ? "Edit" : "Add") note for @Model.DisplayName">
                <svg class="icon" aria-hidden="true"><use href="#i-edit" /></svg>
            </button>
        }
        @* Delete button: hard-removes this item regardless of checked state. *@
        <button type="button"
                class="sl-act danger"
                hx-post="@deleteUrl"
                hx-target="#shopping-list"
                hx-swap="outerHTML"
                aria-label="Delete @Model.DisplayName">
            <svg class="icon" aria-hidden="true"><use href="#i-trash" /></svg>
        </button>
    </div>
</div>
