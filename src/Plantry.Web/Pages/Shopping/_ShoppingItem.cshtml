@using Plantry.Shopping.Application
@using Plantry.Web.Pages.Shared
@using System.Text.Json
@model Plantry.Web.Pages.Shopping.ShoppingItemPartialModel

@{
    var item = Model.Item;
    var categoryOptions = Model.CategoryOptions;
    var unitOptionsList = Model.UnitOptions;
    var doneClass = item.IsChecked ? " done" : "";
    var checkOnClass = item.IsChecked ? " on" : "";
    var isFreeText = item.ProductId is null && item.FreeText is not null;
    // Show recategorize button only when item has no resolved category and there are categories to pick from.
    var showRecat = !item.IsChecked && item.CategoryName is null && categoryOptions.Count > 0;
    var checkOffUrl = Url.Page("./Index", "CheckOff", new { listId = item.ListId, itemId = item.ItemId });
    var uncheckUrl = Url.Page("./Index", "UncheckItem", new { listId = item.ListId, itemId = item.ItemId });
    var deleteUrl = Url.Page("./Index", "DeleteItem", new { listId = item.ListId, itemId = item.ItemId });
    var editQtyUrl = Url.Page("./Index", "EditQuantity", new { listId = item.ListId, itemId = item.ItemId });
    var setNoteUrl = Url.Page("./Index", "SetNote", new { listId = item.ListId, itemId = item.ItemId });
    var recatUrl = Url.Page("./Index", "Recategorize", new { listId = item.ListId, itemId = item.ItemId });
    var hasNote = !string.IsNullOrWhiteSpace(item.Note);
    // The toggle posts to the uncheck handler if checked, or the check-off handler if unchecked.
    var toggleUrl = item.IsChecked ? uncheckUrl : checkOffUrl;
    // Alpine x-data: use JsonSerializer so Razor HTML-encodes the quotes correctly.
    // Never use @Html.Raw(JsonSerializer...) inside a double-quoted x-data attribute.
    var currentQty = item.Quantity.HasValue ? item.Quantity.Value.ToString("0.###") : "";
    var currentNote = item.Note ?? "";
    // Serialize booleans for Alpine — plain JS literals, no string wrapping needed.
}

<div class="sl-item@(doneClass)"
     id="shopping-item-@item.ItemId"
     x-data="{ editingQty: false, editingNote: false, showRecat: false, qty: @(JsonSerializer.Serialize(currentQty)), note: @(JsonSerializer.Serialize(currentNote)) }"
     x-on:keydown.escape.window="editingQty = false; editingNote = false; showRecat = false">
    @* Square check toggle (SPEC §3c): posts check-off or uncheck depending on current state. *@
    <button type="button"
            class="sl-check@(checkOnClass)"
            hx-post="@toggleUrl"
            hx-target="#shopping-list"
            hx-swap="outerHTML"
            aria-label="@(item.IsChecked ? "Uncheck" : "Check off") @item.DisplayName">
        <svg class="icon" aria-hidden="true"><use href="#i-check" /></svg>
    </button>

    <div class="sl-body">
        <div class="sl-name">
            @item.DisplayName
            @if (isFreeText)
            {
                <span class="free-tag">custom</span>
            }
        </div>
        @{
            var showSubLine = !item.IsChecked && (hasNote || item.HasPantryStock || item.HasAttribution);
            // Tracks whether any sub-line peer has been rendered so we know when to emit a dot separator.
            bool subLineHasPeer = false;
        }
        @if (showSubLine)
        {
            <div class="sl-sub">
                @* Pantry stock sub-line peer *@
                @if (item.HasPantryStock)
                {
                    if (item.OnHand > 0)
                    {
                        <span class="sl-instock">@(item.OnHand!.Value.ToString("0.###")) @item.PantryUnitCode in pantry</span>
                    }
                    else
                    {
                        <span class="sl-instock out">out</span>
                    }
                    @if (item.IsLow == true)
                    {
                        <span class="dot" aria-hidden="true"></span>
                        <span class="sl-low">low</span>
                    }
                    subLineHasPeer = true;
                }
                @* Attribution sub-line peers: "for {Recipe}" / "for {Recipe} ×N" / "added by you" *@
                @if (item.HasAttribution)
                {
                    @foreach (var label in item.AttributionLabels!)
                    {
                        if (subLineHasPeer)
                        {
                            <span class="dot" aria-hidden="true"></span>
                        }
                        <span class="sl-attribution">@label</span>
                        subLineHasPeer = true;
                    }
                }
                @* Note sub-line peer *@
                @if (hasNote)
                {
                    if (subLineHasPeer)
                    {
                        <span class="dot" aria-hidden="true"></span>
                    }
                    <span class="sl-note">
                        <svg class="icon" aria-hidden="true"><use href="#i-edit" /></svg>
                        @item.Note
                    </span>
                }
            </div>
        }

        @* Inline note editor: .sl-noterow expands below the name row when editingNote is true *@
        @if (!item.IsChecked)
        {
            <div class="sl-noterow" x-show="editingNote" x-cloak>
                <form hx-post="@setNoteUrl"
                      hx-target="#shopping-list"
                      hx-swap="outerHTML"
                      x-on:submit="editingNote = false">
                    @Html.AntiForgeryToken()
                    <input type="text"
                           name="note"
                           class="sl-noteinput"
                           placeholder="Add a note…"
                           maxlength="500"
                           x-model="note"
                           aria-label="Note for @item.DisplayName" />
                    <button type="submit" class="sl-act save" aria-label="Save note">
                        <svg class="icon" aria-hidden="true"><use href="#i-check" /></svg>
                    </button>
                </form>
            </div>
        }

        @* Recategorize dropdown (plantry-259): shown only for uncategorized items (CategoryName is null).
           The .sl-recat-menu is position:absolute anchored to .sl-item (position:relative), with
           right:0 so it opens flush with the right edge of the row — directly below the tag button
           in .sl-actions (plantry-3dh.2 B). x-on:click.outside closes it when user clicks elsewhere. *@
        @if (showRecat)
        {
            <div class="sl-recat-menu" x-show="showRecat" x-cloak x-on:click.outside="showRecat = false">
                <div class="sl-recat-head">Move to category</div>
                @foreach (var cat in categoryOptions)
                {
                    <form hx-post="@recatUrl"
                          hx-target="#shopping-list"
                          hx-swap="outerHTML"
                          x-on:submit="showRecat = false">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="categoryId" value="@cat.CategoryId" />
                        <button type="submit" class="sl-recat-option">
                            @{
                                var dotStyle = cat.Hue.HasValue
                                    ? $"--cdp-color: oklch(0.55 0.14 {cat.Hue})"
                                    : null;
                            }
                            <span class="sl-cat-pill">
                                <span class="sl-cat-pill__dot" style="@dotStyle" aria-hidden="true"></span>
                                @cat.Name
                            </span>
                        </button>
                    </form>
                }
            </div>
        }
    </div>

    @* Quantity pill: clicking swaps to the inline stepper when not checked. *@
    @if (!item.IsChecked)
    {
        @* Read-only pill — shown when not editing *@
        <button type="button"
                class="sl-qty"
                x-show="!editingQty"
                x-on:click="editingQty = true"
                aria-label="Edit quantity for @item.DisplayName">
            @if (item.Quantity.HasValue)
            {
                @(item.Quantity.Value.ToString("0.###"))@(item.UnitCode is not null ? " " + item.UnitCode : "")
            }
            else
            {
                <svg class="icon" aria-hidden="true"><use href="#i-edit" /></svg>
                <span>qty</span>
            }
        </button>

        @* Inline quantity editor — shown when editingQty is true *@
        <form class="sl-qtyedit"
              x-show="editingQty"
              x-cloak
              hx-post="@editQtyUrl"
              hx-target="#shopping-list"
              hx-swap="outerHTML"
              x-on:submit="editingQty = false">
            @Html.AntiForgeryToken()
            <stepper name="quantity"
                     x-model="qty"
                     input-label="Quantity"
                     decrease-click="qty = (+qty - 1) < 0 ? '0' : (+qty - 1).toFixed(3).replace(/\.?0+$/, '') || '0'"
                     increase-click="qty = (+qty + 1).toFixed(3).replace(/\.?0+$/, '') || '1'"
                     decrease-label="Decrease quantity"
                     increase-label="Increase quantity" />
            @* Unit select: populated with the household's full unit list (plantry-259).
               The current item's unit is pre-selected; "no unit" is always available. *@
            <select name="unitId" class="sl-qsel" aria-label="Unit">
                <option value="">no unit</option>
                @foreach (var u in unitOptionsList)
                {
                    if (item.UnitId == u.UnitId)
                    {
                        <option value="@u.UnitId" selected>@u.Code</option>
                    }
                    else
                    {
                        <option value="@u.UnitId">@u.Code</option>
                    }
                }
            </select>
            <button type="submit" class="sl-act save" aria-label="Save quantity">
                <svg class="icon" aria-hidden="true"><use href="#i-check" /></svg>
            </button>
        </form>
    }
    else
    {
        @* Checked items: read-only qty pill, no editor *@
        @if (item.Quantity.HasValue)
        {
            <span class="sl-qty">
                @(item.Quantity.Value.ToString("0.###"))@(item.UnitCode is not null ? " " + item.UnitCode : "")
            </span>
        }
    }

    @* Action buttons (hover-revealed). Same .sl-actions group as plantry-853; editor buttons added here (plantry-dem). *@
    <div class="sl-actions" aria-label="Item actions">
        @if (!item.IsChecked)
        {
            @* Pencil: toggle the note editor inline below the row *@
            <button type="button"
                    class="sl-act"
                    x-on:click="editingNote = !editingNote; if (editingNote) $nextTick(() => $el.closest('.sl-item').querySelector('.sl-noteinput')?.focus())"
                    x-bind:class="editingNote ? 'sl-act active' : 'sl-act'"
                    aria-label="@(hasNote ? "Edit" : "Add") note for @item.DisplayName">
                <svg class="icon" aria-hidden="true"><use href="#i-edit" /></svg>
            </button>
            @* Tag: recategorize button — shown only when item has no category (plantry-259). *@
            @if (showRecat)
            {
                <button type="button"
                        class="sl-act"
                        x-on:click="showRecat = !showRecat"
                        x-bind:class="showRecat ? 'sl-act active' : 'sl-act'"
                        aria-label="Move @item.DisplayName to a category">
                    <svg class="icon" aria-hidden="true"><use href="#i-tag" /></svg>
                </button>
            }
        }
        @* Delete button: hard-removes this item regardless of checked state. *@
        <button type="button"
                class="sl-act danger"
                hx-post="@deleteUrl"
                hx-target="#shopping-list"
                hx-swap="outerHTML"
                aria-label="Delete @item.DisplayName">
            <svg class="icon" aria-hidden="true"><use href="#i-trash" /></svg>
        </button>
    </div>
</div>
