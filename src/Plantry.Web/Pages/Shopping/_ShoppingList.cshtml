@using Plantry.Shopping.Application
@using Plantry.Web.Pages.Shared
@model Plantry.Web.Pages.Shopping.ShoppingListPartialModel

@{
    var list = Model.List;
    var oobAttr = Model.Oob ? " hx-swap-oob=\"true\"" : "";
    var hasChecked = list is not null && list.CheckedCount > 0;
    var categoryOptions = Model.CategoryOptions;
    var unitOptionsList = Model.UnitOptionsList;
    var suggestions = Model.Suggestions;
}

<div id="shopping-list"@Html.Raw(oobAttr)>
    @* ── Pantry suggestions strip (plantry-48l) ───────────────────────────── *@
    @* Rendered outside the empty-state guard so suggestions appear even when list is empty. *@
    @if (suggestions.Count > 0)
    {
        <div class="sl-suggest" aria-label="Running low in your pantry">
            <div class="sl-suggest-label">Running low in your pantry</div>
            <div class="sl-sug-chips">
                @foreach (var sug in suggestions)
                {
                    <div class="sl-sug">
                        <partial name="Shared/_CatChip" model="new CatChipViewModel(sug.CategoryName, sug.CategoryHue)" />
                        <span class="sl-sug-name">@sug.Name</span>
                        <span class="sl-sug-stock @(sug.OnHand <= 0 ? "out" : "")">@sug.StockLabel</span>
                        <form method="post" action="@Url.Page("./Index", "AddItem")"
                              hx-post="@Url.Page("./Index", "AddItem")"
                              hx-target="#shopping-list" hx-swap="outerHTML">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="Input.ProductId" value="@sug.ProductId" />
                            <button type="submit" class="sadd" aria-label="Add @sug.Name to list">
                                <svg class="icon" aria-hidden="true"><use href="#i-plus" /></svg>
                            </button>
                        </form>
                    </div>
                }
            </div>
        </div>
    }

    @if (list is null || list.TotalCount == 0)
    {
        <div class="sl-empty">
            <div class="big">Your list is empty</div>
            Add a product from the catalog or type a custom item above.
        </div>
    }
    else
    {
        @* Named-category groups (unchecked items only) *@
        @foreach (var group in list.Groups)
        {
            // Derive the color dot hue from the first item in the group that has a CategoryHue
            var groupHue = group.Items.FirstOrDefault(i => i.CategoryHue.HasValue)?.CategoryHue;
            var dotStyle = groupHue.HasValue
                ? $"background: oklch(0.6 0.12 {groupHue})"
                : "background: var(--color-text-faint)";
            <div class="sl-group" aria-label="@group.CategoryName">
                <div class="sl-group-head">
                    <span class="cdot" style="@dotStyle" aria-hidden="true"></span>
                    <h3>@group.CategoryName</h3>
                    <span class="count">@group.Items.Count</span>
                    <span class="spacer"></span>
                </div>
                <div class="sl-rows">
                    @foreach (var item in group.Items)
                    {
                        <partial name="_ShoppingItem" model="new ShoppingItemPartialModel(item, categoryOptions, unitOptionsList)" />
                    }
                </div>
            </div>
        }

        @* Uncategorized bucket (free-text + products with no category, unchecked only) *@
        @if (list.UncategorizedItems.Count > 0)
        {
            <div class="sl-group" aria-label="Uncategorized">
                <div class="sl-group-head">
                    <svg class="icon" aria-hidden="true" style="color: var(--color-text-faint); width: 16px; height: 16px; flex: none"><use href="#i-tag" /></svg>
                    <h3>Uncategorized</h3>
                    <span class="count">@list.UncategorizedItems.Count</span>
                    <span class="spacer"></span>
                </div>
                <div class="sl-rows">
                    @foreach (var item in list.UncategorizedItems)
                    {
                        <partial name="_ShoppingItem" model="new ShoppingItemPartialModel(item, categoryOptions, unitOptionsList)" />
                    }
                </div>
            </div>
        }

        @* Checked items sink to the bottom (SPEC §3c: struck-through, below all unchecked groups) *@
        @if (hasChecked)
        {
            <div class="sl-checked-head">
                <span class="lbl">
                    <svg class="icon" aria-hidden="true"><use href="#i-check" /></svg>
                    Checked off
                </span>
                <span class="spacer"></span>
                <form method="post" action="@Url.Page("./Index", "ClearChecked")">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="sl-clear">
                        <svg class="icon" aria-hidden="true"><use href="#i-trash" /></svg>
                        Clear @list.CheckedCount checked @(list.CheckedCount == 1 ? "item" : "items")
                    </button>
                </form>
            </div>
            <div class="sl-group" aria-label="Checked items">
                <div class="sl-rows">
                    @foreach (var item in list.CheckedItems)
                    {
                        <partial name="_ShoppingItem" model="new ShoppingItemPartialModel(item, categoryOptions, unitOptionsList)" />
                    }
                </div>
            </div>
        }
    }
</div>
