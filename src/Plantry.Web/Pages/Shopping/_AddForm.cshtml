@model Plantry.Web.Pages.Shopping.IndexModel
@{
    // When FormOob is set, the form carries hx-swap-oob so an AddItem POST response can
    // replace the live add form in place — clearing it on success, or re-rendering it with
    // validation errors on failure (plantry-3dh.1, items A & C).
    var formOob = ViewData["FormOob"] as bool? ?? false;
}

<form id="add-item-form"
      hx-post="@Url.Page("./Index", "AddItem")"
      hx-target="#shopping-list" hx-swap="outerHTML"
      hx-swap-oob="@(formOob ? "true" : null)">
    @Html.AntiForgeryToken()

    <div class="sl-add-grid">
        @* Catalog search — searchable-select component *@
        <div class="sl-field">
            <label for="Input_ProductId">
                <svg class="icon" aria-hidden="true"><use href="#i-search" /></svg>
                Search catalog
            </label>
            <searchable-select asp-for="Input.ProductId"
                               items="Model.ProductOptions"
                               search-url="@Url.Page("./Index", "FilterProducts")"
                               placeholder="e.g. Chicken Breast, Spinach…" />
        </div>

        <div class="sl-or"><span>or</span></div>

        @* Free-text custom item *@
        <div class="sl-field">
            <label asp-for="Input.FreeText">
                <svg class="icon" aria-hidden="true"><use href="#i-edit" /></svg>
                Custom item
            </label>
            <input asp-for="Input.FreeText"
                   class="sl-input"
                   placeholder="e.g. Paper towels"
                   maxlength="200" />
        </div>
    </div>

    @* Footer: qty stepper + unit + Add button *@
    <div class="sl-add-foot" x-data="{ qty: 1 }">
        <div class="sl-field">
            <label asp-for="Input.Quantity">Quantity</label>
            <stepper asp-for="Input.Quantity"
                     x-model="qty"
                     x-model-modifier="number"
                     decrease-click="qty = Math.max(0, +(qty - 1).toFixed(2))"
                     increase-click="qty = +(qty + 1).toFixed(2)"
                     decrease-label="Decrease quantity"
                     increase-label="Increase quantity" />
        </div>
        @* Unit select: populated from household catalog units (plantry-259). *@
        <div class="sl-field">
            <label asp-for="Input.UnitId">Unit</label>
            <select asp-for="Input.UnitId" asp-items="Model.UnitOptions" class="sl-qsel" aria-label="Unit"></select>
        </div>
        <div class="spacer"></div>
        <button type="submit" class="btn btn--primary btn--lg">
            <svg class="icon" aria-hidden="true"><use href="#i-plus" /></svg>
            Add to list
        </button>
    </div>

    @* Validation feedback — only rendered when there are model-level errors, so the empty
       state shows no stray alert box (plantry-3dh.1, item C). *@
    @if (!ViewData.ModelState.IsValid)
    {
        <div asp-validation-summary="ModelOnly" class="alert alert--danger" role="alert"
             style="margin-top: 12px"></div>
    }
</form>
