@using Plantry.Web.Pages.Today
@using Plantry.Web.Pages.Shared
@model IndexModel

@* Expiring-soon widget for the Today right rail (SPEC Page 0 §0d, plantry-81x).
   Three states:
   - Onboard (IsColdStart): no tracked stock yet — guide user to add groceries.
   - All-clear: stock exists but nothing is expiring this week.
   - Populated: one or more products expiring within 7 days or already expired. *@

@if (Model.IsColdStart)
{
    @* Onboard empty state — no stock at all *@
    <div class="today-widget today-exp-widget">
        <div class="today-widget__head">
            <h3>Expiring soon</h3>
            <div class="today-widget__spacer"></div>
            <span class="today-count-badge today-count-badge--calm">0</span>
        </div>
        <div class="today-widget__empty today-we--onboard">
            <div class="today-we-mark today-we-mark--onboard">
                <svg class="icon" aria-hidden="true"><use href="#i-box" /></svg>
            </div>
            <div class="today-we-title">Nothing to track yet</div>
            <div class="today-we-sub">
                Add groceries and Plantry watches the clock — items nearing their date show up here.
            </div>
        </div>
        <div class="today-widget__foot">
            <a href="/pantry/take-stock">
                Add groceries
                <svg class="icon" aria-hidden="true"><use href="#i-chevron-right" /></svg>
            </a>
        </div>
    </div>
}
else if (!Model.ExpiringSoon.Any())
{
    @* All-clear state — stock exists but nothing is expiring soon *@
    <div class="today-widget today-exp-widget">
        <div class="today-widget__head">
            <h3>Expiring soon</h3>
            <div class="today-widget__spacer"></div>
            <span class="today-count-badge today-count-badge--calm">0</span>
        </div>
        <div class="today-widget__empty">
            <div class="today-we-mark">
                <svg class="icon" aria-hidden="true"><use href="#i-check" /></svg>
            </div>
            <div class="today-we-title">Nothing expiring this week</div>
            <div class="today-we-sub">
                Your pantry's in good shape. We'll flag anything within 7 days of turning.
            </div>
        </div>
        <div class="today-widget__foot">
            <a href="/Pantry">
                Open pantry
                <svg class="icon" aria-hidden="true"><use href="#i-chevron-right" /></svg>
            </a>
        </div>
    </div>
}
else
{
    @* Populated state — one or more expiring or expired items *@
    <div class="today-widget today-exp-widget">
        <div class="today-widget__head">
            <h3>Expiring soon</h3>
            <span class="today-widget__meta">next 7 days</span>
            <div class="today-widget__spacer"></div>
            <span class="today-count-badge @(Model.ExpiringUrgent ? "" : "today-count-badge--calm")">@Model.ExpiringSoon.Count</span>
        </div>
        <div class="today-exp-list">
            @foreach (var item in Model.ExpiringSoon)
            {
                @* Wording + colour tier come from the shared ExpiryDisplay so this rail, the Recipe rows and
                   the Pantry grid read identically (plantry-fdoq). The row keeps its own urgency dot; the pill
                   carries no icon here (the dot is the surface's urgency mark). *@
                var (whenLabel, tier) = ExpiryDisplay.Format(item.SoonestExpiry, Model.Today);
                var dotClass = $"today-exp-dot--{tier}";
                <div class="today-exp-row">
                    <span class="today-exp-dot @dotClass"></span>
                    <div class="today-exp-main">
                        <div class="today-exp-name">@item.Name</div>
                        @if (!string.IsNullOrEmpty(item.LocationDisplay))
                        {
                            <div class="today-exp-sub">@($"{item.TotalQuantity:0.###} {item.DisplayUnitCode}") · @item.LocationDisplay</div>
                        }
                        else
                        {
                            <div class="today-exp-sub">@($"{item.TotalQuantity:0.###} {item.DisplayUnitCode}")</div>
                        }
                    </div>
                    <span class="badge-expiry badge-expiry--@tier">@whenLabel</span>
                </div>
            }
        </div>
        @* Two-up foot: primary "Use these up" deep-links to the Recipes browse pre-filtered
           to the "use soon" horizon and sorted by cookability (fulfillment-desc is the browse
           default), so the user immediately sees recipes that use their expiring items and can
           mostly make (plantry-w1e). The expiring set and the recipe filter set share one
           household horizon (plantry-5yhd), so the two surfaces agree by construction. *@
        <div class="today-widget__foot today-widget__foot--split">
            <a href="/Recipes?soon=true" class="today-widget__foot-cta">
                <svg class="icon" aria-hidden="true"><use href="#i-timer" /></svg>
                Use these up
            </a>
            <a href="/Pantry">
                Review all in pantry
                <svg class="icon" aria-hidden="true"><use href="#i-chevron-right" /></svg>
            </a>
        </div>
    </div>
}
