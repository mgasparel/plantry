@using Plantry.Web.Pages.Today
@model IndexModel

@* Cook-now recipe picks — Phase-2 degrade for the Today meals band (SPEC Page 0 §0c, plantry-81g).
   Renders up to 3 picks sorted by expiring-ingredient first, then fulfillment pct descending.
   Structured so the Phase-3 planned-meals band (plantry-zp7) can swap in without a layout change:
   keep the outer .today-meals-band wrapper and .today-section-head intact. *@

<div id="today-meals-band" class="today-meals-band">
    <div class="today-section-head">
        <h2>What can I cook right now?</h2>
        <div class="today-section-head__spacer"></div>
        <a class="today-linkbtn" href="/Recipes">
            <svg class="icon" aria-hidden="true"><use href="#i-recipe" /></svg> Browse recipes
        </a>
    </div>

    @if (!Model.CookNowPicks.Any())
    {
        @* Empty state — no recipes yet. Guide user to add or browse recipes (cold-start tie-in). *@
        <div class="today-meals__empty">
            <div class="today-we-mark today-we-mark--onboard">
                <svg class="icon" aria-hidden="true"><use href="#i-recipe" /></svg>
            </div>
            <div class="today-we-title">No recipes yet</div>
            <div class="today-we-sub">
                Add a recipe and Plantry will suggest what you can cook based on what's in your pantry.
            </div>
            <div class="today-meals__empty-actions">
                <a class="btn btn--primary" href="/Recipes/New">Add a recipe</a>
                <a class="btn btn--secondary" href="/Recipes">Browse recipes</a>
            </div>
        </div>
    }
    else
    {
        <div class="today-picks">
            @foreach (var pick in Model.CookNowPicks)
            {
                var hintReady = pick.FullyCookable;
                var cookUrl = $"/Recipes/{pick.RecipeId}/Cook";
                <div class="today-pick">
                    @if (pick.HasPhoto)
                    {
                        <div class="today-pick__photo">
                            <img src="/Recipes/@(pick.RecipeId)?handler=Photo"
                                 alt="@pick.Name"
                                 class="today-pick__img"
                                 loading="lazy" />
                        </div>
                    }
                    else
                    {
                        <div class="today-pick__photo today-pick__photo--placeholder">
                            <svg class="icon" aria-hidden="true"><use href="#i-recipe" /></svg>
                        </div>
                    }

                    <div class="today-pick__body">
                        <div class="today-pick__name">
                            <a href="/Recipes/@pick.RecipeId" class="today-pick__namelink">@pick.Name</a>
                            @if (pick.HasIngredientExpiringSoon)
                            {
                                <span class="today-pick__badge today-pick__badge--soon">Use it up</span>
                            }
                        </div>

                        <div class="today-pick__meta">
                            @if (pick.CookTimeMinutes.HasValue)
                            {
                                <span class="today-pick__meta-item">
                                    <svg class="icon" aria-hidden="true"><use href="#i-timer" /></svg>
                                    @(pick.CookTimeMinutes >= 60
                                        ? $"{pick.CookTimeMinutes / 60}h {pick.CookTimeMinutes % 60}m"
                                        : $"{pick.CookTimeMinutes}m")
                                </span>
                                <span class="today-pick__meta-dot"></span>
                            }
                            <span class="today-pick__meta-item">
                                <svg class="icon" aria-hidden="true"><use href="#i-servings" /></svg>
                                @pick.DefaultServings serving@(pick.DefaultServings == 1 ? "" : "s")
                            </span>
                        </div>

                        <div class="today-pick__hint @(hintReady ? "today-pick__hint--ready" : "today-pick__hint--shop")">
                            @if (hintReady)
                            {
                                <svg class="icon" aria-hidden="true"><use href="#i-check" /></svg>
                                <span>Ready to cook</span>
                            }
                            else
                            {
                                <svg class="icon" aria-hidden="true"><use href="#i-cart" /></svg>
                                <span>@pick.MissingCount ingredient@(pick.MissingCount == 1 ? "" : "s") to pick up first</span>
                            }
                        </div>
                    </div>

                    <div class="today-pick__actions">
                        <a class="btn btn--cook btn--sm today-pick__cook" href="@cookUrl">
                            <svg class="icon" aria-hidden="true"><use href="#i-flame" /></svg>
                            Cook
                        </a>
                    </div>
                </div>
            }
        </div>
    }
</div>
