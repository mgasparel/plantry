@page
@model Plantry.Web.Pages.Today.IndexModel
@{
    ViewData["Title"] = "Today";
    ViewData["ContentClass"] = "page-content--wide";
}

<div class="today-wrap">
    <div class="today-head">
        <div class="today-head__greet">
            <h1 class="today-head__greeting">@Model.Greeting</h1>
            <div class="today-head__date">
                <span>@Model.DateDisplay</span>
                @if (!string.IsNullOrEmpty(Model.HouseholdName))
                {
                    <span class="today-head__ddot"></span>
                    <span>@Model.HouseholdName</span>
                }
            </div>
        </div>
        <div class="today-head__spacer"></div>
        @if (!Model.IsColdStart)
        {
            <div class="today-head__actions">
                <a class="today-linkbtn" href="/Pantry">
                    <svg class="icon" aria-hidden="true"><use href="#i-pantry" /></svg> Pantry
                </a>
                <a class="today-linkbtn today-linkbtn--accent" href="/MealPlan">
                    <svg class="icon" aria-hidden="true"><use href="#i-calendar" /></svg> Weekly plan
                </a>
            </div>
        }
    </div>

    @if (Model.IsColdStart)
    {
        <div class="today-welcome">
            <div class="today-welcome__art">
                <svg viewBox="0 0 120 120" aria-hidden="true" class="today-welcome__logo">
                    <circle cx="60" cy="60" r="50" fill="var(--color-accent-subtle)" />
                    <path d="M40 70 Q60 35 80 70" stroke="var(--color-accent)" stroke-width="3" fill="none" stroke-linecap="round" />
                    <circle cx="60" cy="55" r="8" fill="var(--color-accent)" />
                </svg>
            </div>
            <div class="today-welcome__body">
                <div class="today-welcome__eyebrow">Let's set up your kitchen</div>
                <h2 class="today-welcome__heading">
                    Welcome home@(string.IsNullOrEmpty(Model.HouseholdName) ? "." : $", {Model.HouseholdName}.")
                </h2>
                <p class="today-welcome__sub">
                    Plantry keeps an eye on what's in your pantry, what's about to expire, and what's for dinner — so nothing goes to waste.
                    Three quick steps to get going.
                </p>
                <div class="today-welcome__steps">
                    <a class="today-welcome__step" href="/Pantry">
                        <span class="today-welcome__step-num">1</span>
                        <span class="today-welcome__step-txt">
                            <span class="today-welcome__step-t">Add your groceries</span>
                            <span class="today-welcome__step-s">Snap or forward a receipt to stock your pantry</span>
                        </span>
                        <svg class="icon today-welcome__step-chev" aria-hidden="true"><use href="#i-chevron-right" /></svg>
                    </a>
                    <a class="today-welcome__step" href="/Recipes">
                        <span class="today-welcome__step-num">2</span>
                        <span class="today-welcome__step-txt">
                            <span class="today-welcome__step-t">Browse recipes</span>
                            <span class="today-welcome__step-s">See what you can cook with what you have</span>
                        </span>
                        <svg class="icon today-welcome__step-chev" aria-hidden="true"><use href="#i-chevron-right" /></svg>
                    </a>
                    <a class="today-welcome__step" href="/MealPlan">
                        <span class="today-welcome__step-num">3</span>
                        <span class="today-welcome__step-txt">
                            <span class="today-welcome__step-t">Plan your week</span>
                            <span class="today-welcome__step-s">Drop meals onto the days ahead</span>
                        </span>
                        <svg class="icon today-welcome__step-chev" aria-hidden="true"><use href="#i-chevron-right" /></svg>
                    </a>
                </div>
            </div>
        </div>
    }

    @* Two-column board: main column (meals) + right rail (widgets) *@
    @if (!Model.IsColdStart)
    {
        <div class="today-grid">
            <div class="today-meals">
                @* Meals band — populated by sibling ticket plantry-81g *@
                <div class="today-section-head">
                    <h2>Today's meals</h2>
                    <div class="today-section-head__spacer"></div>
                    <a class="today-linkbtn today-linkbtn--accent" href="/MealPlan">
                        <svg class="icon" aria-hidden="true"><use href="#i-calendar" /></svg> Open weekly plan
                    </a>
                </div>
                <div class="today-meals__empty">
                    <p>Today's meal picks are coming soon.</p>
                </div>
            </div>

            <div class="today-rail">
                @* Expiring-soon widget — populated by sibling ticket plantry-81x *@
                <div class="today-widget">
                    <div class="today-widget__head">
                        <h3>Expiring soon</h3>
                        <div class="today-widget__spacer"></div>
                        <span class="today-count-badge today-count-badge--calm">0</span>
                    </div>
                    <div class="today-widget__empty">
                        <div class="today-we-mark">
                            <svg class="icon" aria-hidden="true"><use href="#i-check" /></svg>
                        </div>
                        <div class="today-we-title">Nothing expiring this week</div>
                        <div class="today-we-sub">Your pantry's in good shape. We'll flag anything within 7 days of turning.</div>
                    </div>
                    <div class="today-widget__foot">
                        <a href="/Pantry">
                            Open pantry
                            <svg class="icon" aria-hidden="true"><use href="#i-chevron-right" /></svg>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
