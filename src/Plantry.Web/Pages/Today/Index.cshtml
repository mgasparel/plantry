@page
@model Plantry.Web.Pages.Today.IndexModel
@{
    ViewData["Title"] = "Today";
    ViewData["ContentClass"] = "page-content--wide";
    var todaySubtitle = string.IsNullOrEmpty(Model.HouseholdName)
        ? Model.DateDisplay
        : $"{Model.DateDisplay} · {Model.HouseholdName}";
}

<div class="today-wrap">
    <page-header title="@(Model.IsColdStart ? "Welcome to Plantry." : Model.Greeting)" subtitle="@todaySubtitle">
        @if (!Model.IsColdStart)
        {
            <a class="today-linkbtn" href="/Pantry">
                <svg class="icon" aria-hidden="true"><use href="#i-pantry" /></svg> Pantry
            </a>
            <a class="today-linkbtn today-linkbtn--accent" href="/MealPlan">
                <svg class="icon" aria-hidden="true"><use href="#i-calendar" /></svg> Weekly plan
            </a>
        }
    </page-header>

    @if (Model.IsColdStart)
    {
        <div class="today-welcome">
            <div class="today-welcome__art">
                <img src="~/images/logo.png" alt="Plantry" class="today-welcome__logo" />
            </div>
            <div class="today-welcome__body">
                <div class="eyebrow today-welcome__eyebrow">Let's set up your kitchen</div>
                <p class="today-welcome__sub">
                    Plantry keeps an eye on what's in your pantry, what's about to expire, and what's for dinner — so nothing goes to waste.
                    Three quick steps to get going.
                </p>
                <div class="today-welcome__steps">
                    <a class="today-welcome__step today-welcome__step--cta" href="/pantry/take-stock">
                        <span class="today-welcome__step-num">1</span>
                        <span class="today-welcome__step-txt">
                            <span class="today-welcome__step-t">Stock your pantry — Take Stock</span>
                            <span class="today-welcome__step-s">Walk your kitchen and tell Plantry what's on your shelves</span>
                        </span>
                        <svg class="icon today-welcome__step-chev" aria-hidden="true"><use href="#i-chevron-right" /></svg>
                    </a>
                    <a class="today-welcome__step" href="/Recipes">
                        <span class="today-welcome__step-num">2</span>
                        <span class="today-welcome__step-txt">
                            <span class="today-welcome__step-t">Browse recipes</span>
                            <span class="today-welcome__step-s">See what you can cook with what you have</span>
                        </span>
                        <svg class="icon today-welcome__step-chev" aria-hidden="true"><use href="#i-chevron-right" /></svg>
                    </a>
                    <a class="today-welcome__step" href="/MealPlan">
                        <span class="today-welcome__step-num">3</span>
                        <span class="today-welcome__step-txt">
                            <span class="today-welcome__step-t">Plan your week</span>
                            <span class="today-welcome__step-s">Drop meals onto the days ahead</span>
                        </span>
                        <svg class="icon today-welcome__step-chev" aria-hidden="true"><use href="#i-chevron-right" /></svg>
                    </a>
                </div>
            </div>
        </div>
    }

    @* Review banner stack — intake sessions in Ready status (SPEC Page 0 §0b, plantry-yb6).
       Renders nothing when there are no pending sessions. Sits between the header and the
       two-column board so it is prominent without disrupting the grid layout. *@
    @if (!Model.IsColdStart && Model.PendingReviewBanners.Count > 0)
    {
        <partial name="_ReviewBannerStack" model="Model" />
    }

    @* Two-column board: main column (meals) + right rail (widgets) *@
    @if (!Model.IsColdStart)
    {
        <div class="today-grid">
            <div class="today-meals">
                @* Meals band — Phase-3 planned meals (plantry-zp7).
                   Replaced the Phase-2 cook-now picks (plantry-81g) without a layout change. *@
                <partial name="_PlannedMealsBand" model="Model" />
            </div>

            <div class="today-rail">
                @if (Model.ShowTakeStockCta)
                {
                    <div class="today-widget today-widget--cta" id="today-take-stock-cta">
                        <div class="today-widget__head">
                            <h3>Stock your pantry</h3>
                        </div>
                        <div class="today-widget__body">
                            <p class="today-cta__sub">Your pantry is empty. Walk your shelves and tell Plantry what you have — takes just a few minutes.</p>
                            <a class="btn btn--primary today-cta__link" href="/pantry/take-stock">
                                Take Stock
                                <svg class="icon" aria-hidden="true"><use href="#i-chevron-right" /></svg>
                            </a>
                        </div>
                    </div>
                }
                @* Expiring-soon widget (plantry-81x) *@
                <partial name="_ExpiringWidget" model="Model" />
            </div>
        </div>
    }
</div>
