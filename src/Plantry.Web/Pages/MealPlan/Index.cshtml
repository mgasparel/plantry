@page
@model Plantry.Web.Pages.MealPlan.IndexModel
@{
    ViewData["Title"] = "Meal Plan";
    ViewData["ContentClass"] = "page-content--full";
}

<div class="plan-main">
    @* Command bar: week nav, This week, budget chip *@
    <div class="plan-bar">
        <nav class="wknav" aria-label="Week navigation">
            <button type="button" class="wknav-btn" aria-label="Previous week"
                    hx-get="/MealPlan?handler=Grid&amp;week=@Model.PrevWeekStart.ToString("yyyy-MM-dd")"
                    hx-target="#plan-main-content"
                    hx-swap="innerHTML">
                <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 18l-6-6 6-6" /></svg>
            </button>
            <span class="wk-label">@Model.WeekLabel</span>
            <button type="button" class="wknav-btn" aria-label="Next week"
                    hx-get="/MealPlan?handler=Grid&amp;week=@Model.NextWeekStart.ToString("yyyy-MM-dd")"
                    hx-target="#plan-main-content"
                    hx-swap="innerHTML">
                <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18l6-6-6-6" /></svg>
            </button>
            @if (Model.WeekStart != Model.ThisWeekStart)
            {
                <button type="button" class="wk-today"
                        hx-get="/MealPlan?handler=Grid&amp;week=@Model.ThisWeekStart.ToString("yyyy-MM-dd")"
                        hx-target="#plan-main-content"
                        hx-swap="innerHTML">This week</button>
            }
        </nav>
        <div class="plan-bar-spacer"></div>
        @* Manage planning gear — dropdown linking to slot config + preferences *@
        <div class="manage-plan-gear" x-data="{ open: false }" style="position:relative">
            <button type="button" class="btn btn--icon" aria-label="Manage planning" title="Manage planning"
                    @@click="open = !open" :aria-expanded="open">
                <svg class="icon" aria-hidden="true"><use href="#i-settings" /></svg>
            </button>
            <div x-show="open" @@click.outside="open = false" x-cloak
                 class="manage-plan-menu" role="menu">
                <a href="/Settings/MealSlots" class="manage-plan-menu__item" role="menuitem" @@click="open = false">Meal slots</a>
                <a href="/Settings/Preferences" class="manage-plan-menu__item" role="menuitem" @@click="open = false">Dietary preferences</a>
            </div>
        </div>
        @* Budget chip — live weekly cost (P3-4) *@
        @{
            var budgetClass = "budget-chip";
            string weekCostDisplay;
            if (Model.WeekTotalCost.HasValue)
            {
                weekCostDisplay = (Model.WeekCostIsPartial ? "~$" : "$") + Model.WeekTotalCost.Value.ToString("F2");
            }
            else
            {
                weekCostDisplay = "—";
            }
        }
        <span class="@budgetClass" title="Estimated weekly grocery cost based on planned meals">
            <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z" /><line x1="3" y1="6" x2="21" y2="6" /><path d="M16 10a4 4 0 0 1-8 0" /></svg>
            <b>@weekCostDisplay</b> / wk
        </span>
        @* Shop for this week — calls ShopForWeek application service (P3-4) *@
        <div x-data="shopWeek()" x-init="init(@System.Text.Json.JsonSerializer.Serialize(Model.WeekStart.ToString("yyyy-MM-dd")))">
            <button type="button" class="btn btn--primary"
                    :disabled="loading || done"
                    @@click="shop()"
                    :title="done ? 'Items added to shopping list' : 'Add all missing planned meal ingredients to the shopping list'">
                <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z" /><line x1="3" y1="6" x2="21" y2="6" /><path d="M16 10a4 4 0 0 1-8 0" /></svg>
                <span x-show="!loading && !done">Shop for this week</span>
                <span x-show="loading" x-cloak>Adding…</span>
                <span x-show="done" x-cloak x-text="addedLabel"></span>
            </button>
        </div>
        @* Auto-fill — wired in P3-6 *@
        <button type="button" class="btn btn--soft" disabled title="AI auto-fill arrives in a later slice">Auto-fill week</button>
    </div>

    @* Body: grid *@
    <div class="plan-body" id="plan-main-content">
        @await Html.PartialAsync("_WeekGrid", Model)
    </div>
</div>

@* Meal editor modal — loaded via htmx into this container *@
<div id="meal-editor-modal" class="modal-veil" style="display:none"
     x-data="{ open: false }"
     x-show="open" x-cloak
     @@keydown.escape.window="open = false">
    <div class="editor" role="dialog" aria-modal="true" id="meal-editor-dialog">
        @* Content injected by htmx *@
    </div>
</div>

@section Scripts {
    <script>
        // Open the editor modal when htmx loads the editor fragment
        document.addEventListener('htmx:afterSwap', function (e) {
            if (e.detail.target && e.detail.target.id === 'meal-editor-dialog') {
                const veil = document.getElementById('meal-editor-modal');
                if (veil) {
                    veil.style.display = 'grid';
                    veil._x_dataStack && (veil._x_dataStack[0].open = true);
                }
            }
        });

        function closeMealEditor() {
            const veil = document.getElementById('meal-editor-modal');
            if (veil) {
                veil.style.display = 'none';
                document.getElementById('meal-editor-dialog').innerHTML = '';
            }
        }

        // Drag-drop: HTML5 + htmx
        function onDragStart(e, date, slotId) {
            e.dataTransfer.setData('text/plain', JSON.stringify({ date, slotId }));
            e.dataTransfer.effectAllowed = 'move';
        }

        function onDragOver(e) {
            e.preventDefault();
            e.dataTransfer.dropEffect = 'move';
            e.currentTarget.classList.add('drag-over');
        }

        function onDragLeave(e) {
            e.currentTarget.classList.remove('drag-over');
        }

        function onDrop(e, toDate, toSlotId) {
            e.preventDefault();
            e.currentTarget.classList.remove('drag-over');
            const data = JSON.parse(e.dataTransfer.getData('text/plain'));
            if (data.date === toDate && data.slotId === toSlotId) return;

            // POST via htmx programmatic trigger
            htmx.ajax('POST',
                `/MealPlan?handler=Move&fromDate=${encodeURIComponent(data.date)}&fromSlotId=${encodeURIComponent(data.slotId)}&toDate=${encodeURIComponent(toDate)}&toSlotId=${encodeURIComponent(toSlotId)}`,
                {
                    target: '#plan-main-content',
                    swap: 'innerHTML',
                    headers: { 'RequestVerificationToken': document.querySelector('[name=__RequestVerificationToken]')?.value ?? '' }
                });
        }

        // Alpine component: "Shop for this week" button (P3-4)
        function shopWeek() {
            return {
                loading: false,
                done: false,
                addedLabel: '',
                weekDate: '',
                init(week) { this.weekDate = week; },
                async shop() {
                    if (this.loading || this.done) return;
                    this.loading = true;
                    try {
                        const token = document.querySelector('[name=__RequestVerificationToken]')?.value ?? '';
                        const body = new URLSearchParams({ week: this.weekDate, __RequestVerificationToken: token });
                        const resp = await fetch('/MealPlan?handler=Shop', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': token },
                            body: body.toString()
                        });
                        if (!resp.ok) throw new Error('Request failed');
                        const data = await resp.json();
                        const n = data.itemsAdded ?? 0;
                        this.addedLabel = n === 0 ? 'Nothing missing' : n === 1 ? '1 item added' : `${n} items added`;
                        this.done = true;
                    } catch {
                        this.loading = false;
                        alert('Could not add items — please try again.');
                    }
                }
            };
        }
    </script>
    @Html.AntiForgeryToken()
}
