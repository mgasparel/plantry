@page
@model Plantry.Web.Pages.MealPlan.IndexModel
@using Plantry.MealPlanning.Domain
@{
    ViewData["Title"] = "Meal Plan";
    ViewData["ContentClass"] = "page-content--fluid";
}

<div class="plan-main" x-data="{ costMode: 'projected' }">
    @* Command bar: week nav, This week, budget chip, auto-fill *@
    @* All dynamic pieces are in _PlanBarNav so they can be re-emitted OOB after htmx grid
       swaps and cell mutations. On first load (Oob=false) the partial renders inline here.
       After any htmx swap the response carries _PlanBarNav(Oob=true) so the nav URLs,
       week label, This-week button, budget chip, and Auto-fill state update without a full
       page reload — fixing the plan-bar staleness bug (plantry-khw). *@
    <div class="plan-bar">
        @await Html.PartialAsync("_PlanBarNav", new Plantry.Web.Pages.MealPlan.IndexModel.PlanBarNavVm(
            Model.WeekStart, Model.PrevWeekStart, Model.NextWeekStart, Model.ThisWeekStart,
            Model.WeekLabel, Model.HasEmptyCells, Model.WeekTotalCost, Model.WeekCostIsPartial, Oob: false,
            ProjectedWeekCost: Model.ProjectedWeekCost,
            ProjectedWeekCostIsPartial: Model.ProjectedWeekCostIsPartial,
            PendingCount: Model.PendingCount,
            WeekBudgetTarget: Model.WeekBudgetTarget,
            ConfirmedOverBudget: Model.WeekBudgetTarget.HasValue && Model.WeekTotalCost > Model.WeekBudgetTarget,
            ProjectedOverBudget: Model.WeekBudgetTarget.HasValue && Model.ProjectedWeekCost > Model.WeekBudgetTarget))
        <div class="plan-bar-spacer"></div>
        @* planTune Alpine config: injected before _PlanBarNav uses it (the partial renders af-split
           which calls planTune(window.__planTuneCfg) on Alpine init). *@
        <script>
            window.__planTuneCfg = {
                // Legacy flat keys kept for backward-compat; buckets drives the generalised component.
                wasteDefault: @(PlanningWeights.Default.Waste),
                costDefault: @(PlanningWeights.Default.Cost),
                varietyDefault: @(PlanningWeights.Default.Variety),
                // Resolved budget (decimal amount, or 0 when not set) — popover money-input reflects persisted value.
                budget: @((Model.WeekBudgetTarget ?? 0m).ToString(System.Globalization.CultureInfo.InvariantCulture)),
                buckets: [
                    { key: 'waste',   label: 'Waste',   color: 'oklch(0.62 0.13 150)', defaultWeight: @(Model.WeekPlanningWeights?.Waste   ?? PlanningWeights.Default.Waste),   appDefault: @(PlanningWeights.Default.Waste)   },
                    { key: 'cost',    label: 'Cost',     color: 'oklch(0.62 0.13 70)',  defaultWeight: @(Model.WeekPlanningWeights?.Cost    ?? PlanningWeights.Default.Cost),    appDefault: @(PlanningWeights.Default.Cost)    },
                    { key: 'variety', label: 'Variety',  color: 'oklch(0.62 0.13 255)', defaultWeight: @(Model.WeekPlanningWeights?.Variety ?? PlanningWeights.Default.Variety), appDefault: @(PlanningWeights.Default.Variety) }
                ]
            };
        </script>
        <span class="autofill-spinner htmx-indicator" aria-hidden="true"></span>
        @* Shop for this week — calls ShopForWeek application service (P3-4).
           This button is NOT in _PlanBarNav because it uses Alpine fetch state (loading/done)
           and its week context is stable for the lifetime of the page session. *@
        <div x-data="shopWeek()" x-init="init(@System.Text.Json.JsonSerializer.Serialize(Model.WeekStart.ToString("yyyy-MM-dd")))">
            <button type="button" class="btn btn--primary"
                    :disabled="loading || done"
                    @@click="shop()"
                    :title="done ? 'Items added to shopping list' : 'Add all missing planned meal ingredients to the shopping list'">
                <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z" /><line x1="3" y1="6" x2="21" y2="6" /><path d="M16 10a4 4 0 0 1-8 0" /></svg>
                <span x-show="!loading && !done">Shop for this week</span>
                <span x-show="loading" x-cloak>Adding…</span>
                <span x-show="done" x-cloak x-text="addedLabel"></span>
            </button>
        </div>
    </div>

    @* Body: grid *@
    <div class="plan-body" id="plan-main-content">
        @await Html.PartialAsync("_WeekGrid", Model)
    </div>
</div>

@* Island hydration payload — read by meal-planner.js via readHydration('meal-planner-island-data').
   Contains endpoint URLs + household member data for the editor island.
   Emitted unconditionally: the island mounts on every MealPlan page load. *@
<script type="application/json" id="meal-planner-island-data">@Html.Raw(Model.IslandHydrationJson)</script>

@* Antiforgery token — read by the island via readAntiforgeryToken() in helpers.js *@
@Html.AntiForgeryToken()

@* Island mount point — meal-planner.js renders the modal veil + editor dialog here.
   Replaces the old Alpine-managed #meal-editor-modal div.
   The island shows/hides the modal via Preact render; htmx is not involved. *@
<div id="meal-planner-island-root"></div>

@section Scripts {
    @* Drag-drop: HTML5 + htmx (MP-O8: identified by mealId, not cell coordinates) *@
    <script>
        function onDragStart(e, mealId, date, slotId) {
            e.dataTransfer.setData('text/plain', JSON.stringify({ mealId, date, slotId }));
            e.dataTransfer.effectAllowed = 'move';
        }

        function onDragOver(e) {
            e.preventDefault();
            e.dataTransfer.dropEffect = 'move';
            e.currentTarget.classList.add('drag-over');
        }

        function onDragLeave(e) {
            e.currentTarget.classList.remove('drag-over');
        }

        function onDrop(e, toDate, toSlotId) {
            e.preventDefault();
            e.currentTarget.classList.remove('drag-over');
            const data = JSON.parse(e.dataTransfer.getData('text/plain'));
            if (data.date === toDate && data.slotId === toSlotId) return;

            // POST via htmx programmatic trigger — relocate by mealId (MP-O8, no swap)
            htmx.ajax('POST',
                `/MealPlan?handler=Move&mealId=${encodeURIComponent(data.mealId)}&toDate=${encodeURIComponent(toDate)}&toSlotId=${encodeURIComponent(toSlotId)}`,
                {
                    target: '#plan-main-content',
                    swap: 'innerHTML',
                    headers: { 'RequestVerificationToken': document.querySelector('[name=__RequestVerificationToken]')?.value ?? '' }
                });
        }

        // Alpine component: "Shop for this week" button (P3-4)
        function shopWeek() {
            return {
                loading: false,
                done: false,
                addedLabel: '',
                weekDate: '',
                init(week) { this.weekDate = week; },
                async shop() {
                    if (this.loading || this.done) return;
                    this.loading = true;
                    try {
                        const token = document.querySelector('[name=__RequestVerificationToken]')?.value ?? '';
                        const body = new URLSearchParams({ week: this.weekDate, __RequestVerificationToken: token });
                        const resp = await fetch('/MealPlan?handler=Shop', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'RequestVerificationToken': token },
                            body: body.toString()
                        });
                        if (!resp.ok) throw new Error('Request failed');
                        const data = await resp.json();
                        const n = data.itemsAdded ?? 0;
                        this.addedLabel = n === 0 ? 'Nothing missing' : n === 1 ? '1 item added' : `${n} items added`;
                        this.done = true;
                    } catch {
                        this.loading = false;
                        alert('Could not add items — please try again.');
                    }
                }
            };
        }
    </script>

    @* Mount the meal-planner island (replaces Alpine mealEditor + addDishFromResult bridge).
       plan-tune.js (planning-weights popover) remains Alpine — it is not part of the editor. *@
    <script type="module">
        import { mountMealPlanner } from '/js/islands/meal-planner.js';
        import { readHydration } from '/js/islands/helpers.js';

        const root = document.getElementById('meal-planner-island-root');
        const hydration = readHydration('meal-planner-island-data');

        if (root && hydration) {
            mountMealPlanner(root, hydration);
        }
    </script>
}
