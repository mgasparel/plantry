@model Plantry.Web.Pages.MealPlan.IndexModel.PlanRailVm
@{
    // When rendered out-of-band (after a cell-targeted mutation), both root elements carry
    // hx-swap-oob so htmx replaces the live rail + reopen tab in place. When rendered inline
    // inside _WeekGrid (full grid swap / first load) they are plain children of .plan-body-inner.
    var oob = Model.Oob ? "true" : null;

    // plantry-5lp: compute display strings for the rail's alternate-figure toggle callout.
    // Each body shows the OPPOSITE figure to whatever the chip displays.
    // Cost figures render with the household display currency through MoneyDisplay (plantry-2x6e.2); the "~"
    // partial marker precedes the symbol.
    string confirmedDisplay;
    if (Model.ConfirmedWeekCost.HasValue)
        confirmedDisplay = (Model.ConfirmedCostIsPartial ? "~" : "") + MoneyDisplay.Format(Model.ConfirmedWeekCost.Value, Model.DisplayCurrency);
    else
        confirmedDisplay = "not yet estimated";

    string projectedDisplay;
    if (Model.ProjectedWeekCost.HasValue)
        projectedDisplay = (Model.ProjectedCostIsPartial ? "~" : "") + MoneyDisplay.Format(Model.ProjectedWeekCost.Value, Model.DisplayCurrency);
    else
        projectedDisplay = "not yet estimated";
}

@* Insights rail — advisory callouts derived from the planned week (P3-5).
   The single source of truth for the rail markup: _WeekGrid renders it inline and every
   cell-targeted mutation re-emits it out-of-band, so it can never go stale.
   plantry-lb9t: when IsHistoricalWeek is true the rail shows an inactive past-week state
   instead of insights (which are only meaningful for current / upcoming weeks). *@
<aside id="plan-rail" class="plan-rail @(Model.IsHistoricalWeek ? "plan-rail--inactive" : "")" :class="{ collapsed: !railOpen }" hx-swap-oob="@oob">
    <div class="rail-head">
        <span class="ri-mark">
            <svg class="icon sparkle-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .962 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.962 0z" /></svg>
        </span>
        <h3>Plan insights</h3>
        <span class="spacer"></span>
        @if (!Model.IsHistoricalWeek && Model.Insights.Count > 0)
        {
            <span class="ri-count">@Model.Insights.Count</span>
        }
        <button type="button" class="rail-collapse" @@click="railOpen = false" title="Hide insights" aria-label="Hide insights">
            <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18l6-6-6-6" /></svg>
        </button>
    </div>
    @if (Model.IsHistoricalWeek)
    {
        @* Past-week inactive state: insights are not meaningful for weeks that have already passed (plantry-lb9t). *@
        <div class="rail-scroll">
            <div class="rail-clean">
                <div class="rc-mark" style="background:var(--color-surface-2);color:var(--color-text-faint)">
                    <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" /><path d="M16 2v4M8 2v4M3 10h18" /></svg>
                </div>
                <div class="rc-t" style="color:var(--color-text-muted)">Past week</div>
                <div class="rc-s">Plan Insights only apply to the current and upcoming weeks.</div>
            </div>
        </div>
    }
    else if (Model.Insights.Count == 0)
    {
        <div class="rail-scroll">
            <div class="rail-clean">
                <div class="rc-mark">
                    <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5" /></svg>
                </div>
                <div class="rc-t">No issues</div>
                <div class="rc-s">This plan uses your expiring stock and fits your budget. Nothing needs your attention.</div>
            </div>
        </div>
    }
    else
    {
        <div class="rail-scroll">
            @* Pending-suggestions info callout (P3-6 pending-aware input — dashed border).
               plantry-5lp: two x-show bodies bound to costMode on the .plan-main ancestor.
               Each body shows the ALTERNATE figure to whatever the chip currently displays,
               plus a plain-language hint to toggle. The b4h "not included in the cost total"
               sentence is replaced by this toggle-aware wording. *@
            @if (Model.PendingCount > 0)
            {
                <div class="callout" data-tone="info" style="border-style:dashed">
                    <span class="co-ico" style="background:var(--color-accent-subtle);color:var(--color-accent)">
                        <svg class="icon sparkle-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .962 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.962 0z" /></svg>
                    </span>
                    <div>
                        <div class="co-title">Previewing @Model.PendingCount suggestion@(Model.PendingCount == 1 ? "" : "s")</div>
                        <div class="co-body" x-show="costMode === 'projected'">Your confirmed total — planned meals only — is <b>@confirmedDisplay</b> / wk. Tap the weekly cost at the top to switch.</div>
                        <div class="co-body" x-show="costMode === 'confirmed'" x-cloak>With these @Model.PendingCount suggestion@(Model.PendingCount == 1 ? "" : "s") accepted, your week would be <b>@projectedDisplay</b> / wk. Tap the weekly cost at the top to switch.</div>
                    </div>
                </div>
            }
            @foreach (var c in Model.Insights)
            {
                <div class="callout" data-tone="@c.Tone">
                    <span class="co-ico">
                        @if (c.Icon == "calendar")
                        {
                            <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" /><path d="M16 2v4M8 2v4M3 10h18" /></svg>
                        }
                        else if (c.Icon == "clock")
                        {
                            @* Expiring stock *@
                            <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" /></svg>
                        }
                        else if (c.Icon == "dollar-sign")
                        {
                            @* Over budget *@
                            <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="1" x2="12" y2="23" /><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" /></svg>
                        }
                        else if (c.Icon == "layers")
                        {
                            @* Hard conflict resolved / split meal *@
                            <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="12 2 2 7 12 12 22 7 12 2" /><polyline points="2 17 12 22 22 17" /><polyline points="2 12 12 17 22 12" /></svg>
                        }
                        else
                        {
                            @* swap / repeat *@
                            <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="17 1 21 5 17 9" /><path d="M3 11V9a4 4 0 0 1 4-4h14" /><polyline points="7 23 3 19 7 15" /><path d="M21 13v2a4 4 0 0 1-4 4H3" /></svg>
                        }
                    </span>
                    <div>
                        <div class="co-title">@c.Title</div>
                        <div class="co-body">@c.Body</div>
                        @if (!string.IsNullOrEmpty(c.ActionUrl))
                        {
                            <a href="@c.ActionUrl" class="co-link">
                                Use soon
                                <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
                            </a>
                        }
                    </div>
                </div>
            }
        </div>
    }
</aside>

@* Floating tab to re-open the rail once collapsed.
   plantry-lb9t: for historical weeks the tab shows no insights badge (the panel is inactive). *@
<button type="button" id="plan-rail-reopen" class="rail-reopen" x-show="!railOpen" x-cloak @@click="railOpen = true" hx-swap-oob="@oob">
    <svg class="icon sparkle-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .962 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.962 0z" /></svg>
    Insights
    @if (!Model.IsHistoricalWeek && Model.Insights.Count > 0)
    {
        <span class="rr-badge">@Model.Insights.Count</span>
    }
</button>
