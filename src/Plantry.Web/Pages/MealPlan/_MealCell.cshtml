@model Plantry.Web.Pages.MealPlan.IndexModel.CellFragmentVm
@{
    var cellId = $"cell-{Model.SlotId.Value:N}-{Model.Date:yyyy-MM-dd}";
    var dateIso = Model.Date.ToString("yyyy-MM-dd");
    var slotId = Model.SlotId.Value;
    var hasGhost = Model.Meals.Count == 0 && Model.PendingProposal is not null;
    var isUnfulfillable = Model.UnfulfillableCellInfo is not null;
    var cellClass = Model.Meals.Count > 0 ? "filled"
        : hasGhost ? "ghost"
        : Model.IsHardConflict ? "conflict"
        : isUnfulfillable ? "conflict"
        : "empty";
    // Tag name for unfulfillable message; falls back to generic text when tag name is unknown.
    var unfulfillableTagName = Model.UnfulfillableCellInfo?.TagName;
    var unfulfillableMsg = unfulfillableTagName is not null
        ? $"Your recipe book has no {unfulfillableTagName} recipes."
        : "Your recipe book has no recipes matching this dietary requirement.";
    var unfulfillableCtaLabel = unfulfillableTagName is not null
        ? $"Add a {unfulfillableTagName} recipe"
        : "Add a recipe";
}

<div id="@cellId"
     class="mcell @cellClass"
     @Html.Raw(Model.IsHardConflict ? "data-conflict=\"hard-stance\"" : isUnfulfillable ? "data-conflict=\"unfulfillable\"" : "")
     ondragover="onDragOver(event)"
     ondragleave="onDragLeave(event)"
     ondrop="onDrop(event, '@dateIso', '@slotId')">

    @* Hard-stance dietary conflict warning (C9 — advisory only, does not block) *@
    @if (Model.HardStanceWarning is not null)
    {
        <div class="ed-warn" x-data="{ open: true }" x-show="open" role="alert">
            <span class="ew-text">@Model.HardStanceWarning</span>
            <button class="ew-dismiss" type="button" @@click="open = false" aria-label="Dismiss warning">
                <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M18 6 6 18M6 6l12 12" /></svg>
            </button>
        </div>
    }

    @if (Model.Meals.Count > 0)
    {
        @* One card per meal — shares the _MealCard partial with the full grid so an edited
           cell keeps its photo, fulfillment, cost and attendees. *@
        @foreach (var meal in Model.Meals)
        {
            @await Html.PartialAsync("_MealCard", new Plantry.Web.Pages.MealPlan.IndexModel.MealCardVm(
                meal, dateIso, Model.SlotId, Model.Members))
        }
        <button class="add-meal"
                hx-get="/MealPlan?handler=Editor&date=@dateIso&slotId=@slotId"
                hx-target="#meal-editor-dialog"
                hx-swap="innerHTML"
                title="Add another meal to this slot"
                aria-label="Add another meal">
            <svg class="icon" aria-hidden="true"><use href="#i-plus" /></svg>
            Add meal
        </button>
    }
    else if (hasGhost)
    {
        @* Ghost cell: AI-suggested proposal awaiting user acceptance *@
        @await Html.PartialAsync("_GhostCell", new Plantry.Web.Pages.MealPlan.IndexModel.GhostCellVm(
            Model.Date, Model.SlotId, Model.SlotLabel, Model.PendingProposal!,
            Model.GhostDishNames ?? Model.PendingProposal!.Dishes.Select(_ => "Recipe").ToList(),
            Model.GhostEnrichment))
    }
    else if (Model.IsHardConflict)
    {
        @* Hard-stance conflict cell (C6): no single dish can satisfy every attendee attending together.
           Full actionable in-cell UI: distinct message explaining the conflict + dual CTAs.
           Supersedes so5.4's minimal "No single dish suits everyone here" seed. *@
        <div class="conflict-notice" role="status">
            <svg class="icon conflict-notice__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            <span class="conflict-notice__text">Attendees&#x2019; requirements conflict &#x2014; no single dish works for everyone.</span>
        </div>
        <div class="conflict-acts">
            <button class="conflict-cta conflict-cta--primary"
                    hx-get="/MealPlan?handler=Editor&date=@dateIso&slotId=@slotId"
                    hx-target="#meal-editor-dialog"
                    hx-swap="innerHTML">
                Add a dish by hand
            </button>
            <a href="/Settings/MealSlots" class="conflict-cta conflict-cta--secondary">
                Adjust who&#x2019;s attending
            </a>
        </div>
    }
    else if (isUnfulfillable)
    {
        @* Unfulfillable cell: one attendee's Required tag has ZERO recipes in the full corpus.
           Distinct from HardConflict — this is a corpus gap (no recipes for a dietary need),
           not an attendee conflict (two attendees whose requirements can't be jointly met).
           Full actionable in-cell UI: specific message naming the missing tag + "Add a [tag] recipe" CTA. *@
        <div class="conflict-notice conflict-notice--unfulfillable" role="status">
            <svg class="icon conflict-notice__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            <span class="conflict-notice__text">@unfulfillableMsg</span>
        </div>
        <div class="conflict-acts">
            <a href="/Recipes/Edit" class="conflict-cta conflict-cta--primary">
                @unfulfillableCtaLabel
            </a>
        </div>
    }
    else
    {
        <div class="empty-acts">
            <button class="empty-add"
                    hx-get="/MealPlan?handler=Editor&date=@dateIso&slotId=@slotId"
                    hx-target="#meal-editor-dialog"
                    hx-swap="innerHTML"
                    aria-label="Add meal">
                <svg class="icon" aria-hidden="true"><use href="#i-plus" /></svg>
            </button>
            <button class="empty-auto"
                    hx-post="/MealPlan?handler=GenerateCell&amp;date=@dateIso&amp;slotId=@slotId"
                    hx-target="#@cellId"
                    hx-swap="outerHTML"
                    hx-indicator=".autofill-spinner"
                    title="Auto-fill this cell with an AI suggestion"
                    aria-label="Auto-fill this cell">
                <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
                Auto-fill
            </button>
        </div>
    }
</div>
