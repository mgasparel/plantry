@model Plantry.Web.Pages.MealPlan.IndexModel.DishSearchVm
@{
    var q = Model.Query ?? "";
    string Lvl(int pct) => pct >= 80 ? "hi" : pct >= 50 ? "mid" : "lo";
}

@if (Model.Recipes.Count > 0)
{
    <div class="dm-group">Recipes</div>
    @foreach (var r in Model.Recipes)
    {
        var rInitial = r.Name.Length > 0 ? r.Name[0].ToString() : "?";
        var photoUrl = $"/Recipes/Details?id={r.RecipeId}&handler=Photo";
        var costAttr = r.CostPerServing?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "";
        <div class="dish-opt"
             data-kind="recipe"
             data-item-id="@r.RecipeId"
             data-name="@r.Name"
             data-servings="@r.DefaultServings"
             data-fulfillment="@(r.FulfillmentPercent?.ToString() ?? "")"
             data-cost-per-serving="@costAttr"
             data-has-photo="@(r.HasPhoto ? "1" : "")"
             onmousedown="addDishFromResult(this)">
            @if (r.HasPhoto)
            {
                <img class="do-thumb" src="@photoUrl" alt="@r.Name"
                     onerror="this.replaceWith(Object.assign(document.createElement('div'),{className:'do-thumb do-thumb--chip',textContent:'@rInitial'}))" />
            }
            else
            {
                <div class="do-thumb do-thumb--chip">@rInitial</div>
            }
            <div class="do-main">
                <div class="do-name">@r.Name</div>
                <div class="do-sub">
                    @if (r.FulfillmentPercent is int pct)
                    {
                        <span class="fdot lvl-@(Lvl(pct))-bg"></span>
                        <span>@pct% in pantry · @r.DefaultServings srv@(r.CostPerServing is { } cps ? $" · ${(cps * r.DefaultServings):F2}" : "")</span>
                    }
                    else
                    {
                        <span>@r.DefaultServings srv</span>
                    }
                </div>
            </div>
        </div>
    }
}

@if (Model.Products.Count > 0)
{
    <div class="dm-group">Pantry items</div>
    @foreach (var p in Model.Products)
    {
        var pInitial = p.Name.Length > 0 ? p.Name[0].ToString() : "?";
        <div class="dish-opt"
             data-kind="product"
             data-item-id="@p.ProductId"
             data-name="@p.Name"
             data-servings="1"
             data-fulfillment=""
             data-cost-per-serving=""
             data-has-photo=""
             onmousedown="addDishFromResult(this)">
            <div class="do-thumb do-thumb--chip">@pInitial</div>
            <div class="do-main">
                <div class="do-name">@p.Name</div>
                <div class="do-sub">Pantry item</div>
            </div>
        </div>
    }
}

@if (Model.Recipes.Count == 0 && Model.Products.Count == 0 && !string.IsNullOrWhiteSpace(q))
{
    <div style="padding:12px 8px;color:var(--color-text-faint);font-size:13px;">No results for "@q"</div>
}
