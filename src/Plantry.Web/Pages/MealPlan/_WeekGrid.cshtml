@model Plantry.Web.Pages.MealPlan.IndexModel

@if (!Model.HasSlots)
{
    <div class="grid-scroll">
        <div class="planner-empty">
            <p class="planner-empty__message">No meal slots are configured yet.</p>
            <a href="/Settings/MealSlots" class="btn btn--primary">Configure meal slots</a>
        </div>
    </div>
}
else
{
    <div class="plan-body-inner" x-data="{ railOpen: true }" style="display:contents">
    <div class="grid-scroll">
        <div class="wkgrid">
            @* Day-column headers *@
            @foreach (var day in Model.WeekDays)
            {
                <div class="day-col day-head @(day.IsToday ? "is-today" : "")">
                    <span class="dh-dow">@day.DayName</span>
                    <span class="dh-date">@day.DateLabel</span>
                    <span class="spacer"></span>
                    @* Per-day auto-fill button — disabled until per-day generation is wired *@
                    <button class="dh-auto" title="Auto-fill @day.DayName (use Auto-fill week)" disabled aria-label="Auto-fill @day.DayName" tabindex="-1">
                        <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
                    </button>
                </div>
            }

            @* Slot bands + cells *@
            @foreach (var slot in Model.Slots)
            {
                @* Slot band (full-width) *@
                <div class="slot-band">
                    <span class="sb-name">@slot.Label</span>
                    <span class="sb-att">
                        @foreach (var m in slot.DefaultAttendees.Take(3))
                        {
                            var member = Model.Members.FirstOrDefault(x => x.UserId == m);
                            if (member is not null)
                            {
                                <span class="pl-av" data-av-color="@(Model.Members.IndexOf(member) % 8)" style="width:20px;height:20px;font-size:8px;" title="@member.DisplayName">@member.Initials</span>
                            }
                        }
                    </span>
                    <span class="sb-rule"></span>
                    @* Manage settings shortcuts (rendered once per slot band — both slot config and preferences) *@
                    <a href="/Settings/MealSlots" class="sb-manage" title="Manage meal slots" aria-label="Manage meal slots" tabindex="-1">
                        <svg class="icon" aria-hidden="true"><use href="#i-settings" /></svg>
                    </a>
                    <a href="/Settings/Preferences" class="sb-manage sb-manage--prefs" title="Dietary preferences" aria-label="Dietary preferences" tabindex="-1">
                        <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
                    </a>
                </div>

                @* Day cells for this slot *@
                @foreach (var day in Model.WeekDays)
                {
                    var cellDate = DateOnly.Parse(day.DateIso);
                    var key = Plantry.Web.Pages.MealPlan.IndexModel.CellKey(cellDate, slot.Id);
                    var meals = Model.MealsByCell.GetValueOrDefault(key) ?? [];
                    var pending = Model.PendingProposals.GetValueOrDefault(key);
                    var cellId = $"cell-{slot.Id.Value:N}-{day.DateIso}";

                    <div id="@cellId"
                         class="mcell @(meals.Count > 0 ? "filled" : pending is not null ? "ghost" : "empty")"
                         ondragover="onDragOver(event)"
                         ondragleave="onDragLeave(event)"
                         ondrop="onDrop(event, '@day.DateIso', '@slot.Id.Value')">

                        @if (meals.Count > 0)
                        {
                            @* CellStack: one card per meal, plus an "Add meal" affordance (proto parity) *@
                            @foreach (var meal in meals)
                            {
                                @await Html.PartialAsync("_MealCard", new Plantry.Web.Pages.MealPlan.IndexModel.MealCardVm(
                                    meal, day.DateIso, slot.Id, Model.Members))
                            }
                            <button class="add-meal"
                                    hx-get="/MealPlan?handler=Editor&date=@day.DateIso&slotId=@slot.Id.Value"
                                    hx-target="#meal-editor-dialog"
                                    hx-swap="innerHTML"
                                    title="Add another meal to this slot"
                                    aria-label="Add another meal for @slot.Label on @day.DayName">
                                <svg class="icon" aria-hidden="true"><use href="#i-plus" /></svg>
                                Add meal
                            </button>
                        }
                        else if (pending is not null)
                        {
                            @* Ghost cell: AI-suggested, awaiting user acceptance *@
                            var ghostDishNames = new List<string>();
                            foreach (var d in pending.Dishes.OrderBy(x => x.Ordinal))
                            {
                                var r = await Plantry.Web.Pages.MealPlan.IndexModel.ResolveRecipeName(d.RecipeId, Model);
                                ghostDishNames.Add(r);
                            }
                            @await Html.PartialAsync("_GhostCell", new Plantry.Web.Pages.MealPlan.IndexModel.GhostCellVm(
                                cellDate, slot.Id, slot.Label, pending, ghostDishNames))
                        }
                        else
                        {
                            @* Empty cell *@
                            <div class="empty-acts">
                                <button class="empty-add"
                                        hx-get="/MealPlan?handler=Editor&date=@day.DateIso&slotId=@slot.Id.Value"
                                        hx-target="#meal-editor-dialog"
                                        hx-swap="innerHTML"
                                        aria-label="Add meal for @slot.Label on @day.DayName">
                                    <svg class="icon" aria-hidden="true"><use href="#i-plus" /></svg>
                                </button>
                                <button class="empty-auto" disabled title="Use Auto-fill week to fill this cell" tabindex="-1">
                                    <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
                                    Auto-fill
                                </button>
                            </div>
                        }
                    </div>
                }
            }
        </div>
    </div>

    @* Insights rail — advisory callouts derived from the planned week *@
    <aside class="plan-rail" :class="{ collapsed: !railOpen }">
        <div class="rail-head">
            <span class="ri-mark">
                <svg class="icon sparkle-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .962 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.962 0z" /></svg>
            </span>
            <h3>Plan insights</h3>
            <span class="spacer"></span>
            @if (Model.Insights.Count > 0)
            {
                <span class="ri-count">@Model.Insights.Count</span>
            }
            <button type="button" class="rail-collapse" @@click="railOpen = false" title="Hide insights" aria-label="Hide insights">
                <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18l6-6-6-6" /></svg>
            </button>
        </div>
        @if (Model.Insights.Count == 0)
        {
            <div class="rail-scroll">
                <div class="rail-clean">
                    <div class="rc-mark">
                        <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5" /></svg>
                    </div>
                    <div class="rc-t">No issues</div>
                    <div class="rc-s">This plan looks healthy. Nothing needs your attention right now.</div>
                </div>
            </div>
        }
        else
        {
            <div class="rail-scroll">
                @foreach (var c in Model.Insights)
                {
                    <div class="callout" data-tone="@c.Tone">
                        <span class="co-ico">
                            @if (c.Icon == "calendar")
                            {
                                <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" /><path d="M16 2v4M8 2v4M3 10h18" /></svg>
                            }
                            else
                            {
                                @* swap / repeat *@
                                <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="17 1 21 5 17 9" /><path d="M3 11V9a4 4 0 0 1 4-4h14" /><polyline points="7 23 3 19 7 15" /><path d="M21 13v2a4 4 0 0 1-4 4H3" /></svg>
                            }
                        </span>
                        <div>
                            <div class="co-title">@c.Title</div>
                            <div class="co-body">@c.Body</div>
                        </div>
                    </div>
                }
            </div>
        }
    </aside>

    @* Floating tab to re-open the rail once collapsed *@
    <button type="button" class="rail-reopen" x-show="!railOpen" x-cloak @@click="railOpen = true">
        <svg class="icon sparkle-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .962 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.962 0z" /></svg>
        Insights
        @if (Model.Insights.Count > 0)
        {
            <span class="rr-badge">@Model.Insights.Count</span>
        }
    </button>

    @* Pending bar — visible when there are staged AI suggestions *@
    @if (Model.PendingCount > 0)
    {
        @await Html.PartialAsync("_PendingBar", Model)
    }
    </div>
}
