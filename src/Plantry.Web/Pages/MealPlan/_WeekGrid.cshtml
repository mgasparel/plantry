@model Plantry.Web.Pages.MealPlan.IndexModel

@if (!Model.HasSlots)
{
    <div class="grid-scroll">
        <div class="planner-empty">
            <p class="planner-empty__message">No meal slots are configured yet.</p>
            <a href="/Settings/MealSlots" class="btn btn--primary">Configure meal slots</a>
        </div>
    </div>
}
else
{
    <div class="plan-body-inner" x-data="{ railOpen: true }" style="display:contents">
    <div class="grid-scroll">
        <div class="wkgrid">
            @* Day-column headers *@
            @foreach (var day in Model.WeekDays)
            {
                <div class="day-col day-head @(day.IsToday ? "is-today" : "")">
                    <span class="dh-dow">@day.DayName</span>
                    <span class="dh-date">@day.DateLabel</span>
                    <span class="spacer"></span>
                    @* Per-day auto-fill button — generates suggestions for just this day (P3-6b scope=today) *@
                    <button class="dh-auto"
                            hx-post="/MealPlan?handler=Generate&week=@day.DateIso&scope=today"
                            hx-target="#plan-main-content"
                            hx-swap="innerHTML"
                            hx-indicator=".autofill-spinner"
                            title="Auto-fill @day.DayName with AI suggestions"
                            aria-label="Auto-fill @day.DayName">
                        <svg class="icon sparkle-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .962 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.962 0z"/></svg>
                    </button>
                </div>
            }

            @* Slot bands + cells *@
            @foreach (var slot in Model.Slots)
            {
                @* Slot band (full-width) *@
                <div class="slot-band">
                    <span class="sb-name">@slot.Label</span>
                    <span class="sb-att">
                        @foreach (var m in slot.DefaultAttendees.Take(3))
                        {
                            var member = Model.Members.FirstOrDefault(x => x.UserId == m);
                            if (member is not null)
                            {
                                <span class="pl-av" data-av-color="@(Model.Members.IndexOf(member) % 8)" style="width:20px;height:20px;font-size:8px;" title="@member.DisplayName">@member.Initials</span>
                            }
                        }
                    </span>
                    <span class="sb-rule"></span>
                    @* Manage settings shortcuts (rendered once per slot band — both slot config and preferences) *@
                    <a href="/Settings/MealSlots" class="sb-manage" title="Manage meal slots" aria-label="Manage meal slots" tabindex="-1">
                        <svg class="icon" aria-hidden="true"><use href="#i-settings" /></svg>
                    </a>
                    <a href="/Settings/Preferences" class="sb-manage sb-manage--prefs" title="Dietary preferences" aria-label="Dietary preferences" tabindex="-1">
                        <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
                    </a>
                </div>

                @* Day cells for this slot.
                   The cell body (filled / ghost / empty) is delegated to _MealCell — the SAME
                   partial the per-cell htmx fragment swap returns — so the markup lives in exactly
                   ONE place. (Previously this block duplicated the empty-cell markup, which is why
                   the per-cell "Auto-fill" button stayed disabled here after _MealCell was wired.) *@
                @foreach (var day in Model.WeekDays)
                {
                    var cellDate = DateOnly.Parse(day.DateIso);
                    var key = Plantry.Web.Pages.MealPlan.IndexModel.CellKey(cellDate, slot.Id);
                    var meals = Model.MealsByCell.GetValueOrDefault(key) ?? [];
                    var pending = Model.PendingProposals.GetValueOrDefault(key);

                    // Resolve ghost dish names + rolled-up enrichment for the full-grid render so the
                    // delegated _MealCell shows the same "% in pantry · $cost" the fragment swap does.
                    List<string>? ghostDishNames = null;
                    Plantry.Web.Pages.MealPlan.IndexModel.MealFulfillmentVm? ghostEnr = null;
                    if (pending is not null)
                    {
                        ghostDishNames = new List<string>();
                        foreach (var d in pending.Dishes.OrderBy(x => x.Ordinal))
                        {
                            ghostDishNames.Add(await Plantry.Web.Pages.MealPlan.IndexModel.ResolveRecipeName(d.RecipeId, Model));
                        }
                        ghostEnr = Model.GhostEnrichments.GetValueOrDefault(key);
                    }

                    @await Html.PartialAsync("_MealCell", new Plantry.Web.Pages.MealPlan.IndexModel.CellFragmentVm(
                        cellDate, slot.Id, slot.Label, meals, Model.WeekStart, Model.Members,
                        null, pending, ghostDishNames, ghostEnr,
                        IsHardConflict: Model.ConflictCells.ContainsKey(key),
                        UnfulfillableCellInfo: Model.UnfulfillableCells.GetValueOrDefault(key)))
                }
            }
        </div>
    </div>

    @* Insights rail (+ floating reopen tab) — extracted to _PlanRail so the identical markup
       can be re-emitted out-of-band after a cell-targeted mutation. Inline here it carries no
       hx-swap-oob (Oob defaults false). *@
    @await Html.PartialAsync("_PlanRail", new Plantry.Web.Pages.MealPlan.IndexModel.PlanRailVm(
        Model.Insights, Model.PendingCount,
        ConfirmedWeekCost: Model.WeekTotalCost, ConfirmedCostIsPartial: Model.WeekCostIsPartial,
        ProjectedWeekCost: Model.ProjectedWeekCost, ProjectedCostIsPartial: Model.ProjectedWeekCostIsPartial))

    @* Pending bar — visible when there are staged AI suggestions *@
    @if (Model.PendingCount > 0)
    {
        @await Html.PartialAsync("_PendingBar", Model)
    }
    </div>
}
