@model Plantry.Web.Pages.MealPlan.IndexModel.EditorPageModel
@*
    Meal editor panel — ADR-013 §4/§5 compliant.

    Client state (ADR-005 blesses Alpine for draft collections):
      - Draft dish list (dishes[], mode, note, att, attOverridden)

    Server projections (no client formula):
      - Rollup footer (fulfillment %, est. cost) → OnPostRollupAsync → _EditorRollup fragment
        swapped into #ed-rollup-{slotIdStr}.

    The mealEditor Alpine.data() component lives in wwwroot/js/meal-editor.js.
    Its x-data attribute receives a JSON config object with the Razor-rendered initial state.
    This eliminates the @click attribute-string bug class (see bd memories).
*@
@{
    var vm = Model.Vm;
    var slot = Model.Slot;
    var members = Model.Members;
    var dateStr = vm.Date.ToString("yyyy-MM-dd");
    var dowLabel = vm.Date.DayOfWeek.ToString()[..3];
    var monthDay = vm.Date.ToString("MMM d");
    var isToday = vm.Date == DateOnly.FromDateTime(DateTime.Today);
    var defaultAtt = vm.SlotDefaultAttendees ?? [];
    var currentAtt = vm.AttendeesOverride ?? defaultAtt;
    var isOverridden = vm.AttendeesOverride != null;
    var isNote = vm.Note != null;
    var slotIdStr = slot.Id.Value.ToString("D");
    // cellKey mirrors the format used by CellFragmentAsync: "{slotGuid:N}-{dateStr}"
    var cellKey = slot.Id.Value.ToString("N") + "-" + dateStr;
    var searchUrl = $"/MealPlan?handler=Search";
    var rollupUrl = $"/MealPlan?handler=Rollup&date={dateStr}&slotId={slotIdStr}";

    // Serialize only the initial dish shape needed by the Alpine component.
    // Per-dish fulfillment/cost remain on the dish for the per-dish subtitle
    // (dishMeta helper in meal-editor.js) but are NOT aggregated client-side.
    var dishesJson = System.Text.Json.JsonSerializer.Serialize(vm.Dishes.Select(d => new
    {
        kind = d.Kind.ToString().ToLower(),
        itemId = d.ItemId.ToString("D"),
        name = d.Name,
        servings = d.Servings,
        fulfillment = d.FulfillmentPercent,
        costPerServing = d.CostPerServing,
        hasPhoto = d.HasPhoto
    }));
    var attJson = System.Text.Json.JsonSerializer.Serialize(currentAtt);
    var defaultAttJson = System.Text.Json.JsonSerializer.Serialize(defaultAtt);
    var noteJson = System.Text.Json.JsonSerializer.Serialize(vm.Note ?? "");

    // Config object threaded into Alpine.data('mealEditor') via x-data.
    // Using Html.Raw + a <script> data approach (see Razor + Alpine x-data attribute gotcha in bd
    // memories: NEVER inject JSON into a double-quoted attribute with @Html.Raw — use a <script>
    // data block and read it from JS, or a single-quoted attribute via JSON.parse).
    var mealIdJson = vm.MealId.HasValue
        ? System.Text.Json.JsonSerializer.Serialize(vm.MealId.Value.ToString("D"))
        : "null";
}

@* Razor + Alpine x-data attribute gotcha mitigation (bd memories):
   JSON must NOT be embedded in a double-quoted attribute. Pass a JS variable name instead,
   where the variable is set in a <script> block immediately above the root element.
   The script block sets window.__mealEditorCfg_<slotId> to avoid conflicts when
   multiple editors could exist in the same page lifecycle. *@
<script>
    (function () {
        'use strict';
        window['__mealEditorCfg_@(slot.Id.Value.ToString("N"))'] = {
            mode: @(isNote ? "'note'" : "'dishes'"),
            note: @Html.Raw(noteJson),
            dishes: @Html.Raw(dishesJson),
            att: @Html.Raw(attJson),
            defaultAtt: @Html.Raw(defaultAttJson),
            attOverridden: @(isOverridden ? "true" : "false"),
            dateStr: '@dateStr',
            slotIdStr: '@slotIdStr',
            cellKey: '@cellKey',
            mealId: @Html.Raw(mealIdJson),
            isEditing: @(vm.IsEditing ? "true" : "false"),
            clearMealId: @Html.Raw(vm.IsEditing && vm.MealId.HasValue
                ? System.Text.Json.JsonSerializer.Serialize(vm.MealId.Value.ToString("D"))
                : "null")
        };
    })();
</script>

<div x-data="mealEditor(window['__mealEditorCfg_@(slot.Id.Value.ToString("N"))'])"
     id="meal-editor-inner">

    @* Header *@
    <div class="ed-head">
        <div class="eh-slot">
            <svg class="icon" aria-hidden="true"><use href="#i-clock" /></svg>
        </div>
        <div>
            <h2>@slot.Label</h2>
            <div class="eh-sub">@dowLabel, @monthDay@(isToday ? " · Today" : "")</div>
        </div>
        <span class="spacer"></span>
        <button class="ed-close" type="button" onclick="closeMealEditor()" aria-label="Close">
            <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M18 6 6 18M6 6l12 12" /></svg>
        </button>
    </div>

    @* Body *@
    <div class="ed-body">

        @* Who's eating *@
        <div class="ed-sect">
            <div class="ed-sect-head">
                <span class="es-label">Who's eating</span>
                <span class="spacer"></span>
                <span class="ed-att-note" x-show="attOverridden">overrides slot default</span>
            </div>
            <div class="ed-att">
                @foreach (var member in members)
                {
                    var uid = member.UserId.ToString("D");
                    var avColor = members.IndexOf(member) % 8;
                    <button type="button"
                            class="ed-att-chip"
                            :class="att.indexOf('@uid') >= 0 ? '' : 'off'"
                            @@click="toggleAtt('@uid')"
                            aria-label="Toggle @member.DisplayName">
                        <span class="pl-av" data-av-color="@avColor" style="width:22px;height:22px;font-size:9px;">@member.Initials</span>
                        @member.DisplayName
                    </button>
                }
            </div>
        </div>

        @* Dishes section *@
        <div class="ed-sect" x-show="mode === 'dishes'">
            <div class="ed-sect-head">
                <span class="es-label">Dishes</span>
                <span class="spacer"></span>
                <div class="ed-note-toggle">or <button type="button" @@click="switchToNote()">add a note instead</button></div>
            </div>

            <div class="ed-dishes" x-show="dishes.length > 0">
                <template x-for="(d, idx) in dishes" :key="idx">
                    <div class="ed-dish">
                        <template x-if="d.hasPhoto">
                            <img class="edd-thumb edd-thumb--photo" :src="photoUrl(d)" :alt="d.name"
                                 @@error="d.hasPhoto = false" />
                        </template>
                        <template x-if="!d.hasPhoto">
                            <div class="edd-thumb edd-thumb--chip" x-text="d.name.charAt(0)"></div>
                        </template>
                        <div class="edd-main">
                            <div class="edd-name" x-text="d.name"></div>
                            <div class="edd-meta">
                                <span class="fdot" :class="'lvl-' + lvl(d.fulfillment) + '-bg'" x-show="d.fulfillment != null"></span>
                                <span x-text="dishMeta(d)"></span>
                            </div>
                        </div>
                        <div class="serv-step">
                            <button type="button" @@click="decServings(d)" aria-label="Fewer">−</button>
                            <span class="sv"><span x-text="d.servings"></span><small>serv</small></span>
                            <button type="button" @@click="incServings(d)" aria-label="More">+</button>
                        </div>
                        <button type="button" class="edd-del" @@click="removeDish(idx)" aria-label="Remove dish">
                            <svg class="icon" aria-hidden="true"><use href="#i-trash" /></svg>
                        </button>
                    </div>
                </template>
            </div>

            @* Dish search typeahead *@
            <div class="dish-search" x-data="{ dsOpen: false, dsQ: '' }">
                <div class="ds-input">
                    <svg class="icon" aria-hidden="true"><use href="#i-search" /></svg>
                    <input type="text"
                           id="dish-search-input-@slotIdStr"
                           x-model="dsQ"
                           placeholder="Search recipes or pantry items to add…"
                           @@focus="dsOpen = true"
                           @@blur="setTimeout(function() { dsOpen = false; }, 200)"
                           hx-get="@searchUrl"
                           hx-trigger="input changed delay:200ms"
                           hx-target="#dish-results-@slotIdStr"
                           hx-swap="innerHTML"
                           hx-include="[id='dish-search-input-@slotIdStr']"
                           name="q"
                           autocomplete="off" />
                </div>
                <div class="dish-menu"
                     id="dish-results-@slotIdStr"
                     x-show="dsOpen && dsQ.length > 0">
                </div>
            </div>
        </div>

        @* Note section *@
        <div class="ed-sect" x-show="mode === 'note'">
            <div class="ed-sect-head">
                <span class="es-label">Note</span>
                <span class="spacer"></span>
                <div class="ed-note-toggle">or <button type="button" @@click="switchToDishes()">plan dishes instead</button></div>
            </div>
            <div class="ed-note-field">
                <input type="text" x-model="note" placeholder="e.g. Takeout, Out of town…" />
            </div>
            <div class="ed-note-chips">
                @foreach (var preset in new[] { "Takeout", "Out of town", "Leftovers", "Dining out", "Skip this meal" })
                {
                    <button type="button" @@click="note = '@preset'">@preset</button>
                }
            </div>
        </div>

    </div>

    @* Footer *@
    <div class="ed-foot">
        @* Rollup container — swapped by OnPostRollupAsync via the Alpine _postRollup() helper.
           Rendered server-side on initial open so the footer is immediately meaningful for
           existing meals with dishes (server computes via fulfillmentService/costingService
           in OnGetEditorAsync). After open, the Alpine component posts on every dish-list
           change so the rollup stays current without any client formula (ADR-013 §4/§5). *@
        <div class="ed-rollup" id="ed-rollup-@slotIdStr">
            @await Html.PartialAsync("_EditorRollup", new Plantry.Web.Pages.MealPlan.IndexModel.EditorRollupVm(
                IsNote: vm.Note != null,
                HasDishes: vm.Dishes.Count > 0,
                FulfillmentPercent: vm.InitialFulfillmentPercent,
                TotalCost: vm.InitialTotalCost,
                CostIsPartial: vm.InitialCostIsPartial))
        </div>
        <span class="spacer"></span>

        @if (vm.IsEditing && vm.MealId.HasValue)
        {
            <button type="button" class="txt-btn danger" @@click="clearMeal()">
                Remove meal
            </button>
        }

        <button type="button" class="btn btn--secondary" onclick="closeMealEditor()">Cancel</button>

        <button type="button"
                class="btn btn--primary"
                :disabled="!canSave"
                @@click="save()">
            Save meal
        </button>
    </div>
</div>
