@page
@model Plantry.Web.Pages.Recipes.IndexModel
@{
    ViewData["Title"] = "Recipes";
    // .recipes-browse-wrap (max-width 1260px) sets its own width; opt out of the default
    // 900px .page-content cap so the gallery/grid can use the full prototype width.
    ViewData["ContentClass"] = "page-content--wide";

    var cookableLine = Model.Result.CookableCount switch
    {
        1 => "1 recipe ready to make tonight without a shopping trip.",
        > 1 => $"{Model.Result.CookableCount} recipes ready to make tonight without a shopping trip.",
        _ => "Stock up to unlock what you can cook."
    };
    var recipesSubtitle = $"What you can cook with what you have. {cookableLine}";
}

<div class="recipes-browse-wrap"
     x-data="{
         view: localStorage.getItem('recipeView') ?? 'gallery',
         setView(v) { this.view = v; localStorage.setItem('recipeView', v); }
     }">

    @* ── Header row (shared .page-header primitive — plantry-7yf1) ────────── *@
    <page-header title="Recipes" subtitle="@recipesSubtitle">
        <a href="/Recipes/New" class="btn btn--primary">
            <svg class="icon" aria-hidden="true"><use href="#i-plus" /></svg> New Recipe
        </a>
    </page-header>

    @* ── Toolbar ─────────────────────────────────────────────────────────── *@
    <form id="recipes-filter-form" method="get" action="/Recipes">
        <div class="recipes-browse-toolbar">

            @* Search box (debounced htmx live filter) *@
            <div class="recipes-search">
                <svg class="icon recipes-search__icon" aria-hidden="true"><use href="#i-search" /></svg>
                <input class="recipes-search__input"
                       type="search"
                       name="q"
                       value="@Model.Q"
                       placeholder="Search recipes…"
                       hx-get="/Recipes"
                       hx-trigger="input changed delay:300ms"
                       hx-target="#recipes-results"
                       hx-swap="innerHTML"
                       hx-include="#recipes-filter-form"
                       autocomplete="off" />
            </div>

            @* Tag filter chips *@
            @if (Model.Result.AllTags.Count > 0)
            {
                <div class="filter-chip-bar">
                    @{
                        var allActive = Model.TagId is null;
                    }
                    <button type="button"
                            class="filter-chip @(allActive ? "is-active filter-chip--accent" : "")"
                            hx-get="/Recipes"
                            hx-target="#recipes-results"
                            hx-swap="innerHTML"
                            hx-include="#recipes-filter-form"
                            hx-vals='{"tagId": ""}'>
                        <partial name="Shared/_FilterChip" model='new Plantry.Web.Pages.Shared.FilterChipViewModel("All")' />
                    </button>
                    @foreach (var tag in Model.Result.AllTags)
                    {
                        var isActive = Model.TagId == tag.Id.Value;
                        var color = IndexModel.TagColor(tag.Name);
                        <button type="button"
                                class="filter-chip @(isActive ? "is-active filter-chip--accent" : "")"
                                hx-get="/Recipes"
                                hx-target="#recipes-results"
                                hx-swap="innerHTML"
                                hx-include="#recipes-filter-form"
                                hx-vals='{"tagId": "@(isActive ? "" : tag.Id.Value)"}'>
                            <partial name="Shared/_FilterChip" model='new Plantry.Web.Pages.Shared.FilterChipViewModel(tag.Name, DotColor: isActive ? null : color)' />
                        </button>
                    }
                </div>
            }

            <div class="recipes-browse-toolbar__spacer"></div>

            @* Use-soon toggle *@
            <button type="button"
                    class="filter-chip @(Model.Soon ? "is-active filter-chip--warning" : "")"
                    hx-get="/Recipes"
                    hx-target="#recipes-results"
                    hx-swap="innerHTML"
                    hx-include="#recipes-filter-form"
                    hx-vals='{"soon": "@(!Model.Soon ? "true" : "false")"}'>
                <partial name="Shared/_FilterChip" model='new Plantry.Web.Pages.Shared.FilterChipViewModel("Use soon", IconId: "i-timer")' />
            </button>

            @* Sort select *@
            <select class="recipes-sort-select"
                    name="sort"
                    hx-get="/Recipes"
                    hx-trigger="change"
                    hx-target="#recipes-results"
                    hx-swap="innerHTML"
                    hx-include="#recipes-filter-form">
                <!option value="fulfillment" @(Model.Sort is null or "fulfillment" ? "selected" : "")>Sort: Fulfillment</!option>
                <!option value="cost"      @(Model.Sort == "cost"     ? "selected" : "")>Sort: Cost per serving</!option>
                <!option value="cooktime"  @(Model.Sort == "cooktime" ? "selected" : "")>Sort: Cook time</!option>
                <!option value="recent"    @(Model.Sort == "recent"   ? "selected" : "")>Sort: Recently added</!option>
                <!option value="name"      @(Model.Sort == "name"     ? "selected" : "")>Sort: Name</!option>
            </select>

            @* View toggle (persisted in localStorage via Alpine) *@
            <div class="recipes-view-toggle" role="group" aria-label="View mode">
                <button type="button"
                        class="recipes-view-toggle__btn"
                        :class="{'is-active': view === 'gallery'}"
                        @@click="setView('gallery')">
                    <svg class="icon" aria-hidden="true"><use href="#i-gallery" /></svg> Gallery
                </button>
                <button type="button"
                        class="recipes-view-toggle__btn"
                        :class="{'is-active': view === 'grid'}"
                        @@click="setView('grid')">
                    <svg class="icon" aria-hidden="true"><use href="#i-rows" /></svg> Grid
                </button>
            </div>

            @* Hidden inputs to carry state through htmx requests *@
            <input type="hidden" name="tagId" value="@(Model.TagId?.ToString() ?? "")" />
            <input type="hidden" name="soon" value="@(Model.Soon ? "true" : "false")" />
            <input type="hidden" name="desc" value="@(Model.Desc ? "true" : "false")" />
        </div>
    </form>

    @* ── Results ──────────────────────────────────────────────────────────── *@
    <div id="recipes-results">
        @await Html.PartialAsync("_RecipesBrowseResults", Model)
    </div>
</div>
