@page "/Recipes/{id:guid}/Cook"
@using System.Globalization
@model Plantry.Web.Pages.Recipes.CookModel
@inject Microsoft.AspNetCore.Mvc.ViewFeatures.IFileVersionProvider FileVersionProvider
@{
    ViewData["Title"] = $"Cook {Model.Cook.RecipeName}";
    ViewData["ContentClass"] = "page-content--wide";
    var cook = Model.Cook;
    // Versioned path for the pure skip/count module, loaded ahead of the Alpine factory (cache-bust via
    // ?v= — the island convention, see Dev/Index.cshtml). Query-string, so the base path is stable.
    var cookLogicSrc = FileVersionProvider.AddFileVersionToPath(
        ViewContext.HttpContext.Request.PathBase, "/js/islands/cook-logic.js");
    // All lines across the recipe's own direct ingredients AND every inclusion group — the notices,
    // Alpine seed payload, and rail counts consider both (recipe-composition.md §6).
    var allLines = cook.Lines.Concat(cook.InclusionGroups.SelectMany(g => g.Lines)).ToList();
    var allTrackedLines = allLines.Where(l => !l.IsUntracked).ToList();
    var hasShortfall = allLines.Any(l => l.IsShortfall);
    var hasUnitGap = allLines.Any(l => l.IsUnitGap);
    var hasInclusions = cook.InclusionGroups.Count > 0;

    // Alpine seed: one entry per tracked line keyed by LineKey (== IngredientId for direct lines, so the
    // pre-composition payload is byte-for-byte identical for a recipe with no inclusions).
    var linesJson = System.Text.Json.JsonSerializer.Serialize(
        allTrackedLines.Select(l => new
        {
            id = l.LineKey,
            variantId = l.IsParent && l.VariantOptions.Any(v => v.IsAutoSelected)
                ? l.VariantOptions.First(v => v.IsAutoSelected).VariantId.ToString()
                : (string?)null,
            qty = l.ScaledQuantity.HasValue ? (object)l.ScaledQuantity.Value : null
        }));
    var unitsJson = System.Text.Json.JsonSerializer.Serialize(
        Model.UnitOptions.Select(u => new { id = u.Value, code = u.Text }));

    // Build the x-data init. The active-ingredient count is now AUTHORITATIVE (set-based over the seeded
    // line keys, cook-logic.js), so the rail no longer needs a per-inclusion line-count map — flat and
    // composed recipes both emit the same 2-arg call (a flat recipe is byte-for-byte pre-composition).
    var xData = $"cookConfirm({linesJson}, {unitsJson})";
}

@* ── Alpine scope: per-line skip state + variant picker selections ────────── *@
<div id="cook-confirm" x-data="@xData">

    <div class="rd-wrap">
        <a href="/Recipes/@cook.RecipeId" class="rd-back">
            <svg class="icon" aria-hidden="true"><use href="#i-chevron-right" /></svg>
            Back to recipe
        </a>

        <div class="cook-grid">

            @* ═══════════════════════════════════════════════════════════════
               MAIN: Ingredients confirmation list
               ═══════════════════════════════════════════════════════════════ *@
            <div class="cook-main">
                <div class="cook-header">
                    <h1 class="cook-title">
                        <svg class="icon" aria-hidden="true"><use href="#i-flame" /></svg>
                        Cook @cook.RecipeName
                    </h1>
                    <p class="cook-sub">
                        @cook.DesiredServings serving@(cook.DesiredServings == 1 ? "" : "s")
                        @if (cook.Scale != 1m)
                        {
                            <span class="cook-scale-badge">×@cook.Scale.ToString("G3", CultureInfo.InvariantCulture)</span>
                        }
                    </p>
                </div>

                @* Shortfall notice — never blocks, just informs (C8/R9) *@
                @if (hasShortfall)
                {
                    <div class="cook-shortfall-notice" role="alert">
                        <svg class="icon" aria-hidden="true"><use href="#i-alert" /></svg>
                        <span>
                            <b>Some ingredients are running low or missing.</b>
                            You can still confirm — the cook will use whatever is available.
                        </span>
                    </div>
                }

                @* Unit-gap notice — honest "can't compare units" state, info tone, a promise not an
                   apology (plantry-qll2.5). Nothing is wrong with the pantry; we just can't convert
                   the stock unit to the recipe unit yet. *@
                @if (hasUnitGap)
                {
                    <div class="cook-unitgap-notice" role="status">
                        <svg class="icon" aria-hidden="true"><use href="#i-info" /></svg>
                        <span>
                            <b>Some ingredients need a unit conversion.</b>
                            You can still confirm — they'll be deducted automatically once the conversion is known.
                        </span>
                    </div>
                }

                <div class="card">
                    <div class="card__head">
                        <div>
                            <h3 class="card__head-title">Ingredients</h3>
                            <p class="card__head-sub">
                                Scaled to @cook.DesiredServings serving@(cook.DesiredServings == 1 ? "" : "s")
                                @if (cook.DesiredServings != cook.DefaultServings)
                                {
                                    <span>from @cook.DefaultServings default</span>
                                }
                            </p>
                        </div>
                    </div>
                    <div class="card__body cook-ing-list" role="list" aria-label="Ingredients">

                        @{ string? lastGroup = null; }
                        @foreach (var line in cook.Lines)
                        {
                            if (line.GroupHeading != lastGroup && line.GroupHeading is not null)
                            {
                                lastGroup = line.GroupHeading;
                                <div class="cook-ing-group-heading">@line.GroupHeading</div>
                            }
                            else if (line.GroupHeading is null)
                            {
                                lastGroup = null;
                            }

                            <partial name="_CookIngredientRow" model="line" />
                        }

                        @if (!cook.Lines.Any() && !hasInclusions)
                        {
                            <p style="color:var(--color-text-faint);font-size:14px;padding:12px 0">No tracked ingredients.</p>
                        }
                    </div>
                </div>

                @* ═══════════════════════════════════════════════════════════════
                   INCLUSION GROUPS (recipe-composition.md §6, D6/D7) — one card per
                   inclusion: sub name + effective servings header, whole-inclusion skip,
                   and the sub's expanded lines with the SAME per-line toolkit direct lines get.
                   ═══════════════════════════════════════════════════════════════ *@
                @foreach (var group in cook.InclusionGroups)
                {
                    <div class="card cook-inclusion-group"
                         :class="{ 'cook-inclusion-group--skipped': isInclusionSkipped('@group.PathKey') }">
                        <div class="card__head cook-inclusion-head">
                            <div>
                                <h3 class="card__head-title">@group.SubRecipeName</h3>
                                <p class="card__head-sub">
                                    @FormatServings(group.EffectiveServings) serving@(group.EffectiveServings == 1m ? "" : "s")
                                </p>
                            </div>
                            @* A descendant group's own Skip-all is disabled when an ANCESTOR inclusion is
                               whole-skipped (its lines are already dropped by the ancestor — consume parity,
                               Q2). A strict-ancestor test (not the exact self) keeps THIS group's Undo live
                               when only it is skipped. *@
                            <button type="button"
                                    class="btn btn--ghost btn--sm cook-inclusion-skip-btn"
                                    @@click="toggleInclusion('@group.PathKey')"
                                    :aria-pressed="isInclusionSkipped('@group.PathKey')"
                                    :disabled="isAncestorInclusionSkipped('@group.PathKey')"
                                    aria-label="Skip @group.SubRecipeName">
                                <span x-show="!isInclusionSkipped('@group.PathKey')">Skip all</span>
                                <span x-show="isInclusionSkipped('@group.PathKey')">Undo</span>
                            </button>
                        </div>
                        <div class="card__body cook-ing-list" role="list" aria-label="@group.SubRecipeName ingredients">
                            @foreach (var line in group.Lines)
                            {
                                <partial name="_CookIngredientRow" model="line" />
                            }
                        </div>
                    </div>
                }

                @* ═══════════════════════════════════════════════════════════════
                   ADD PRODUCT (plantry-7zjm) — the "add" primitive of skip/modify/add.
                   Search-only picker over EXISTING catalog products; on pick, an editable
                   qty + unit row is appended and posted as AddedLines. The recipe is untouched.
                   Substitution "on the fly" = skip the original + add a replacement.
                   ═══════════════════════════════════════════════════════════════ *@
                <div class="card cook-add" @@pick-product="addProduct($event.detail)">
                    <div class="card__head">
                        <div>
                            <h3 class="card__head-title">Add a product</h3>
                            <p class="card__head-sub">
                                Add an existing product to just this cook — it's consumed with the recipe
                                but doesn't change the recipe itself.
                            </p>
                        </div>
                    </div>
                    <div class="card__body">
                        @* Search-only picker — no allow-create, so there is no path to mint a new product here. *@
                        <div class="cook-add__search">
                            @* Stable id keeps the emitted listbox id deterministic for the L4 snapshot
                               tests (a random ss-<guid> id would flake Cook_full every render). *@
                            <searchable-select id="cook-add-search"
                                               search-url="/Recipes/@cook.RecipeId/Cook?handler=SearchProducts"
                                               placeholder="Search products to add…" />
                        </div>

                        @* One editable row per added product; visually distinguished from recipe lines. *@
                        <template x-for="p in addedProducts" :key="p.key">
                            <div class="cook-added-row">
                                <div class="cook-added-row__body">
                                    <span class="cook-added-row__name" x-text="p.name"></span>
                                    <span class="cook-added-row__badge">added</span>
                                </div>
                                <div class="cook-added-row__qty">
                                    <stepper name=""
                                             x-model="p.qty"
                                             decrease-click="p.qty = Math.max(0, (parseFloat(p.qty) || 0) - 1)"
                                             increase-click="p.qty = (parseFloat(p.qty) || 0) + 1"
                                             decrease-label="Decrease quantity"
                                             increase-label="Increase quantity"
                                             input-label="Added product quantity" />
                                    <select class="field__input cook-added-row__unit-sel"
                                            x-model="p.unitId"
                                            aria-label="Added product unit">
                                        @foreach (var u in Model.UnitOptions)
                                        {
                                            <option value="@u.Value">@u.Text</option>
                                        }
                                    </select>
                                </div>
                                <button type="button" class="btn btn--ghost btn--sm cook-added-row__remove"
                                        @@click="removeAdded(p.key)" aria-label="Remove added product">
                                    Remove
                                </button>
                            </div>
                        </template>
                    </div>
                </div>
            </div>

            @* ═══════════════════════════════════════════════════════════════
               ACTION RAIL: confirm + back
               ═══════════════════════════════════════════════════════════════ *@
            <div class="cook-rail">
                <div class="card">
                    <div class="card__head">
                        <div>
                            <h3 class="card__head-title">Ready to cook?</h3>
                            @if (hasShortfall)
                            {
                                <p class="card__head-sub" style="color:var(--color-warning)">Some ingredients are short — you can still proceed.</p>
                            }
                            else if (hasUnitGap)
                            {
                                <p class="card__head-sub" style="color:var(--color-info)">Some ingredients need a conversion — you can still proceed.</p>
                            }
                            else
                            {
                                <p class="card__head-sub" style="color:var(--color-success)">Everything looks good.</p>
                            }
                        </div>
                    </div>
                    <div class="card__body">
                        <form method="post" action="/Recipes/@cook.RecipeId/Cook?Servings=@cook.DesiredServings">
                            @Html.AntiForgeryToken()

                            @* Skipped direct ingredient ids — generated dynamically by Alpine *@
                            <template x-for="ingId in directSkips" :key="ingId">
                                <input type="hidden" name="SkippedIngredientIds" :value="ingId" />
                            </template>

                            @* Direct-line quantity overrides — emitted only for lines the user changed (C9 modify) *@
                            <template x-for="m in directModifiedQuantities" :key="m.id">
                                <input type="hidden" :name="`QuantityOverrides[${m.id}]`" :value="m.qty" />
                            </template>

                            @* Path-qualified inclusion resolutions (recipe-composition.md §6, D6/D7). Only
                               emitted when the recipe has inclusions so a flat recipe posts the exact
                               pre-composition field set. *@
                            @if (hasInclusions)
                            {
                                @* Whole-inclusion skips (D7) *@
                                <template x-for="p in skippedInclusions" :key="p">
                                    <input type="hidden" name="SkippedInclusions" :value="p" />
                                </template>

                                @* Per-line skips on expanded inclusion lines (C9) *@
                                <template x-for="k in inclusionSkips" :key="k">
                                    <input type="hidden" name="SkippedInclusionLineKeys" :value="k" />
                                </template>

                                @* Per-line quantity overrides on expanded inclusion lines (C9 modify) *@
                                <template x-for="m in inclusionModifiedQuantities" :key="m.id">
                                    <input type="hidden" :name="`InclusionQuantityOverrides[${m.id}]`" :value="m.qty" />
                                </template>
                            }

                            @* Added products (plantry-7zjm) — existing catalog products added to just this cook.
                               Contiguous 0-based indices so the AddedLines[] list model binds. *@
                            <template x-for="(p, i) in addedProducts" :key="p.key">
                                <span>
                                    <input type="hidden" :name="`AddedLines[${i}].ProductId`" :value="p.productId" />
                                    <input type="hidden" :name="`AddedLines[${i}].Quantity`" :value="p.qty" />
                                    <input type="hidden" :name="`AddedLines[${i}].UnitId`" :value="p.unitId" />
                                </span>
                            </template>

                            @* Variant picker selections (hidden inputs emitted per parent-product line above) *@

                            <div class="cook-rail-summary">
                                <div class="cook-rail-stat">
                                    <span class="cook-rail-stat__val" x-text="activeCount">@allTrackedLines.Count</span>
                                    <span class="cook-rail-stat__lbl">ingredients</span>
                                </div>
                                <div class="cook-rail-stat" x-show="skippedIds.length > 0" x-cloak>
                                    <span class="cook-rail-stat__val" x-text="skippedIds.length"></span>
                                    <span class="cook-rail-stat__lbl">skipped</span>
                                </div>
                            </div>

                            @* Yield-on-cook (plantry-854a, recipe-composition.md §9): store leftover / prepped
                               servings as inventory. Only shown when the recipe declares a yield. Leave the
                               quantity at 0 to store nothing. *@
                            @if (cook.Yield is { } y)
                            {
                                <div class="cook-rail-yield" x-data="{ store: @(y.SuggestedQuantity.ToString(System.Globalization.CultureInfo.InvariantCulture)) }"
                                     style="margin-top:16px;padding:12px;border:1px solid var(--border,#ddd);border-radius:8px">
                                    <label class="field__label" for="StoreYieldQuantity">
                                        Storing leftovers of <strong>@y.ProductName</strong>?
                                    </label>
                                    <div class="form-grid__unit-suffix" style="margin-top:6px">
                                        <input id="StoreYieldQuantity" name="StoreYieldQuantity" type="number"
                                               min="0" step="0.001" class="field__input"
                                               x-model.number="store" value="@y.SuggestedQuantity.ToString(System.Globalization.CultureInfo.InvariantCulture)" />
                                        <span class="form-grid__unit-suffix__label">@y.UnitCode</span>
                                    </div>
                                    <div x-show="store > 0" x-cloak style="margin-top:8px">
                                        <label class="field__label" for="StoreYieldExpiry">Use by (optional)</label>
                                        <input id="StoreYieldExpiry" name="StoreYieldExpiry" type="date"
                                               class="field__input" />
                                    </div>
                                    <p style="margin-top:6px;font-size:var(--font-size-sm);color:var(--color-text-muted)">
                                        Adds a lot of @y.ProductName to your pantry. Eaten-now servings need no action.
                                    </p>
                                </div>
                            }

                            <div style="display:flex;flex-direction:column;gap:8px;margin-top:16px">
                                <button type="submit" class="btn btn--cook btn--full">
                                    <svg class="icon" aria-hidden="true"><use href="#i-flame" /></svg>
                                    Confirm cook
                                </button>
                                <a href="/Recipes/@cook.RecipeId" class="btn btn--secondary btn--full" style="text-align:center">
                                    Cancel
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

        </div>@* /cook-grid *@
    </div>@* /rd-wrap *@
</div>@* /cook-confirm *@

@functions {
    // Canonical amount rendering (plantry-jun6) — one rule shared with Details and the editor.
    private static string FormatQty(decimal qty) => IngredientAmount.Format(qty);

    // Effective inclusion servings for the group header — trims trailing zeros ("2", "1.5").
    private static string FormatServings(decimal servings) =>
        servings.ToString("0.###", CultureInfo.InvariantCulture);
}

@section Scripts {
@* Pure skip/count predicates (plantry-xvdo). Loaded as a CLASSIC (non-deferred) script BEFORE the
   inline cookConfirm factory so both run during parse, ahead of the deferred alpine.min.js that
   evaluates x-data — see cook-logic.js header for the load-order rationale. It sets window.CookLogic. *@
<script src="@cookLogicSrc"></script>
<script>
function cookConfirm(lines, units) {
    // lines: [{id: "lineKey", variantId: "guid-or-null", qty: <number|null>}, ...]
    //   lineKey == IngredientId for a direct line, or "{pathKey}|{ingredientId}" for an expanded
    //   inclusion line (recipe-composition.md §6, D6).
    // units: [{id: "guid", code: "g"}, ...] — for the Add-product row unit selector (plantry-7zjm).
    // The active-ingredient count and every skip/grey predicate delegate to window.CookLogic (a pure,
    // node --test-covered module) so the rail stat, per-line greying, and group-card greying share one
    // authoritative, order-independent, prefix-aware definition that matches the server's consume.
    return {
        // Track which lines are individually skipped (by lineKey — direct and inclusion alike).
        skippedIds: [],
        // Track which whole inclusions are skipped (by pathKey, D7).
        skippedInclusions: [],
        // Track variant picker selections: {[lineKey]: variantId}.
        _variants: Object.fromEntries(
            lines.filter(l => l.variantId).map(l => [l.id, l.variantId])
        ),
        // Track quantity values: {[lineKey]: number}.
        _quantities: Object.fromEntries(
            lines.filter(l => l.qty != null).map(l => [l.id, l.qty])
        ),
        // Original (scaled) quantities for change detection.
        _origQuantities: Object.fromEntries(
            lines.filter(l => l.qty != null).map(l => [l.id, l.qty])
        ),
        // Every tracked line key, seeded once — the authoritative set the active count reduces over.
        _lineKeys: lines.map(l => l.id),

        // ── Added products (plantry-7zjm) ─────────────────────────────────────
        // Existing catalog products the user added to just this cook. Each row posts as
        // AddedLines[i].{ProductId,Quantity,UnitId}; the recipe definition is untouched.
        units: units || [],
        addedProducts: [],
        _addSeq: 0,

        isSkipped(lineKey) { return this.skippedIds.includes(lineKey); },
        toggleSkip(lineKey) {
            if (this.isSkipped(lineKey)) {
                this.skippedIds = this.skippedIds.filter(id => id !== lineKey);
            } else {
                this.skippedIds.push(lineKey);
            }
        },

        // ── Whole-inclusion skip (D7) ─────────────────────────────────────────
        // PREFIX-AWARE: an inclusion path is skipped when it is exactly skipped OR sits under a
        // whole-skipped ANCESTOR — matching the server's WholeInclusionSkip prefix consume. This one
        // predicate drives (a) activeCount, (b) per-line greying (skippedExpr), and (c) the group card
        // :class, so a nested descendant card/line greys when an ancestor is whole-skipped.
        isInclusionSkipped(pathKey) {
            return CookLogic.isPathUnderSkip(pathKey, this.skippedInclusions);
        },
        // A STRICT ancestor of this path is whole-skipped (exact self excluded) — disables a descendant
        // group's own Skip-all under a skipped ancestor while keeping its own Undo live.
        isAncestorInclusionSkipped(pathKey) {
            return CookLogic.isAncestorSkipped(pathKey, this.skippedInclusions);
        },
        toggleInclusion(pathKey) {
            if (this.isInclusionSkipped(pathKey)) {
                this.skippedInclusions = this.skippedInclusions.filter(p => p !== pathKey);
            } else {
                this.skippedInclusions.push(pathKey);
            }
        },

        pickerVariant(lineKey) { return this._variants[lineKey] ?? null; },
        setVariant(lineKey, variantId) { this._variants[lineKey] = variantId; },
        quantity(lineKey) {
            const v = this._quantities[lineKey];
            return v != null ? v : '';
        },
        setQuantity(lineKey, raw) {
            const n = parseFloat(raw);
            this._quantities[lineKey] = (!isNaN(n) && n >= 0) ? n : null;
        },
        adjustQty(lineKey, delta) {
            const cur = this._quantities[lineKey] ?? this._origQuantities[lineKey] ?? 0;
            const next = Math.max(0, cur + delta);
            this._quantities[lineKey] = next;
        },

        // Append an added product from a pick-product event dispatched by the search picker.
        // Defaults the quantity to 1 and the unit to the product's default (falling back to the
        // first known unit). Untracked products are still added here; the server drops them (C12).
        addProduct(detail) {
            if (!detail || !detail.value) return;
            const unitId = detail.defaultUnit || (this.units[0] && this.units[0].id) || '';
            this.addedProducts.push({
                key: 'add-' + (this._addSeq++),
                productId: detail.value,
                name: detail.name || '',
                qty: 1,
                unitId: unitId,
            });
        },
        removeAdded(key) {
            this.addedProducts = this.addedProducts.filter(p => p.key !== key);
        },
        get modifiedQuantities() {
            return Object.entries(this._quantities)
                .filter(([id, v]) => {
                    if (v == null || isNaN(v) || v < 0) return false;
                    return v !== (this._origQuantities[id] ?? null);
                })
                .map(([id, qty]) => ({ id, qty }));
        },
        // True once this line's quantity has been overridden from its machine-computed default (C9 modify).
        // Drives the per-line display toggle: the pretty simplified default (quantity-display.md §7) versus
        // the verbatim decimal in the authored unit an override shows (Q9). Pure function of held state.
        isModified(lineKey) {
            const v = this._quantities[lineKey];
            if (v == null || isNaN(v) || v < 0) return false;
            return v !== (this._origQuantities[lineKey] ?? null);
        },
        // Split the resolution sets by line kind so direct lines post the flat pre-composition
        // contract and inclusion lines post the path-qualified fields (lineKey carries a '|').
        get directSkips() { return this.skippedIds.filter(k => !k.includes('|')); },
        get inclusionSkips() { return this.skippedIds.filter(k => k.includes('|')); },
        get directModifiedQuantities() { return this.modifiedQuantities.filter(m => !m.id.includes('|')); },
        get inclusionModifiedQuantities() { return this.modifiedQuantities.filter(m => m.id.includes('|')); },
        // AUTHORITATIVE, set-based: count each tracked line once, excluding it when individually skipped
        // OR under any whole-inclusion skip path. Order-independent and correct for nested inclusions —
        // no double-count (a line both skipped and under a skipped group drops once) and no nested
        // under-count (a descendant drops under a skipped ancestor). See cook-logic.js.
        get activeCount() {
            return CookLogic.activeLineCount(this._lineKeys, this.skippedIds, this.skippedInclusions);
        },
    };
}
</script>
}
