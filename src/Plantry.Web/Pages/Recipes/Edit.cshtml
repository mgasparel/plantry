@page "/Recipes/{id:guid?}/Edit"
@model Plantry.Web.Pages.Recipes.EditModel
@inject Microsoft.AspNetCore.Mvc.ViewFeatures.IFileVersionProvider FileVersionProvider
@{
    ViewData["Title"] = Model.IsCreate ? "New Recipe" : "Edit Recipe";
    // Pure section transforms (normalize / cross-section move / rename-cascade / delete) live in a
    // plain, unit-tested ES module (recipe-sections.js) bridged to window.RecipeSections below. This
    // is NOT a reactive island — Alpine remains the page's reactive layer (ADR-020); the module only
    // hosts the testable pure logic the Alpine handlers call at interaction time.
    var recipeSectionsSrc = FileVersionProvider.AddFileVersionToPath(
        ViewContext.HttpContext.Request.PathBase, "/js/recipe-sections.js");
}

@*
    Recipe editor — J6 (create) and J7 (edit).

    Alpine x-data carries:
      - tags[]         : array of {id, name} objects — selected tag chips
      - tagQuery       : the current filter text in the tag input
      - tagDropOpen    : whether the tag picker dropdown is visible
      - tagOptions[]   : [{id, name}] — all active household tags (server-serialised, filter client-side)
      - filteredTagOptions() : tagOptions filtered by tagQuery, excluding already-selected tags
      - addTagFromOption(opt) : adds a tag chip from a dropdown selection
      - servings       : current servings value (mirrors the input, for scale-offer visibility)
      - origServings   : the original servings (populated from server; 0 for create)
      - hasIngredients : whether the recipe has pre-existing ingredients (enables scale offer)
      - scaleMode      : "Keep" | "Proportional"
      - rows[]         : committed ingredient rows — each has { _id, ordinal, productId, productName, qty,
                          unitId, groupHeading, isUntracked, newStapleName, newStapleUnit,
                          needsConversion, conversionFactor, conversionFromUnitId, conversionToUnitId }
                          _id is a stable client id (survives reorder); ordinal is the canonical
                          post/render position, reassigned by recipe-sections.js on every mutation.
      - unitCodes{}    : unitId → unit-code map, for rendering read-only row summaries
      - sections()     : rows clustered into display sections (Ungrouped first, then headings first-seen)
      - removeRow(row) : removes the given row, then re-normalises section order + ordinals
      - onDragStart(row,ev), onDragOver(section,ev), onDragEnd() : live-shift drag with cross-section
                          GroupHeading reassignment (delegates to window.RecipeSections.placeRow)
      - renameSection / deleteSection : heading rename cascade + section delete → Ungrouped

    Ingredient editing uses an add/edit *sheet* (modal) rather than inline rows. Committed rows
    render read-only (rowSummary(row)); the sheet edits a working copy:
      - sheetOpen      : whether the sheet is shown (mounted via x-if)
      - editingIdx     : null while adding; the row index while editing
      - draft{}        : working copy of the ingredient being added/edited (same shape as a row)
      - openAdd() / openEdit(idx) / closeSheet() / saveSheet() : sheet lifecycle. saveSheet pushes
                          a new row or splices the edited one back into rows[].

    Hidden inputs are generated from rows[] by x-bind:value, so the server binds
    Input.Lines[n].PropertyName via model binding. Per ADR-005, Alpine owns the unsaved draft state;
    the form-binding hidden inputs are the source of truth that posts and mirror rows[].
*@

@*
    Inline-create staple mode (C12): in the add/edit sheet, when the product search yields no match
    the user clicks "Create as staple" to switch the draft from product-pick mode to new-staple mode.
    The search input becomes the staple name and a unit select appears. Surfaced by draft.newStapleName !== null.
*@

@{
    // Build the tags initial state as [{id, name}] objects and the tag options as [{id, name}] for filtering.
    // JsonSerializer.Serialize without Html.Raw — the JSON is emitted as a safe JavaScript literal via
    // Alpine's x-data attribute; Razor HTML-encodes the attribute value, so the string must NOT be
    // double-encoded via Html.Raw. Alpine reads the attribute value before HTML entity decoding and the
    // browser decodes entities in attribute values, so &quot; / &amp; round-trip correctly.
    var tagsInitJson = System.Text.Json.JsonSerializer.Serialize(
        Model.Input.TagIds
            .Zip(Model.Input.TagNames, (id, name) => new { id = id.ToString(), name })
            .ToList());
    var tagOptionsJson = System.Text.Json.JsonSerializer.Serialize(
        Model.TagOptions
            .Select(o => new { id = o.Value, name = o.Text })
            .ToList());
}

<div id="recipe-editor"
     x-data="{
         tags: @tagsInitJson,
         tagQuery: '',
         tagDropOpen: false,
         tagOptions: @tagOptionsJson,
         filteredTagOptions() {
             const q = this.tagQuery.trim().toLowerCase();
             return this.tagOptions.filter(o =>
                 !this.tags.some(t => t.id === o.id) &&
                 (!q || o.name.toLowerCase().includes(q)));
         },
         addTagFromOption(opt) {
             if (!this.tags.some(t => t.id === opt.id))
                 this.tags.push({ id: opt.id, name: opt.name });
             this.tagQuery = '';
             this.tagDropOpen = false;
             this.$nextTick(() => this.$refs.tagInput.focus());
         },
         servings: @Model.Input.DefaultServings,
         origServings: @Model.OriginalServings,
         hasIngredients: @(Model.HasExistingIngredients ? "true" : "false"),
         scaleMode: '@Model.Input.ScaleMode.ToString()',
         rows: @System.Text.Json.JsonSerializer.Serialize(
             Model.Input.Lines.Select((l, i) => new {
                 _id = i,
                 ordinal = l.Ordinal,
                 productId = l.ProductId?.ToString() ?? "",
                 productName = l.ProductName ?? "",
                 qty = l.Quantity?.ToString() ?? "",
                 unitId = l.UnitId?.ToString() ?? "",
                 defaultUnitId = l.ConversionToUnitId.ToString(),
                 defaultUnitCode = l.ConversionToUnitId != Guid.Empty
                     ? (Model.UnitOptions.FirstOrDefault(u => u.Value == l.ConversionToUnitId.ToString())?.Text ?? "")
                     : "",
                 groupHeading = l.GroupHeading ?? "",
                 isUntracked = false,
                 newStapleName = (string?)null,
                 newStapleUnit = "",
                 // Tracked-product create fields (plantry-orix) — persisted rows always start with defaults
                 // (these fields only become non-default when the user commits from the create-view on
                 // a new inline-create row; existing catalog-product rows always have newIsTracked:false).
                 newIsTracked = false,
                 newGroupId = "",
                 newGroupName = "",
                 newStapleCategoryId = "",
                 needsConversion = l.NeedsConversion,
                 conversionFactor = l.ConversionFactor?.ToString() ?? "",
                 conversionFromUnitId = l.ConversionFromUnitId.ToString(),
                 conversionToUnitId = l.ConversionToUnitId.ToString(),
             })),
         _nextId: @Model.Input.Lines.Count,
         unitCodes: @System.Text.Json.JsonSerializer.Serialize(Model.UnitOptions.ToDictionary(u => u.Value, u => u.Text)),

         // Ingredient sheet (add / edit)
         sheetOpen: false,
         // sheetView: 'search' | 'create' — drives the two-view swap in _ProductSearchCreateSheet
         // (plantry-nb4x).  Recipes currently only uses the search view; plantry-orix wires the
         // create-view path for the tracked-product create on this surface.
         sheetView: 'search',
         editingIdx: null,
         draft: {},
         blankDraft() {
             return { _id: null, ordinal: 0, productId: '', productName: '', qty: '', unitId: '',
                 defaultUnitId: '', defaultUnitCode: '',
                 groupHeading: '', isUntracked: false, newStapleName: null, newStapleUnit: '',
                 newIsTracked: false,
                 newStapleCategoryId: '', newGroupId: '', newGroupName: '',
                 needsConversion: false, conversionFactor: '', conversionFromUnitId: '', conversionToUnitId: '' };
         },
         openAdd() { this.editingIdx = null; this.sheetView = 'search'; this.draft = this.blankDraft(); this.sheetOpen = true; this._syncSearch(''); },
         // editingIdx carries the row's stable _id while editing (null while adding). The shared
         // sheet only tests `editingIdx === null` (add vs edit), so an _id value satisfies it.
         openEdit(row) { this.editingIdx = row._id; this.sheetView = 'search'; this.draft = JSON.parse(JSON.stringify(row)); this.sheetOpen = true; this._syncSearch(this.draft.productName); },
         // The sheet stays mounted (x-show), so the nested searchableSelect inits once. Push the
         // current product label into its search box each time the sheet opens.
         _syncSearch(label) { this.$nextTick(() => window.dispatchEvent(new CustomEvent('sheet-product-set', { detail: label || '' }))); },
         closeSheet() { this.sheetView = 'search'; this.sheetOpen = false; },
         draftIsEmpty() {
             return !this.draft.productId && !(this.draft.newStapleName && this.draft.newStapleName.trim());
         },
         saveSheet() {
             if (this.draftIsEmpty()) { this.sheetView = 'search'; this.sheetOpen = false; return; }
             // When saving from the create view, mark the row as a tracked product create
             // (plantry-orix). The untracked-staple path (C12) is now only used when newIsTracked
             // is false — which is the legacy path kept for backward compatibility in the data model;
             // the create view always mints tracked products (the whole point of plantry-orix).
             // Also pre-populate draft.unitId from draft.newStapleUnit so R5 (tracked needs unit)
             // is satisfied without requiring a separate edit after sheet close.
             if (this.sheetView === 'create' && this.draft.newStapleName !== null) {
                 this.draft.newIsTracked = true;
                 if (this.draft.newStapleUnit && !this.draft.unitId) {
                     this.draft.unitId = this.draft.newStapleUnit;
                 }
             }
             if (this.editingIdx === null) {
                 this.draft._id = this._nextId++;
                 this.rows.push(JSON.parse(JSON.stringify(this.draft)));
             } else {
                 const i = this.rows.findIndex(r => r._id === this.editingIdx);
                 if (i >= 0) this.rows.splice(i, 1, JSON.parse(JSON.stringify(this.draft)));
             }
             // Re-cluster the flat list into canonical section order (ungrouped-first, first-seen)
             // and reassign ordinals so the posted order equals what Details renders.
             this.rows = window.RecipeSections.normalizeRows(this.rows);             this.sheetView = 'search';
             this.sheetOpen = false;
         },
         unitLabel(id) { return this.unitCodes[id] || ''; },
         rowSummary(row) {
             // Group heading is NO LONGER crammed into the summary — it is the section header now.
             const name = row.newStapleName ? row.newStapleName : row.productName;
             const parts = [];
             if (!row.isUntracked && row.qty) parts.push(row.qty + (this.unitLabel(row.unitId) ? ' ' + this.unitLabel(row.unitId) : ''));
             if (row.isUntracked) parts.push('untracked');
             return parts.length ? name + ' · ' + parts.join(' · ') : name;
         },
         removeRow(row) {
             this.rows = window.RecipeSections.normalizeRows(this.rows.filter(r => r._id !== row._id));         },

         // ── Section model (plantry-vff8) ───────────────────────────────────────────
         _isUngrouped(h) { return h == null || String(h).trim() === ''; },
         // Display sections for render: the ungrouped bucket first (nameless), then each named
         // heading in first-appearance order. Mirrors recipe-sections.js deriveSections but kept
         // inline so the FIRST synchronous render never depends on window.RecipeSections having
         // loaded yet (that module is bridged after Alpine starts; every mutation call below runs
         // at interaction time, when it is guaranteed present).
         sections() {
             const secs = [{ key: '__ungrouped__', heading: '', isUngrouped: true,
                             items: this.rows.filter(r => this._isUngrouped(r.groupHeading)) }];
             const seen = [];
             for (const r of this.rows) {
                 const h = r.groupHeading;
                 if (this._isUngrouped(h) || seen.includes(h)) continue;
                 seen.push(h);
                 secs.push({ key: 'g:' + h, heading: h, isUngrouped: false,
                             items: this.rows.filter(x => x.groupHeading === h) });
             }
             return secs;
         },
         // The nameless Ungrouped header is hidden when it is the only section (a recipe with no
         // headings looks essentially like today); it appears once at least one named section
         // exists. The ungrouped rows themselves always render (header or not).
         showUngroupedHeader() { return this.sections().length > 1; },
         // Distinct existing section names on this recipe — feeds the add/edit sheet's section picker.
         existingSectionHeadings() {
             const seen = [];
             for (const r of this.rows) {
                 if (this._isUngrouped(r.groupHeading) || seen.includes(r.groupHeading)) continue;
                 seen.push(r.groupHeading);
             }
             return seen;
         },
         renameSection(oldHeading, newName) {
             this.rows = window.RecipeSections.renameSection(this.rows, oldHeading, newName);         },
         deleteSection(heading) {
             this.rows = window.RecipeSections.deleteSection(this.rows, heading);         },

         // ── Drag (live-shift, cross-section reassignment) ──────────────────────────
         _dragId: null,
         _dragActive: false,
         onDragStart(row, ev) {
             this._dragId = row._id;
             this._dragActive = true;
             if (ev && ev.dataTransfer) { ev.dataTransfer.effectAllowed = 'move'; ev.dataTransfer.setData('text/plain', String(row._id)); }
         },
         // Live shift: as the pointer moves over a section, reflow the dragged row to the cursor
         // position and (when the section differs) reassign its group — so the editor order tracks
         // the Details render in real time. Mutates rows on dragover, exactly like the flat editor
         // did; the reactive :class keeps the dragged row styled across re-renders.
         onDragOver(section, ev) {
             if (this._dragId === null) return;
             ev.preventDefault();
             const container = ev.currentTarget;
             const rowEls = Array.from(container.querySelectorAll('.ingredient-row'))
                 .filter(el => Number(el.dataset.rowId) !== this._dragId);
             let beforeId = null, closest = -Infinity;
             for (const el of rowEls) {
                 const box = el.getBoundingClientRect();
                 const offset = ev.clientY - box.top - box.height / 2;
                 if (offset < 0 && offset > closest) { closest = offset; beforeId = Number(el.dataset.rowId); }
             }
             this.rows = window.RecipeSections.placeRow(this.rows, this._dragId, section.heading, beforeId);
         },
         onDragEnd() {
             this._dragId = null;
             this._dragActive = false;
             this.rows = window.RecipeSections.normalizeRows(this.rows);         },
         removeTag(i) { this.tags.splice(i, 1); },
         selectProduct(row, detail) {
             row.productId = detail.value;
             row.productName = detail.name;
             row.isUntracked = detail.track === 'false';
             if (row.isUntracked) { row.qty = ''; row.unitId = ''; row.defaultUnitId = ''; row.defaultUnitCode = ''; }
             else if (detail.defaultUnit) { row.unitId = detail.defaultUnit; row.defaultUnitId = detail.defaultUnit; row.defaultUnitCode = detail.defaultUnitCode || ''; }
             // Clear any stale conversion prompt when the product changes.
             row.needsConversion = false; row.conversionFactor = '';
         },
         _convCheckTimer: null,
         _triggerConversionCheck() {
             clearTimeout(this._convCheckTimer);
             const draft = this.draft;
             if (!draft.productId || !draft.unitId || draft.isUntracked || draft.newStapleName !== null) {
                 draft.needsConversion = false;
                 return;
             }
             if (draft.unitId === draft.defaultUnitId) {
                 draft.needsConversion = false;
                 return;
             }
             this._convCheckTimer = setTimeout(async () => {
                 const url = `@Url.Page("./Edit", "CheckConversion")?productId=${encodeURIComponent(draft.productId)}&fromUnitId=${encodeURIComponent(draft.unitId)}`;
                 try {
                     const res = await fetch(url, { headers: { 'Accept': 'application/json' } });
                     if (!res.ok) return;
                     const data = await res.json();
                     if (data.needsConversion) {
                         draft.needsConversion = true;
                         draft.defaultUnitId = data.defaultUnitId || draft.defaultUnitId;
                         draft.defaultUnitCode = data.defaultUnitCode || draft.defaultUnitCode;
                     } else {
                         draft.needsConversion = false;
                     }
                 } catch (_) { /* network error — silently ignore, server backstop handles it */ }
             }, 250);
         },
         showScaleOffer() { return !this.isCreate && this.hasIngredients && parseInt(this.servings) !== this.origServings; },
         isCreate: @(Model.IsCreate ? "true" : "false"),
         init() {
             this.$watch('draft.unitId', () => this._triggerConversionCheck());
             this.$watch('draft.productId', () => { this.draft.needsConversion = false; this._triggerConversionCheck(); });
         },
     }">

    @* ── Error banner ─────────────────────────────────────────────────────────── *@
    @if (Model.SaveError is { } err)
    {
        <div class="save-error" role="alert" style="background:var(--color-danger-bg);border:1px solid var(--color-danger);border-radius:var(--radius-md);padding:var(--space-3) var(--space-4);margin-bottom:var(--space-4);color:var(--color-danger)">
            <svg class="icon" aria-hidden="true"><use href="#i-alert" /></svg>
            @err
        </div>
    }

    <form method="post" enctype="multipart/form-data" class="form-stack">
        @Html.AntiForgeryToken()

        @* ── Recipe basics card ──────────────────────────────────────────────── *@
        <div class="card">
            <div class="card__head">
                <div><h3 class="card__head-title">Recipe details</h3></div>
            </div>
            <div class="card__body">
                <div class="form-grid">
                    <field asp-for="Input.Name" stacked full>
                        <input asp-for="Input.Name" class="field__input" placeholder="e.g. Chicken soup" />
                        <span asp-validation-for="Input.Name" class="field__error"></span>
                    </field>

                    <field asp-for="Input.DefaultServings" stacked label="Servings">
                        <input asp-for="Input.DefaultServings" class="field__input" type="number" min="1" step="1"
                               x-model.number="servings" />
                        <span asp-validation-for="Input.DefaultServings" class="field__error"></span>
                    </field>

                    <field asp-for="Input.CookTimeMinutes" stacked label="Cook Time">
                        <div class="form-grid__unit-suffix">
                            <input asp-for="Input.CookTimeMinutes" class="field__input" type="number" min="1" step="1" />
                            <span class="form-grid__unit-suffix__label">min</span>
                        </div>
                    </field>

                    <field asp-for="Input.Source" stacked full>
                        <input asp-for="Input.Source" class="field__input" placeholder="e.g. Family recipe or https://example.com/recipe" />
                    </field>

                    <div style="grid-column: 1 / -1">
                        <label class="form-grid__field__label" style="font-size:var(--font-size-sm);color:var(--color-text-muted);display:block;margin-bottom:var(--space-1)">Photo</label>
                        <input type="file" name="photo" accept="image/*" class="field__input" />
                        @if (!Model.IsCreate)
                        {
                            <p style="font-size:var(--font-size-sm);color:var(--color-text-muted);margin:var(--space-1) 0 0">Upload a new photo to replace the existing one. Leave blank to keep it.</p>
                        }
                    </div>
                </div>
            </div>
        </div>

        @* ── Servings scale offer (J7 step 3) — shown on edit when servings change ── *@
        @if (!Model.IsCreate)
        {
            <input type="hidden" name="Input.ScaleMode" :value="scaleMode" />
            <div class="card" x-show="showScaleOffer()" x-cloak>
                <div class="card__head">
                    <div>
                        <h3 class="card__head-title">Scale ingredients?</h3>
                        <p class="card__head-sub">You changed the default servings. How should ingredient quantities be adjusted?</p>
                    </div>
                </div>
                <div class="card__body">
                    <div class="seg-ctrl" role="group" aria-label="Scale mode">
                        <label class="seg-ctrl__item">
                            <input type="radio" name="_scaleMode" value="Proportional" x-model="scaleMode" />
                            <span>Proportional — scale quantities</span>
                        </label>
                        <label class="seg-ctrl__item">
                            <input type="radio" name="_scaleMode" value="Keep" x-model="scaleMode" />
                            <span>Keep — preserve quantities</span>
                        </label>
                    </div>
                </div>
            </div>
        }
        else
        {
            <input type="hidden" name="Input.ScaleMode" value="Keep" />
        }

        @* ── Tags type-to-filter multi-select (read-only vocabulary) ──────────── *@
        <div class="card">
            <div class="card__head">
                <div>
                    <h3 class="card__head-title">Tags</h3>
                    <p class="card__head-sub">Type to filter defined tags and select one to add it as a chip.</p>
                </div>
            </div>
            <div class="card__body">
                @* Hidden inputs post the selected TagIds array (one input per chip) *@
                <template x-for="(tag, ti) in tags" :key="tag.id">
                    <input type="hidden" name="Input.TagIds" :value="tag.id" />
                </template>

                @* Empty-household guidance: shown when no active tags are defined *@
                @if (!Model.TagOptions.Any())
                {
                    <p style="font-size:var(--font-size-sm);color:var(--color-text-muted)">
                        No tags defined yet.
                        <a href="/Settings/Tags">Manage tags in Settings</a> to build your vocabulary.
                    </p>
                }
                else
                {
                    @* Chip display + filter input with dropdown ──────────────────── *@
                    <div style="position:relative">
                        <div class="recipe-tag-editor" style="display:flex;flex-wrap:wrap;gap:var(--space-2);align-items:center;border:1px solid var(--color-border);border-radius:var(--radius-md);padding:var(--space-2) var(--space-3);min-height:2.5rem;cursor:text" @@click="$refs.tagInput.focus()">
                            <template x-for="(tag, ti) in tags" :key="tag.id">
                                <span class="badge badge--neutral" style="display:inline-flex;align-items:center;gap:var(--space-1)">
                                    <span x-text="tag.name"></span>
                                    <button type="button" class="btn btn--ghost btn--sm" style="padding:0 2px;line-height:1;font-size:inherit" aria-label="Remove tag" @@click.stop="removeTag(ti)">×</button>
                                </span>
                            </template>
                            <input type="text" x-ref="tagInput" x-model="tagQuery"
                                   placeholder="Filter tags…"
                                   class="field__input" style="border:none;outline:none;box-shadow:none;padding:0;min-width:8rem;flex:1"
                                   @@focus="tagDropOpen = true"
                                   @@input="tagDropOpen = true"
                                   @@keydown.escape="tagDropOpen = false; tagQuery = ''"
                                   @@keydown.backspace="if (!tagQuery && tags.length) removeTag(tags.length - 1)"
                                   autocomplete="off" />
                        </div>
                        @* Dropdown — lists matching active tags not already selected *@
                        <div x-show="tagDropOpen && filteredTagOptions().length > 0"
                             x-cloak
                             @@click.outside="tagDropOpen = false"
                             style="position:absolute;z-index:50;left:0;right:0;margin-top:2px;background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius-md);max-height:12rem;overflow-y:auto;box-shadow:var(--shadow-md)">
                            <template x-for="opt in filteredTagOptions()" :key="opt.id">
                                <button type="button"
                                        class="tag-picker-option"
                                        style="display:block;width:100%;text-align:left;padding:var(--space-2) var(--space-3);background:none;border:none;cursor:pointer;font:inherit;color:var(--color-text)"
                                        @@mousedown.prevent="addTagFromOption(opt)"
                                        x-text="opt.name"></button>
                            </template>
                        </div>
                    </div>
                }
            </div>
        </div>

        @* ── Ingredients ──────────────────────────────────────────────────────── *@
        <div class="card">
            <div class="card__head">
                <div>
                    <h3 class="card__head-title">Ingredients</h3>
                    <p class="card__head-sub">Grouped into sections. Drag a row to reorder it, or across a section to move it. Rename a section heading once to rename it for every ingredient in it.</p>
                </div>
            </div>
            <div class="card__body" style="padding:0">
                @*
                    Hidden form inputs — the source of truth that POSTs. Rendered from the flat, canonical
                    `rows` array (index 0..n-1) so Input.Lines[i] binds in the same order Details will
                    group and render (recipe-sections.js keeps rows ungrouped-first + sections first-seen
                    with ordinal == index). Kept separate from the sectioned visual below so the visual
                    can cluster rows without disturbing the posted index/ordinal. The row objects here are
                    the SAME references the visual renders, so edits (e.g. the conversion factor) sync.
                *@
                <div hidden aria-hidden="true">
                    <template x-for="(row, idx) in rows" :key="row._id">
                        <div>
                            <input type="hidden" :name="'Input.Lines[' + idx + '].Ordinal'" :value="row.ordinal" />
                            <input type="hidden" :name="'Input.Lines[' + idx + '].ProductId'" :value="row.productId" />
                            @* ProductName is display-only but must be posted so the re-rendered form
                               can repopulate the Alpine productName state after a validation failure. *@
                            <input type="hidden" :name="'Input.Lines[' + idx + '].ProductName'" :value="row.productName" />
                            <input type="hidden" :name="'Input.Lines[' + idx + '].NewStapleName'" :value="row.newStapleName ?? ''" />
                            <input type="hidden" :name="'Input.Lines[' + idx + '].NewStapleDefaultUnitId'" :value="row.newStapleUnit" />
                            @* Tracked-product create fields (plantry-orix) *@
                            <input type="hidden" :name="'Input.Lines[' + idx + '].NewIsTracked'" :value="row.newIsTracked" />
                            <input type="hidden" :name="'Input.Lines[' + idx + '].NewGroupId'" :value="row.newGroupId ?? ''" />
                            <input type="hidden" :name="'Input.Lines[' + idx + '].NewGroupName'" :value="row.newGroupName ?? ''" />
                            <input type="hidden" :name="'Input.Lines[' + idx + '].NewStapleCategoryId'" :value="row.newStapleCategoryId ?? ''" />
                            <input type="hidden" :name="'Input.Lines[' + idx + '].Quantity'" :value="row.qty" />
                            <input type="hidden" :name="'Input.Lines[' + idx + '].UnitId'" :value="row.unitId" />
                            <input type="hidden" :name="'Input.Lines[' + idx + '].GroupHeading'" :value="row.groupHeading" />
                            <input type="hidden" :name="'Input.Lines[' + idx + '].ConversionFactor'" :value="row.conversionFactor" />
                        </div>
                    </template>
                </div>

                @* Sectioned, drag-reorderable ingredient list — mirrors the Details grouping. *@
                <div id="ingredient-rows" :class="{ 'ingredient-sections--dragging': _dragActive }">
                    <template x-for="section in sections()" :key="section.key">
                        @* Whole section is a drop zone: dragging over its header or its rows moves the
                           dragged row into it (reassigning group), live-shifting to the cursor position. *@
                        <div class="ing-section"
                             @@dragover.prevent="onDragOver(section, $event)"
                             @@drop.prevent="onDragEnd()">

                            @* Named-section header: inline rename + count + delete. Ungrouped header is
                               nameless/muted and only shown once a named section exists. *@
                            <div class="ing-section__head" x-show="!section.isUngrouped || showUngroupedHeader()">
                                <template x-if="section.isUngrouped">
                                    <span class="ing-section__name ing-section__name--ungrouped" title="Ingredients with no section">Ungrouped</span>
                                </template>
                                <template x-if="!section.isUngrouped">
                                    <input class="ing-section__name" type="text"
                                           :value="section.heading"
                                           title="Rename this section — every ingredient in it follows"
                                           aria-label="Section heading"
                                           @@change="renameSection(section.heading, $event.target.value)"
                                           @@keydown.enter.prevent="$event.target.blur()" />
                                </template>
                                <span class="ing-section__count"
                                      x-text="section.items.length + (section.items.length === 1 ? ' item' : ' items')"></span>
                                <template x-if="!section.isUngrouped">
                                    <button type="button" class="ing-section__del"
                                            aria-label="Delete section"
                                            title="Delete section (its ingredients move to Ungrouped)"
                                            @@click="deleteSection(section.heading)">
                                        <svg class="icon" aria-hidden="true"><use href="#i-minus" /></svg>
                                    </button>
                                </template>
                            </div>

                            <div class="ing-rows">
                                <template x-for="row in section.items" :key="row._id">
                                    <div class="ingredient-row"
                                         :data-row-id="row._id"
                                         :class="{ 'ingredient-row--needs-conversion': row.needsConversion, 'ingredient-row--dragging': row._id === _dragId }"
                                         draggable="true"
                                         @@dragstart="onDragStart(row, $event)"
                                         @@dragend="onDragEnd()">

                                        <div class="ingredient-row__body">
                                            @* Drag handle *@
                                            <div class="ingredient-row__drag" aria-hidden="true" title="Drag to reorder or move between sections">
                                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="8" x2="21" y2="8"/><line x1="3" y1="16" x2="21" y2="16"/></svg>
                                            </div>

                                            @* Summary — product · qty unit. Click to edit. *@
                                            <button type="button" class="ingredient-row__summary"
                                                    @@click="openEdit(row)"
                                                    :title="'Edit ' + (row.newStapleName || row.productName)">
                                                <span x-text="rowSummary(row)"></span>
                                            </button>

                                            @* Edit *@
                                            <button type="button" class="btn btn--ghost btn--sm ingredient-row__action"
                                                    aria-label="Edit ingredient" @@click="openEdit(row)">
                                                <svg class="icon" aria-hidden="true"><use href="#i-edit" /></svg>
                                            </button>
                                            @* Delete *@
                                            <button type="button" class="btn btn--ghost btn--sm ingredient-row__action"
                                                    aria-label="Remove ingredient" @@click="removeRow(row)"
                                                    style="color:var(--color-danger)">
                                                <svg class="icon" aria-hidden="true"><use href="#i-minus" /></svg>
                                            </button>
                                        </div>

                                        @* Inline ProductConversion form (C10 — NeedsConversion backstop, post-save) *@
                                        @* Label: "1 {fromUnit} = [factor] {defaultUnit}" matches storage direction
                                           (AddConversionAsync(from:yourUnit, to:defaultUnit, factor)) and the Catalog
                                           product page display ("1 cup = 120 g"). *@
                                        <div x-show="row.needsConversion"
                                             class="ingredient-row__conversion"
                                             style="background:var(--color-warning-bg);border-top:1px solid var(--color-warning);padding:var(--space-3) var(--space-4)">
                                            <p style="font-size:var(--font-size-sm);margin:0 0 var(--space-2)">
                                                No conversion path found. How much is 1 <span x-text="unitLabel(row.unitId)"></span>?
                                            </p>
                                            <div style="display:flex;align-items:center;gap:var(--space-2);flex-wrap:wrap">
                                                <span style="font-size:var(--font-size-sm);color:var(--color-text-muted)">1 <span x-text="unitLabel(row.unitId)"></span> =</span>
                                                <input type="number" class="field__input" step="any" min="0"
                                                       placeholder="e.g. 120"
                                                       x-model="row.conversionFactor"
                                                       style="width:8rem" />
                                                <span style="font-size:var(--font-size-sm);color:var(--color-text-muted)" x-text="unitLabel(row.conversionToUnitId)"></span>
                                            </div>
                                        </div>
                                    </div>
                                </template>
                            </div>
                        </div>
                    </template>
                </div>

                @* Empty state *@
                <div x-show="rows.length === 0"
                     style="padding:var(--space-4);color:var(--color-text-muted);font-size:var(--font-size-sm)">
                    No ingredients yet — add your first one below.
                </div>

                <div style="padding:var(--space-4)">
                    <button type="button" class="btn btn--ghost btn--sm" @@click="openAdd()">
                        <svg class="icon" aria-hidden="true"><use href="#i-plus" /></svg>
                        Add ingredient
                    </button>
                </div>
            </div>
        </div>

        @* ── Ingredient add/edit sheet (P4-6: shared partial) ──────────────────────── *@
        @* Kept in the DOM via x-show (not x-if) so the searchable-select Alpine component inits
           once at page load — see _ProductSearchCreateSheet.cshtml for the rationale. *@
        @*
            GroupOptions and CategoryOptions are populated by the page model (plantry-orix) so the
            create-view Group combobox (plantry-40n6) and Defaults collapsible (plantry-y53t) render
            with the household's real data. CreateLabel is "as a new product" (not the Recipes default
            "as a new staple") because the create view now mints a tracked catalog product —
            the untracked-staple path (C12) still works via the legacy newIsTracked=false route.
        *@
        <partial name="Shared/_ProductSearchCreateSheet"
                 model='new Plantry.Web.Pages.Shared.ProductSearchCreateSheetViewModel
                 {
                     SearchUrl           = Url.Page("./Edit", "SearchProducts")!,
                     UnitOptions         = Model.UnitOptions,
                     CategoryOptions     = Model.CategoryOptions,
                     GroupOptions        = Model.GroupOptions,
                     TrackStock          = true,
                     ExtraFieldsPartial  = "Shared/_IngredientConversionPrompt",
                     CreateLabel         = "as a new product",
                     StapleNamePlaceholder = "Product name (e.g. Olive Oil)",
                 }' />

        @* ── Directions ───────────────────────────────────────────────────────── *@
        <div class="card">
            <div class="card__head">
                <div>
                    <h3 class="card__head-title">Directions</h3>
                    <p class="card__head-sub">One step per line. A blank line starts a new step. A line starting with # becomes a section heading.</p>
                </div>
            </div>
            <div class="card__body">
                <textarea asp-for="Input.Directions"
                          class="field__input"
                          rows="10"
                          placeholder="# Prep&#10;Dice the onion.&#10;&#10;Sauté in butter for 5 minutes.&#10;&#10;# Cook&#10;Add the broth and simmer 20 minutes."
                          style="width:100%;resize:vertical;font-family:inherit"></textarea>
            </div>
        </div>

        @* ── Submit bar ───────────────────────────────────────────────────────── *@
        <div class="commit-bar">
            <a href="@(Model.IsCreate ? "/Recipes" : $"/Recipes/{Model.Id}")" class="btn btn--ghost commit-bar__cancel">Cancel</a>
            <span class="commit-bar__spacer"></span>
            <button type="submit" class="btn btn--primary">
                @(Model.IsCreate ? "Create recipe" : "Save changes")
            </button>
        </div>
    </form>
</div>

@* ── CSS for ingredient sections + rows (scoped to this page) ─────────────────── *@
<style>
    /* ── Section (plantry-vff8): heading card + its clustered rows ── */
    .ing-section { border-bottom: 1px solid var(--color-border); }
    .ing-section:last-of-type { border-bottom: none; }
    .ing-section__head {
        display: flex;
        align-items: center;
        gap: var(--space-2);
        padding: var(--space-3) var(--space-3) var(--space-2) var(--space-4);
    }
    .ing-section__name {
        flex: 1;
        min-width: 0;
        font-size: 11px;
        letter-spacing: .06em;
        text-transform: uppercase;
        color: var(--color-text-faint);
        font-weight: 700;
        background: none;
        border: 1px solid transparent;
        border-radius: var(--radius-sm);
        padding: 3px 6px;
        font-family: inherit;
    }
    /* Only the editable (named) heading gets the hover/focus affordance. */
    input.ing-section__name:hover { border-color: var(--color-border); }
    input.ing-section__name:focus {
        outline: none;
        border-color: var(--color-accent);
        background: var(--color-surface-2);
        color: var(--color-text);
        letter-spacing: normal;
        text-transform: none;
        font-size: var(--font-size-sm);
        font-weight: 600;
    }
    .ing-section__name--ungrouped { font-style: italic; color: var(--color-text-faint); }
    .ing-section__count { font-size: 11px; color: var(--color-text-faint); font-weight: 600; flex-shrink: 0; }
    .ing-section__del {
        background: none;
        border: none;
        color: var(--color-text-faint);
        cursor: pointer;
        padding: 4px;
        border-radius: var(--radius-sm);
        flex-shrink: 0;
        display: flex;
        align-items: center;
    }
    .ing-section__del:hover { color: var(--color-danger); background: var(--color-danger-bg); }

    .ing-rows { min-height: 4px; }
    /* While a drag is active, keep even an emptied section a comfortable drop target. */
    .ingredient-sections--dragging .ing-rows { min-height: 34px; }

    .ingredient-row {
        display: flex;
        flex-direction: column;
        border-bottom: 1px solid var(--color-border);
    }
    .ing-rows .ingredient-row:last-child { border-bottom: none; }
    .ingredient-row--needs-conversion { border-left: 3px solid var(--color-warning); }
    .ingredient-row--dragging { opacity: .4; }

    /* Read-only landed row: drag · summary (grows) · edit · delete */
    .ingredient-row__body {
        display: flex;
        align-items: center;
        gap: var(--space-2);
        padding: var(--space-2) var(--space-3) var(--space-2) var(--space-4);
    }
    .ingredient-row__drag {
        cursor: grab;
        color: var(--color-text-muted);
        padding: var(--space-2);
        display: flex;
        align-items: center;
        flex-shrink: 0;
    }
    /* Summary reads as text but is a button (click-to-edit). */
    .ingredient-row__summary {
        flex: 1;
        min-width: 0;
        text-align: left;
        background: none;
        border: none;
        padding: var(--space-2) 0;
        font: inherit;
        color: var(--color-text);
        cursor: pointer;
    }
    .ingredient-row__summary:hover { color: var(--color-accent); }
    .ingredient-row__action { flex-shrink: 0; }

    .recipe-tag-editor:focus-within { border-color: var(--color-accent); }
    .tag-picker-option:hover { background: var(--color-surface-2) !important; }
</style>

@section Scripts {
    @* Bridge the pure section-transform module onto window.RecipeSections. Loads after Alpine
       starts; every handler that calls it (drag, rename, delete, add, remove) runs at interaction
       time, so it is guaranteed present by then. Not an island — no reactive runtime here. *@
    <script type="module">
        window.RecipeSections = await import('@Html.Raw(recipeSectionsSrc)');
    </script>
}
