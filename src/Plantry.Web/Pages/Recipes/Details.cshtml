@page "/Recipes/{id:guid}"
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@inject Microsoft.AspNetCore.Mvc.ViewFeatures.IFileVersionProvider FileVersionProvider
@using System.Globalization
@using Plantry.Recipes.Domain
@model Plantry.Web.Pages.Recipes.DetailsModel
@{
    ViewData["Title"] = Model.Recipe.Name;
    // Canonical amount formatter (plantry-jun6): the servings-scaled ingredient quantities are
    // rendered client-side, so bridge the ingredient-amount.js twin onto window.IngredientAmount
    // (see the Scripts section) so fmt() agrees with the C# IngredientAmount.Format server render.
    var ingredientAmountSrc = FileVersionProvider.AddFileVersionToPath(
        ViewContext.HttpContext.Request.PathBase, "/js/ingredient-amount.js");
    // Two-column detail grid (.rd-wrap, max-width 1180px) sets its own width; opt out of the
    // default 900px .page-content cap so the rail isn't squeezed into a single narrow column.
    ViewData["ContentClass"] = "page-content--wide";
    var recipe = Model.Recipe;
    var cost = recipe.Cost;

    // Cook time display.
    string? cookTimeDisplay = recipe.CookTimeMinutes.HasValue
        ? (recipe.CookTimeMinutes.Value >= 60
            ? $"{recipe.CookTimeMinutes.Value / 60}h {recipe.CookTimeMinutes.Value % 60}m".Replace(" 0m", "")
            : $"{recipe.CookTimeMinutes.Value} min")
        : null;

    // Cost: total = per serving * defaultServings (Alpine rescales client-side via scale).
    decimal? costTotal = cost.Amount.HasValue ? cost.Amount.Value * recipe.DefaultServings : null;

    // Initial fulfillment card model (rendered at default servings on first load), built by the page
    // model so the add-to-shopping button labels carry their server-computed state (plantry-gsj).
    var initialFulfilmentModel = Model.FulfilmentCard;
}

@* ── Alpine scope: servings stepper + ingredient quantity scaling ─────────────────────────────── *@
@* _fulfTimer: debounce handle so rapid stepper taps fire only one htmx request (J3). The add-to-list
   button states are server-truth (swapped in via the card partial), so no Alpine flags live here. *@
<div id="recipe-detail"
     x-data="{
         servings: @recipe.DefaultServings,
         defaultServings: @recipe.DefaultServings,
         _fulfTimer: null,
         get scale() { return this.servings / this.defaultServings; },
         // Canonical amount rendering (plantry-jun6) — mirrors C# IngredientAmount.Format via the
         // ingredient-amount.js twin bridged onto window.IngredientAmount below. Falls back to a plain
         // round+string on the off-chance the module has not resolved yet on first paint; the server
         // already emitted the cleaned value as the x-text fallback text, so nothing shows unformatted.
         fmt(qty) {
             const v = qty * this.scale;
             return window.IngredientAmount
                 ? window.IngredientAmount.formatAmount(v)
                 : Number(v.toFixed(4)).toString();
         },
         refreshFulfilment() {
             clearTimeout(this._fulfTimer);
             this._fulfTimer = setTimeout(() => {
                 htmx.ajax('GET', '/Recipes/@recipe.Id?handler=Fulfilment&servings=' + this.servings, { target: '#rd-fulf-card', swap: 'outerHTML' });
             }, 250);
         }
     }">

    <div class="rd-wrap">
        <a href="/Recipes" class="rd-back">
            <svg class="icon" aria-hidden="true"><use href="#i-chevron-right" /></svg>
            All recipes
        </a>

        @* ── Archive-blocked (N5) error banner (plantry-fqb0.3, D12) ── *@
        @if (Model.SaveError is { } archiveErr)
        {
            <div class="save-error" role="alert" style="background:var(--color-danger-bg);border:1px solid var(--color-danger);border-radius:var(--radius-md);padding:var(--space-3) var(--space-4);margin-bottom:var(--space-4);color:var(--color-danger);display:flex;align-items:center;gap:var(--space-2)">
                <svg class="icon" aria-hidden="true"><use href="#i-alert" /></svg>
                @archiveErr
            </div>
        }

        @* ── Recipe actions (edit / archive) ── *@
        <div class="rd-actions" style="display:flex;gap:var(--space-2);justify-content:flex-end;margin-bottom:var(--space-3)">
            <a href="/Recipes/@recipe.Id/Edit" class="btn btn--ghost btn--sm">
                <svg class="icon" aria-hidden="true"><use href="#i-edit" /></svg>
                Edit
            </a>
            <form method="post" action="/Recipes/@recipe.Id?handler=Archive" style="display:inline"
                  onsubmit="return confirm('Archive this recipe? It will no longer appear in your recipe list.');">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn--ghost btn--sm" style="color:var(--color-danger)">
                    <svg class="icon" aria-hidden="true"><use href="#i-minus" /></svg>
                    Archive
                </button>
            </form>
        </div>

        <div class="rd-grid">

            @* ═══════════════════════════════════════════════════════════════
               MAIN COLUMN: hero + meta strip + directions
               ═══════════════════════════════════════════════════════════════ *@
            <div class="rd-main">

                @* ── Hero: photo/placeholder with overlaid name, tags, blurb ─── *@
                <div class="rd-hero">
                    @if (recipe.HasPhoto)
                    {
                        <img class="rd-hero__photo"
                             src="/Recipes/@recipe.Id?handler=Photo"
                             alt="@recipe.Name"
                             loading="lazy" />
                    }
                    else
                    {
                        <div class="rd-hero__placeholder" aria-hidden="true">
                            <svg class="icon" aria-hidden="true"><use href="#i-recipe" /></svg>
                        </div>
                    }
                    <div class="rd-hero__scrim" aria-hidden="true"></div>
                    <div class="rd-hero__info">
                        @if (recipe.Tags.Count > 0)
                        {
                            <div class="rd-hero__tags" role="list" aria-label="Tags">
                                @foreach (var tag in recipe.Tags)
                                {
                                    var tagName = tag.Name ?? tag.Id.ToString("N")[..8];
                                    @* Stable per-tag id so the diet-nudge "Remove tag" action can drop just this
                                       chip in place via an hx-swap-oob="delete" fragment (plantry-klvd). *@
                                    <span id="recipe-tag-@tag.Id" class="recipe-tag-mini" role="listitem">
                                        <span class="recipe-tag-mini__dot" style="background:@IndexModel.TagColor(tagName)"></span>
                                        @tagName
                                    </span>
                                }
                            </div>
                        }
                        <h1 class="rd-hero__name">@recipe.Name</h1>
                        @if (!string.IsNullOrWhiteSpace(recipe.Source))
                        {
                            <p class="rd-hero__blurb">@recipe.Source</p>
                        }
                    </div>
                </div>

                @* ── Meta stat strip: cook time / servings / cost per serving ── *@
                <div class="rd-meta" role="list" aria-label="Recipe stats">
                    <div class="rd-meta__cell" role="listitem">
                        <div class="rd-meta__ico" aria-hidden="true">
                            <svg class="icon"><use href="#i-clock" /></svg>
                        </div>
                        <div class="rd-meta__body">
                            <div class="rd-meta__val">
                                @(cookTimeDisplay ?? "—")
                            </div>
                            <div class="rd-meta__lbl">Cook time</div>
                        </div>
                    </div>
                    <div class="rd-meta__cell" role="listitem">
                        <div class="rd-meta__ico" aria-hidden="true">
                            <svg class="icon"><use href="#i-servings" /></svg>
                        </div>
                        <div class="rd-meta__body">
                            <div class="rd-meta__val">
                                <span x-text="servings + (servings === 1 ? ' serving' : ' servings')">@recipe.DefaultServings servings</span>
                            </div>
                            <div class="rd-meta__lbl">
                                Yields<span x-show="scale !== 1" x-cloak>
                                    &nbsp;·&nbsp;scaled <span x-text="Math.round(scale * 100) / 100"></span>&times;
                                </span>
                            </div>
                        </div>
                    </div>
                    <div class="rd-meta__cell" role="listitem">
                        <div class="rd-meta__ico" aria-hidden="true">
                            <svg class="icon"><use href="#i-tag" /></svg>
                        </div>
                        <div class="rd-meta__body">
                            @if (cost.Completeness != CostCompleteness.None && cost.Amount.HasValue)
                            {
                                <div class="rd-meta__val rd-meta__val--mono">
                                    @cost.Amount.Value.ToString("C2", CultureInfo.CurrentCulture)
                                    @if (cost.Completeness == CostCompleteness.Partial)
                                    {
                                        <span title="Partial cost estimate — @(cost.CostableCount - cost.PricedCount) ingredient(s) have no price">~</span>
                                    }
                                </div>
                                <div class="rd-meta__lbl">
                                    Per serving&nbsp;·&nbsp;@costTotal!.Value.ToString("C2", CultureInfo.CurrentCulture) total
                                </div>
                            }
                            else
                            {
                                <div class="rd-meta__val" style="color:var(--color-text-faint)">—</div>
                                <div class="rd-meta__lbl">Cost per serving</div>
                            }
                        </div>
                    </div>
                </div>

                @* ── Directions: derived steps/sections (C13) ──────────────────── *@
                @if (recipe.DirectionBlocks.Count > 0)
                {
                    <div class="rd-directions">
                        <div class="recipe-directions" id="recipe-directions">
                            @foreach (var block in recipe.DirectionBlocks)
                            {
                                if (block.Kind == DirectionBlockKind.Section)
                                {
                                    <h4 class="recipe-direction-section">@block.Text</h4>
                                }
                                else
                                {
                                    <div class="recipe-direction-step">
                                        <span class="recipe-direction-step__num" aria-hidden="true">@block.StepNumber</span>
                                        <p class="recipe-direction-step__text">@block.Text</p>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                }

            </div>@* /rd-main *@

            @* ═══════════════════════════════════════════════════════════════
               ACTION RAIL: fulfillment card + ingredients card
               ═══════════════════════════════════════════════════════════════ *@
            <div class="rd-rail">

                @* ── Fulfillment rail card ──────────────────────────────────── *@
                @* Antiforgery token — required so the htmx POST to OnPostAddMissingAsync
                   passes ASP.NET Core validation. The global htmx-antiforgery.js hook
                   picks it up via document.querySelector('input[name="__RequestVerificationToken"]').
                   Placed here (outside the swappable partial) so it survives fulfillment refreshes. *@
                @{ var __rdTokens = Antiforgery.GetAndStoreTokens(ViewContext.HttpContext); }
                <input type="hidden" name="@__rdTokens.FormFieldName" value="@__rdTokens.RequestToken" />
                @* Initial fulfillment card render at default servings. The stepper's refreshFulfilment()
                   call swaps this via OnGetFulfilmentAsync recomputed at the selected servings (J3). *@
                <partial name="_DetailsFulfilmentCard" model="initialFulfilmentModel" />

                @* ── Diet-tag contradiction nudge (plantry-qll2.3) ───────────────
                   Deferred htmx swap after a qualifying edit-save: the placeholder loads the /Recipes/DietNudge
                   fragment, which runs the household assistive-AI gate + the untrusted LLM check and returns the
                   one-line .callout (or nothing). Rendered only when the editor flagged this save, so the LLM
                   never runs on a plain recipe view. The save is already committed — this is advisory only (C9). *@
                @if (Model.ShowDietNudgeCheck)
                {
                    <div hx-get="/Recipes/DietNudge?id=@recipe.Id"
                         hx-trigger="load"
                         hx-swap="outerHTML"></div>
                }

                @* ── Ingredients card with servings stepper in header ────────── *@
                <div class="rd-ing-card">
                    <div class="rd-ing-head">
                        <h3>Ingredients</h3>
                        <div class="rd-ing-head__spacer"></div>
                        <span class="rd-serv-stepper__lbl">Servings</span>
                        <stepper variant="compact"
                                 group-label="Servings"
                                 x-text="servings"
                                 display-fallback="@recipe.DefaultServings"
                                 decrease-click="servings = Math.max(1, servings - 1); refreshFulfilment()"
                                 increase-click="servings = Math.min(24, servings + 1); refreshFulfilment()"
                                 decrease-disabled="servings <= 1"
                                 increase-disabled="servings >= 24"
                                 decrease-label="Fewer servings"
                                 increase-label="More servings" />
                    </div>

                    @* Ingredient rows are wrapped in #rd-ing-rows so the OOB swap from
                       _DetailsFulfilmentCard can update per-ingredient status dots and sub-labels
                       whenever the servings stepper triggers a fulfillment refresh (J3). *@
                    <div class="rd-ing-list" role="list" aria-label="Ingredients">
                        <div id="rd-ing-rows">
                            <partial name="_IngredientRows" model="recipe.IngredientGroups" />
                        </div>
                    </div>
                </div>

                @* ── Included recipes (plantry-fqb0.3, §5 / D15) — 'N servings · Sub' link in ordinal
                      position with an expandable read-only preview of the sub's expanded ingredients.
                      Lives OUTSIDE #rd-ing-rows so the servings-stepper OOB swap never disturbs it. ── *@
                @if (Model.Inclusions.Count > 0)
                {
                    <div class="rd-incl-card">
                        <div class="rd-incl-head"><h3>Included recipes</h3></div>
                        @foreach (var inc in Model.Inclusions)
                        {
                            var batchHint = Plantry.Web.Pages.Recipes.DetailsModel.FormatBatchHint(inc.Servings, inc.SubDefaultServings);
                            <div class="rd-incl" role="listitem">
                                <a class="rd-incl__title" href="/Recipes/@inc.SubRecipeId">
                                    <svg class="icon" aria-hidden="true"><use href="#i-recipe" /></svg>
                                    <span>@Plantry.Web.Pages.Recipes.DetailsModel.FormatServings(inc.Servings) · @inc.SubName</span>
                                </a>
                                @if (!string.IsNullOrEmpty(batchHint))
                                {
                                    <div class="rd-incl__hint">≈ @batchHint</div>
                                }
                                @if (inc.Preview.Count > 0)
                                {
                                    <details class="rd-incl__preview">
                                        <summary>Ingredients (@inc.Preview.Count)</summary>
                                        <ul class="rd-incl__list">
                                            @foreach (var item in inc.Preview)
                                            {
                                                <li class="rd-incl__item">
                                                    <span class="rd-incl__item-name">@item.ProductName</span>
                                                    @if (item.Quantity.HasValue)
                                                    {
                                                        <span class="rd-incl__item-amt">@IngredientAmount.Format(item.Quantity.Value)@(string.IsNullOrEmpty(item.UnitCode) ? "" : " " + item.UnitCode)</span>
                                                    }
                                                </li>
                                            }
                                        </ul>
                                    </details>
                                }
                            </div>
                        }
                    </div>
                }

            </div>@* /rd-rail *@

        </div>@* /rd-grid *@
    </div>@* /rd-wrap *@

</div>@* /recipe-detail *@

@* ── Included-recipes card styling (plantry-fqb0.3) — page-specific; composes plenish.css tokens ── *@
<style>
    .rd-incl-card {
        margin-top: var(--space-4);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-lg);
        background: var(--color-surface);
        overflow: hidden;
    }
    .rd-incl-head { padding: var(--space-3) var(--space-4); border-bottom: 1px solid var(--color-border); }
    .rd-incl-head h3 { margin: 0; font-size: var(--font-size-md); }
    .rd-incl { padding: var(--space-3) var(--space-4); border-bottom: 1px solid var(--color-border); }
    .rd-incl:last-child { border-bottom: none; }
    .rd-incl__title {
        display: flex; align-items: center; gap: var(--space-2);
        color: var(--color-text); font-weight: 600; text-decoration: none;
    }
    .rd-incl__title:hover { color: var(--color-accent); }
    .rd-incl__title .icon { color: var(--color-accent); flex-shrink: 0; }
    .rd-incl__hint { font-size: var(--font-size-sm); color: var(--color-text-muted); margin: 2px 0 0 calc(16px + var(--space-2)); }
    .rd-incl__preview { margin: var(--space-2) 0 0 calc(16px + var(--space-2)); }
    .rd-incl__preview > summary {
        cursor: pointer; font-size: var(--font-size-sm); color: var(--color-text-muted);
        list-style: revert;
    }
    .rd-incl__preview > summary:hover { color: var(--color-accent); }
    .rd-incl__list { list-style: none; margin: var(--space-2) 0 0; padding: 0; }
    .rd-incl__item {
        display: flex; justify-content: space-between; gap: var(--space-2);
        font-size: var(--font-size-sm); padding: 2px 0; color: var(--color-text);
    }
    .rd-incl__item-amt { color: var(--color-text-muted); flex-shrink: 0; font-variant-numeric: tabular-nums; }
</style>

@section Scripts {
    @* Bridge the canonical amount formatter onto window.IngredientAmount so the Alpine fmt() renders
       servings-scaled quantities with the same trailing-zero rule as C# IngredientAmount.Format
       (plantry-jun6). Not an island — no reactive runtime here; fmt() has a synchronous fallback for
       the first paint before this resolves, and the server already emitted the cleaned amount text. *@
    <script type="module">
        window.IngredientAmount = await import('@Html.Raw(ingredientAmountSrc)');
    </script>
}
