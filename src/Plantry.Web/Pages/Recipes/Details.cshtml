@page "/Recipes/{id:guid}"
@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@using System.Globalization
@using Plantry.Recipes.Domain
@model Plantry.Web.Pages.Recipes.DetailsModel
@{
    ViewData["Title"] = Model.Recipe.Name;
    // Two-column detail grid (.rd-wrap, max-width 1180px) sets its own width; opt out of the
    // default 900px .page-content cap so the rail isn't squeezed into a single narrow column.
    ViewData["ContentClass"] = "page-content--wide";
    var recipe = Model.Recipe;
    var cost = recipe.Cost;

    // Cook time display.
    string? cookTimeDisplay = recipe.CookTimeMinutes.HasValue
        ? (recipe.CookTimeMinutes.Value >= 60
            ? $"{recipe.CookTimeMinutes.Value / 60}h {recipe.CookTimeMinutes.Value % 60}m".Replace(" 0m", "")
            : $"{recipe.CookTimeMinutes.Value} min")
        : null;

    // Cost: total = per serving * defaultServings (Alpine rescales client-side via scale).
    decimal? costTotal = cost.Amount.HasValue ? cost.Amount.Value * recipe.DefaultServings : null;

    // Initial fulfillment card model (rendered at default servings on first load).
    // Oob: false — the OOB attribute must NOT be emitted on initial render; htmx does not
    // process hx-swap-oob on elements already in the DOM. The stepper triggers
    // OnGetFulfilmentAsync (Oob: true) to recompute and swap at the selected servings.
    var initialFulfilmentModel = new Plantry.Web.Pages.Recipes.DetailsFulfilmentCardModel(
        RecipeId: recipe.Id,
        DefaultServings: recipe.DefaultServings,
        Fulfillment: recipe.Fulfillment,
        IngredientGroups: recipe.IngredientGroups,
        Oob: false);
}

@* ── Alpine scope: servings stepper + ingredient quantity scaling + add-missing state ─────────── *@
@* _fulfTimer: debounce handle so rapid stepper taps fire only one htmx request (J3). *@
<div id="recipe-detail"
     x-data="{
         servings: @recipe.DefaultServings,
         defaultServings: @recipe.DefaultServings,
         missingAdded: false,
         _fulfTimer: null,
         get scale() { return this.servings / this.defaultServings; },
         fmt(qty) { let v = qty * this.scale; return v % 1 === 0 ? v.toString() : v.toPrecision(3).replace(/\\.?0+$/, ''); },
         refreshFulfilment() {
             clearTimeout(this._fulfTimer);
             this._fulfTimer = setTimeout(() => {
                 htmx.ajax('GET', '/Recipes/@recipe.Id?handler=Fulfilment&servings=' + this.servings, { target: '#rd-fulf-card', swap: 'outerHTML' });
             }, 250);
         }
     }">

    <div class="rd-wrap">
        <a href="/Recipes" class="rd-back">
            <svg class="icon" aria-hidden="true"><use href="#i-chevron-right" /></svg>
            All recipes
        </a>
        <div class="rd-grid">

            @* ═══════════════════════════════════════════════════════════════
               MAIN COLUMN: hero + meta strip + directions
               ═══════════════════════════════════════════════════════════════ *@
            <div class="rd-main">

                @* ── Hero: photo/placeholder with overlaid name, tags, blurb ─── *@
                <div class="rd-hero">
                    @if (recipe.HasPhoto)
                    {
                        <img class="rd-hero__photo"
                             src="/Recipes/@recipe.Id?handler=Photo"
                             alt="@recipe.Name"
                             loading="lazy" />
                    }
                    else
                    {
                        <div class="rd-hero__placeholder" aria-hidden="true">
                            <svg class="icon" aria-hidden="true"><use href="#i-recipe" /></svg>
                        </div>
                    }
                    <div class="rd-hero__scrim" aria-hidden="true"></div>
                    <div class="rd-hero__info">
                        @if (recipe.Tags.Count > 0)
                        {
                            <div class="rd-hero__tags" role="list" aria-label="Tags">
                                @foreach (var tag in recipe.Tags)
                                {
                                    var tagName = tag.Name ?? tag.Id.ToString("N")[..8];
                                    <span class="recipe-tag-mini" role="listitem">
                                        <span class="recipe-tag-mini__dot" style="background:@IndexModel.TagColor(tagName)"></span>
                                        @tagName
                                    </span>
                                }
                            </div>
                        }
                        <h1 class="rd-hero__name">@recipe.Name</h1>
                        @if (!string.IsNullOrWhiteSpace(recipe.Source))
                        {
                            <p class="rd-hero__blurb">@recipe.Source</p>
                        }
                    </div>
                </div>

                @* ── Meta stat strip: cook time / servings / cost per serving ── *@
                <div class="rd-meta" role="list" aria-label="Recipe stats">
                    <div class="rd-meta__cell" role="listitem">
                        <div class="rd-meta__ico" aria-hidden="true">
                            <svg class="icon"><use href="#i-clock" /></svg>
                        </div>
                        <div class="rd-meta__body">
                            <div class="rd-meta__val">
                                @(cookTimeDisplay ?? "—")
                            </div>
                            <div class="rd-meta__lbl">Cook time</div>
                        </div>
                    </div>
                    <div class="rd-meta__cell" role="listitem">
                        <div class="rd-meta__ico" aria-hidden="true">
                            <svg class="icon"><use href="#i-servings" /></svg>
                        </div>
                        <div class="rd-meta__body">
                            <div class="rd-meta__val">
                                <span x-text="servings + (servings === 1 ? ' serving' : ' servings')">@recipe.DefaultServings servings</span>
                            </div>
                            <div class="rd-meta__lbl">
                                Yields<span x-show="scale !== 1" x-cloak>
                                    &nbsp;·&nbsp;scaled <span x-text="Math.round(scale * 100) / 100"></span>&times;
                                </span>
                            </div>
                        </div>
                    </div>
                    <div class="rd-meta__cell" role="listitem">
                        <div class="rd-meta__ico" aria-hidden="true">
                            <svg class="icon"><use href="#i-tag" /></svg>
                        </div>
                        <div class="rd-meta__body">
                            @if (cost.Completeness != CostCompleteness.None && cost.Amount.HasValue)
                            {
                                <div class="rd-meta__val rd-meta__val--mono">
                                    @cost.Amount.Value.ToString("C2", CultureInfo.CurrentCulture)
                                    @if (cost.Completeness == CostCompleteness.Partial)
                                    {
                                        <span title="Partial cost estimate — @(cost.CostableCount - cost.PricedCount) ingredient(s) have no price">~</span>
                                    }
                                </div>
                                <div class="rd-meta__lbl">
                                    Per serving&nbsp;·&nbsp;@costTotal!.Value.ToString("C2", CultureInfo.CurrentCulture) total
                                </div>
                            }
                            else
                            {
                                <div class="rd-meta__val" style="color:var(--color-text-faint)">—</div>
                                <div class="rd-meta__lbl">Cost per serving</div>
                            }
                        </div>
                    </div>
                </div>

                @* ── Directions: derived steps/sections (C13) ──────────────────── *@
                @if (recipe.DirectionBlocks.Count > 0)
                {
                    <div class="rd-directions">
                        <div class="recipe-directions" id="recipe-directions">
                            @foreach (var block in recipe.DirectionBlocks)
                            {
                                if (block.Kind == DirectionBlockKind.Section)
                                {
                                    <h4 class="recipe-direction-section">@block.Text</h4>
                                }
                                else
                                {
                                    <div class="recipe-direction-step">
                                        <span class="recipe-direction-step__num" aria-hidden="true">@block.StepNumber</span>
                                        <p class="recipe-direction-step__text">@block.Text</p>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                }

            </div>@* /rd-main *@

            @* ═══════════════════════════════════════════════════════════════
               ACTION RAIL: fulfillment card + ingredients card
               ═══════════════════════════════════════════════════════════════ *@
            <div class="rd-rail">

                @* ── Fulfillment rail card ──────────────────────────────────── *@
                @* Antiforgery token — required so the htmx POST to OnPostAddMissingAsync
                   passes ASP.NET Core validation. The global htmx-antiforgery.js hook
                   picks it up via document.querySelector('input[name="__RequestVerificationToken"]').
                   Placed here (outside the swappable partial) so it survives fulfillment refreshes. *@
                @{ var __rdTokens = Antiforgery.GetAndStoreTokens(ViewContext.HttpContext); }
                <input type="hidden" name="@__rdTokens.FormFieldName" value="@__rdTokens.RequestToken" />
                @* Initial fulfillment card render at default servings. The stepper's refreshFulfilment()
                   call swaps this via OnGetFulfilmentAsync recomputed at the selected servings (J3). *@
                <partial name="_DetailsFulfilmentCard" model="initialFulfilmentModel" />

                @* ── Ingredients card with servings stepper in header ────────── *@
                <div class="rd-ing-card">
                    <div class="rd-ing-head">
                        <h3>Ingredients</h3>
                        <div class="rd-ing-head__spacer"></div>
                        <span class="rd-serv-stepper__lbl">Servings</span>
                        <div class="rd-serv-stepper" role="group" aria-label="Servings">
                            <button type="button"
                                    class="rd-serv-stepper__btn"
                                    aria-label="Fewer servings"
                                    @@click="servings = Math.max(1, servings - 1); missingAdded = false; refreshFulfilment()"
                                    :disabled="servings <= 1">
                                <svg class="icon" aria-hidden="true"><use href="#i-minus" /></svg>
                            </button>
                            <span class="rd-serv-stepper__val" x-text="servings">@recipe.DefaultServings</span>
                            <button type="button"
                                    class="rd-serv-stepper__btn"
                                    aria-label="More servings"
                                    @@click="servings = Math.min(24, servings + 1); missingAdded = false; refreshFulfilment()"
                                    :disabled="servings >= 24">
                                <svg class="icon" aria-hidden="true"><use href="#i-plus" /></svg>
                            </button>
                        </div>
                    </div>

                    @* Ingredient rows are wrapped in #rd-ing-rows so the OOB swap from
                       _DetailsFulfilmentCard can update per-ingredient status dots and sub-labels
                       whenever the servings stepper triggers a fulfillment refresh (J3). *@
                    <div class="rd-ing-list" role="list" aria-label="Ingredients">
                        <div id="rd-ing-rows">
                            @foreach (var group in recipe.IngredientGroups)
                            {
                                @if (group.Heading is { } heading)
                                {
                                    <div class="rd-ing-row" style="padding-bottom:2px;padding-top:10px">
                                        <h4 style="margin:0;font-size:11px;letter-spacing:0.06em;text-transform:uppercase;color:var(--color-text-faint);font-weight:700;">@heading</h4>
                                    </div>
                                }
                                @foreach (var item in group.Items)
                                {
                                    // Fulfillment status for this ingredient — look up by IngredientId.
                                    // (IngredientItemView carries Status already from RecipeDetailView.From)
                                    var status = item.Status;
                                    var statusClass = status switch
                                    {
                                        IngredientStatus.InStock   => "rd-ing-status--have",
                                        IngredientStatus.Low       => "rd-ing-status--low",
                                        IngredientStatus.Missing   => "rd-ing-status--miss",
                                        _                          => "rd-ing-status--untracked",
                                    };
                                    var iconRef = status switch
                                    {
                                        IngredientStatus.InStock   => "#i-check",
                                        IngredientStatus.Low       => "#i-alert",
                                        IngredientStatus.Missing   => "#i-alert",
                                        _                          => "#i-recipe",
                                    };
                                    var subClass = status switch
                                    {
                                        IngredientStatus.InStock   => "rd-ing-sub--have",
                                        IngredientStatus.Low       => "rd-ing-sub--low",
                                        IngredientStatus.Missing   => "rd-ing-sub--miss",
                                        _                          => "rd-ing-sub--untracked",
                                    };
                                    // Sub-label text.
                                    string subLabel;
                                    if (item.IsUntracked)
                                    {
                                        subLabel = "untracked";
                                    }
                                    else if (status == IngredientStatus.InStock)
                                    {
                                        subLabel = "In your pantry";
                                    }
                                    else if (status == IngredientStatus.Low)
                                    {
                                        subLabel = "Running low";
                                    }
                                    else
                                    {
                                        subLabel = "Not in your pantry";
                                    }

                                    <div class="rd-ing-row" role="listitem">
                                        <div class="rd-ing-status @(statusClass)" aria-hidden="true">
                                            <svg class="icon"><use href="@iconRef" /></svg>
                                        </div>
                                        <div class="rd-ing-main">
                                            <div class="rd-ing-name">
                                                @item.ProductName
                                                @if (item.ExpiresWithinDays.HasValue)
                                                {
                                                    <span class="rd-ing-soon">
                                                        <svg class="icon" aria-hidden="true"><use href="#i-timer" /></svg>
                                                        @item.ExpiresWithinDays.Value d
                                                    </span>
                                                }
                                            </div>
                                            <div class="rd-ing-sub @(subClass)">@subLabel</div>
                                        </div>
                                        <div class="rd-ing-amt">
                                            @if (!item.IsUntracked && item.Quantity.HasValue)
                                            {
                                                <span class="rd-ing-qty" x-text="fmt(@(item.Quantity.Value.ToString(CultureInfo.InvariantCulture)))">@item.Quantity.Value.ToString("G29", CultureInfo.InvariantCulture)</span>
                                                @if (!string.IsNullOrEmpty(item.UnitCode))
                                                {
                                                    <span> @item.UnitCode</span>
                                                }
                                            }
                                        </div>
                                    </div>
                                }
                            }
                            @if (recipe.IngredientGroups.Count == 0 || recipe.IngredientGroups.All(g => g.Items.Count == 0))
                            {
                                <p class="rd-ing-row" style="color:var(--color-text-faint);font-size:14px">No ingredients yet.</p>
                            }
                        </div>
                    </div>
                </div>

            </div>@* /rd-rail *@

        </div>@* /rd-grid *@
    </div>@* /rd-wrap *@

</div>@* /recipe-detail *@
