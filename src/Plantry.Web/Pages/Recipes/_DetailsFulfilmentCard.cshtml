@model Plantry.Web.Pages.Recipes.DetailsFulfilmentCardModel
@using System.Globalization
@using Plantry.Recipes.Application
@using Plantry.Recipes.Domain
@using Plantry.Web.Pages.Shared
@{
    var vm = Model;
    var oobAttr = vm.Oob ? " hx-swap-oob=\"true\"" : "";
    var fulfillment = vm.Fulfillment;
    var recipeId = vm.RecipeId;
    var missingCount = fulfillment.Overall.MissingCount;
    var lowCount = fulfillment.Overall.LowCount;
    var totalTracked = fulfillment.Lines.Count(l => l.Status != IngredientStatus.Untracked);
    var inStockCount = fulfillment.Lines.Count(l => l.Status == IngredientStatus.InStock);
    var soonCount = fulfillment.Lines.Count(l => l.ExpiresWithinDays.HasValue);
    var pct = totalTracked > 0
        ? (int)Math.Round(100.0 * (inStockCount + lowCount) / totalTracked)
        : 100;
    var lvlClass = pct >= 80 ? "fulf-hi" : pct >= 50 ? "fulf-mid" : "fulf-lo";

    // Server-truth add-to-shopping button states (plantry-gsj). The label reflects the real delta
    // between the recipe's shortfall/required set and its existing contribution slice — computed in
    // the page model on every render (initial load, servings refresh, post-add swap), so there is no
    // client-side flag flip and no flash. Covered → greyed "Added"; Fresh → "Add N missing/ingredients";
    // Partial → "Add N more" (servings grew).
    var missingBtn = vm.MissingButton ?? new Plantry.Web.Pages.Recipes.AddButtonView(false, AddButtonState.Fresh, 0);
    var allBtn = vm.AllButton ?? new Plantry.Web.Pages.Recipes.AddButtonView(false, AddButtonState.Fresh, 0);

    // Label for a button: the noun ("missing to shopping list" / "ingredient…") applies only to a
    // fresh add; a top-up is always "Add N more to shopping list"; a covered button reads "Added".
    string AddLabel(Plantry.Web.Pages.Recipes.AddButtonView b, string freshNoun) => b.State switch
    {
        AddButtonState.Covered => "Added",
        AddButtonState.Partial => $"Add {b.PendingLines} more to shopping list",
        _                      => $"Add {b.PendingLines} {freshNoun}",
    };

    // Reconciliation summary (plantry-gsj), rendered only after an add action. Zero segments are
    // omitted so an all-already-present press reads "N already on your list" rather than "Added 0 · …".
    string? summaryText = null;
    if (vm.Summary is { IsEmpty: false } s)
    {
        var parts = new List<string>();
        if (s.Added > 0) parts.Add($"Added {s.Added}");
        if (s.AlreadyPresent > 0) parts.Add($"{s.AlreadyPresent} already on your list");
        if (s.CheckedOff > 0) parts.Add($"{s.CheckedOff} checked off");
        summaryText = string.Join(" · ", parts);
    }
}

@* Primary swap target: the fulfillment rail card.
   Triggered by the servings stepper via hx-get on Details.cshtml. *@
<div id="rd-fulf-card" class="rd-fulf-card @(fulfillment.Overall.FullyCookable ? "rd-fulf-card--cookable" : "")">
    <div class="rd-fulf-top">
        <div class="rd-fulf-headline">
            <span class="rd-fulf-count @(lvlClass)">@inStockCount of @totalTracked</span>
            <span class="rd-fulf-of">ingredients</span>
        </div>
        <div class="rd-fulf-sub">in your pantry right now</div>
        <partial name="Shared/_Meter" model='new MeterViewModel {
            Percent      = pct,
            Tone         = MeterViewModel.FulfTone(pct),
            Layout       = MeterLayout.BarOnly,
            AriaValueNow = pct,
            WrapperClass = "rd-fulf-bar"
        }' />
        <div class="rd-fulf-chips">
            @if (inStockCount > 0)
            {
                <span class="rd-fulf-chip rd-fulf-chip--have">
                    <span class="rd-fulf-chip__dot fulf-hi-bg"></span>
                    @inStockCount in stock
                </span>
            }
            @if (lowCount > 0)
            {
                <span class="rd-fulf-chip rd-fulf-chip--low">
                    <span class="rd-fulf-chip__dot fulf-mid-bg"></span>
                    @lowCount running low
                </span>
            }
            @if (missingCount > 0)
            {
                <span class="rd-fulf-chip rd-fulf-chip--miss">
                    <span class="rd-fulf-chip__dot fulf-lo-bg"></span>
                    @missingCount to buy
                </span>
            }
        </div>
    </div>

    @* Contextual note: expiring-soon takes priority over ready-to-cook. *@
    @if (soonCount > 0)
    {
        <div class="rd-fulf-note rd-fulf-note--soon" role="note">
            <svg class="icon" aria-hidden="true"><use href="#i-timer" /></svg>
            <span><b>@soonCount ingredient@(soonCount == 1 ? "" : "s") expiring soon.</b> A good reason to cook this now and use them up.</span>
        </div>
    }
    else if (fulfillment.Overall.FullyCookable)
    {
        <div class="rd-fulf-note rd-fulf-note--ready" role="note">
            <svg class="icon" aria-hidden="true"><use href="#i-check" /></svg>
            <span><b>You have everything.</b> Nothing to buy — you can make this tonight.</span>
        </div>
    }

    <div class="rd-actions">
        @* Cook link: Alpine binding carries current servings; fallback href uses default. *@
        <a :href="`/Recipes/@recipeId/Cook?Servings=${servings}`"
           href="/Recipes/@recipeId/Cook?Servings=@vm.DefaultServings"
           class="btn btn--cook">
            <svg class="icon" aria-hidden="true"><use href="#i-flame" /></svg>
            Cook this
        </a>

        @* Hidden input keeps the current Alpine servings value available to htmx via hx-include.
           Alpine's :value binding keeps it in sync whenever the servings stepper changes. *@
        <input type="hidden" id="rd-servings-input" name="servings" :value="servings" />

        @* Add ALL tracked ingredients to shopping list — plantry-s1z, idempotent SET/sync (plantry-gsj).
           On press, the POST returns this whole card re-rendered with server-truth labels + a role=status
           summary, swapping #rd-fulf-card — no client-side flag flip. Covered → greyed "Added". *@
        @if (allBtn.Show)
        {
            var allCovered = allBtn.State == AddButtonState.Covered;
            <button type="button" class="btn btn--soft"
                    hx-post="/Recipes/@recipeId?handler=AddAll"
                    hx-include="#rd-servings-input"
                    hx-target="#rd-fulf-card"
                    hx-swap="outerHTML"
                    disabled="@(allCovered ? "disabled" : null)">
                <svg class="icon" aria-hidden="true"><use href="@(allCovered ? "#i-check" : "#i-cart")" /></svg>
                <span>@AddLabel(allBtn, allBtn.PendingLines == 1 ? "ingredient to shopping list" : "ingredients to shopping list")</span>
            </button>
        }

        @* Add missing to shopping list — J5 step 6 (P2-4b), idempotent SET/sync (plantry-gsj). *@
        @if (missingBtn.Show)
        {
            var missingCovered = missingBtn.State == AddButtonState.Covered;
            <button type="button" class="btn btn--soft"
                    hx-post="/Recipes/@recipeId?handler=AddMissing"
                    hx-include="#rd-servings-input"
                    hx-target="#rd-fulf-card"
                    hx-swap="outerHTML"
                    disabled="@(missingCovered ? "disabled" : null)">
                <svg class="icon" aria-hidden="true"><use href="@(missingCovered ? "#i-check" : "#i-cart")" /></svg>
                <span>@AddLabel(missingBtn, "missing to shopping list")</span>
            </button>
        }
        <a href="/Recipes/@recipeId/Edit" class="btn btn--secondary">
            <svg class="icon" aria-hidden="true"><use href="#i-edit" /></svg>
            Edit recipe
        </a>
    </div>

    @* Reconciliation summary — announced via role=status/aria-live after an add action (plantry-gsj).
       Reuses the existing aria-live status pattern (cf. Intake/Upload, MealPlan _PendingBar). Rendered
       only on a post-add swap; absent on initial load and servings refreshes. *@
    @if (summaryText is not null)
    {
        <p class="rd-fulf-status" role="status" aria-live="polite">@summaryText</p>
    }
</div>

@* OOB swap: per-ingredient status dots and sub-labels in the ingredients card.
   Emitted ONLY when Oob=true (htmx partial response from OnGetFulfilmentAsync).
   On initial full-page render Oob=false, so this entire block is omitted — the
   main Details.cshtml renders #rd-ing-rows exactly once inside the ingredients card.
   Rendering it twice (even without hx-swap-oob) would create a duplicate ingredient
   list visible in the rail. Mirrors the Oob-gated emission pattern in
   _PantryList.cshtml and _StockDetail.cshtml (which also suppress their fragment
   entirely on non-OOB renders rather than just dropping the attribute). *@
@if (vm.Oob)
{
<div id="rd-ing-rows"@Html.Raw(oobAttr)>
    <partial name="_IngredientRows" model="vm.IngredientGroups" />
</div>
}
