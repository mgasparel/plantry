@model System.Collections.Generic.IReadOnlyList<Plantry.Web.Pages.Recipes.IngredientGroupView>
@using System.Globalization
@using Plantry.Recipes.Domain
@* Shared partial: renders the #rd-ing-rows content — group headings and per-ingredient rows.
   Consumed by both Details.cshtml (initial full-page render) and _DetailsFulfilmentCard.cshtml
   (OOB swap on servings-stepper change). Single source of truth for row/badge/status-switch markup
   so that downstream changes (e.g. plantry-17n expired-badge) only need to land here. *@
@foreach (var group in Model)
{
    @if (group.Heading is { } heading)
    {
        <div class="rd-ing-row" style="padding-bottom:2px;padding-top:10px">
            <h4 style="margin:0;font-size:11px;letter-spacing:0.06em;text-transform:uppercase;color:var(--color-text-faint);font-weight:700;">@heading</h4>
        </div>
    }
    @foreach (var item in group.Items)
    {
        // Fulfillment status for this ingredient — carried by IngredientItemView from RecipeDetailView.From.
        var status = item.Status;
        // Unit gap (plantry-z2sr): the row reads Missing only because on-hand stock can't be converted to
        // the recipe unit. It is an honest "can't compare" state, not an empty pantry, so it renders in the
        // info tone with a popover rather than the danger "Not in your pantry" — mirroring the Cook page's
        // IsUnitGap treatment (plantry-qll2.5). Only meaningful when the status is Missing.
        var unitGap = item.UnitMismatch;
        var statusClass = unitGap ? "rd-ing-status--unitgap" : status switch
        {
            IngredientStatus.InStock   => "rd-ing-status--have",
            IngredientStatus.Low       => "rd-ing-status--low",
            IngredientStatus.Missing   => "rd-ing-status--miss",
            _                          => "rd-ing-status--untracked",
        };
        var iconRef = unitGap ? "#i-info" : status switch
        {
            IngredientStatus.InStock   => "#i-check",
            IngredientStatus.Low       => "#i-alert",
            IngredientStatus.Missing   => "#i-alert",
            _                          => "#i-recipe",
        };
        var subClass = unitGap ? "rd-ing-sub--unitgap" : status switch
        {
            IngredientStatus.InStock   => "rd-ing-sub--have",
            IngredientStatus.Low       => "rd-ing-sub--low",
            IngredientStatus.Missing   => "rd-ing-sub--miss",
            _                          => "rd-ing-sub--untracked",
        };
        // Sub-label text.
        string subLabel;
        if (item.IsUntracked)
        {
            subLabel = "untracked";
        }
        else if (unitGap)
        {
            subLabel = "Can't compare units";
        }
        else if (status == IngredientStatus.InStock)
        {
            subLabel = "In your pantry";
        }
        else if (status == IngredientStatus.Low)
        {
            subLabel = "Running low";
        }
        else
        {
            subLabel = "Not in your pantry";
        }

        <div class="rd-ing-row" role="listitem">
            <div class="rd-ing-status @(statusClass)" aria-hidden="true">
                <svg class="icon"><use href="@iconRef" /></svg>
            </div>
            <div class="rd-ing-main">
                <div class="rd-ing-name">
                    @item.ProductName
                    @if (item.ExpiresWithinDays is { } d)
                    {
                        @* Wording + colour tier from the shared ExpiryDisplay so the pill reads identically to
                           the Today rail and Pantry grid (plantry-fdoq). ExpiresWithinDays is already the signed,
                           horizon-clamped days-until-expiry, so drive the days-based entry directly. Keep the
                           recipe's timer icon. *@
                        var (expLabel, expTier) = Plantry.Web.Pages.Shared.ExpiryDisplay.FromDaysUntilExpiry(d);
                        <span class="badge-expiry badge-expiry--@expTier">
                            <svg class="icon" aria-hidden="true"><use href="#i-timer" /></svg>
                            @expLabel
                        </span>
                    }
                </div>
                @* @subLabel and @if are kept adjacent (no leading whitespace) so a normal row renders
                   byte-identically to before — only a unit-gap row emits the extra popover markup. *@
                <div class="rd-ing-sub @(subClass)">@subLabel@if (unitGap)
                    {
                        @* Honest "can't compare" explanation (plantry-z2sr): on-hand stock is measured in
                           a unit with no conversion path to the recipe's unit. The popover links out to the
                           product page where the Add-conversion affordance lives (same destination as the
                           Cook page's unit-gap link, plantry-qll2.5). Start-aligned so it never clips the
                           left rail margin. *@
                        <popover position="start" label="i" title="Can't compare units">
                            You have some on hand, but it's measured in a unit we can't convert to this recipe's unit — so we can't tell whether it's enough.
                            <a href="/Catalog/Products/@item.ProductId">Add a conversion</a>
                        </popover>
                    }</div>
            </div>
            <div class="rd-ing-amt">
                @if (!item.IsUntracked && item.Quantity.HasValue)
                {
                    @* Server render is the 1× vulgar-fraction display (quantity-display.md Q1/§7). The
                       servings stepper scales the amount client-side; the JS twin is decimal-only
                       (plantry-jun6), so keep the server-rendered fraction at scale === 1 and only hand off
                       to the decimal scaler when scaled — never clobbering the 1× fraction on first paint. *@
                    var displayText = item.DisplayQuantity ?? IngredientAmount.Format(item.Quantity.Value);
                    var qtyLiteral = item.Quantity.Value.ToString(CultureInfo.InvariantCulture);
                    <span class="rd-ing-qty" x-text="scale === 1 ? @Html.Raw(JsLiteral(displayText)) : fmt(@qtyLiteral)">@displayText</span>
                    @if (!string.IsNullOrEmpty(item.UnitCode))
                    {
                        <span> @item.UnitCode</span>
                    }
                }
            </div>
        </div>
    }
}
@if (Model.Count == 0 || Model.All(g => g.Items.Count == 0))
{
    <p class="rd-ing-row" style="color:var(--color-text-faint);font-size:14px">No ingredients yet.</p>
}

@functions {
    // Single-quoted JS string literal for an Alpine x-text expression (the attribute itself is
    // double-quoted). The value is a server-formatted amount (digits + fraction glyphs); escape defensively
    // so it stays a valid literal regardless. Emitted via Html.Raw so the quotes/backslashes are not encoded.
    private static string JsLiteral(string s) =>
        "'" + s.Replace("\\", "\\\\").Replace("'", "\\'") + "'";
}
