@model System.Collections.Generic.IReadOnlyList<Plantry.Web.Pages.Recipes.IngredientGroupView>
@* Shared partial: renders the #rd-ing-rows content — group headings, per-ingredient rows, and
   collapsible inclusion roll-up rows (plantry-4037). Consumed by both Details.cshtml (initial
   full-page render) and _DetailsFulfilmentCard.cshtml (OOB swap on servings-stepper change). Single
   source of truth for the row list so downstream changes only need to land here.
   Each group's Items is a union of two row shapes (recipe-composition.md §5): a direct ingredient
   (IngredientRowView, rendered via _IngredientRow) and a collapsible sub-recipe roll-up
   (InclusionRowView, rendered via _InclusionFoldRow) — both slot into the SAME ordinal position /
   authored GroupHeading, so an inclusion composes with sections exactly like an ingredient line. *@
@foreach (var group in Model)
{
    @if (group.Heading is { } heading)
    {
        <div class="rd-ing-row" style="padding-bottom:2px;padding-top:10px">
            <h4 style="margin:0;font-size:11px;letter-spacing:0.06em;text-transform:uppercase;color:var(--color-text-faint);font-weight:700;">@heading</h4>
        </div>
    }
    @foreach (var row in group.Items)
    {
        @if (row is Plantry.Web.Pages.Recipes.IngredientRowView ingRow)
        {
            <partial name="_IngredientRow" model="ingRow.Item" />
        }
        else if (row is Plantry.Web.Pages.Recipes.InclusionRowView inclRow)
        {
            <partial name="_InclusionFoldRow" model="inclRow" />
        }
    }
}
@if (Model.Count == 0 || Model.All(g => g.Items.Count == 0))
{
    <p class="rd-ing-row" style="color:var(--color-text-faint);font-size:14px">No ingredients yet.</p>
}
