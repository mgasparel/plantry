@page
@model Plantry.Web.Pages.Catalog.IndexModel
@{
    ViewData["Title"] = "Catalog";
}

<page-header title="Catalog" subtitle="Manage the reference data your household uses to track stock: units, categories, and locations." />

@* Products moved out of the Catalog hub (plantry-sjfn) — Pantry (Everything scope) is now the one
   list of products, stocked or not. Catalog is purely reference data: Units, Categories, Locations. *@
<nav class="hub-list" aria-label="Catalog sections">
        <a href="/Catalog/Units" class="hub-list__item">
            <span class="hub-list__icon"><svg class="icon" aria-hidden="true"><use href="#i-scale" /></svg></span>
            <div class="hub-list__text">
                <span class="hub-list__label">Units</span>
                <span class="hub-list__sub">Mass, volume, and count units used for sizing and conversions</span>
            </div>
            <svg class="icon hub-list__chevron" aria-hidden="true"><use href="#i-chevron-right" /></svg>
        </a>
        <a href="/Catalog/Categories" class="hub-list__item">
            <span class="hub-list__icon"><svg class="icon" aria-hidden="true"><use href="#i-grid" /></svg></span>
            <div class="hub-list__text">
                <span class="hub-list__label">Categories</span>
                <span class="hub-list__sub">Group products and set default expiry windows</span>
            </div>
            <svg class="icon hub-list__chevron" aria-hidden="true"><use href="#i-chevron-right" /></svg>
        </a>
        <a href="/Catalog/Locations" class="hub-list__item">
            <span class="hub-list__icon"><svg class="icon" aria-hidden="true"><use href="#i-location" /></svg></span>
            <div class="hub-list__text">
                <span class="hub-list__label">Locations</span>
                <span class="hub-list__sub">Where stock lives — pantry shelves, fridges, freezers</span>
            </div>
            <svg class="icon hub-list__chevron" aria-hidden="true"><use href="#i-chevron-right" /></svg>
        </a>
</nav>
