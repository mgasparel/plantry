@page
@model Plantry.Web.Pages.Catalog.Products.CreateModel
@{
    ViewData["Title"] = "New Product";
}

<section class="catalog-section">
    <h2 class="catalog-section__heading">New Product</h2>

    <div asp-validation-summary="ModelOnly" class="alert alert--danger" role="alert"></div>

    <form method="post" class="form-stack">
        <div class="field field--inline">
            <label asp-for="Input.Name" class="field__label">Name</label>
            <input asp-for="Input.Name" class="field__input" placeholder="e.g. Whole milk" />
            <span asp-validation-for="Input.Name" class="field__error"></span>
        </div>
        <div class="field field--inline">
            <label asp-for="Input.DefaultUnitId" class="field__label">Default unit</label>
            <select asp-for="Input.DefaultUnitId" class="field__input" asp-items="Model.UnitOptions">
                <option value="">— Select a unit —</option>
            </select>
            <span asp-validation-for="Input.DefaultUnitId" class="field__error"></span>
        </div>
        <div class="field field--inline">
            <label asp-for="Input.CategoryId" class="field__label">Category</label>
            <select asp-for="Input.CategoryId" class="field__input" asp-items="Model.CategoryOptions">
                <option value="">— None —</option>
            </select>
            <span asp-validation-for="Input.CategoryId" class="field__error"></span>
        </div>
        <div class="field field--inline">
            <label asp-for="Input.DefaultLocationId" class="field__label">Default location</label>
            <select asp-for="Input.DefaultLocationId" class="field__input" asp-items="Model.LocationOptions">
                <option value="">— None —</option>
            </select>
            <span asp-validation-for="Input.DefaultLocationId" class="field__error"></span>
        </div>
        <field asp-for="Input.TrackStock"
               hint="Off: treated as an always-available staple (salt, water) — never counted, never consumed by cooking, never added to shopping lists.">
            <input asp-for="Input.TrackStock" type="checkbox" />
        </field>
        <button type="submit" class="btn btn--primary">Create Product</button>
        @* Cancel returns to Pantry (plantry-sjfn) — the unified product list; /Catalog/Products is
           now just a redirect stub, so linking straight to /Pantry avoids the extra hop. *@
        <a href="/Pantry" class="btn btn--ghost">Cancel</a>
    </form>
</section>
