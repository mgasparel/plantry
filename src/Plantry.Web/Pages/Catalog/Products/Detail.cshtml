@page "{id:guid}"
@model Plantry.Web.Pages.Catalog.Products.DetailModel
@{
    ViewData["Title"] = Model.Product?.Name ?? "Product";
    var product = Model.Product!;
}

<div asp-validation-summary="ModelOnly" class="alert alert--danger" role="alert"></div>

<section class="catalog-section">
    <div class="catalog-section__header">
        <h2 class="catalog-section__heading">
            @product.Name
            @if (product.IsArchived)
            {
                <span class="catalog-list__meta">(archived)</span>
            }
        </h2>
        <div class="form-stack form-stack--row">
            <a href="/Catalog/Products/Edit/@product.Id.Value" class="btn btn--ghost btn--sm">Edit</a>
            @if (product.IsArchived)
            {
                <form method="post" asp-page-handler="Unarchive" asp-route-id="@product.Id.Value">
                    <button type="submit" class="btn btn--ghost btn--sm">Unarchive</button>
                </form>
            }
            else
            {
                <form method="post" asp-page-handler="Archive" asp-route-id="@product.Id.Value">
                    <button type="submit" class="btn btn--ghost btn--sm">Archive</button>
                </form>
            }
        </div>
    </div>

    <ul class="catalog-list" role="list">
        <li class="catalog-list__item">
            <span class="catalog-list__primary">Category</span>
            <span class="catalog-list__secondary">@(product.CategoryName ?? "Uncategorized")</span>
        </li>
        <li class="catalog-list__item">
            <span class="catalog-list__primary">Default unit</span>
            <span class="catalog-list__secondary">@product.DefaultUnitCode</span>
        </li>
        <li class="catalog-list__item">
            <span class="catalog-list__primary">Default location</span>
            <span class="catalog-list__secondary">@(product.DefaultLocationName ?? "—")</span>
        </li>
        <li class="catalog-list__item">
            <span class="catalog-list__primary">Expiry defaults</span>
            <span class="catalog-list__secondary">
                Ambient: @(product.DefaultDueDays?.ToString() ?? "—") days &middot;
                After opening: @(product.DefaultDueDaysAfterOpening?.ToString() ?? "—") days &middot;
                After freezing: @(product.DefaultDueDaysAfterFreezing?.ToString() ?? "—") days &middot;
                After thawing: @(product.DefaultDueDaysAfterThawing?.ToString() ?? "—") days
            </span>
        </li>
    </ul>
</section>

<section class="catalog-section">
    <h2 class="catalog-section__heading">Parent / variant group</h2>

    @if (product.ParentName is { } parentName)
    {
        <ul class="catalog-list" role="list">
            <li class="catalog-list__item">
                <span class="catalog-list__primary">Variant of</span>
                <span class="catalog-list__secondary">@parentName</span>
                <form method="post" asp-page-handler="Detach" asp-route-id="@product.Id.Value" class="catalog-list__action">
                    <button type="submit" class="btn btn--ghost btn--sm">Detach from parent</button>
                </form>
            </li>
        </ul>
    }
    else if (product.Variants.Count > 0)
    {
        <p class="empty-state">This product groups the following variants — it cannot itself hold stock.</p>
        <ul class="catalog-list" role="list">
            @foreach (var variant in product.Variants)
            {
                <li class="catalog-list__item">
                    <a href="/Catalog/Products/Detail/@variant.Id.Value" class="catalog-list__primary">@variant.Name</a>
                </li>
            }
        </ul>
    }
    else
    {
        <p class="empty-state">Standalone product — not part of a parent/variant group.</p>
        <form method="post" asp-page-handler="MakeVariant" asp-route-id="@product.Id.Value" class="form-stack form-stack--row">
            <div class="field field--inline">
                <label asp-for="VariantInput.ParentProductId" class="field__label">Make a variant of</label>
                <select asp-for="VariantInput.ParentProductId" class="field__input" asp-items="Model.ParentOptions">
                    <option value="">— Select a product —</option>
                </select>
                <span asp-validation-for="VariantInput.ParentProductId" class="field__error"></span>
            </div>
            <button type="submit" class="btn btn--ghost btn--sm">Make variant</button>
        </form>
    }
</section>

<section class="catalog-section">
    <h2 class="catalog-section__heading">SKUs</h2>

    @if (product.Skus.Count == 0)
    {
        <p class="empty-state">No SKUs yet — add a pack size below.</p>
    }
    else
    {
        <ul class="catalog-list" role="list">
            @foreach (var sku in product.Skus)
            {
                <li class="catalog-list__item">
                    <span class="catalog-list__primary">@sku.Label</span>
                    <span class="catalog-list__secondary">
                        @(sku.SizeQuantity is { } qty ? $"{qty.ToString("0.###")} {sku.SizeUnitCode}" : "No declared size")
                    </span>
                    <form method="post" asp-page-handler="RemoveSku" asp-route-id="@product.Id.Value" asp-route-skuId="@sku.Id.Value" class="catalog-list__action">
                        <button type="submit" class="btn btn--ghost btn--sm">Remove</button>
                    </form>
                </li>
            }
        </ul>
    }

    <form method="post" asp-page-handler="AddSku" asp-route-id="@product.Id.Value" class="form-stack">
        <div class="field field--inline">
            <label asp-for="SkuInput.Label" class="field__label">Label</label>
            <input asp-for="SkuInput.Label" class="field__input" placeholder="e.g. 2 L carton" />
            <span asp-validation-for="SkuInput.Label" class="field__error"></span>
        </div>
        <div class="field field--inline">
            <label asp-for="SkuInput.SizeQuantity" class="field__label">Size quantity</label>
            <input asp-for="SkuInput.SizeQuantity" class="field__input" type="number" step="any" min="0" />
            <span asp-validation-for="SkuInput.SizeQuantity" class="field__error"></span>
        </div>
        <div class="field field--inline">
            <label asp-for="SkuInput.SizeUnitId" class="field__label">Size unit</label>
            <select asp-for="SkuInput.SizeUnitId" class="field__input" asp-items="Model.UnitOptions">
                <option value="">— None —</option>
            </select>
        </div>
        <button type="submit" class="btn btn--primary">Add SKU</button>
    </form>
</section>

<section class="catalog-section">
    <h2 class="catalog-section__heading">Conversions</h2>
    <p>Product-specific conversions for cross-dimension or density relationships (e.g. "1 cup flour = 120 g").</p>

    @if (product.Conversions.Count == 0)
    {
        <p class="empty-state">No product-specific conversions yet.</p>
    }
    else
    {
        <ul class="catalog-list" role="list">
            @foreach (var conversion in product.Conversions)
            {
                <li class="catalog-list__item">
                    <span class="catalog-list__primary">1 @conversion.FromUnitCode = @conversion.Factor.ToString("0.######") @conversion.ToUnitCode</span>
                    <form method="post" asp-page-handler="RemoveConversion" asp-route-id="@product.Id.Value" asp-route-conversionId="@conversion.Id.Value" class="catalog-list__action">
                        <button type="submit" class="btn btn--ghost btn--sm">Remove</button>
                    </form>
                </li>
            }
        </ul>
    }

    <form method="post" asp-page-handler="AddConversion" asp-route-id="@product.Id.Value" class="form-stack">
        <div class="field field--inline">
            <label asp-for="ConversionInput.FromUnitId" class="field__label">From unit</label>
            <select asp-for="ConversionInput.FromUnitId" class="field__input" asp-items="Model.UnitOptions">
                <option value="">— Select a unit —</option>
            </select>
            <span asp-validation-for="ConversionInput.FromUnitId" class="field__error"></span>
        </div>
        <div class="field field--inline">
            <label asp-for="ConversionInput.ToUnitId" class="field__label">To unit</label>
            <select asp-for="ConversionInput.ToUnitId" class="field__input" asp-items="Model.UnitOptions">
                <option value="">— Select a unit —</option>
            </select>
            <span asp-validation-for="ConversionInput.ToUnitId" class="field__error"></span>
        </div>
        <div class="field field--inline">
            <label asp-for="ConversionInput.Factor" class="field__label">Factor</label>
            <input asp-for="ConversionInput.Factor" class="field__input" type="number" step="any" min="0" />
            <span asp-validation-for="ConversionInput.Factor" class="field__error"></span>
        </div>
        <button type="submit" class="btn btn--primary">Add conversion</button>
    </form>
</section>
