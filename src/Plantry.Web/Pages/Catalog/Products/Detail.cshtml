@page "/Catalog/Products/{id:guid}"
@model Plantry.Web.Pages.Catalog.Products.DetailModel
@{
    ViewData["Title"] = Model.Product?.Name ?? "Product";
    var product = Model.Product!;
}

<div asp-validation-summary="ModelOnly" class="alert alert--danger" role="alert"></div>

@* Product identity now uses the shared .page-header primitive (plantry-7yf1): category ->
   eyebrow, name -> title, "(archived)" -> muted title-meta, Archive/Unarchive -> actions. No
   subtitle (Catalog has no natural stat line). Lifted out of the first card's head. *@
<page-header eyebrow="@product.CategoryName" title="@product.Name"
             title-meta="@(product.IsArchived ? "(archived)" : null)">
    @if (product.IsArchived)
    {
        <form method="post" asp-page-handler="Unarchive" asp-route-id="@product.Id.Value">
            <button type="submit" class="btn btn--ghost btn--sm">Unarchive</button>
        </form>
    }
    else
    {
        <form method="post" asp-page-handler="Archive" asp-route-id="@product.Id.Value"
              onsubmit="return confirm('Archive this product? It will be hidden from your catalog and won\'t appear when adding items. You can unarchive it later.');">
            <button type="submit" class="btn btn--ghost btn--sm">Archive</button>
        </form>
    }
</page-header>

<div class="card">
    <div class="card__body">
        <form method="post" class="form-stack">
            <div class="form-grid">
                <field asp-for="Input.Name" stacked full>
                    <input asp-for="Input.Name" class="field__input" />
                    <span asp-validation-for="Input.Name" class="field__error"></span>
                </field>
                <field asp-for="Input.CategoryId" stacked>
                    <select asp-for="Input.CategoryId" class="field__input" asp-items="Model.CategoryOptions">
                        <option value="">— None —</option>
                    </select>
                </field>
                <field asp-for="Input.DefaultUnitId" stacked>
                    <select asp-for="Input.DefaultUnitId" class="field__input" asp-items="Model.UnitOptions">
                        <option value="">— Select a unit —</option>
                    </select>
                    <span asp-validation-for="Input.DefaultUnitId" class="field__error"></span>
                </field>
                <field asp-for="Input.DefaultLocationId" stacked full>
                    <select asp-for="Input.DefaultLocationId" class="field__input" asp-items="Model.LocationOptions">
                        <option value="">— None —</option>
                    </select>
                </field>
                <field asp-for="Input.DefaultDueDays" stacked>
                    <div class="form-grid__unit-suffix">
                        <input asp-for="Input.DefaultDueDays" class="field__input" type="number" min="0" />
                        <span class="form-grid__unit-suffix__label">days</span>
                    </div>
                    <span asp-validation-for="Input.DefaultDueDays" class="field__error"></span>
                </field>
                <field asp-for="Input.DefaultDueDaysAfterOpening" stacked>
                    <div class="form-grid__unit-suffix">
                        <input asp-for="Input.DefaultDueDaysAfterOpening" class="field__input" type="number" min="0" />
                        <span class="form-grid__unit-suffix__label">days</span>
                    </div>
                    <span asp-validation-for="Input.DefaultDueDaysAfterOpening" class="field__error"></span>
                </field>
                <field asp-for="Input.DefaultDueDaysAfterFreezing" stacked>
                    <div class="form-grid__unit-suffix">
                        <input asp-for="Input.DefaultDueDaysAfterFreezing" class="field__input" type="number" min="0" />
                        <span class="form-grid__unit-suffix__label">days</span>
                    </div>
                    <span asp-validation-for="Input.DefaultDueDaysAfterFreezing" class="field__error"></span>
                </field>
                <field asp-for="Input.DefaultDueDaysAfterThawing" stacked>
                    <div class="form-grid__unit-suffix">
                        <input asp-for="Input.DefaultDueDaysAfterThawing" class="field__input" type="number" min="0" />
                        <span class="form-grid__unit-suffix__label">days</span>
                    </div>
                    <span asp-validation-for="Input.DefaultDueDaysAfterThawing" class="field__error"></span>
                </field>
            </div>
            <div>
                <button type="submit" class="btn btn--primary">Save changes</button>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card__head">
        <div>
            <h3 class="card__head-title">Parent / variant group</h3>
        </div>
    </div>
    <div class="card__body">
        @if (product.ParentName is { } parentName)
        {
            <ul class="catalog-list" role="list">
                <li class="catalog-list__item">
                    <span class="catalog-list__primary">Variant of</span>
                    <span class="catalog-list__secondary">@parentName</span>
                    <form method="post" asp-page-handler="Detach" asp-route-id="@product.Id.Value" class="catalog-list__action">
                        <button type="submit" class="btn btn--ghost btn--sm">Detach from parent</button>
                    </form>
                </li>
            </ul>
        }
        else if (product.Variants.Count > 0)
        {
            <p class="empty-state">This product groups the following variants — it cannot itself hold stock.</p>
            <ul class="catalog-list" role="list">
                @foreach (var variant in product.Variants)
                {
                    <li class="catalog-list__item">
                        <a href="/Catalog/Products/@variant.Id.Value" class="catalog-list__primary">@variant.Name</a>
                    </li>
                }
            </ul>
            <partial name="_AddVariantForm" />
        }
        else
        {
            <p class="empty-state">Standalone product — not part of a parent/variant group.</p>
            <partial name="_AddVariantForm" />
            <form method="post" asp-page-handler="MakeVariant" asp-route-id="@product.Id.Value" class="form-stack form-stack--row">
                <div class="field field--inline">
                    <label asp-for="VariantInput.ParentProductId" class="field__label">Make a variant of</label>
                    <select asp-for="VariantInput.ParentProductId" class="field__input" asp-items="Model.ParentOptions">
                        <option value="">— Select a product —</option>
                    </select>
                    <span asp-validation-for="VariantInput.ParentProductId" class="field__error"></span>
                </div>
                <button type="submit" class="btn btn--ghost btn--sm">Make variant</button>
            </form>
        }
    </div>
</div>

<div class="card">
    <div class="card__head">
        <div>
            <h3 class="card__head-title">SKUs</h3>
        </div>
    </div>
    <div class="card__body">
        @if (product.Skus.Count > 0)
        {
            <ul class="catalog-list" role="list">
                @foreach (var sku in product.Skus)
                {
                    <li class="catalog-list__item">
                        <span class="catalog-list__primary">@sku.Label</span>
                        <span class="catalog-list__secondary">
                            @(sku.SizeQuantity is { } qty ? $"{qty.ToString("0.###")} {sku.SizeUnitCode}" : "No declared size")
                        </span>
                        <form method="post" asp-page-handler="RemoveSku" asp-route-id="@product.Id.Value" asp-route-skuId="@sku.Id.Value" class="catalog-list__action">
                            <button type="submit" class="btn btn--ghost btn--sm">Remove</button>
                        </form>
                    </li>
                }
            </ul>
        }
        <form method="post" asp-page-handler="AddSku" asp-route-id="@product.Id.Value" class="form-stack">
            <div class="form-grid">
                <field asp-for="SkuInput.Label" stacked full>
                    <input asp-for="SkuInput.Label" class="field__input" placeholder="e.g. 2 L carton" />
                    <span asp-validation-for="SkuInput.Label" class="field__error"></span>
                </field>
                <field asp-for="SkuInput.SizeQuantity" stacked>
                    <input asp-for="SkuInput.SizeQuantity" class="field__input" type="number" step="any" min="0" />
                    <span asp-validation-for="SkuInput.SizeQuantity" class="field__error"></span>
                </field>
                <field asp-for="SkuInput.SizeUnitId" stacked>
                    <select asp-for="SkuInput.SizeUnitId" class="field__input" asp-items="Model.UnitOptions">
                        <option value="">— None —</option>
                    </select>
                </field>
            </div>
            <div>
                <button type="submit" class="btn btn--primary">Add SKU</button>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card__head">
        <div>
            <h3 class="card__head-title">Conversions</h3>
            <p class="card__head-sub">Product-specific cross-dimension relationships (e.g. "1 cup flour = 120 g").</p>
        </div>
    </div>
    <div class="card__body">
        @if (product.Conversions.Count > 0)
        {
            <ul class="catalog-list" role="list">
                @foreach (var conversion in product.Conversions)
                {
                    <li class="catalog-list__item">
                        <span class="catalog-list__primary">1 @conversion.FromUnitCode = @conversion.Factor.ToString("0.######") @conversion.ToUnitCode</span>
                        @if (conversion.IsAiSuggested)
                        {
                            <span class="badge badge--info" title="Machine-suggested factor — usable now; confirm to endorse it.">AI-suggested</span>
                        }
                        <div class="catalog-list__actions">
                            @if (conversion.IsAiSuggested)
                            {
                                <form method="post" asp-page-handler="PromoteConversion" asp-route-id="@product.Id.Value" asp-route-conversionId="@conversion.Id.Value">
                                    <button type="submit" class="btn btn--secondary btn--sm">Confirm</button>
                                </form>
                            }
                            <form method="post" asp-page-handler="RemoveConversion" asp-route-id="@product.Id.Value" asp-route-conversionId="@conversion.Id.Value">
                                <button type="submit" class="btn btn--ghost btn--sm">Remove</button>
                            </form>
                        </div>
                    </li>
                }
            </ul>
        }
        <form method="post" asp-page-handler="AddConversion" asp-route-id="@product.Id.Value" class="form-stack">
            <div class="form-grid">
                <field asp-for="ConversionInput.FromUnitId" stacked>
                    <select asp-for="ConversionInput.FromUnitId" class="field__input" asp-items="Model.UnitOptions">
                        <option value="">— Select a unit —</option>
                    </select>
                    <span asp-validation-for="ConversionInput.FromUnitId" class="field__error"></span>
                </field>
                <field asp-for="ConversionInput.ToUnitId" stacked>
                    <select asp-for="ConversionInput.ToUnitId" class="field__input" asp-items="Model.UnitOptions">
                        <option value="">— Select a unit —</option>
                    </select>
                    <span asp-validation-for="ConversionInput.ToUnitId" class="field__error"></span>
                </field>
                <field asp-for="ConversionInput.Factor" stacked full>
                    <input asp-for="ConversionInput.Factor" class="field__input" type="number" step="any" min="0" />
                    <span asp-validation-for="ConversionInput.Factor" class="field__error"></span>
                </field>
            </div>
            <div>
                <button type="submit" class="btn btn--primary">Add conversion</button>
            </div>
        </form>
    </div>
</div>
