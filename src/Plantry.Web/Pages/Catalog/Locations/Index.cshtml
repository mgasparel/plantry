@page
@model Plantry.Web.Pages.Catalog.Locations.IndexModel
@using Plantry.Web.Pages.Shared
@{
    ViewData["Title"] = "Locations";

    var locationRows = new RowListViewModel(
        Model.Locations.OrderBy(l => l.Name)
            .Select(l => new RowListItem(l.Name, Secondary: l.Type.ToString(), Id: l.Id.Value.ToString()))
            .ToList(),
        EmptyMessage: "No locations yet — add your first one below.",
        Deletable: true);
}

<page-header title="Locations" subtitle="Where stock lives — fridges, freezers, and pantry shelves your household uses." />

<div asp-validation-summary="ModelOnly" class="alert alert--danger" role="alert"></div>

<section class="catalog-section">
    <partial name="Shared/_RowList" model="locationRows" />
</section>

<section class="catalog-section">
    <h2 class="catalog-section__heading">Add a location</h2>
    <form method="post" asp-page-handler="Create" class="form-stack">
        <div class="field field--inline">
            <label asp-for="Input.Name" class="field__label">Name</label>
            <input asp-for="Input.Name" class="field__input" placeholder="e.g. Garage freezer" />
            <span asp-validation-for="Input.Name" class="field__error"></span>
        </div>
        <div class="field field--inline">
            <label asp-for="Input.Type" class="field__label">Type</label>
            <select asp-for="Input.Type" class="field__input" asp-items="Html.GetEnumSelectList<Plantry.Catalog.Domain.LocationType>()"></select>
            <span asp-validation-for="Input.Type" class="field__error"></span>
        </div>
        <button type="submit" class="btn btn--primary">Create location</button>
    </form>
</section>
