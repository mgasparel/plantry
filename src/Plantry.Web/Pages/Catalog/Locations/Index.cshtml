@page
@model Plantry.Web.Pages.Catalog.Locations.IndexModel
@{
    ViewData["Title"] = "Locations";
}

<div asp-validation-summary="ModelOnly" class="alert alert--danger" role="alert"></div>

<section class="catalog-section">
    <h2 class="catalog-section__heading">Locations</h2>
    @if (Model.Locations.Count == 0)
    {
        <p class="empty-state">No locations yet — add your first one below.</p>
    }
    else
    {
        <ul class="catalog-list" role="list">
            @foreach (var location in Model.Locations.OrderBy(l => l.Name))
            {
                <li class="catalog-list__item">
                    <span class="catalog-list__primary">@location.Name</span>
                    <span class="catalog-list__secondary">@location.Type</span>
                    <form method="post" asp-page-handler="Delete" asp-route-id="@location.Id.Value" class="catalog-list__action">
                        <button type="submit" class="btn btn--ghost btn--sm">Remove</button>
                    </form>
                </li>
            }
        </ul>
    }
</section>

<section class="catalog-section">
    <h2 class="catalog-section__heading">Add a location</h2>
    <form method="post" asp-page-handler="Create" class="form-stack">
        <div class="field field--inline">
            <label asp-for="Input.Name" class="field__label">Name</label>
            <input asp-for="Input.Name" class="field__input" placeholder="e.g. Garage freezer" />
            <span asp-validation-for="Input.Name" class="field__error"></span>
        </div>
        <div class="field field--inline">
            <label asp-for="Input.Type" class="field__label">Type</label>
            <select asp-for="Input.Type" class="field__input" asp-items="Html.GetEnumSelectList<Plantry.Catalog.Domain.LocationType>()"></select>
            <span asp-validation-for="Input.Type" class="field__error"></span>
        </div>
        <button type="submit" class="btn btn--primary">Add location</button>
    </form>
</section>
